---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";
import AreaSectionSurface from "../../components/content/AreaSectionSurface.astro";
import EmptyStateCard from "../../components/content/EmptyStateCard.astro";
import { subjectTitleMap } from "../../data/subjects";
import { getAreaAuditData } from "../../data/areaAudit";

const { stats, groupedUnmapped, groupedRemapped } = await getAreaAuditData();
---

<BaseLayout
  title="Themen-Audit – Schlaufuchs"
  description="Interne Übersicht über noch nicht in die sichtbare Area-Struktur eingepflegte Themenpfade."
>
  <div class="page-shell">
    <section class="hero">
      <p class="eyebrow">Pflege</p>
      <h1>Themen-Audit</h1>
      <p class="lead">
        Diese Seite zeigt, welche Inhalte noch kein sauberes Mapping in der sichtbaren Fachstruktur haben
        und wo Alias-Pfade aktuell alte Links abfangen.
      </p>
    </section>

    <AreaSectionSurface variant="topics">
      <SectionHeading kicker="Übersicht" title="Audit-Status" />
      <div class="stats-grid">
        <article class="stat-card">
          <span>Geprüfte Inhalte</span>
          <strong>{stats.total}</strong>
        </article>
        <article class="stat-card">
          <span>Einträge ohne Mapping</span>
          <strong>{stats.unmappedEntries}</strong>
        </article>
        <article class="stat-card">
          <span>Eindeutige fehlende Themenpfade</span>
          <strong>{stats.uniqueUnmappedPaths}</strong>
        </article>
        <article class="stat-card">
          <span>Legacy-Alias aktiv</span>
          <strong>{stats.remappedEntries}</strong>
        </article>
      </div>
    </AreaSectionSurface>

    {stats.uniqueUnmappedPaths === 0 ? (
      <EmptyStateCard
        kicker="Gut"
        title="Aktuell keine ungemappten Themenpfade gefunden"
        body="Die sichtbare Area-Struktur deckt die vorhandenen Inhalte derzeit vollständig ab."
      />
    ) : (
      <AreaSectionSurface variant="tasks">
        <SectionHeading kicker="Fehlende Struktur" title="Noch nicht eingepflegte Themenpfade" />
        <div class="subject-groups">
          {[...groupedUnmapped.entries()].map(([subjectSlug, items]) => (
            <section class="subject-group">
              <h2>{subjectTitleMap[subjectSlug] ?? subjectSlug}</h2>
              <div class="table-shell">
                <table>
                  <thead>
                    <tr>
                      <th>Themenpfad</th>
                      <th>Typ</th>
                      <th>Beispiele</th>
                    </tr>
                  </thead>
                  <tbody>
                    {items.map((item) => (
                      <tr>
                        <td><code>{item.path.join("/") || "—"}</code></td>
                        <td>{item.kinds}</td>
                        <td>{item.examples.join(" · ")}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))}
        </div>
      </AreaSectionSurface>
    )}

    {stats.remappedEntries > 0 && (
      <AreaSectionSurface variant="articles">
        <SectionHeading kicker="Legacy-Schutz" title="Alias-Pfade, die aktuell alte Links abfangen" />
        <div class="subject-groups">
          {[...groupedRemapped.entries()].map(([subjectSlug, items]) => (
            <section class="subject-group">
              <h2>{subjectTitleMap[subjectSlug] ?? subjectSlug}</h2>
              <div class="table-shell">
                <table>
                  <thead>
                    <tr>
                      <th>Inhalt</th>
                      <th>Alias</th>
                      <th>Neue Struktur</th>
                    </tr>
                  </thead>
                  <tbody>
                    {items.slice(0, 24).map((item) => (
                      <tr>
                        <td>{item.title}</td>
                        <td>
                          {item.legacyPaths
                            .filter((parts) => parts.join("/") !== item.canonicalPath.join("/"))
                            .map((parts) => parts.join("/"))
                            .join(" · ")}
                        </td>
                        <td><code>{item.canonicalPath.join("/")}</code></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))}
        </div>
      </AreaSectionSurface>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell { display:grid; gap:1rem; }
  .hero { display:grid; gap:.85rem; }
  .eyebrow { margin:0; color:var(--text-soft); font-size:.84rem; font-weight:800; letter-spacing:.05em; text-transform:uppercase; }
  h1 { margin:0; color:var(--text-strong); font-size:clamp(2.2rem,4vw,3.6rem); line-height:.98; letter-spacing:-.045em; }
  .lead { margin:0; color:var(--text); line-height:1.75; max-width:68rem; }
  .stats-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(min(100%, 14rem), 17rem)); gap:.85rem; justify-content:start; }
  .stat-card { display:grid; gap:.35rem; padding:1rem 1.05rem; border:1px solid var(--border); border-radius:22px; background:var(--surface); box-shadow:var(--shadow-soft); }
  .stat-card span { color:var(--text-soft); font-size:.9rem; }
  .stat-card strong { color:var(--text-strong); font-size:1.9rem; line-height:1; }
  .subject-groups { display:grid; gap:1rem; }
  .subject-group { display:grid; gap:.7rem; }
  .subject-group h2 { margin:0; color:var(--text-strong); font-size:1.15rem; line-height:1.15; }
  .table-shell { overflow:auto; border:1px solid var(--border); border-radius:22px; background:var(--surface); box-shadow:var(--shadow-soft); }
  table { width:100%; border-collapse:collapse; min-width:42rem; }
  th, td { padding:.8rem .95rem; text-align:left; vertical-align:top; border-bottom:1px solid var(--border); }
  th { color:var(--text-soft); font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; }
  td { color:var(--text); line-height:1.55; }
  code { color:var(--text-strong); font-size:.9em; }
  tbody tr:last-child td { border-bottom:none; }
  @media (max-width:580px) {
    .stats-grid { grid-template-columns:1fr; }
  }
</style>
