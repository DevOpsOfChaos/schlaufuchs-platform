---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const newsEntries = await getCollection("news", ({ data }) => !data.draft);

  return newsEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"news"> };
const { Content } = await render(entry);
const formattedDate = entry.data.publishedAt.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <section class="news-hero">
    <div class="hero-copy">
      <p class="eyebrow">News</p>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </div>

    <div class="meta-card" data-present="hide">
      <span>Veröffentlicht</span>
      <strong>{formattedDate}</strong>
      <a href={`${base}news`}>Zur News-Übersicht →</a>
    </div>
  </section>

  <section class="news-shell">
    <article class="news-content">
      <Content />
    </article>

    {entry.data.tags.length > 0 && (
      <aside class="news-aside" data-present="hide">
        <div class="aside-card">
          <h2>Tags</h2>
          <ul class="tag-list">
            {entry.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
      </aside>
    )}
  </section>
</BaseLayout>

<style>
  .news-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(15rem, 20rem);
    gap: 1rem;
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.35rem, 4.5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  :global(html[data-presentation-mode="on"]) h1 {
    font-size: clamp(2.7rem, 5.3vw, 4.8rem);
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  :global(html[data-presentation-mode="on"]) .lead {
    font-size: 1.18rem;
    line-height: 1.85;
    max-width: 60rem;
  }

  .meta-card,
  .news-content,
  .aside-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .meta-card {
    display: grid;
    gap: 0.45rem;
    padding: 1.2rem;
    border-radius: 22px;
  }

  .meta-card span {
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta-card strong {
    color: var(--text-strong);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .meta-card a {
    color: var(--text-strong);
    font-weight: 700;
  }

  .news-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(12rem, 18rem);
    gap: 1rem;
    margin-top: 1.6rem;
  }

  :global(html[data-presentation-mode="on"]) .news-hero,
  :global(html[data-presentation-mode="on"]) .news-shell {
    grid-template-columns: 1fr;
  }

  .news-content {
    padding: 1.4rem;
    border-radius: 28px;
    box-shadow: var(--shadow-card);
  }

  :global(html[data-presentation-mode="on"]) .news-content {
    padding: 1.9rem 2rem;
  }

  .aside-card {
    padding: 1.3rem;
    border-radius: 22px;
  }

  .aside-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
  }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }

  .tag-list li {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .news-content :global(h2) {
    margin-top: 1.75rem;
    color: var(--text-strong);
    font-size: 1.5rem;
    line-height: 1.15;
  }

  :global(html[data-presentation-mode="on"]) .news-content :global(h2) {
    font-size: 2rem;
    margin-top: 2rem;
  }

  .news-content :global(h2:first-child) {
    margin-top: 0;
  }

  .news-content :global(p),
  .news-content :global(li) {
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  :global(html[data-presentation-mode="on"]) .news-content :global(p),
  :global(html[data-presentation-mode="on"]) .news-content :global(li) {
    font-size: 1.12rem;
    line-height: 1.9;
  }

  .news-content :global(ul) {
    padding-left: 1.2rem;
  }

  @media (max-width: 980px) {
    .news-hero,
    .news-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
