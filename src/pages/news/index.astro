---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="News – Schlaufuchs" description="Größere Updates von Schlaufuchs.">
  <section class="page">
    <p class="eyebrow">News</p>
    <h1>Größere Updates folgen hier gesammelt.</h1>
    <p>Diese Seite bleibt bewusst ruhig. Hier landen später nur inhaltlich oder produktseitig relevante Änderungen.</p>
  </section>
</BaseLayout>

<style>
  .page {
    padding: 2.5rem 0;
    max-width: 48rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.08;
    color: var(--text-strong);
    max-width: 14ch;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.75;
  }
</style>
