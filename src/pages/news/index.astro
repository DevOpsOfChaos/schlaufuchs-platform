---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const entries = (await getCollection("news"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    ...entry,
    href: `${base}news/${entry.id}`,
    dateLabel: entry.data.publishedAt.toLocaleDateString("de-DE", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }),
    category: entry.data.tags[0] ?? "Update",
  }));

const latestEntry = entries[0];
---

<BaseLayout title="News – Schlaufuchs" description="Änderungen, Inhaltswellen und Plattformschritte als Feed.">
  <section class="news-head">
    <div>
      <p class="eyebrow">News</p>
      <h1>Änderungen als echter Feed</h1>
      <p class="lead">
        Hier laufen sichtbare Inhaltswellen, Plattformschritte und größere Verbesserungen der
        Lernplattform zusammen. Der Feed wird direkt aus der News-Collection aufgebaut.
      </p>
    </div>

    <div class="news-stat">
      <span>Live-Einträge</span>
      <strong>{entries.length}</strong>
      <p>{latestEntry ? `Zuletzt aktualisiert: ${latestEntry.dateLabel}` : "Die ersten News-Einträge werden jetzt sichtbar aufgebaut."}</p>
    </div>
  </section>

  {entries.length > 0 ? (
    <section class="feed">
      {entries.map((entry, index) => (
        <a class={`feed-card tone-${index % 3}`} href={entry.href}>
          <div class="meta">
            <span>{entry.dateLabel}</span>
            <span>{entry.category}</span>
          </div>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.description}</p>
        </a>
      ))}
    </section>
  ) : (
    <section class="empty-shell">
      <article class="empty-card">
        <h2>Noch keine News sichtbar</h2>
        <p>Die News-Collection ist vorbereitet und kann jetzt Schritt für Schritt mit echten Plattform-Updates gefüllt werden.</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .news-head {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(15rem, 19rem);
    gap: 1rem;
    align-items: start;
    padding: 0.25rem 0 0;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1.04;
  }

  .lead {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: var(--text-soft);
    line-height: 1.7;
  }

  .news-stat,
  .empty-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .news-stat {
    display: grid;
    gap: 0.4rem;
    padding: 1.3rem;
    border-radius: 24px;
  }

  .news-stat span {
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .news-stat strong {
    color: var(--text-strong);
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .news-stat p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
  }

  .feed,
  .empty-shell {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .feed-card {
    position: relative;
    overflow: hidden;
    padding: 1.4rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .feed-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .feed-card::after {
    content: "";
    position: absolute;
    right: -2rem;
    bottom: -2.3rem;
    width: 7rem;
    height: 7rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.07);
    pointer-events: none;
  }

  .feed-card.tone-0 { background: linear-gradient(135deg, rgba(93,113,175,.28), rgba(232,237,248,.76)); }
  .feed-card.tone-1 { background: linear-gradient(135deg, rgba(95,139,158,.20), rgba(235,244,247,.82)); }
  .feed-card.tone-2 { background: linear-gradient(135deg, rgba(173,144,156,.22), rgba(245,239,241,.84)); }
  :global(html[data-theme="dark"]) .feed-card.tone-0 { background: linear-gradient(135deg, rgba(72,95,164,.36), rgba(22,31,58,.92)); }
  :global(html[data-theme="dark"]) .feed-card.tone-1 { background: linear-gradient(135deg, rgba(28,71,87,.40), rgba(18,37,45,.92)); }
  :global(html[data-theme="dark"]) .feed-card.tone-2 { background: linear-gradient(135deg, rgba(96,72,104,.34), rgba(49,38,43,.92)); }

  .meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .feed-card h2,
  .empty-card h2 {
    margin: 0.75rem 0 0;
    color: var(--text-strong);
    font-size: clamp(1.45rem, 2vw, 1.8rem);
    line-height: 1.1;
  }

  .feed-card p,
  .empty-card p {
    margin: 0.8rem 0 0;
    color: var(--text);
    line-height: 1.62;
    max-width: 46rem;
  }

  .empty-card {
    padding: 1.4rem 1.5rem;
    border-radius: 22px;
  }

  @media (max-width: 980px) {
    .news-head {
      grid-template-columns: 1fr;
    }
  }
</style>
