---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleNews } from "../../data/content";

const base = import.meta.env.BASE_URL;

const formatDate = (date: Date) =>
  date.toLocaleDateString("de-DE", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });

const entries = (await getVisibleNews()).map((entry) => ({
  ...entry,
  href: `${base}news/${entry.id}`,
  dateLabel: formatDate(entry.data.publishedAt),
  category: entry.data.tags[0] ?? "Update",
}));

const latestEntry = entries[0];
const archiveEntries = entries.slice(1, 4);
---

<BaseLayout title="News – Schlaufuchs" description="Änderungen und Updates als einfache News-Seite.">
  <section class="news-head">
    <div>
      <p class="eyebrow">News</p>
      <h1>Neuigkeiten und Updates</h1>
      <p class="lead">Hier findest du aktuelle Änderungen und neue Inhalte.</p>
    </div>
  </section>

  {latestEntry && (
    <section class="latest-shell">
      <a class="latest-card" href={latestEntry.href}>
        <div class="meta" data-present="hide">
          <span>{latestEntry.dateLabel}</span>
          <span>{latestEntry.category}</span>
        </div>
        <h2>{latestEntry.data.title}</h2>
        <p>{latestEntry.data.description}</p>
      </a>
    </section>
  )}

  {entries.length > 1 ? (
    <section class="feed-section">
      <div class="section-head">
        <div>
          <p class="section-kicker">Weitere Einträge</p>
          <h2>Frühere Updates</h2>
        </div>
      </div>

      <section class="feed">
        {archiveEntries.map((entry, index) => (
          <a class={`feed-card tone-${index % 3}`} href={entry.href}>
            <div class="meta" data-present="hide">
              <span>{entry.dateLabel}</span>
              <span>{entry.category}</span>
            </div>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
          </a>
        ))}
      </section>
    </section>
  ) : entries.length === 0 ? (
    <section class="empty-shell">
      <article class="empty-card">
        <h2>Noch keine News sichtbar</h2>
        <p>Aktuell sind noch keine News-Einträge sichtbar.</p>
      </article>
    </section>
  ) : null}
</BaseLayout>

<style>
  .news-head {
    display: grid;
    gap: 1rem;
    padding: 0.25rem 0 0;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1.04;
  }

  .lead {
    margin: 1rem 0 0;
    max-width: 42rem;
    color: var(--text-soft);
    line-height: 1.7;
  }

  .empty-card,
  .latest-card,
  .feed-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .latest-shell,
  .feed-section,
  .empty-shell {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .latest-card,
  .feed-card {
    position: relative;
    overflow: hidden;
    padding: 1.45rem 1.55rem;
    border-radius: 24px;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .latest-card:hover,
  .feed-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .latest-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.14), rgba(238,242,255,0.92));
  }

  :global(html[data-theme="dark"]) .latest-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.22), rgba(18,27,46,0.94));
  }

  .feed {
    display: grid;
    gap: 1rem;
  }

  .feed-card.tone-0 { background: linear-gradient(135deg, rgba(93,113,175,.28), rgba(232,237,248,.76)); }
  .feed-card.tone-1 { background: linear-gradient(135deg, rgba(95,139,158,.20), rgba(235,244,247,.82)); }
  .feed-card.tone-2 { background: linear-gradient(135deg, rgba(173,144,156,.22), rgba(245,239,241,.84)); }
  :global(html[data-theme="dark"]) .feed-card.tone-0 { background: linear-gradient(135deg, rgba(72,95,164,.36), rgba(22,31,58,.92)); }
  :global(html[data-theme="dark"]) .feed-card.tone-1 { background: linear-gradient(135deg, rgba(28,71,87,.40), rgba(18,37,45,.92)); }
  :global(html[data-theme="dark"]) .feed-card.tone-2 { background: linear-gradient(135deg, rgba(96,72,104,.34), rgba(49,38,43,.92)); }

  .meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .latest-card h2,
  .feed-card h3,
  .empty-card h2,
  .section-head h2 {
    margin: 0.75rem 0 0;
    color: var(--text-strong);
    line-height: 1.1;
  }

  .latest-card h2,
  .section-head h2 {
    font-size: clamp(1.45rem, 2vw, 1.8rem);
  }

  .feed-card h3,
  .empty-card h2 {
    font-size: clamp(1.3rem, 1.8vw, 1.6rem);
  }

  .latest-card p,
  .feed-card p,
  .empty-card p {
    margin: 0.8rem 0 0;
    color: var(--text);
    line-height: 1.62;
    max-width: 46rem;
  }

  .empty-card {
    padding: 1.4rem 1.5rem;
    border-radius: 22px;
  }
</style>
