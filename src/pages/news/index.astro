---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const mascot = `${base}assets/mascots/general.png`;
---

<BaseLayout title="News – Schlaufuchs" description="Größere Updates von Schlaufuchs.">
  <section class="news-hero">
    <div class="copy">
      <p class="eyebrow">News</p>
      <h1>Größere Updates folgen hier gesammelt.</h1>
      <p>Diese Seite bleibt bewusst ruhig. Hier landen später nur größere inhaltliche oder produktseitige Änderungen.</p>
    </div>

    <div class="mascot" aria-hidden="true">
      <img src={mascot} alt="" loading="eager" />
    </div>
  </section>
</BaseLayout>

<style>
  .news-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: end;
    padding: 2.2rem 2.2rem 0;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .copy { padding-bottom: 1.9rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--text-soft); }
  h1 { margin: 0 0 1rem; color: var(--text-strong); font-size: clamp(2.2rem, 4vw, 3.8rem); line-height: 1.04; max-width: 12ch; }
  p:last-child { margin: 0; color: var(--text-soft); line-height: 1.7; max-width: 42rem; }

  .mascot { width: min(100%, 13rem); }
  .mascot img { width: 100%; display: block; object-fit: contain; }

  @media (max-width: 820px) {
    .news-hero { grid-template-columns: 1fr; padding: 1.8rem 1.4rem 0; }
    .copy { padding-bottom: 1rem; }
    .mascot { justify-self: center; width: min(100%, 10rem); }
  }
</style>
