---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSearchEntries } from "../../data/content";

const searchEntries = await getSearchEntries(import.meta.env.BASE_URL);
const base = import.meta.env.BASE_URL;
const quickFilters = ["Alle", "Mathematik", "Informatik", "Elektrotechnik", "Linux", "Web Development", "News"];
---

<BaseLayout title="Suche – Schlaufuchs" description="Themen, Aufgaben, Wissensseiten und News durchsuchen.">
  <section class="search-hero">
    <div class="copy">
      <p class="eyebrow">Suche</p>
      <h1>Schnell finden statt lange klicken.</h1>
      <p class="lead">
        Die Suche greift direkt auf die sichtbaren Fachbereiche, Wissensseiten, Aufgaben und
        News der Plattform zu. So werden Inhalte nicht nur gesammelt, sondern wirklich auffindbar.
      </p>
    </div>

    <div class="hero-stat" data-present="hide">
      <span>Live-Einträge</span>
      <strong>{searchEntries.length}</strong>
      <p>Fachbereiche, Wissensseiten, Aufgaben und News werden gemeinsam durchsucht.</p>
    </div>
  </section>

  <section class="search-panel" data-present="hide">
    <label class="search-input-shell" for="search-input">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input id="search-input" type="search" placeholder="Nach Thema, Aufgabe oder Wissensseite suchen ..." autocomplete="off" />
    </label>

    <div class="filter-row" aria-label="Bereichsfilter">
      {quickFilters.map((filter, index) => (
        <button
          type="button"
          class:list={["filter-chip", { active: index === 0 }]}
          data-filter={filter}
        >
          {filter}
        </button>
      ))}
    </div>

    <p class="search-status" id="search-status">Alle {searchEntries.length} Einträge sichtbar.</p>
  </section>

  <section class="results-grid" id="search-results">
    {searchEntries.map((item) => (
      <a
        class="result-card"
        href={item.href}
        data-title={item.title.toLowerCase()}
        data-description={item.description.toLowerCase()}
        data-kind={item.kind.toLowerCase()}
        data-area={item.area.toLowerCase()}
        data-tags={item.tags.toLowerCase()}
      >
        <div class="meta" data-present="hide">
          <span>{item.kind}</span>
          <span>{item.area}</span>
        </div>
        <h2>{item.title}</h2>
        <p>{item.description}</p>
      </a>
    ))}
  </section>

  <p class="empty-state" id="search-empty" hidden>Keine Treffer gefunden.</p>

  <script is:inline>
    const root = document.documentElement;
    const input = document.getElementById("search-input");
    const cards = Array.from(document.querySelectorAll(".result-card"));
    const chips = Array.from(document.querySelectorAll(".filter-chip"));
    const emptyState = document.getElementById("search-empty");
    const status = document.getElementById("search-status");
    const params = new URLSearchParams(window.location.search);

    let activeFilter = (params.get("bereich") || "Alle").toLowerCase();

    const normalizeFilter = (value) => {
      const normalized = (value || "Alle").toLowerCase();
      const available = chips.map((chip) => (chip.getAttribute("data-filter") || "Alle").toLowerCase());
      return available.includes(normalized) ? normalized : "alle";
    };

    const syncUrl = (query, filter) => {
      const next = new URL(window.location.href);
      if (query) {
        next.searchParams.set("q", query);
      } else {
        next.searchParams.delete("q");
      }

      if (filter && filter !== "alle") {
        next.searchParams.set("bereich", filter);
      } else {
        next.searchParams.delete("bereich");
      }

      history.replaceState({}, "", next);
    };

    const renderFilterButtons = () => {
      chips.forEach((chip) => {
        const chipFilter = (chip.getAttribute("data-filter") || "Alle").toLowerCase();
        chip.classList.toggle("active", chipFilter === activeFilter);
      });
    };

    const updateStatus = (visibleCount, query, filter, presentationMode) => {
      if (!status) return;
      if (presentationMode) {
        status.textContent = `${visibleCount} Einträge sichtbar.`;
        return;
      }

      const filterLabel = filter !== "alle" ? ` im Bereich ${filter}` : "";
      if (!query && filter === "alle") {
        status.textContent = `Alle ${visibleCount} Einträge sichtbar.`;
        return;
      }

      if (query) {
        status.textContent = `${visibleCount} Treffer für „${query}“${filterLabel}.`;
        return;
      }

      status.textContent = `${visibleCount} Einträge sichtbar${filterLabel}.`;
    };

    const applySearch = () => {
      const presentationMode = root.dataset.presentationMode === "on";
      const query = presentationMode ? "" : (input?.value || "").trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const haystack = [
          card.getAttribute("data-title") || "",
          card.getAttribute("data-description") || "",
          card.getAttribute("data-kind") || "",
          card.getAttribute("data-area") || "",
          card.getAttribute("data-tags") || "",
        ].join(" ");
        const area = card.getAttribute("data-area") || "";
        const matchesQuery = !query || haystack.includes(query);
        const matchesFilter = presentationMode || activeFilter === "alle" || area === activeFilter;
        const visible = matchesQuery && matchesFilter;
        card.toggleAttribute("hidden", !visible);
        if (visible) visibleCount += 1;
      });

      emptyState?.toggleAttribute("hidden", visibleCount !== 0);
      updateStatus(visibleCount, query, activeFilter, presentationMode);
      syncUrl(query, activeFilter);
    };

    const setInitialState = () => {
      activeFilter = normalizeFilter(activeFilter);
      const initialQuery = params.get("q") || "";
      if (input) {
        input.value = initialQuery;
      }
      renderFilterButtons();
    };

    input?.addEventListener("input", applySearch);

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeFilter = normalizeFilter(chip.getAttribute("data-filter") || "Alle");
        renderFilterButtons();
        applySearch();
      });
    });

    window.addEventListener("presentationmode-changed", applySearch);
    window.addEventListener("keydown", (event) => {
      const target = event.target;
      const tagName = target instanceof HTMLElement ? target.tagName : "";
      const isTyping = target instanceof HTMLElement && (target.isContentEditable || ["INPUT", "TEXTAREA", "SELECT"].includes(tagName));
      if (isTyping || root.dataset.presentationMode === "on") return;
      if (event.key === "/") {
        event.preventDefault();
        input?.focus();
      }
    });

    setInitialState();
    applySearch();
  </script>

  <style>
    .search-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(15rem, 19rem);
      gap: 1rem;
      align-items: start;
      padding: 0.3rem 0 0;
    }

    :global(html[data-presentation-mode="on"]) .search-hero,
    :global(html[data-presentation-mode="on"]) .results-grid {
      grid-template-columns: 1fr;
    }

    .eyebrow {
      margin: 0 0 0.75rem;
      color: var(--text-soft);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      color: var(--text-strong);
      font-size: clamp(2.2rem, 4vw, 3.7rem);
      line-height: 1.04;
      max-width: 12ch;
    }

    .lead {
      max-width: 44rem;
      margin: 1rem 0 0;
      color: var(--text-soft);
      line-height: 1.72;
    }

    .hero-stat {
      display: grid;
      gap: 0.4rem;
      padding: 1.3rem;
      border-radius: 24px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      box-shadow: var(--shadow-soft);
    }

    .hero-stat span {
      color: var(--text-soft);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-stat strong {
      color: var(--text-strong);
      font-size: 3rem;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .hero-stat p {
      margin: 0;
      color: var(--text);
      line-height: 1.6;
    }

    .search-panel {
      display: grid;
      gap: 0.9rem;
      margin-top: 1.35rem;
    }

    .search-input-shell {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      min-height: 3.6rem;
      padding: 0 1.1rem;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      box-shadow: var(--shadow-soft);
    }

    .search-icon {
      color: var(--text-soft);
      font-size: 1.1rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .search-input-shell input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--text-strong);
      font: inherit;
    }

    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .filter-chip {
      min-height: 2.7rem;
      padding: 0 1rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      box-shadow: var(--shadow-soft);
    }

    .filter-chip.active {
      border-color: var(--border-strong);
      background: var(--surface-2);
      color: var(--text-strong);
    }

    .search-status {
      margin: 0;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .results-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.35rem;
    }

    .result-card {
      min-height: 14rem;
      padding: 1.35rem;
      border-radius: 22px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      box-shadow: var(--shadow-soft);
      color: inherit;
      transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
    }

    .result-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-card);
      border-color: var(--border-strong);
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      color: var(--text-soft);
      font-size: 0.92rem;
    }

    .result-card h2 {
      margin: 0.8rem 0 0;
      color: var(--text-strong);
      font-size: clamp(1.35rem, 2vw, 1.7rem);
      line-height: 1.12;
    }

    .result-card p {
      margin: 0.8rem 0 0;
      color: var(--text);
      line-height: 1.6;
    }

    .empty-state {
      margin: 1rem 0 0;
      color: var(--text-soft);
    }

    @media (max-width: 980px) {
      .search-hero,
      .results-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
