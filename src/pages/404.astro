---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Seite nicht gefunden – Schlaufuchs" description="Die angeforderte Seite konnte nicht gefunden werden." noIndex={true}>
  <section class="not-found-shell">
    <article class="not-found-card">
      <p class="eyebrow">404</p>
      <h1>Diese Seite gibt es in der neuen Plattformstruktur nicht mehr.</h1>
      <p class="lead">
        Der Inhalt wurde möglicherweise verschoben, umbenannt oder in einen Fachbereich integriert.
        Über die Hauptzugänge findest du schnell zurück in die aktuelle Struktur.
      </p>

      <div class="actions">
        <a class="primary" href={`${base}`}>Zur Startseite</a>
        <a class="secondary" href={`${base}fachbereiche`}>Zu den Fachbereichen</a>
        <a class="secondary" href={`${base}suchen`}>Zur Suche</a>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .not-found-shell {
    display: grid;
    place-items: center;
    min-height: 62vh;
  }

  .not-found-card {
    width: min(100%, 52rem);
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 30px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.2rem, 4.4vw, 3.7rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    max-width: 15ch;
  }

  .lead {
    margin: 1rem 0 0;
    max-width: 44rem;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.04rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.05rem;
    padding: 0 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .actions .primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .actions .secondary {
    background: var(--surface);
    color: var(--text-strong);
  }
</style>
