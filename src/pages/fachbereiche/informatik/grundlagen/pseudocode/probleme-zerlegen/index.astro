---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { informatikLeafPages } from "../../../../../../data/informatik_leaf_pages";

const page = informatikLeafPages["probleme-zerlegen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Informatik", href: "/fachbereiche/informatik" },
  { label: "Informatik Grundlagen", href: "/fachbereiche/informatik/grundlagen" },
  { label: "Pseudocode", href: "/fachbereiche/informatik/grundlagen/pseudocode" },
  { label: "Probleme zerlegen", href: "/fachbereiche/informatik/grundlagen/pseudocode/probleme-zerlegen" },
];
const related = [
  {
    title: "Pseudocode",
    text: "Weiteres Unterthema in Pseudocode.",
    href: "/fachbereiche/informatik/grundlagen/pseudocode/pseudocode",
    tone: "cs-a",
  },
  {
    title: "Ablaufpläne",
    text: "Weiteres Unterthema in Pseudocode.",
    href: "/fachbereiche/informatik/grundlagen/pseudocode/ablaufplaene",
    tone: "cs-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
