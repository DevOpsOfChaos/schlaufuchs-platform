---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { informatikLeafPages } from "../../../../../../data/informatik_leaf_pages";

const page = informatikLeafPages["vergleich"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Informatik", href: "/fachbereiche/informatik" },
  { label: "Informatik Grundlagen", href: "/fachbereiche/informatik/grundlagen" },
  { label: "Algorithmen", href: "/fachbereiche/informatik/grundlagen/algorithmen" },
  { label: "Vergleich", href: "/fachbereiche/informatik/grundlagen/algorithmen/vergleich" },
];
const related = [
  {
    title: "Algorithmen",
    text: "Weiteres Unterthema in Algorithmen.",
    href: "/fachbereiche/informatik/grundlagen/algorithmen/algorithmen",
    tone: "cs-a",
  },
  {
    title: "Abläufe",
    text: "Weiteres Unterthema in Algorithmen.",
    href: "/fachbereiche/informatik/grundlagen/algorithmen/ablaeufe",
    tone: "cs-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
