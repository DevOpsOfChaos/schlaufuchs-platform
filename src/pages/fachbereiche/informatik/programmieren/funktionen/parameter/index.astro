---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { informatikLeafPages } from "../../../../../../data/informatik_leaf_pages";

const page = informatikLeafPages["parameter"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Informatik", href: "/fachbereiche/informatik" },
  { label: "Informatik Programmieren", href: "/fachbereiche/informatik/programmieren" },
  { label: "Funktionen", href: "/fachbereiche/informatik/programmieren/funktionen" },
  { label: "Parameter", href: "/fachbereiche/informatik/programmieren/funktionen/parameter" },
];
const related = [
  {
    title: "Funktionen",
    text: "Weiteres Unterthema in Funktionen.",
    href: "/fachbereiche/informatik/programmieren/funktionen/funktionen",
    tone: "cs-a",
  },
  {
    title: "Rückgabewerte",
    text: "Weiteres Unterthema in Funktionen.",
    href: "/fachbereiche/informatik/programmieren/funktionen/rueckgabewerte",
    tone: "cs-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
