---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { informatikLeafPages } from "../../../../../../data/informatik_leaf_pages";

const page = informatikLeafPages["c-einstieg"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Informatik", href: "/fachbereiche/informatik" },
  { label: "Informatik Programmieren", href: "/fachbereiche/informatik/programmieren" },
  { label: "C", href: "/fachbereiche/informatik/programmieren/c" },
  { label: "C Einstieg", href: "/fachbereiche/informatik/programmieren/c/c-einstieg" },
];
const related = [
  {
    title: "Datentypen in C",
    text: "Weiteres Unterthema in C.",
    href: "/fachbereiche/informatik/programmieren/c/datentypen-in-c",
    tone: "cs-b",
  },
  {
    title: "Eingabe und Ausgabe",
    text: "Weiteres Unterthema in C.",
    href: "/fachbereiche/informatik/programmieren/c/eingabe-ausgabe",
    tone: "cs-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
