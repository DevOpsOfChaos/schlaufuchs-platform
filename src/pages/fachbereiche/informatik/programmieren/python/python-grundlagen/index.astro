---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { informatikLeafPages } from "../../../../../../data/informatik_leaf_pages";

const page = informatikLeafPages["python-grundlagen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Informatik", href: "/fachbereiche/informatik" },
  { label: "Informatik Programmieren", href: "/fachbereiche/informatik/programmieren" },
  { label: "Python", href: "/fachbereiche/informatik/programmieren/python" },
  { label: "Python Grundlagen", href: "/fachbereiche/informatik/programmieren/python/python-grundlagen" },
];
const related = [
  {
    title: "Variablen",
    text: "Weiteres Unterthema in Python.",
    href: "/fachbereiche/informatik/programmieren/python/variablen",
    tone: "cs-b",
  },
  {
    title: "Bedingungen",
    text: "Weiteres Unterthema in Python.",
    href: "/fachbereiche/informatik/programmieren/python/bedingungen",
    tone: "cs-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
