---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["variablen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Grundlagen", href: "/fachbereiche/mathematik/grundlagen" },
  { label: "Terme", href: "/fachbereiche/mathematik/grundlagen/terme" },
  { label: "Variablen", href: "/fachbereiche/mathematik/grundlagen/terme/variablen" },
];
const related = [
  {
    title: "Klammern",
    text: "Weiteres Unterthema in Terme.",
    href: "/fachbereiche/mathematik/grundlagen/terme/klammern",
    tone: "math-b",
  },
  {
    title: "Terme umformen",
    text: "Weiteres Unterthema in Terme.",
    href: "/fachbereiche/mathematik/grundlagen/terme/term-umformen",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
