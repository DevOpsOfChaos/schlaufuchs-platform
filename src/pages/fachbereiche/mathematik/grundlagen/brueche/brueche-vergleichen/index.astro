---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["brueche-vergleichen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Grundlagen", href: "/fachbereiche/mathematik/grundlagen" },
  { label: "Brüche", href: "/fachbereiche/mathematik/grundlagen/brueche" },
  { label: "Brüche vergleichen", href: "/fachbereiche/mathematik/grundlagen/brueche/brueche-vergleichen" },
];
const related = [
  {
    title: "Brüche verstehen",
    text: "Weiteres Unterthema in Brüche.",
    href: "/fachbereiche/mathematik/grundlagen/brueche/brueche-verstehen",
    tone: "math-a",
  },
  {
    title: "Brüche umformen",
    text: "Weiteres Unterthema in Brüche.",
    href: "/fachbereiche/mathematik/grundlagen/brueche/brueche-umformen",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
