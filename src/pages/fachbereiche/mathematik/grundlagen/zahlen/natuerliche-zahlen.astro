---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { withBase } from "../../../../../utils/base";

const targetHref = withBase("wissen/mathematik/grundlagen/zahlen/natuerliche-zahlen");
---

<BaseLayout title="Natürliche Zahlen – Fachinfo" description="Weiterleitung zur ausführlichen Wissensseite über natürliche Zahlen.">
  <script is:inline define:vars={{ targetHref }}>
    window.location.replace(targetHref);
  </script>
  <section>
    <h1>Natürliche Zahlen</h1>
    <p>Die ausführliche Inhaltsseite wird geöffnet.</p>
    <a href={targetHref}>Zur Wissensseite</a>
  </section>
</BaseLayout>
