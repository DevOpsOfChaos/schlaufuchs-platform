---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["rechenarten"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Grundlagen", href: "/fachbereiche/mathematik/grundlagen" },
  { label: "Zahlen", href: "/fachbereiche/mathematik/grundlagen/zahlen" },
  { label: "Rechenarten", href: "/fachbereiche/mathematik/grundlagen/zahlen/rechenarten" },
];
const related = [
  {
    title: "Natürliche Zahlen",
    text: "Weiteres Unterthema in Zahlen.",
    href: "/fachbereiche/mathematik/grundlagen/zahlen/natuerliche-zahlen",
    tone: "math-a",
  },
  {
    title: "Ganze Zahlen",
    text: "Weiteres Unterthema in Zahlen.",
    href: "/fachbereiche/mathematik/grundlagen/zahlen/ganze-zahlen",
    tone: "math-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
