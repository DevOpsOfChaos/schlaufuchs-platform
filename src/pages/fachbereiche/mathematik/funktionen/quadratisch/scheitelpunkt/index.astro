---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["scheitelpunkt"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Funktionen", href: "/fachbereiche/mathematik/funktionen" },
  { label: "Quadratisch", href: "/fachbereiche/mathematik/funktionen/quadratisch" },
  { label: "Scheitelpunkt", href: "/fachbereiche/mathematik/funktionen/quadratisch/scheitelpunkt" },
];
const related = [
  {
    title: "Quadratische Funktionen",
    text: "Weiteres Unterthema in Quadratisch.",
    href: "/fachbereiche/mathematik/funktionen/quadratisch/quadratische-funktionen",
    tone: "math-a",
  },
  {
    title: "Normalform",
    text: "Weiteres Unterthema in Quadratisch.",
    href: "/fachbereiche/mathematik/funktionen/quadratisch/normalform",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
