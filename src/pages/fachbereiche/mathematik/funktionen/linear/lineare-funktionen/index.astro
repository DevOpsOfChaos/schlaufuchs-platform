---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["lineare-funktionen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Funktionen", href: "/fachbereiche/mathematik/funktionen" },
  { label: "Linear", href: "/fachbereiche/mathematik/funktionen/linear" },
  { label: "Lineare Funktionen", href: "/fachbereiche/mathematik/funktionen/linear/lineare-funktionen" },
];
const related = [
  {
    title: "Steigung",
    text: "Weiteres Unterthema in Linear.",
    href: "/fachbereiche/mathematik/funktionen/linear/steigung",
    tone: "math-b",
  },
  {
    title: "Achsenabschnitt",
    text: "Weiteres Unterthema in Linear.",
    href: "/fachbereiche/mathematik/funktionen/linear/achsenschnitt",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
