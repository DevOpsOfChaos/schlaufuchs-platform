---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["wuerfel"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Geometrie", href: "/fachbereiche/mathematik/geometrie" },
  { label: "Volumen", href: "/fachbereiche/mathematik/geometrie/volumen" },
  { label: "Würfel", href: "/fachbereiche/mathematik/geometrie/volumen/wuerfel" },
];
const related = [
  {
    title: "Quader",
    text: "Weiteres Unterthema in Volumen.",
    href: "/fachbereiche/mathematik/geometrie/volumen/quader",
    tone: "math-a",
  },
  {
    title: "Zylinder",
    text: "Weiteres Unterthema in Volumen.",
    href: "/fachbereiche/mathematik/geometrie/volumen/zylinder",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
