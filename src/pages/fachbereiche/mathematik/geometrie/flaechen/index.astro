---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import TopicLandingPage from "../../../../../components/content/TopicLandingPage.astro";
import { mathematikTopics } from "../../../../../data/mathematik_topics";

const page = mathematikTopics["flaechen"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Geometrie", href: "/fachbereiche/mathematik/geometrie" },
  { label: "Flächen", href: "/fachbereiche/mathematik/geometrie/flaechen" },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <TopicLandingPage page={page} breadcrumbs={breadcrumbs} />
</BaseLayout>
