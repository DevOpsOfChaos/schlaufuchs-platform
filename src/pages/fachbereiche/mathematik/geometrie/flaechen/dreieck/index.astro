---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { mathematikLeafPages } from "../../../../../../data/mathematik_leaf_pages";

const page = mathematikLeafPages["dreieck"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Mathematik", href: "/fachbereiche/mathematik" },
  { label: "Mathematik Geometrie", href: "/fachbereiche/mathematik/geometrie" },
  { label: "Flächen", href: "/fachbereiche/mathematik/geometrie/flaechen" },
  { label: "Dreieck", href: "/fachbereiche/mathematik/geometrie/flaechen/dreieck" },
];
const related = [
  {
    title: "Rechteck und Quadrat",
    text: "Weiteres Unterthema in Flächen.",
    href: "/fachbereiche/mathematik/geometrie/flaechen/rechteck-und-quadrat",
    tone: "math-a",
  },
  {
    title: "Kreis",
    text: "Weiteres Unterthema in Flächen.",
    href: "/fachbereiche/mathematik/geometrie/flaechen/kreis",
    tone: "math-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
