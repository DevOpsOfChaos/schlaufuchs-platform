---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["chown"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux System", href: "/fachbereiche/linux/system" },
  { label: "Rechte", href: "/fachbereiche/linux/system/rechte" },
  { label: "chown", href: "/fachbereiche/linux/system/rechte/chown" },
];
const related = [
  {
    title: "Dateirechte",
    text: "Weiteres Unterthema in Rechte.",
    href: "/fachbereiche/linux/system/rechte/dateirechte",
    tone: "linux-a",
  },
  {
    title: "chmod",
    text: "Weiteres Unterthema in Rechte.",
    href: "/fachbereiche/linux/system/rechte/chmod",
    tone: "linux-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
