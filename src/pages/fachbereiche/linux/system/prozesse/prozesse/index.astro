---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["prozesse"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux System", href: "/fachbereiche/linux/system" },
  { label: "Prozesse", href: "/fachbereiche/linux/system/prozesse" },
  { label: "Prozesse", href: "/fachbereiche/linux/system/prozesse/prozesse" },
];
const related = [
  {
    title: "ps und top",
    text: "Weiteres Unterthema in Prozesse.",
    href: "/fachbereiche/linux/system/prozesse/ps-top",
    tone: "linux-b",
  },
  {
    title: "kill",
    text: "Weiteres Unterthema in Prozesse.",
    href: "/fachbereiche/linux/system/prozesse/kill",
    tone: "linux-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
