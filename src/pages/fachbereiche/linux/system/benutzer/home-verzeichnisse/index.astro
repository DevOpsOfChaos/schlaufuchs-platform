---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["home-verzeichnisse"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux System", href: "/fachbereiche/linux/system" },
  { label: "Benutzer", href: "/fachbereiche/linux/system/benutzer" },
  { label: "Home-Verzeichnisse", href: "/fachbereiche/linux/system/benutzer/home-verzeichnisse" },
];
const related = [
  {
    title: "Benutzer und Gruppen",
    text: "Weiteres Unterthema in Benutzer.",
    href: "/fachbereiche/linux/system/benutzer/benutzer-und-gruppen",
    tone: "linux-a",
  },
  {
    title: "id und groups",
    text: "Weiteres Unterthema in Benutzer.",
    href: "/fachbereiche/linux/system/benutzer/id-groups",
    tone: "linux-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
