---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["shell-konfiguration"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Praxis", href: "/fachbereiche/linux/praxis" },
  { label: "Konfiguration", href: "/fachbereiche/linux/praxis/konfiguration" },
  { label: "Shell-Konfiguration", href: "/fachbereiche/linux/praxis/konfiguration/shell-konfiguration" },
];
const related = [
  {
    title: "Alias",
    text: "Weiteres Unterthema in Konfiguration.",
    href: "/fachbereiche/linux/praxis/konfiguration/alias",
    tone: "linux-b",
  },
  {
    title: "Profile",
    text: "Weiteres Unterthema in Konfiguration.",
    href: "/fachbereiche/linux/praxis/konfiguration/profile",
    tone: "linux-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
