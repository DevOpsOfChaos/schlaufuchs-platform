---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["nano"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Praxis", href: "/fachbereiche/linux/praxis" },
  { label: "nano", href: "/fachbereiche/linux/praxis/nano" },
  { label: "nano", href: "/fachbereiche/linux/praxis/nano/nano" },
];
const related = [
  {
    title: "Speichern und Beenden",
    text: "Weiteres Unterthema in nano.",
    href: "/fachbereiche/linux/praxis/nano/speichern-und-beenden",
    tone: "linux-b",
  },
  {
    title: "Konfig-Dateien",
    text: "Weiteres Unterthema in nano.",
    href: "/fachbereiche/linux/praxis/nano/konfig-dateien",
    tone: "linux-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
