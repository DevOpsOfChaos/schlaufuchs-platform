---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import ArticleLayout from "../../../../../../components/content/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

const articleId = "linux/shell/befehle/grundbefehle";
const articles = await getCollection("articles");
const entry = articles.find((item) => item.id.replace(/\.(md|mdx)$/i, "") === articleId);

if (!entry) {
  throw new Error(`Article not found for: linux/shell/befehle/grundbefehle`);
}

const { Content, headings } = await render(entry);
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Shell", href: "/fachbereiche/linux/shell" },
  { label: "Befehle", href: "/fachbereiche/linux/shell/befehle" },
  { label: "Grundbefehle", href: "/fachbereiche/linux/shell/befehle/grundbefehle" },
];
const prevLink = null;
const nextLink = { title: "Dateibefehle", href: "/fachbereiche/linux/shell/befehle/dateibefehle" };
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <ArticleLayout
    entry={entry}
    Content={Content}
    headings={headings}
    breadcrumbs={breadcrumbs}
    prevLink={prevLink}
    nextLink={nextLink}
  />
</BaseLayout>
