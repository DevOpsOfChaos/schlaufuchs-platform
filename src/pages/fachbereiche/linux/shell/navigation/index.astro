---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import InfoEntryGrid from "../../../../../components/content/InfoEntryGrid.astro";

const base = import.meta.env.BASE_URL;
const mascot = `${base}assets/mascots/linux.png`;

const groups = [
  {
    title: "Erste Schritte",
    text: "Grundbegriffe und Orientierung für den Einstieg in die Navigation im Terminal.",
    tone: "linux-a",
    links: [
      { label: "Was ist ein Verzeichnis?", href: "/fachbereiche/linux/shell/navigation" },
      { label: "Aktuelles Verzeichnis", href: "/fachbereiche/linux/shell/navigation" },
    ],
  },
  {
    title: "Wichtige Wege",
    text: "Die grundlegenden Befehle, mit denen man sich durch das Dateisystem bewegt.",
    tone: "linux-b",
    links: [
      { label: "pwd verstehen", href: "/fachbereiche/linux/shell/navigation" },
      { label: "cd nutzen", href: "/fachbereiche/linux/shell/navigation" },
      { label: "ls lesen", href: "/fachbereiche/linux/shell/navigation" },
    ],
  },
  {
    title: "Direkte Infoseiten",
    text: "Kleine, direkte Themen für schnelle Erklärungen ohne weitere Zwischenebene.",
    tone: "linux-c",
    links: [
      { label: "Absolute Pfade", href: "/fachbereiche/linux/shell/navigation" },
      { label: "Relative Pfade", href: "/fachbereiche/linux/shell/navigation" },
    ],
  },
];
---

<BaseLayout
  title="Navigation – Linux Shell – Schlaufuchs"
  description="Unter-Unterthema für Linux Shell Navigation."
>
  <section class="hero">
    <div class="copy">
      <p class="eyebrow">Unter-Unterbereich</p>
      <h1>Navigation</h1>
      <p class="lead">Die erste echte Unterebene im neuen System. So lassen sich Themen, Unterthemen und Infoseiten sauber erweitern.</p>
    </div>

    <div class="mascot" aria-hidden="true">
      <img src={mascot} alt="" loading="eager" />
    </div>
  </section>

  <InfoEntryGrid groups={groups} />
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.2rem;
    align-items: end;
    padding: 2.1rem 2.1rem 0;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -110px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: rgba(127, 140, 255, 0.12);
  }

  .copy { position: relative; z-index: 1; padding-bottom: 1.8rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--text-soft); }
  h1 { margin: 0; color: var(--text-strong); font-size: clamp(2.4rem, 4vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
  .lead { margin: 1rem 0 0; max-width: 42rem; color: var(--text-soft); line-height: 1.7; }

  .mascot { position: relative; z-index: 1; width: min(100%, 13rem); }
  .mascot img { width: 100%; display: block; object-fit: contain; }

  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; padding: 1.8rem 1.4rem 0; }
    .copy { padding-bottom: 1rem; }
    .mascot { justify-self: center; width: min(100%, 10rem); }
  }
</style>
