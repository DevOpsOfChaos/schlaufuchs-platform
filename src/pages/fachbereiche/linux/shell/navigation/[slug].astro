---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import ArticleLayout from "../../../../../components/content/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

const navigationSet = [
  {
    slug: "pwd",
    articleId: "linux/shell/navigation/pwd",
    title: "pwd verstehen",
    href: "/fachbereiche/linux/shell/navigation/pwd",
  },
  {
    slug: "cd",
    articleId: "linux/shell/navigation/cd",
    title: "cd verstehen",
    href: "/fachbereiche/linux/shell/navigation/cd",
  },
  {
    slug: "pfade",
    articleId: "linux/shell/navigation/pfade",
    title: "Pfade verstehen",
    href: "/fachbereiche/linux/shell/navigation/pfade",
  },
];

export async function getStaticPaths() {
  return [
    { params: { slug: "pwd" } },
    { params: { slug: "cd" } },
    { params: { slug: "pfade" } },
  ];
}

const { slug } = Astro.params;
const current = navigationSet.find((item) => item.slug === slug);

if (!current) {
  throw new Error(`Unknown linux navigation article slug: ${slug}`);
}

const articles = await getCollection("articles");
const entry = articles.find(
  (item) => item.id.replace(/\.(md|mdx)$/i, "") === current.articleId,
);

if (!entry) {
  throw new Error(`Article not found for: ${current.articleId}`);
}

const { Content, headings } = await render(entry);

const currentIndex = navigationSet.findIndex((item) => item.slug === slug);
const prevLink = currentIndex > 0 ? navigationSet[currentIndex - 1] : null;
const nextLink = currentIndex < navigationSet.length - 1 ? navigationSet[currentIndex + 1] : null;

const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Shell", href: "/fachbereiche/linux/shell" },
  { label: "Navigation", href: "/fachbereiche/linux/shell/navigation" },
  { label: entry.data.title, href: `/fachbereiche/linux/shell/navigation/${slug}` },
];
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <ArticleLayout
    entry={entry}
    Content={Content}
    headings={headings}
    breadcrumbs={breadcrumbs}
    prevLink={prevLink}
    nextLink={nextLink}
  />
</BaseLayout>
