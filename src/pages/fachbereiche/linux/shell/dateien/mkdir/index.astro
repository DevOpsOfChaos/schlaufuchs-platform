---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import ArticleLayout from "../../../../../../components/content/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

const articleId = "linux/shell/dateien/mkdir";
const articles = await getCollection("articles");
const entry = articles.find((item) => item.id.replace(/\.(md|mdx)$/i, "") === articleId);

if (!entry) {
  throw new Error(`Article not found for: linux/shell/dateien/mkdir`);
}

const { Content, headings } = await render(entry);
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Shell", href: "/fachbereiche/linux/shell" },
  { label: "Dateien", href: "/fachbereiche/linux/shell/dateien" },
  { label: "mkdir verstehen", href: "/fachbereiche/linux/shell/dateien/mkdir" },
];
const prevLink = { title: "ls verstehen", href: "/fachbereiche/linux/shell/dateien/ls" };
const nextLink = null;
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <ArticleLayout
    entry={entry}
    Content={Content}
    headings={headings}
    breadcrumbs={breadcrumbs}
    prevLink={prevLink}
    nextLink={nextLink}
  />
</BaseLayout>
