---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { linuxLeafPages } from "../../../../../../data/linux_leaf_pages";

const page = linuxLeafPages["mkdir"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Linux", href: "/fachbereiche/linux" },
  { label: "Linux Shell", href: "/fachbereiche/linux/shell" },
  { label: "Dateien", href: "/fachbereiche/linux/shell/dateien" },
  { label: "mkdir", href: "/fachbereiche/linux/shell/dateien/mkdir" },
];
const related = [
  {
    title: "Dateien und Ordner",
    text: "Weiteres Unterthema in Dateien.",
    href: "/fachbereiche/linux/shell/dateien/dateien-und-ordner",
    tone: "linux-a",
  },
  {
    title: "ls",
    text: "Weiteres Unterthema in Dateien.",
    href: "/fachbereiche/linux/shell/dateien/ls",
    tone: "linux-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
