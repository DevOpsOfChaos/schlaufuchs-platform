---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap, getSubjectMeta } from "../../../data/subjects";
import { getTopicTail } from "../../../data/topics";
import {
  getAreaEntriesForPath,
  getAreaEntriesForSubtree,
  getAreaTopicTitle,
  getVisibleAreaCards,
} from "../../../data/areaStructure";
import { withBase, withBaseAsset } from "../../../utils/base";
import PageTrail from "../../../components/content/PageTrail.astro";
import AreaSearchHero from "../../../components/content/AreaSearchHero.astro";
import AreaTopicCard from "../../../components/content/AreaTopicCard.astro";
import AreaSectionSurface from "../../../components/content/AreaSectionSurface.astro";
import AreaLeafResourceCard from "../../../components/content/AreaLeafResourceCard.astro";
import SectionHeading from "../../../components/content/SectionHeading.astro";
import EmptyStateCard from "../../../components/content/EmptyStateCard.astro";

interface PageProps {
  subjectSlug: string;
  parts: string[];
}

export async function getStaticPaths() {
  const [articles, exercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
  const pathMap = new Map<string, { params: { subject: string; parts: string }; props: PageProps }>();

  for (const entry of articles) {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    if (!subjectSlug) continue;
    const tail = getTopicTail(entry);

    for (let index = 0; index < tail.length - 1; index += 1) {
      const parts = tail.slice(0, index + 1);
      const key = `${subjectSlug}/${parts.join("/")}`;
      if (pathMap.has(key)) continue;
      pathMap.set(key, { params: { subject: subjectSlug, parts: parts.join("/") }, props: { subjectSlug, parts } });
    }
  }

  for (const entry of exercises) {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    if (!subjectSlug) continue;
    const tail = getTopicTail(entry).slice(0, -1);

    for (let index = 0; index < tail.length; index += 1) {
      const parts = tail.slice(0, index + 1);
      const key = `${subjectSlug}/${parts.join("/")}`;
      if (pathMap.has(key)) continue;
      pathMap.set(key, { params: { subject: subjectSlug, parts: parts.join("/") }, props: { subjectSlug, parts } });
    }
  }

  return [...pathMap.values()];
}

const { subjectSlug, parts } = Astro.props as PageProps;
const normalizedParts = parts.filter(Boolean);
const subjectTitle = subjectTitleMap[subjectSlug] ?? "Fachbereich";
const detail = getSubjectMeta(subjectSlug);
const imageSrc = detail ? withBaseAsset(`assets/mascots/${detail.icon}`) : undefined;
const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
const subjectArticles = allArticles.filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subjectSlug);
const subjectExercises = allExercises.filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subjectSlug);

const sortByTitle = <T extends { data: { title: string } }>(items: T[]) =>
  [...items].sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));

const combinedEntries = [...subjectArticles, ...subjectExercises];
const childCards = getVisibleAreaCards(subjectSlug, normalizedParts, combinedEntries);
const directArticles = sortByTitle(getAreaEntriesForPath(subjectSlug, normalizedParts, subjectArticles));
const directExercises = sortByTitle(getAreaEntriesForPath(subjectSlug, normalizedParts, subjectExercises));
const subtreeArticles = sortByTitle(getAreaEntriesForSubtree(subjectSlug, normalizedParts, subjectArticles));
const subtreeExercises = sortByTitle(getAreaEntriesForSubtree(subjectSlug, normalizedParts, subjectExercises));
const isLeafPage = childCards.length === 0;
const searchArticles = isLeafPage ? directArticles : subtreeArticles;
const searchExercises = isLeafPage ? directExercises : subtreeExercises;
const accentOrder = ["a", "b", "c", "d"] as const;
const getAccent = (index: number) => accentOrder[index % accentOrder.length];

const trail = [
  { label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) },
  ...normalizedParts.map((_, index) => {
    const path = normalizedParts.slice(0, index + 1);
    return {
      label: getAreaTopicTitle(subjectSlug, path),
      href: withBase(`fachbereiche/${subjectSlug}/${path.join("/")}`),
    };
  }),
];

const backHref = trail.length > 1 ? trail[trail.length - 2].href : withBase(`fachbereiche/${subjectSlug}`);
const pageTitle = getAreaTopicTitle(subjectSlug, normalizedParts);
const isEmpty = isLeafPage && directArticles.length === 0 && directExercises.length === 0;
---

<BaseLayout title={`${pageTitle} – ${subjectTitle} – Schlaufuchs`} description={`${pageTitle} im Bereich ${subjectTitle}.`}>
  <div class="page-shell" data-area-root>
    <PageTrail backHref={backHref} trail={trail} />

    <AreaSearchHero
      title={pageTitle}
      scopeLabel={subjectTitle}
      searchPlaceholder={`In ${pageTitle} suchen`}
      imageSrc={imageSrc}
      imageAlt={`${subjectTitle} – Fuchsmotiv`}
      tone={detail?.tone ?? "math"}
      inputName={`search-${subjectSlug}-${normalizedParts.join("-") || "root"}`}
      searchHint="Suche zeigt Themen, Wissensseiten und Aufgaben getrennt."
    />

    {isEmpty ? (
      <EmptyStateCard
        kicker="Kein Inhalt"
        title="Zu diesem Thema liegt aktuell kein direkter Inhalt vor"
        body="Gehe eine Ebene zurück oder nutze die Suche, um passende Wissensseiten und Aufgaben in diesem Bereich zu finden."
        primaryHref={backHref}
        primaryLabel="Eine Ebene zurück →"
        secondaryHref={withBase(`fachbereiche/${subjectSlug}`)}
        secondaryLabel="Zum Fachbereich →"
      />
    ) : (
      <>
        {childCards.length > 0 && (
          <AreaSectionSurface variant="topics" data-default-section>
            <SectionHeading kicker="Themen" title={`Unterthemen in ${pageTitle}`} />
            <div class="topic-grid">
              {childCards.map((item, index) => (
                <AreaTopicCard
                  title={item.title}
                  description={item.description}
                  href={withBase(`fachbereiche/${subjectSlug}/${item.path.join("/")}`)}
                  tone={detail?.tone ?? "math"}
                  icon={item.icon}
                  chips={item.chips}
                  searchText={item.searchText}
                  eyebrow="Unterthema"
                  accent={getAccent(index)}
                />
              ))}
            </div>
          </AreaSectionSurface>
        )}

        {isLeafPage && directArticles.length > 0 && (
          <AreaSectionSurface variant="articles" data-default-section>
            <SectionHeading kicker="Wissensseiten" title={`Wissensseiten in ${pageTitle}`} />
            <div class="leaf-grid">
              {directArticles.map((entry) => (
                <AreaLeafResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · Wissensseite`}
                  href={withBase(`wissen/${entry.id}`)}
                  ctaLabel="Wissensseite öffnen →"
                  variant="article"
                  searchText={`${entry.data.title} ${entry.data.description} ${(entry.data.tags ?? []).join(" ")}`}
                />
              ))}
            </div>
          </AreaSectionSurface>
        )}

        {isLeafPage && directExercises.length > 0 && (
          <AreaSectionSurface variant="tasks" data-default-section>
            <SectionHeading kicker="Aufgaben" title={`Passende Aufgaben in ${pageTitle}`} />
            <div class="leaf-grid">
              {directExercises.map((entry, index) => (
                <AreaLeafResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · Aufgabe`}
                  href={withBase(`aufgaben/${entry.id}`)}
                  ctaLabel="Aufgabe öffnen →"
                  variant="task"
                  accent={getAccent(index)}
                  searchText={`${entry.data.title} ${entry.data.description} ${(entry.data.tags ?? []).join(" ")}`}
                />
              ))}
            </div>
          </AreaSectionSurface>
        )}

        <section class="search-results" data-search-results hidden>
          <AreaSectionSurface variant="topics" muted data-search-group="topics">
            <SectionHeading kicker="Themen" title="Passende Themen" />
            <div class="topic-grid">
              {childCards.map((item, index) => (
                <AreaTopicCard
                  title={item.title}
                  description={item.description}
                  href={withBase(`fachbereiche/${subjectSlug}/${item.path.join("/")}`)}
                  tone={detail?.tone ?? "math"}
                  icon={item.icon}
                  chips={item.chips}
                  searchText={item.searchText}
                  eyebrow="Unterthema"
                  accent={getAccent(index)}
                />
              ))}
            </div>
            <p class="empty-note" data-empty-note hidden>Kein Thema passt zu deiner Suche.</p>
          </AreaSectionSurface>

          <AreaSectionSurface variant="articles" muted data-search-group="articles">
            <SectionHeading kicker="Wissensseiten" title="Passende Wissensseiten" />
            <div class="leaf-grid">
              {searchArticles.map((entry) => (
                <AreaLeafResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · Wissensseite`}
                  href={withBase(`wissen/${entry.id}`)}
                  ctaLabel="Wissensseite öffnen →"
                  variant="article"
                  searchText={`${entry.data.title} ${entry.data.description} ${(entry.data.tags ?? []).join(" ")}`}
                />
              ))}
            </div>
            <p class="empty-note" data-empty-note hidden>Keine Wissensseite passt zu deiner Suche.</p>
          </AreaSectionSurface>

          <AreaSectionSurface variant="tasks" muted data-search-group="tasks">
            <SectionHeading kicker="Aufgaben" title="Passende Aufgaben" />
            <div class="leaf-grid">
              {searchExercises.map((entry, index) => (
                <AreaLeafResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · Aufgabe`}
                  href={withBase(`aufgaben/${entry.id}`)}
                  ctaLabel="Aufgabe öffnen →"
                  variant="task"
                  accent={getAccent(index)}
                  searchText={`${entry.data.title} ${entry.data.description} ${(entry.data.tags ?? []).join(" ")}`}
                />
              ))}
            </div>
            <p class="empty-note" data-empty-note hidden>Keine Aufgabe passt zu deiner Suche.</p>
          </AreaSectionSurface>

          <p class="search-empty-all" data-search-empty-all hidden>Zu deiner Suche passt in diesem Themenbereich aktuell nichts.</p>
        </section>
      </>
    )}
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-area-root]");
    if (!root) return;
    const input = root.querySelector("[data-area-search-input]");
    const results = root.querySelector("[data-search-results]");
    const defaults = [...root.querySelectorAll("[data-default-section]")];

    if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLElement)) return;

    const runSearch = () => {
      const query = input.value.trim().toLowerCase();
      const searching = query.length > 0;

      results.hidden = !searching;
      defaults.forEach((section) => {
        if (section instanceof HTMLElement) section.hidden = searching;
      });

      let anyVisible = false;
      const groups = [...root.querySelectorAll("[data-search-group]")];
      groups.forEach((group) => {
        if (!(group instanceof HTMLElement)) return;
        const items = [...group.querySelectorAll("[data-search-item]")];
        let visible = 0;
        items.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          const haystack = (item.dataset.searchText ?? "").toLowerCase();
          const match = !searching || haystack.includes(query);
          item.hidden = !match;
          if (match) visible += 1;
        });
        const empty = group.querySelector("[data-empty-note]");
        if (empty instanceof HTMLElement) empty.hidden = visible > 0;
        group.hidden = visible === 0;
        if (visible > 0) anyVisible = true;
      });

      const globalEmpty = root.querySelector("[data-search-empty-all]");
      if (globalEmpty instanceof HTMLElement) globalEmpty.hidden = anyVisible || !searching;
    };

    input.addEventListener("input", runSearch);
  })();
</script>

<style>
  .page-shell,
  .search-results {
    display: grid;
    gap: 1rem;
  }

  .topic-grid,
  .leaf-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty-note,
  .search-empty-all {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .topic-grid,
    .leaf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
