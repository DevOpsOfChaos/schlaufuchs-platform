---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../../data/subjects";
import {
  getEntriesForPrimarySubject,
  getTopicDisplayLabel,
  getTopicTail,
  humanizeTopicSegment,
  isTopicPrefix,
} from "../../../data/topics";
import { withBase } from "../../../utils/base";
import PageTrail from "../../../components/content/PageTrail.astro";
import OverviewPanel from "../../../components/content/OverviewPanel.astro";
import SectionHeading from "../../../components/content/SectionHeading.astro";
import ResourceCard from "../../../components/content/ResourceCard.astro";
import EmptyStateCard from "../../../components/content/EmptyStateCard.astro";

interface PageProps {
  subjectSlug: string;
  parts: string[];
  exactArticleId?: string;
}

export async function getStaticPaths() {
  const [articles, exercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
  const pathMap = new Map<string, { params: { subject: string; parts: string }; props: PageProps }>();

  for (const entry of articles) {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    if (!subjectSlug) continue;
    const tail = getTopicTail(entry);
    for (let index = 0; index < tail.length; index += 1) {
      const parts = tail.slice(0, index + 1);
      const key = `${subjectSlug}/${parts.join("/")}`;
      const existing = pathMap.get(key);
      const next = {
        params: { subject: subjectSlug, parts: parts.join("/") },
        props: { subjectSlug, parts, exactArticleId: index === tail.length - 1 ? entry.id : undefined },
      };
      if (!existing || next.props.exactArticleId) pathMap.set(key, next);
    }
  }

  for (const entry of exercises) {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    if (!subjectSlug) continue;
    const tail = getTopicTail(entry).slice(0, -1);
    for (let index = 0; index < tail.length; index += 1) {
      const parts = tail.slice(0, index + 1);
      const key = `${subjectSlug}/${parts.join("/")}`;
      if (pathMap.has(key)) continue;
      pathMap.set(key, { params: { subject: subjectSlug, parts: parts.join("/") }, props: { subjectSlug, parts } });
    }
  }

  return [...pathMap.values()];
}

const { subjectSlug, parts, exactArticleId } = Astro.props as PageProps;
const normalizedParts = parts.filter(Boolean);
const subjectTitle = subjectTitleMap[subjectSlug] ?? "Fachbereich";
const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
const subjectArticles = getEntriesForPrimarySubject(allArticles, subjectSlug);
const subjectExercises = getEntriesForPrimarySubject(allExercises, subjectSlug);
const exactArticle = exactArticleId ? allArticles.find((entry) => entry.id === exactArticleId) ?? null : null;

if (exactArticle) {
  return Astro.redirect(withBase(`wissen/${exactArticle.id}`));
}

const trail = [
  { label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) },
  ...normalizedParts.map((segment, index) => ({
    label: humanizeTopicSegment(segment),
    href: withBase(`fachbereiche/${subjectSlug}/${normalizedParts.slice(0, index + 1).join("/")}`),
  })),
];

const backHref = trail.length > 1 ? trail[trail.length - 2].href : withBase(`fachbereiche/${subjectSlug}`);
const topicTitle = humanizeTopicSegment(normalizedParts.at(-1) ?? subjectTitle);

const prefixed = <T extends (typeof subjectArticles)[number] | (typeof subjectExercises)[number]>(entries: T[]) =>
  entries.filter((entry) => {
    const tail = getTopicTail(entry);
    return tail.length > normalizedParts.length && isTopicPrefix(normalizedParts, tail);
  });

const directArticles = prefixed(subjectArticles).filter((entry) => getTopicTail(entry).length === normalizedParts.length + 1);
const directExercises = prefixed(subjectExercises).filter((entry) => getTopicTail(entry).length === normalizedParts.length + 1);
const descendants = prefixed([...subjectArticles, ...subjectExercises]);

const childTopics = [...new Map(
  descendants.flatMap((entry) => {
    const tail = getTopicTail(entry);
    const slug = tail[normalizedParts.length];
    return tail.length > normalizedParts.length + 1 && slug
      ? [[slug, { slug, title: humanizeTopicSegment(slug), articleCount: 0, exerciseCount: 0, path: [...normalizedParts, slug] }]]
      : [];
  }),
).values()].map((topic) => {
  const articleCount = prefixed(subjectArticles).filter((entry) => getTopicTail(entry)[normalizedParts.length] === topic.slug).length;
  const exerciseCount = prefixed(subjectExercises).filter((entry) => getTopicTail(entry)[normalizedParts.length] === topic.slug).length;
  return {
    ...topic,
    articleCount,
    exerciseCount,
    totalCount: articleCount + exerciseCount,
    href: withBase(`fachbereiche/${subjectSlug}/${[...normalizedParts, topic.slug].join("/")}`),
  };
}).sort((a, b) => b.totalCount - a.totalCount || a.title.localeCompare(b.title, "de"));

const siblingTopics = normalizedParts.length > 0
  ? [...new Map(
      [...subjectArticles, ...subjectExercises].flatMap((entry) => {
        const tail = getTopicTail(entry);
        if (tail.length < normalizedParts.length) return [];
        const parent = normalizedParts.slice(0, -1);
        if (!isTopicPrefix(parent, tail)) return [];
        const siblingSlug = tail[parent.length];
        if (!siblingSlug || siblingSlug === normalizedParts.at(-1)) return [];
        return [[siblingSlug, { slug: siblingSlug, title: humanizeTopicSegment(siblingSlug), path: [...parent, siblingSlug] }]];
      }),
    ).values()]
      .map((item) => ({ ...item, href: withBase(`fachbereiche/${subjectSlug}/${item.path.join("/")}`) }))
      .sort((a, b) => a.title.localeCompare(b.title, "de"))
  : [];

const isEmptyPath = normalizedParts.length > 0 && childTopics.length === 0 && directArticles.length === 0 && directExercises.length === 0;

const overviewPoints = [
  `${directArticles.length} Wissensseiten und ${directExercises.length} Aufgaben liegen direkt in diesem Themenblock.`,
  childTopics.length > 0
    ? `${childTopics.length} Unterthemen bauen diesen Bereich weiter aus und führen tiefer in den Themenpfad.`
    : "Dieser Bereich ist bereits die unterste sichtbare Überblicksebene innerhalb des Themenpfads.",
  "Leaf-Wissensseiten werden bewusst auf /wissen weitergeleitet, damit Fachinfos nur eine zentrale Hauptansicht haben.",
];

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const topicIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M5 12h14"></path>
  <path d="m13 6 6 6-6 6"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout
  title={`${topicTitle} – ${subjectTitle} – Schlaufuchs`}
  description={`Fachübersicht zu ${topicTitle} im Bereich ${subjectTitle}.`}
>
  <div class="page-shell">
    <PageTrail backHref={backHref} trail={trail} />

    <section class="hero">
      <p class="eyebrow">Themenpfad</p>
      <h1>{topicTitle}</h1>
      <p class="lead">Hier bündelst du alle direkt passenden Wissensseiten, Aufgaben und Unterthemen zu {topicTitle} in {subjectTitle}.</p>
    </section>

    {isEmptyPath ? (
      <EmptyStateCard
        kicker="Pfad ohne Treffer"
        title="Zu diesem Themenpfad liegt im Overlay noch kein direkter Inhalt vor"
        body="Der Pfad ist aktuell leer oder wurde durch einen älteren Stand noch nicht mit echter Wissensseite oder Aufgabe gefüllt. Von hier aus kommst du sicher zurück in den Fachbereich oder auf die übergeordnete Pfadebene."
        primaryHref={backHref}
        primaryLabel="Eine Ebene zurück →"
        secondaryHref={withBase(`fachbereiche/${subjectSlug}`)}
        secondaryLabel="Zum Fachbereich →"
      />
    ) : (
      <>
        <OverviewPanel
          title="Was du in diesem Themenblock findest"
          kicker="Überblick"
          points={overviewPoints}
          actionHref={withBase(`fachbereiche/${subjectSlug}`)}
          actionLabel="Zum Fachbereich →"
        />

        {childTopics.length > 0 && (
          <section class="related-section">
            <SectionHeading kicker="Unterthemen" title="Tiefe Themenblöcke in diesem Pfad" />
            <div class="related-grid">
              {childTopics.map((topic) => (
                <ResourceCard
                  title={topic.title}
                  description={`${topic.articleCount} Wissensseiten · ${topic.exerciseCount} Aufgaben in diesem Unterthema.`}
                  meta="Unterthema"
                  href={topic.href}
                  ctaLabel="Unterthema öffnen →"
                  icon={topicIcon}
                  variant="topic"
                />
              ))}
            </div>
          </section>
        )}

        {directArticles.length > 0 && (
          <section class="related-section">
            <SectionHeading kicker="Wissensseiten" title="Direkt passende Fachinfos in diesem Themenblock" />
            <p class="related-intro">Diese Wissensseiten liegen genau auf dieser Ebene des Themenpfads. Die Karten führen direkt in die zentrale Wissensansicht.</p>
            <div class="related-grid">
              {directArticles.map((entry) => (
                <ResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
                  href={withBase(`wissen/${entry.id}`)}
                  ctaLabel="Wissensseite öffnen →"
                  icon={articleIcon}
                  variant="article"
                />
              ))}
            </div>
          </section>
        )}

        {directExercises.length > 0 && (
          <section class="related-section">
            <SectionHeading kicker="Aufgaben" title="Direkt passende Aufgaben in diesem Themenblock" />
            <p class="related-intro">Diese Aufgaben liegen auf derselben Themenebene und eignen sich gut direkt unterhalb der Wissensseiten.</p>
            <div class="related-grid">
              {directExercises.map((entry) => (
                <ResourceCard
                  title={entry.data.title}
                  description={entry.data.description}
                  meta={`${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
                  href={withBase(`aufgaben/${entry.id}`)}
                  ctaLabel="Aufgabe öffnen →"
                  icon={taskIcon}
                  variant="task"
                />
              ))}
            </div>
          </section>
        )}
      </>
    )}

    {siblingTopics.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Daneben" title="Benachbarte Themenpfade auf derselben Ebene" />
        <div class="sibling-row">
          {siblingTopics.map((item) => <a class="sibling-link" href={item.href}>{item.title}</a>)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell,
  .hero,
  .related-section {
    display: grid;
    gap: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.45rem, 4.8vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead,
  .related-intro {
    margin: 0;
    max-width: 64rem;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.04rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .sibling-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .sibling-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  @media (max-width: 980px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
