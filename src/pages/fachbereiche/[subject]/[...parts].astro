---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap, getSubjectMeta } from "../../../data/subjects";
import { getTopicDisplayLabel, getEntriesForPrimarySubject } from "../../../data/topics";
import {
  getAreaEntriesForPath,
  getAreaNode,
  getAreaTopicDescription,
  getAreaTopicTitle,
  getVisibleAreaCards,
} from "../../../data/areaStructure";
import { withBase } from "../../../utils/base";
import PageTrail from "../../../components/content/PageTrail.astro";
import SectionHeading from "../../../components/content/SectionHeading.astro";
import ResourceCard from "../../../components/content/ResourceCard.astro";
import EmptyStateCard from "../../../components/content/EmptyStateCard.astro";
import AreaSearchHero from "../../../components/content/AreaSearchHero.astro";
import AreaTopicCard from "../../../components/content/AreaTopicCard.astro";

interface PageProps {
  subjectSlug: string;
  parts: string[];
}

export async function getStaticPaths() {
  const [articles, exercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
  const allEntries = [...articles, ...exercises];
  const subjectSlugs = new Set<string>();

  for (const entry of allEntries) {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    if (subjectSlug) subjectSlugs.add(subjectSlug);
  }

  const pathMap = new Map<string, { params: { subject: string; parts: string }; props: PageProps }>();
  for (const subjectSlug of subjectSlugs) {
    const subjectEntries = allEntries.filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subjectSlug);
    const rootCards = getVisibleAreaCards(subjectSlug, [], subjectEntries);
    const topCards = getVisibleAreaCards(subjectSlug, [], subjectEntries, { flattenSingleRoot: true });

    for (const card of [...rootCards, ...topCards]) {
      pathMap.set(`${subjectSlug}/${card.path.join("/")}`, {
        params: { subject: subjectSlug, parts: card.path.join("/") },
        props: { subjectSlug, parts: card.path },
      });
    }

    for (const card of rootCards) {
      const childCards = getVisibleAreaCards(subjectSlug, card.path, subjectEntries);
      for (const child of childCards) {
        pathMap.set(`${subjectSlug}/${child.path.join("/")}`, {
          params: { subject: subjectSlug, parts: child.path.join("/") },
          props: { subjectSlug, parts: child.path },
        });
      }
    }

    for (const card of topCards) {
      const childCards = getVisibleAreaCards(subjectSlug, card.path, subjectEntries);
      for (const child of childCards) {
        pathMap.set(`${subjectSlug}/${child.path.join("/")}`, {
          params: { subject: subjectSlug, parts: child.path.join("/") },
          props: { subjectSlug, parts: child.path },
        });
      }
    }
  }

  return [...pathMap.values()];
}

const { subjectSlug, parts } = Astro.props as PageProps;
const normalizedParts = parts.filter(Boolean);
const subjectTitle = subjectTitleMap[subjectSlug] ?? "Fachbereich";
const detail = getSubjectMeta(subjectSlug) ?? { tone: "math", icon: "math.png" };
const mascotSrc = withBase(`assets/mascots/${detail.icon}`);

const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
const subjectArticles = getEntriesForPrimarySubject(allArticles, subjectSlug);
const subjectExercises = getEntriesForPrimarySubject(allExercises, subjectSlug);
const subjectEntries = [...subjectArticles, ...subjectExercises];

const areaNode = getAreaNode(subjectSlug, normalizedParts);
const childCards = getVisibleAreaCards(subjectSlug, normalizedParts, subjectEntries);
const directArticles = getAreaEntriesForPath(subjectSlug, normalizedParts, subjectArticles);
const directExercises = getAreaEntriesForPath(subjectSlug, normalizedParts, subjectExercises);

const trail = [
  { label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) },
  ...normalizedParts.map((segment, index) => ({
    label: getAreaTopicTitle(subjectSlug, normalizedParts.slice(0, index + 1)),
    href: withBase(`fachbereiche/${subjectSlug}/${normalizedParts.slice(0, index + 1).join("/")}`),
  })),
];
const backHref = trail.length > 1 ? trail[trail.length - 2].href : withBase(`fachbereiche/${subjectSlug}`);
const title = getAreaTopicTitle(subjectSlug, normalizedParts);
const description = getAreaTopicDescription(subjectSlug, normalizedParts, "Hier findest du passende Wissensseiten und Aufgaben in diesem Themenbereich.");
const isEmptyPath = !areaNode || (childCards.length === 0 && directArticles.length === 0 && directExercises.length === 0);

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout title={`${title} – ${subjectTitle} – Schlaufuchs`} description={`${title} in ${subjectTitle}.`}>
  <div class="page-shell" data-area-search-root>
    <PageTrail backHref={backHref} trail={trail} />

    <AreaSearchHero
      title={title}
      scopeLabel="Fachthema"
      tone={detail.tone}
      imageSrc={mascotSrc}
      imageAlt={`${subjectTitle} Bereichsfuchs`}
      searchPlaceholder={`In ${title} nach Wissen und Aufgaben suchen`}
      searchHint="Wissensseiten und Aufgaben bleiben in der Anzeige getrennt."
    />

    <section class="search-empty" data-search-empty hidden>
      <p>Zu deiner Suche gibt es in diesem Themenbereich gerade keinen sichtbaren Themenblock, keine Wissensseite und keine Aufgabe.</p>
    </section>

    {isEmptyPath ? (
      <EmptyStateCard
        kicker="Themenbereich leer"
        title="Hier liegt im Moment noch kein sichtbarer Inhalt"
        body="Dieser Themenbereich ist aktuell leer. Du kannst eine Ebene zurückgehen oder in den Fachbereich wechseln."
        primaryHref={backHref}
        primaryLabel="Eine Ebene zurück →"
        secondaryHref={withBase(`fachbereiche/${subjectSlug}`)}
        secondaryLabel="Zum Fachbereich →"
      />
    ) : (
      <>
        {childCards.length > 0 && (
          <section class="section-block" id="fachthemen" data-search-group>
            <SectionHeading kicker="Fachthemen" title="Themen in diesem Bereich" />
            <div class="topic-grid">
              {childCards.map((item) => (
                <AreaTopicCard
                  title={item.title}
                  description={item.description}
                  href={withBase(`fachbereiche/${subjectSlug}/${item.path.join("/")}`)}
                  tone={detail.tone}
                  icon={item.icon}
                  searchText={item.searchText}
                />
              ))}
            </div>
          </section>
        )}

        {directArticles.length > 0 && (
          <section class="section-block tinted-block knowledge-block" id="wissensseiten" data-search-group>
            <SectionHeading kicker="Wissensseiten" title="Wissensseiten in diesem Themenbereich" />
            <p class="section-copy">{description}</p>
            <div class="entry-grid">
              {directArticles.map((entry) => (
                <div data-search-item data-search-text={`${entry.data.title} ${entry.data.description} ${getTopicDisplayLabel(entry)}`}>
                  <ResourceCard
                    title={entry.data.title}
                    description={entry.data.description}
                    meta={`${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
                    href={withBase(`wissen/${entry.id}`)}
                    ctaLabel="Wissensseite öffnen →"
                    icon={articleIcon}
                    variant="article"
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        {directExercises.length > 0 && (
          <section class="section-block tinted-block task-block" id="aufgaben" data-search-group>
            <SectionHeading kicker="Aufgaben" title="Passende Aufgaben in diesem Themenbereich" />
            <div class="entry-grid">
              {directExercises.map((entry) => (
                <div data-search-item data-search-text={`${entry.data.title} ${entry.data.description} ${getTopicDisplayLabel(entry)}`}>
                  <ResourceCard
                    title={entry.data.title}
                    description={entry.data.description}
                    meta={`${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
                    href={withBase(`aufgaben/${entry.id}`)}
                    ctaLabel="Aufgabe öffnen →"
                    icon={taskIcon}
                    variant="task"
                  />
                </div>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const roots = document.querySelectorAll('[data-area-search-root]');
    roots.forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.searchReady === 'true') return;
      root.dataset.searchReady = 'true';
      const input = root.querySelector('[data-area-search-input]');
      const groups = [...root.querySelectorAll('[data-search-group]')];
      const empty = root.querySelector('[data-search-empty]');
      if (!(input instanceof HTMLInputElement)) return;

      const update = () => {
        const query = input.value.trim().toLowerCase();
        let visibleCount = 0;
        groups.forEach((group) => {
          const items = [...group.querySelectorAll('[data-search-item]')];
          let groupVisible = 0;
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            const haystack = (item.dataset.searchText ?? '').toLowerCase();
            const show = !query || haystack.includes(query);
            item.hidden = !show;
            if (show) groupVisible += 1;
          });
          if (group instanceof HTMLElement) group.hidden = groupVisible === 0;
          visibleCount += groupVisible;
        });
        if (empty instanceof HTMLElement) empty.hidden = !query || visibleCount > 0;
      };

      input.addEventListener('input', update);
      update();
    });
  })();
</script>

<style>
  .page-shell,
  .section-block {
    display: grid;
    gap: 1rem;
  }

  .section-block {
    margin-top: 1.2rem;
  }

  .topic-grid,
  .entry-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .tinted-block {
    padding: 1rem;
    border-radius: 32px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-soft);
  }

  .knowledge-block {
    background: color-mix(in oklab, var(--card-bg) 92%, rgb(233 239 251) 8%);
  }

  .task-block {
    background: color-mix(in oklab, var(--card-bg) 90%, rgb(247 240 228) 10%);
  }

  .section-copy {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    max-width: 62rem;
    font-size: 1.01rem;
  }

  .search-empty {
    padding: 1rem 1.1rem;
    border: 1px dashed var(--border-strong);
    border-radius: 24px;
    background: color-mix(in oklab, var(--surface) 88%, white 12%);
  }

  .search-empty p {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  @media (max-width: 980px) {
    .topic-grid,
    .entry-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
