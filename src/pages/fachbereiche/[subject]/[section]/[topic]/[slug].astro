---
import { withBase } from "../../../../../utils/base";
import { getVisibleArticles } from "../../../../../data/content";
import { getTopicTail } from "../../../../../data/topics";
import { resolvePrimarySubjectSlug } from "../../../../../data/subjects";
import LeafInfoPage from "../../../../../components/content/LeafInfoPage.astro";

export async function getStaticPaths() {
  const articles = await getVisibleArticles();
  return articles.filter((entry) => getTopicTail(entry).length === 3).flatMap((entry) => {
    const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject);
    const tail = getTopicTail(entry);
    if (!subjectSlug || tail.length !== 3) return [];
    return [{ params: { subject: subjectSlug, section: tail[0], topic: tail[1], slug: tail[2] }, props: { entry } }];
  });
}

const { entry } = Astro.props;
const targetHref = withBase(`wissen/${entry.id}`);
---

<LeafInfoPage title={entry.data.title} description={entry.data.description} targetHref={targetHref} />
