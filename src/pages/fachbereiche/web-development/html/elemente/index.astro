---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import TopicLandingPage from "../../../../../components/content/TopicLandingPage.astro";
import { webdevelopmentTopics } from "../../../../../data/web_development_topics";

const page = webdevelopmentTopics["elemente"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development HTML", href: "/fachbereiche/web-development/html" },
  { label: "Elemente", href: "/fachbereiche/web-development/html/elemente" },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <TopicLandingPage page={page} breadcrumbs={breadcrumbs} />
</BaseLayout>
