---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["links"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development HTML", href: "/fachbereiche/web-development/html" },
  { label: "Elemente", href: "/fachbereiche/web-development/html/elemente" },
  { label: "Links", href: "/fachbereiche/web-development/html/elemente/links" },
];
const related = [
  {
    title: "Textelemente",
    text: "Weiteres Unterthema in Elemente.",
    href: "/fachbereiche/web-development/html/elemente/textelemente",
    tone: "web-a",
  },
  {
    title: "Listen",
    text: "Weiteres Unterthema in Elemente.",
    href: "/fachbereiche/web-development/html/elemente/listen",
    tone: "web-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
