---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["saubere-struktur"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development HTML", href: "/fachbereiche/web-development/html" },
  { label: "Semantik", href: "/fachbereiche/web-development/html/semantik" },
  { label: "Saubere Struktur", href: "/fachbereiche/web-development/html/semantik/saubere-struktur" },
];
const related = [
  {
    title: "Semantische Tags",
    text: "Weiteres Unterthema in Semantik.",
    href: "/fachbereiche/web-development/html/semantik/semantische-tags",
    tone: "web-a",
  },
  {
    title: "Layout-Bereiche",
    text: "Weiteres Unterthema in Semantik.",
    href: "/fachbereiche/web-development/html/semantik/layout-bereiche",
    tone: "web-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
