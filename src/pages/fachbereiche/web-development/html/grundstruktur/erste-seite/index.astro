---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["erste-seite"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development HTML", href: "/fachbereiche/web-development/html" },
  { label: "Grundstruktur", href: "/fachbereiche/web-development/html/grundstruktur" },
  { label: "Erste Seite", href: "/fachbereiche/web-development/html/grundstruktur/erste-seite" },
];
const related = [
  {
    title: "HTML-Dokument",
    text: "Weiteres Unterthema in Grundstruktur.",
    href: "/fachbereiche/web-development/html/grundstruktur/html-dokument",
    tone: "web-a",
  },
  {
    title: "Head und Body",
    text: "Weiteres Unterthema in Grundstruktur.",
    href: "/fachbereiche/web-development/html/grundstruktur/head-und-body",
    tone: "web-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
