---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["mobile-first"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development CSS", href: "/fachbereiche/web-development/css" },
  { label: "Responsive", href: "/fachbereiche/web-development/css/responsive" },
  { label: "Mobile First", href: "/fachbereiche/web-development/css/responsive/mobile-first" },
];
const related = [
  {
    title: "Media Queries",
    text: "Weiteres Unterthema in Responsive.",
    href: "/fachbereiche/web-development/css/responsive/media-queries",
    tone: "web-a",
  },
  {
    title: "Breakpoints",
    text: "Weiteres Unterthema in Responsive.",
    href: "/fachbereiche/web-development/css/responsive/breakpoints",
    tone: "web-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
