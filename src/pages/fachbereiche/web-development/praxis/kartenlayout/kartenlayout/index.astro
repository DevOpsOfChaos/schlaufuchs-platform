---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["kartenlayout"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development Praxis", href: "/fachbereiche/web-development/praxis" },
  { label: "Kartenlayout", href: "/fachbereiche/web-development/praxis/kartenlayout" },
  { label: "Kartenlayout", href: "/fachbereiche/web-development/praxis/kartenlayout/kartenlayout" },
];
const related = [
  {
    title: "Card Grid",
    text: "Weiteres Unterthema in Kartenlayout.",
    href: "/fachbereiche/web-development/praxis/kartenlayout/card-grid",
    tone: "web-b",
  },
  {
    title: "Card Content",
    text: "Weiteres Unterthema in Kartenlayout.",
    href: "/fachbereiche/web-development/praxis/kartenlayout/card-content",
    tone: "web-c",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
