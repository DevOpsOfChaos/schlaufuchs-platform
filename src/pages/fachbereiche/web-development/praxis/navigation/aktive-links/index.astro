---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["aktive-links"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development Praxis", href: "/fachbereiche/web-development/praxis" },
  { label: "Navigation", href: "/fachbereiche/web-development/praxis/navigation" },
  { label: "Aktive Links", href: "/fachbereiche/web-development/praxis/navigation/aktive-links" },
];
const related = [
  {
    title: "Navigation bauen",
    text: "Weiteres Unterthema in Navigation.",
    href: "/fachbereiche/web-development/praxis/navigation/navigation-bauen",
    tone: "web-a",
  },
  {
    title: "Responsive Nav",
    text: "Weiteres Unterthema in Navigation.",
    href: "/fachbereiche/web-development/praxis/navigation/responsive-nav",
    tone: "web-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
