---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import LeafInfoPage from "../../../../../../components/content/LeafInfoPage.astro";
import { webdevelopmentLeafPages } from "../../../../../../data/web_development_leaf_pages";

const page = webdevelopmentLeafPages["startlayout"];
const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Web Development", href: "/fachbereiche/web-development" },
  { label: "Web Development Praxis", href: "/fachbereiche/web-development/praxis" },
  { label: "Erste Webseite", href: "/fachbereiche/web-development/praxis/erste-webseite" },
  { label: "Startlayout", href: "/fachbereiche/web-development/praxis/erste-webseite/startlayout" },
];
const related = [
  {
    title: "Erste Webseite",
    text: "Weiteres Unterthema in Erste Webseite.",
    href: "/fachbereiche/web-development/praxis/erste-webseite/erste-webseite",
    tone: "web-a",
  },
  {
    title: "Dateistruktur",
    text: "Weiteres Unterthema in Erste Webseite.",
    href: "/fachbereiche/web-development/praxis/erste-webseite/dateistruktur",
    tone: "web-b",
  },
];
---

<BaseLayout title={page.title + " – Schlaufuchs"} description={page.description}>
  <LeafInfoPage page={page} breadcrumbs={breadcrumbs} related={related} />
</BaseLayout>
