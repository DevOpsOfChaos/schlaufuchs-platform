---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, getVisibleSubjects } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { getEntriesForPrimarySubject } from "../../data/topics";
import { getVisibleAreaCards } from "../../data/areaStructure";
import { withBase, withBaseAsset } from "../../utils/base";
import AreaSearchHero from "../../components/content/AreaSearchHero.astro";
import AreaTopicCard from "../../components/content/AreaTopicCard.astro";
import AreaSectionSurface from "../../components/content/AreaSectionSurface.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";

export async function getStaticPaths() {
  const subjects = await getVisibleSubjects();
  return subjects.map((subject) => ({ params: { slug: subject.data.slug }, props: { subject } }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  tone: "math",
  icon: "math.png",
  kicker: "Fachbereich",
  entry: "",
  highlights: [],
  intro: "",
  sections: [],
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const sortByTitle = <T extends { data: { title: string } }>(items: T[]) =>
  [...items].sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));

const subjectArticles = sortByTitle(getEntriesForPrimarySubject(articles, subject.data.slug));
const subjectExercises = sortByTitle(getEntriesForPrimarySubject(exercises, subject.data.slug));
const combinedEntries = [...subjectArticles, ...subjectExercises];
const topicCards = getVisibleAreaCards(subject.data.slug, [], combinedEntries, { flattenSingleRoot: true });
const imageSrc = withBaseAsset(`assets/mascots/${detail.icon}`);
const accentOrder = ["a", "b", "c", "d"] as const;
const getAccent = (index: number) => accentOrder[index % accentOrder.length];
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <div class="page-shell" data-area-root data-page-mode="topics">
    <AreaSearchHero
      title={subject.data.title}
      scopeLabel="Fachbereich"
      searchPlaceholder={`In ${subject.data.title} suchen`}
      imageSrc={imageSrc}
      imageAlt={`${subject.data.title} – Fuchsmotiv`}
      tone={detail.tone}
      inputName={`search-${subject.data.slug}`}
      searchHint="Die Suche filtert auf dieser Seite nur die Themen."
    />

    {topicCards.length > 0 && (
      <AreaSectionSurface variant="topics" data-search-group="topics">
        <SectionHeading kicker="Themen" title={`Themen in ${subject.data.title}`} />
        <div class="topic-grid">
          {topicCards.map((item, index) => (
            <AreaTopicCard
              title={item.title}
              description={item.description}
              href={withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`)}
              tone={detail.tone}
              icon={item.icon}
              chips={item.chips}
              searchText={item.searchText}
              accent={getAccent(index)}
            />
          ))}
        </div>
        <p class="empty-note" data-empty-note hidden>Kein Thema passt zu deiner Suche.</p>
      </AreaSectionSurface>
    )}

    <p class="search-empty-all" data-search-empty-all hidden>Zu deiner Suche passt in diesem Fachbereich aktuell kein Thema.</p>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const setupAreaSearch = (root) => {
      if (!(root instanceof HTMLElement) || root.dataset.areaSearchReady === "true") return;
      root.dataset.areaSearchReady = "true";

      const input = root.querySelector("[data-area-search-input]");
      if (!(input instanceof HTMLInputElement)) return;

      const groups = [...root.querySelectorAll("[data-search-group]")];
      const globalEmpty = root.querySelector("[data-search-empty-all]");

      const runSearch = () => {
        const query = input.value.trim().toLowerCase();
        const searching = query.length > 0;
        let anyVisible = false;

        groups.forEach((group) => {
          if (!(group instanceof HTMLElement)) return;
          const items = [...group.querySelectorAll("[data-search-item]")];
          let visible = 0;

          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            const haystack = (item.dataset.searchText ?? "").toLowerCase();
            const match = !searching || haystack.includes(query);
            item.hidden = !match;
            if (match) visible += 1;
          });

          const empty = group.querySelector("[data-empty-note]");
          if (empty instanceof HTMLElement) empty.hidden = !searching || visible > 0;
          if (visible > 0) anyVisible = true;
        });

        if (globalEmpty instanceof HTMLElement) {
          globalEmpty.hidden = !searching || anyVisible;
        }
      };

      input.addEventListener("input", runSearch);
      (root).__areaRunSearch = runSearch;
      runSearch();
    };

    document.querySelectorAll("[data-area-root]").forEach(setupAreaSearch);
    window.addEventListener("pageshow", () => {
      document.querySelectorAll("[data-area-root]").forEach((root) => {
        if (root && typeof (root).__areaRunSearch === "function") {
          (root).__areaRunSearch();
        }
      });
    });
  })();
</script>

<style>
  .page-shell {
    display: grid;
    gap: 1rem;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty-note,
  .search-empty-all {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
