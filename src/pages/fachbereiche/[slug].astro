---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, getVisibleSubjects } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { getEntriesForPrimarySubject } from "../../data/topics";
import { getVisibleAreaCards } from "../../data/areaStructure";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import AreaSearchHero from "../../components/content/AreaSearchHero.astro";
import AreaTopicCard from "../../components/content/AreaTopicCard.astro";

export async function getStaticPaths() {
  const subjects = await getVisibleSubjects();
  return subjects.map((subject) => ({ params: { slug: subject.data.slug }, props: { subject } }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  tone: "math",
  icon: "math.png",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const subjectArticles = getEntriesForPrimarySubject(articles, subject.data.slug);
const subjectExercises = getEntriesForPrimarySubject(exercises, subject.data.slug);
const areaCards = getVisibleAreaCards(subject.data.slug, [], [...subjectArticles, ...subjectExercises], { flattenSingleRoot: true }).map((item) => ({
  ...item,
  href: withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`),
}));
const mascotSrc = withBase(`assets/mascots/${detail.icon}`);
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <div class="page-shell" data-area-search-root>
    <AreaSearchHero
      title={subject.data.title}
      scopeLabel="Fachbereich"
      tone={detail.tone}
      imageSrc={mascotSrc}
      imageAlt={`${subject.data.title} Bereichsfuchs`}
      searchPlaceholder={`In ${subject.data.title} nach Wissen und Aufgaben suchen`}
      searchHint="Wissensseiten und Aufgaben bleiben in der Anzeige getrennt."
    />

    <section class="search-empty" data-search-empty hidden>
      <p>Zu deiner Suche gibt es in diesem Fachbereich gerade keinen sichtbaren Themenblock.</p>
    </section>

    {areaCards.length > 0 && (
      <section class="section-block" id="fachthemen" data-search-group>
        <SectionHeading kicker="Fachthemen" title="Themen in diesem Fachbereich" />
        <div class="topic-grid">
          {areaCards.map((item) => (
            <AreaTopicCard
              title={item.title}
              description={item.description}
              href={item.href}
              tone={detail.tone}
              icon={item.icon}
              searchText={item.searchText}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const roots = document.querySelectorAll('[data-area-search-root]');
    roots.forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.searchReady === 'true') return;
      root.dataset.searchReady = 'true';
      const input = root.querySelector('[data-area-search-input]');
      const groups = [...root.querySelectorAll('[data-search-group]')];
      const empty = root.querySelector('[data-search-empty]');
      if (!(input instanceof HTMLInputElement)) return;

      const update = () => {
        const query = input.value.trim().toLowerCase();
        let visibleCount = 0;
        groups.forEach((group) => {
          const items = [...group.querySelectorAll('[data-search-item]')];
          let groupVisible = 0;
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            const haystack = (item.dataset.searchText ?? '').toLowerCase();
            const show = !query || haystack.includes(query);
            item.hidden = !show;
            if (show) groupVisible += 1;
          });
          if (group instanceof HTMLElement) group.hidden = groupVisible === 0;
          visibleCount += groupVisible;
        });
        if (empty instanceof HTMLElement) empty.hidden = !query || visibleCount > 0;
      };

      input.addEventListener('input', update);
      update();
    });
  })();
</script>

<style>
  .page-shell,
  .section-block {
    display: grid;
    gap: 1rem;
  }

  .section-block {
    margin-top: 1.2rem;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .search-empty {
    padding: 1rem 1.1rem;
    border: 1px dashed var(--border-strong);
    border-radius: 24px;
    background: color-mix(in oklab, var(--surface) 88%, white 12%);
  }

  .search-empty p {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  @media (max-width: 980px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
