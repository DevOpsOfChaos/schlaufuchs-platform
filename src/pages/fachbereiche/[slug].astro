---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, getVisibleSubjects, levelLabels } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { withBase } from "../../utils/base";

export async function getStaticPaths() {
  const subjects = await getVisibleSubjects();

  return subjects.map((subject) => ({
    params: { slug: subject.data.slug },
    props: { subject },
  }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  intro: subject.data.description,
  highlights: [],
  sections: [],
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
  learnModeTitle: "Im Lernmodus mit diesem Bereich arbeiten",
  learnModeItems: [],
  tone: "default",
  icon: "",
  kicker: "Fachbereich",
  entry: "Grundlagen",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const featuredArticles = articles.slice(0, 6);
const featuredExercises = exercises.slice(0, 6);
const directEntry = featuredArticles[0];
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <section class="subject-hero">
    <div class="hero-copy">
      <p class="eyebrow">Fachbereich</p>
      <h1>{subject.data.title}</h1>
      <p class="lead">{detail.intro}</p>

      <div class="hero-actions" data-present="hide">
        <a class="hero-button primary" href={withBase("fachbereiche")}>Alle Fachbereiche</a>
        <a class="hero-button secondary" href={withBase("suchen")}>Im Fach suchen</a>
      </div>
    </div>

    <div class="hero-side">
      {directEntry ? (
        <article class="entry-card">
          <span class="entry-label">Direkter Einstieg</span>
          <h2>{directEntry.data.title}</h2>
          <p>{directEntry.data.description}</p>
          <a href={withBase(`wissen/${directEntry.id}`)}>Zur Wissensseite →</a>
        </article>
      ) : (
        <article class="entry-card">
          <span class="entry-label">Direkter Einstieg</span>
          <h2>{detail.entry}</h2>
          <p>In diesem Fach findest du Grundlagen, Wissensseiten und passende Aufgaben in einer klaren Struktur.</p>
        </article>
      )}
    </div>
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Wissen</p>
        <h2>Wichtige Wissensseiten in diesem Fach</h2>
      </div>
    </div>

    {featuredArticles.length > 0 ? (
      <div class="content-grid">
        {featuredArticles.map((entry) => (
          <article class="content-card">
            <div class="content-top">
              <h3>{entry.data.title}</h3>
              <span>{levelLabels[entry.data.level]}</span>
            </div>
            <p>{entry.data.description}</p>
            <a href={withBase(`wissen/${entry.id}`)}>Wissensseite öffnen →</a>
          </article>
        ))}
      </div>
    ) : (
      <article class="empty-card">
        <h3>Noch keine Wissensseiten sichtbar</h3>
        <p>Für dieses Fach sind aktuell noch keine Wissensseiten sichtbar.</p>
      </article>
    )}
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Themen</p>
        <h2>Wichtige Themen im Überblick</h2>
      </div>
    </div>

    <div class="section-grid">
      {detail.sections.map((section) => (
        <article class="section-card">
          <h3>{section.title}</h3>
          <ul>
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Aufgaben</p>
        <h2>Passende Aufgaben in diesem Fach</h2>
      </div>
    </div>

    {featuredExercises.length > 0 ? (
      <div class="content-grid">
        {featuredExercises.map((entry) => (
          <article class="content-card">
            <div class="content-top">
              <h3>{entry.data.title}</h3>
              <span>{levelLabels[entry.data.level]}</span>
            </div>
            <p>{entry.data.description}</p>
            <a href={withBase(`aufgaben/${entry.id}`)}>Aufgabe öffnen →</a>
          </article>
        ))}
      </div>
    ) : (
      <article class="empty-card" data-present="hide">
        <h3>Noch keine Aufgaben sichtbar</h3>
        <p>Für dieses Fach sind aktuell noch keine Aufgaben sichtbar.</p>
      </article>
    )}
  </section>

  <section class="subject-section learn-mode-only">
    <div class="section-head">
      <div>
        <p class="section-kicker">Lernmodus</p>
        <h2>So kannst du den Bereich lernen</h2>
      </div>
    </div>

    <article class="learn-mode-card">
      <h3>{detail.learnModeTitle}</h3>
      <ul>
        {detail.learnModeItems.map((item) => <li>{item}</li>)}
      </ul>
      <a class="learn-mode-link" href={withBase("aufgaben")}>Zu den Aufgaben →</a>
    </article>
  </section>
</BaseLayout>

<style>
  .subject-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 23rem);
    gap: 1.25rem;
    align-items: start;
  }

  .eyebrow,
  .section-kicker,
  .entry-label {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.7vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.05rem;
    max-width: 52rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 1.45rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .hero-button.secondary {
    background: var(--surface);
    color: var(--text-strong);
  }

  .hero-side,
  .section-grid,
  .content-grid {
    display: grid;
    gap: 1rem;
  }

  .section-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .subject-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.9rem;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 3vw, 2.35rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .entry-card,
  .section-card,
  .content-card,
  .empty-card,
  .learn-mode-card {
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    padding: 1.35rem;
  }

  .entry-card h2,
  .section-card h3,
  .content-card h3,
  .empty-card h3,
  .learn-mode-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .entry-card p,
  .content-card p,
  .empty-card p {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .entry-card a,
  .content-card a,
  .learn-mode-link {
    display: inline-block;
    margin-top: 0.95rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .section-card ul,
  .learn-mode-card ul {
    list-style: none;
    margin: 0.95rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .section-card li,
  .learn-mode-card li {
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    line-height: 1.55;
  }

  .section-card li:last-child,
  .learn-mode-card li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .content-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .content-top span {
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .learn-mode-only {
    display: none;
  }

  :global(html[data-learn-mode="on"]) .learn-mode-only {
    display: grid;
  }

  .learn-mode-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"]) .learn-mode-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  @media (max-width: 980px) {
    .subject-hero,
    .section-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
