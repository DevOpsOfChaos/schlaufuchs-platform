---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const base = import.meta.env.BASE_URL;

const subjectDetails: Record<
  string,
  {
    intro: string;
    highlights: string[];
    sections: { title: string; items: string[] }[];
    knowledgeLabel: string;
    exerciseLabel: string;
    learnModeTitle: string;
    learnModeItems: string[];
  }
> = {
  mathematik: {
    intro:
      "Mathematik auf Schlaufuchs bündelt Grundlagen, Analysis, Algebra und Vektorgeometrie in klaren Themenfeldern. Der Bereich verbindet fachliche Übersicht, Wissensseiten und passende Aufgaben.",
    highlights: ["Funktionen", "Analysis", "Algebra", "Vektorgeometrie"],
    sections: [
      { title: "Grundlagen", items: ["Funktionen und Graphen", "Lineare und quadratische Funktionen", "Erste Analysis"] },
      { title: "Zentrale Themen", items: ["Differentialrechnung", "Integralrechnung", "Lineare Gleichungssysteme"] },
      { title: "Erweiterungen", items: ["Komplexe Zahlen", "Geraden und Ebenen", "Fourier und FFT"] },
    ],
    knowledgeLabel: "Wissensseiten",
    exerciseLabel: "Aufgaben",
    learnModeTitle: "Mathematik im Lernmodus nutzen",
    learnModeItems: [
      "Starte mit den Grundlagen und wechsle danach gezielt in Analysis oder Algebra.",
      "Nutze Aufgaben erst nach dem inhaltlichen Überblick, damit Begriffe und Verfahren sitzen.",
      "Arbeite Themen in kleinen Blöcken: verstehen, Beispiel ansehen, dann Aufgaben ergänzen.",
    ],
  },
  linux: {
    intro:
      "Linux auf Schlaufuchs bündelt Shell, Rechte, Benutzer, SSH und Shellskripte in klar gegliederten Themenbereichen. Der Bereich verbindet Praxiswissen, Nachschlagen und passende Aufgaben.",
    highlights: ["Shell", "Rechte", "Shellskripte", "SSH"],
    sections: [
      { title: "Grundlagen", items: ["Shell und Prompt", "Dateirechte", "Benutzer und Gruppen"] },
      { title: "Zentrale Themen", items: ["chmod", "Dateibesitz", "Shellskripte"] },
      { title: "Praxis", items: ["SSH", "Schlüssel", "Fernzugriff und Tools"] },
    ],
    knowledgeLabel: "Wissensseiten",
    exerciseLabel: "Aufgaben",
    learnModeTitle: "Linux im Lernmodus nutzen",
    learnModeItems: [
      "Beginne mit Shell und Rechten, bevor du Automatisierung oder Fernzugriff vertiefst.",
      "Wechsle zwischen Wissensseite und Terminalpraxis in kleinen, klaren Schritten.",
      "Nutze SSH und Shellskripte erst dann stärker, wenn die Grundbefehle sicher sitzen.",
    ],
  },
  informatik: {
    intro:
      "Informatik auf Schlaufuchs bündelt Grundlagen, Programmierlogik und erste systemnahe Themen in einer klaren Fachübersicht. Der Bereich verbindet Einordnung, Wissensseiten und passende Aufgaben.",
    highlights: ["Grundlagen", "Programmierung", "C", "Struktur"],
    sections: [
      { title: "Grundlagen", items: ["Einführung in die Informatik", "Computer- und Programmiergrundlagen"] },
      { title: "Programmierung", items: ["C und Python einordnen", "Programmstruktur verstehen"] },
      { title: "Vertiefung", items: ["C-Grundlagen", "Kontrollstrukturen", "Eingaben und Ausgaben"] },
    ],
    knowledgeLabel: "Wissensseiten",
    exerciseLabel: "Aufgaben",
    learnModeTitle: "Informatik im Lernmodus nutzen",
    learnModeItems: [
      "Arbeite zuerst über Grundideen und Begriffe, bevor du konkrete Syntax in den Vordergrund stellst.",
      "Verbinde Kontrollstrukturen und Programmstruktur mit kleinen Code-Aufgaben statt isoliertem Auswendiglernen.",
      "Nutze Aufgaben besonders dort, wo Abläufe, Bedingungen und Programmlogik verglichen werden sollen.",
    ],
  },
  elektrotechnik: {
    intro:
      "Elektrotechnik auf Schlaufuchs bündelt technische Grundlagen, digitale Technik, Netzwerke und Mikrocontroller in übersichtlichen Themenfeldern. Der Bereich verbindet Fachinformationen, Wissensseiten und passende Aufgaben.",
    highlights: ["Signale", "Halbleiter", "Netzwerke", "Mikrocontroller"],
    sections: [
      { title: "Grundlagen", items: ["Computer und CPU", "Daten, Signale und Codierung", "Netzwerke und Protokolle"] },
      { title: "Zentrale Themen", items: ["Logikgatter", "Dioden", "MOSFETs und Transistoren"] },
      { title: "Praxis und Rechnen", items: ["Netzwerkanalyse", "Wechselstrom", "Arduino und ESP32"] },
    ],
    knowledgeLabel: "Wissensseiten",
    exerciseLabel: "Aufgaben",
    learnModeTitle: "Elektrotechnik im Lernmodus nutzen",
    learnModeItems: [
      "Starte mit Signalen, Logik und Grundbausteinen, bevor du in Rechnen oder Mikrocontroller gehst.",
      "Nutze Aufgaben vor allem dann, wenn Größen, Schaltungen oder Zusammenhänge sicher eingeordnet werden sollen.",
      "Arbeite praktische Themen wie Arduino oder ESP32 am besten erst nach einem klaren Überblick über die Grundlagen.",
    ],
  },
  "web-development": {
    intro:
      "Web Development auf Schlaufuchs bündelt HTML, CSS und erste Layout-Themen in einer klaren Fachübersicht. Der Bereich verbindet Wissensseiten, Nachschlage-Struktur und passende Aufgaben.",
    highlights: ["HTML", "CSS", "Semantik", "Layouts"],
    sections: [
      { title: "Grundlagen", items: ["HTML-Grundlagen", "HTML-Semantik", "Seitenstruktur"] },
      { title: "Zentrale Themen", items: ["Links, Bilder und Pfade", "CSS-Grundlagen", "Selektoren"] },
      { title: "Praxis", items: ["Box-Modell", "Layouts", "kleine Code-Aufgaben"] },
    ],
    knowledgeLabel: "Wissensseiten",
    exerciseLabel: "Aufgaben",
    learnModeTitle: "Web Development im Lernmodus nutzen",
    learnModeItems: [
      "Beginne mit Struktur und Semantik, bevor du dich in CSS-Details oder Layout-Fragen verlierst.",
      "Verbinde Wissensseiten direkt mit kleinen Code-Aufgaben, damit HTML und CSS sichtbar zusammenwirken.",
      "Nutze den Lernmodus besonders dann, wenn du Themen in einer sinnvollen Reihenfolge durcharbeiten willst.",
    ],
  },
};

export async function getStaticPaths() {
  const subjects = (await getCollection("subjects"))
    .filter((subject) => subject.data.slug !== "daten-und-signale");

  return subjects.map((subject) => ({
    params: { slug: subject.data.slug },
    props: { subject },
  }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = subjectDetails[subject.data.slug] ?? {
  intro: subject.data.description,
  highlights: [],
  sections: [],
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
  learnModeTitle: "Im Lernmodus mit diesem Bereich arbeiten",
  learnModeItems: [],
};

const relatedSubjects = subject.data.slug === "elektrotechnik"
  ? ["elektrotechnik", "daten-und-signale"]
  : [subject.data.slug];

const articles = (await getCollection("articles"))
  .filter((entry) => !entry.data.draft && relatedSubjects.includes(entry.data.subject))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));
const exercises = (await getCollection("exercises"))
  .filter((entry) => !entry.data.draft && relatedSubjects.includes(entry.data.subject))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));

const levelLabels = {
  einfach: "Einfach",
  mittel: "Mittel",
  fortgeschritten: "Fortgeschritten",
} as const;
---

<BaseLayout
  title={`${subject.data.title} – Schlaufuchs`}
  description={subject.data.description}
>
  <section class="subject-hero">
    <div class="hero-copy">
      <p class="eyebrow">Fachbereich</p>
      <h1>{subject.data.title}</h1>
      <p class="lead">{detail.intro}</p>

      <div class="hero-actions" data-present="hide">
        <a class="hero-button primary" href={`${base}fachbereiche`}>Alle Fachbereiche</a>
        <a class="hero-button secondary" href={`${base}suchen`}>Thema im Fach suchen</a>
      </div>
    </div>

    <div class="hero-stats">
      <article class="stat-card">
        <span>{detail.knowledgeLabel}</span>
        <strong>{articles.length}</strong>
      </article>
      <article class="stat-card" data-present="hide">
        <span>{detail.exerciseLabel}</span>
        <strong>{exercises.length}</strong>
      </article>
      <article class="stat-card">
        <span>Themenfelder</span>
        <strong>{detail.highlights.length}</strong>
      </article>
    </div>
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Überblick</p>
        <h2>So ist der Bereich gegliedert</h2>
      </div>
    </div>

    <div class="section-grid">
      {detail.sections.map((section) => (
        <article class="section-card">
          <h3>{section.title}</h3>
          <ul>
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="subject-section learn-mode-only">
    <div class="section-head">
      <div>
        <p class="section-kicker">Lernmodus</p>
        <h2>Zusätzliche Lernsicht für diesen Fachbereich</h2>
        <p>Im Lernmodus wird der Fachbereich nicht nur als Sammlung von Themen genutzt, sondern stärker als geordnete Arbeits- und Vertiefungssicht gelesen.</p>
      </div>
    </div>

    <article class="learn-mode-card">
      <h3>{detail.learnModeTitle}</h3>
      <ul>
        {detail.learnModeItems.map((item) => <li>{item}</li>)}
      </ul>
      <a class="learn-mode-link" href={`${base}aufgaben`}>Passende Aufgaben öffnen →</a>
    </article>
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Themenfelder</p>
        <h2>Wichtige Bereiche in diesem Fach</h2>
      </div>
    </div>

    <div class="highlight-grid">
      {detail.highlights.map((item) => (
        <article class="highlight-card">
          <h3>{item}</h3>
          <p>Dieses Themenfeld gehört zu den zentralen Bestandteilen des Fachbereichs und wird fortlaufend mit Wissensseiten und Aufgaben ergänzt.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="subject-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Verfügbare Inhalte</p>
        <h2>Aktuell im Fachbereich sichtbar</h2>
        <p>Wissensseiten und Aufgaben sind direkt im Fachbereich verankert und wachsen mit jeder weiteren Inhaltswelle sichtbar mit.</p>
      </div>
    </div>

    <div class="content-grid two-up">
      <article class="content-card">
        <div class="content-top">
          <h3>Wissensseiten</h3>
          <span>{articles.length}</span>
        </div>

        {articles.length > 0 ? (
          <ul class="content-list">
            {articles.slice(0, 6).map((entry) => (
              <li>
                <div class="content-copy">
                  <a href={`${base}wissen/${entry.id}`}>{entry.data.title}</a>
                  <small>{entry.data.description}</small>
                </div>
                <span>{levelLabels[entry.data.level]}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Die ersten Kernseiten für diesen Fachbereich werden jetzt schrittweise in die Plattform eingezogen.</p>
        )}
      </article>

      <article class="content-card" data-present="hide">
        <div class="content-top">
          <h3>Aufgaben</h3>
          <span>{exercises.length}</span>
        </div>

        {exercises.length > 0 ? (
          <ul class="content-list">
            {exercises.slice(0, 6).map((entry) => (
              <li>
                <div class="content-copy">
                  <a href={`${base}aufgaben/${entry.id}`}>{entry.data.title}</a>
                  <small>{entry.data.description}</small>
                </div>
                <span>{levelLabels[entry.data.level]}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Passende Aufgabenformate werden für diesen Fachbereich schrittweise sichtbar ergänzt.</p>
        )}
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .subject-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 24rem);
    gap: 1.25rem;
    align-items: start;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.7vw, 4.3rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 1.45rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .hero-button.secondary {
    background: var(--surface);
    color: var(--text-strong);
  }

  .hero-stats {
    display: grid;
    gap: 0.85rem;
  }

  .stat-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .stat-card span {
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .stat-card strong {
    color: var(--text-strong);
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .subject-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .learn-mode-only {
    display: none;
  }

  :global(html[data-learn-mode="on"]) .learn-mode-only {
    display: grid;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.75rem, 2.9vw, 2.35rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-head p {
    margin: 0.75rem 0 0;
    max-width: 44rem;
    color: var(--text-soft);
    line-height: 1.64;
  }

  .section-grid,
  .highlight-grid,
  .content-grid {
    display: grid;
    gap: 1rem;
  }

  .section-grid,
  .highlight-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-grid.two-up {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  :global(html[data-presentation-mode="on"]) .content-grid.two-up {
    grid-template-columns: 1fr;
  }

  .section-card,
  .highlight-card,
  .content-card,
  .learn-mode-card {
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    padding: 1.35rem;
  }

  .learn-mode-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"]) .learn-mode-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  .section-card h3,
  .highlight-card h3,
  .content-top h3,
  .learn-mode-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.12rem;
  }

  .section-card ul,
  .content-list,
  .learn-mode-card ul {
    list-style: none;
    margin: 0.95rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .section-card li,
  .content-list li,
  .learn-mode-card li {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .section-card li:last-child,
  .content-list li:last-child,
  .learn-mode-card li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .highlight-card p,
  .empty {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.66;
  }

  .learn-mode-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .content-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .content-top span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    min-height: 2rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    border: 1px solid var(--border);
  }

  .content-copy {
    display: grid;
    gap: 0.3rem;
  }

  .content-copy a {
    color: var(--text-strong);
    font-weight: 650;
  }

  .content-copy small {
    color: var(--text-soft);
    line-height: 1.45;
  }

  .content-list span {
    color: var(--text-soft);
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .subject-hero,
    .content-grid.two-up,
    .section-grid,
    .highlight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
