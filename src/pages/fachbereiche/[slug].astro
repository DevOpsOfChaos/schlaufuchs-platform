---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, getVisibleSubjects } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { getEntriesForPrimarySubject } from "../../data/topics";
import { getVisibleAreaCards } from "../../data/areaStructure";
import { withBase, withBaseAsset } from "../../utils/base";
import AreaSearchHero from "../../components/content/AreaSearchHero.astro";
import AreaTopicCard from "../../components/content/AreaTopicCard.astro";
import AreaSectionSurface from "../../components/content/AreaSectionSurface.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";

export async function getStaticPaths() {
  const subjects = await getVisibleSubjects();
  return subjects.map((subject) => ({ params: { slug: subject.data.slug }, props: { subject } }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  tone: "math",
  icon: "math.png",
  kicker: "Fachbereich",
  entry: "",
  highlights: [],
  intro: "",
  sections: [],
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const subjectArticles = getEntriesForPrimarySubject(articles, subject.data.slug);
const subjectExercises = getEntriesForPrimarySubject(exercises, subject.data.slug);
const combinedEntries = [...subjectArticles, ...subjectExercises];
const topicCards = getVisibleAreaCards(subject.data.slug, [], combinedEntries, { flattenSingleRoot: true });
const imageSrc = withBaseAsset(`assets/mascots/${detail.icon}`);
const accentOrder = ["a", "b", "c", "d", "e", "f"] as const;
const getAccent = (index: number) => accentOrder[index % accentOrder.length];
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <div class="page-shell">
    <AreaSearchHero
      title={subject.data.title}
      scopeLabel="Fachbereich"
      imageSrc={imageSrc}
      imageAlt={`${subject.data.title} – Fuchsmotiv`}
      tone={detail.tone}
    />

    {topicCards.length > 0 && (
      <AreaSectionSurface variant="topics">
        <SectionHeading kicker="Themen" title={`Themen in ${subject.data.title}`} />
        <div class="topic-grid">
          {topicCards.map((item, index) => (
            <AreaTopicCard
              title={item.title}
              description={item.description}
              href={withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`)}
              tone={detail.tone}
              icon={item.icon}
              chips={item.chips}
              searchText={item.searchText}
              accent={getAccent(index)}
            />
          ))}
        </div>
      </AreaSectionSurface>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell {
    display: grid;
    gap: 1rem;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.85rem;
  }
</style>
