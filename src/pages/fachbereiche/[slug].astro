---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, getVisibleSubjects, levelLabels } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { getEntriesForPrimarySubject, getTopicHierarchyStats, getTopicTail, getTopicSnapshot, humanizeTopicSegment } from "../../data/topics";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";

export async function getStaticPaths() {
  const subjects = await getVisibleSubjects();
  return subjects.map((subject) => ({ params: { slug: subject.data.slug }, props: { subject } }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  intro: subject.data.description,
  entry: "Grundlagen",
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const subjectArticles = getEntriesForPrimarySubject(articles, subject.data.slug);
const subjectExercises = getEntriesForPrimarySubject(exercises, subject.data.slug);
const topicSections = getTopicHierarchyStats(subjectArticles, subjectExercises).map((section) => ({
  ...section,
  href: withBase(`fachbereiche/${subject.data.slug}/${section.hrefPath.join("/")}`),
  children: section.children.map((topic) => ({
    ...topic,
    href: withBase(`fachbereiche/${subject.data.slug}/${topic.path.join("/")}`),
  })),
}));
const featuredArticles = subjectArticles.slice(0, 6);
const featuredExercises = subjectExercises.slice(0, 6);
const directEntry = featuredArticles[0];
const strongestPaths = getTopicSnapshot([...subjectArticles, ...subjectExercises]).slice(0, 5).map((item) => ({
  ...item,
  href: withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`),
}));

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <div class="page-shell">
    <section class="subject-hero">
      <div class="hero-copy">
        <p class="eyebrow">Fachbereich</p>
        <h1>{subject.data.title}</h1>
        <p class="lead">{detail.intro}</p>
        <div class="hero-stats">
          <article><strong>{subjectArticles.length}</strong><span>{detail.knowledgeLabel}</span></article>
          <article><strong>{subjectExercises.length}</strong><span>{detail.exerciseLabel}</span></article>
          <article><strong>{topicSections.length}</strong><span>Themenblöcke</span></article>
        </div>
      </div>

      <div class="hero-side">
        {directEntry ? (
          <article class="entry-card">
            <span class="entry-label">Direkter Einstieg</span>
            <h2>{directEntry.data.title}</h2>
            <p>{directEntry.data.description}</p>
            <a href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(directEntry).join("/")}`)}>Zur Fachinfo →</a>
          </article>
        ) : (
          <article class="entry-card">
            <span class="entry-label">Direkter Einstieg</span>
            <h2>{detail.entry}</h2>
            <p>In diesem Fach findest du Grundlagen, Wissensseiten und passende Aufgaben in einer klaren Struktur.</p>
          </article>
        )}
      </div>
    </section>

    {strongestPaths.length > 0 && (
      <section class="subject-section">
        <SectionHeading kicker="Schwerpunkte" title="Stärkste Themenpfade in diesem Fach" />
        <div class="spotlight-grid">
          {strongestPaths.map((item) => (
            <a class="spotlight-card" href={item.href}>
              <div>
                <h3>{item.title}</h3>
                <p>{item.count} Einträge im Themenpfad</p>
              </div>
              <span>→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {topicSections.length > 0 && (
      <section class="subject-section">
        <SectionHeading kicker="Themen" title="Direkt in die Fachthemen" />
        <div class="section-grid linked-topics">
          {topicSections.map((section) => (
            <article class="section-card topic-link-card">
              <div class="topic-link-top">
                <a class="topic-head-link" href={section.href}><h3>{section.title}</h3></a>
                <span class="count-pill">{section.totalCount}</span>
              </div>
              <p class="topic-summary">{section.articleCount} Wissensseiten · {section.exerciseCount} Aufgaben</p>
              {section.children.length > 0 ? (
                <ul>
                  {section.children.slice(0, 4).map((item) => (
                    <li>
                      <a href={item.href}>{item.title}</a>
                      <small>{item.articleCount} · {item.exerciseCount}</small>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="topic-link-text">Öffne die Themenübersicht mit Fachinfos, Wissensseiten und passenden Aufgaben.</p>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {featuredArticles.length > 0 && (
      <section class="subject-section">
        <SectionHeading kicker="Fachinfos" title="Wichtige Wissensseiten in diesem Fach" />
        <div class="content-grid">
          {featuredArticles.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${levelLabels[entry.data.level]} · ${humanizeTopicSegment(getTopicTail(entry).at(-1) ?? entry.data.section)}`}
              href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}
              ctaLabel="Fachinfo öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    )}

    {featuredExercises.length > 0 && (
      <section class="subject-section">
        <SectionHeading kicker="Aufgaben" title="Passende Aufgaben in diesem Fach" />
        <div class="content-grid">
          {featuredExercises.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${levelLabels[entry.data.level]} · ${humanizeTopicSegment(getTopicTail(entry).slice(0, -1).at(-1) ?? entry.data.section ?? "Thema")}`}
              href={withBase(`aufgaben/${entry.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell,
  .subject-section {
    display: grid;
    gap: 1rem;
  }

  .subject-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 23rem);
    gap: 1.25rem;
    align-items: start;
  }

  .eyebrow,
  .entry-label {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.7vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.05rem;
    max-width: 52rem;
  }

  .hero-stats,
  .spotlight-grid,
  .section-grid,
  .content-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-stats {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 1.4rem;
  }

  .spotlight-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero-stats article,
  .entry-card,
  .section-card,
  .spotlight-card {
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .hero-stats article,
  .spotlight-card {
    padding: 1rem 1.05rem;
  }

  .hero-stats strong {
    color: var(--text-strong);
    font-size: 1.45rem;
    line-height: 1;
  }

  .hero-stats span,
  .topic-summary,
  .section-card small,
  .spotlight-card p {
    color: var(--text-soft);
    line-height: 1.5;
    margin: 0;
  }

  .entry-card,
  .section-card {
    padding: 1.35rem;
  }

  .entry-card h2,
  .section-card h3,
  .spotlight-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .entry-card p,
  .topic-link-text {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .entry-card a {
    display: inline-block;
    margin-top: 0.95rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .spotlight-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.9rem;
    color: inherit;
  }

  .spotlight-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 800;
  }

  .topic-link-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .topic-head-link {
    color: inherit;
  }

  .count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.1rem;
    min-height: 2.1rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .section-card ul {
    list-style: none;
    margin: 0.95rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .section-card li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: baseline;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--border);
  }

  .section-card li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .section-card li a {
    color: var(--text-strong);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .subject-hero,
    .section-grid,
    .content-grid,
    .hero-stats,
    .spotlight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
