---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegacyRedirectPage from "../../components/ui/LegacyRedirectPage.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Bereich verschoben – Schlaufuchs" description="HTML/CSS ist jetzt Teil von Web Development." noIndex={true}>
  <LegacyRedirectPage
    title="HTML und CSS ist jetzt im Fachbereich Web Development gebündelt."
    lead="Dieser frühere Einstieg wird nicht mehr als eigenes Hauptfach geführt. Du wirst automatisch zur aktuellen Fachseite weitergeleitet."
    targetHref={`${base}fachbereiche/web-development`}
    targetLabel="Zu Web Development"
  />
</BaseLayout>
