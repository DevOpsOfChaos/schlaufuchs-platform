---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleSubjects } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";

const base = import.meta.env.BASE_URL;

const subjects = (await getVisibleSubjects())
  .map((subject) => ({
    ...subject,
    meta: getSubjectMeta(subject.data.slug),
  }))
  .filter((subject) => subject.meta !== null);
---

<BaseLayout
  title="Fachbereiche – Schlaufuchs"
  description="Übersicht über die Hauptfächer von Schlaufuchs mit klarer Fachlogik und direkten Einstiegen."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Fachbereiche</p>
      <h1>Die Plattform wird über klare Hauptfächer und Fachbereiche strukturiert.</h1>
      <p class="lead">
        Schlaufuchs bündelt die Inhalte in fünf sauberen Fachbereichen. Jeder Bereich verbindet
        Fachidentität, Wissensseiten, Aufgaben und sinnvolle Einstiege.
      </p>
    </div>

    <div class="hero-actions" data-present="hide">
      <a class="hero-button primary" href={`${base}aufgaben`}>Zu Aufgaben und Übungen</a>
      <a class="hero-button secondary" href={`${base}suchen`}>Thema suchen</a>
    </div>
  </section>

  <section class="grid">
    {subjects.map((subject) => (
      <a class={`card ${subject.meta!.tone}`} href={`${base}fachbereiche/${subject.data.slug}`}>
        <div class="card-top">
          <span class="kicker" data-present="hide">{subject.meta!.kicker}</span>
          <span class="entry" data-present="hide">Start: {subject.meta!.entry}</span>
        </div>

        <div class="card-copy">
          <h2>{subject.data.title}</h2>
          <p>{subject.data.description}</p>
        </div>

        <ul class="highlight-list">
          {subject.meta!.highlights.slice(0, 3).map((item) => <li>{item}</li>)}
        </ul>

        <span class="card-link">Zum Fachbereich →</span>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 1rem 0 0.4rem;
  }

  .hero-copy {
    max-width: 46rem;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.5vw, 4.25rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text-soft);
    line-height: 1.75;
    font-size: 1.04rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .hero-button.secondary {
    background: var(--surface);
    color: var(--text-strong);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  :global(html[data-presentation-mode="on"]) .grid {
    grid-template-columns: 1fr;
  }

  .card {
    display: grid;
    gap: 1.15rem;
    padding: 1.45rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    min-height: 18rem;
    position: relative;
    overflow: hidden;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .card::after {
    content: "";
    position: absolute;
    right: -1.75rem;
    bottom: -2rem;
    width: 7rem;
    height: 7rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    pointer-events: none;
  }

  .card.math { background: linear-gradient(135deg, rgba(93,113,175,0.22), rgba(232,237,248,0.82)); }
  .card.web { background: linear-gradient(135deg, rgba(173,144,156,0.18), rgba(245,239,241,0.84)); }
  .card.cs { background: linear-gradient(135deg, rgba(95,139,158,0.18), rgba(235,244,247,0.84)); }
  .card.linux { background: linear-gradient(135deg, rgba(175,163,122,0.18), rgba(242,239,230,0.84)); }
  .card.ee { background: linear-gradient(135deg, rgba(173,147,144,0.16), rgba(244,236,235,0.84)); }

  :global(html[data-theme="dark"]) .card.math { background: linear-gradient(135deg, rgba(72,95,164,0.34), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .card.web { background: linear-gradient(135deg, rgba(96,72,104,0.28), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .card.cs { background: linear-gradient(135deg, rgba(28,71,87,0.34), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .card.linux { background: linear-gradient(135deg, rgba(84,76,44,0.24), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .card.ee { background: linear-gradient(135deg, rgba(83,60,58,0.24), rgba(42,29,31,0.94)); }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .kicker,
  .entry {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.1rem 0.7rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    border: 1px solid rgba(148,163,184,0.16);
    color: var(--text-strong);
    background: rgba(255,255,255,0.24);
  }

  :global(html[data-theme="dark"]) .kicker,
  :global(html[data-theme="dark"]) .entry {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.08);
  }

  .card-copy h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.55rem, 2.5vw, 2rem);
    line-height: 1.03;
    letter-spacing: -0.04em;
  }

  .card-copy p {
    margin: 0.8rem 0 0;
    color: var(--text);
    line-height: 1.66;
  }

  .highlight-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
  }

  .highlight-list li {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.16);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-size: 0.9rem;
    font-weight: 600;
  }

  :global(html[data-theme="dark"]) .highlight-list li {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.08);
  }

  .card-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
