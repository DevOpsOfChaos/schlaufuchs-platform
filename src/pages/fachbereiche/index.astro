---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const subjects = (await getCollection("subjects"))
  .sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Fachbereiche – Schlaufuchs"
  description="Übersicht über die Fachbereiche von Schlaufuchs."
>
  <section class="hero">
    <p class="eyebrow">Fachbereiche</p>
    <h1>Die Inhalte werden in klaren Themenfeldern aufgebaut.</h1>
    <p class="lead">
      Kein unlogischer Seitenwildwuchs. Jeder Bereich bekommt eine klare Identität und saubere Struktur.
    </p>
  </section>

  <section class="grid">
    {subjects.map((subject) => (
      <a class="card" href={`${base}fachbereiche/${subject.data.slug}`}>
        <span class="kicker">Fachbereich</span>
        <h2>{subject.data.title}</h2>
        <p>{subject.data.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2.5rem 0 1.5rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    line-height: 1.05;
    margin: 0 0 1rem;
    max-width: 13ch;
  }

  .lead {
    margin: 0;
    color: var(--text-muted);
    max-width: 48rem;
    line-height: 1.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    display: block;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: rgba(245, 158, 11, 0.45);
  }

  .kicker {
    display: inline-block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .card h2 {
    margin: 0 0 0.7rem;
  }

  .card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
