---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleSubjects } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";

const base = import.meta.env.BASE_URL;

const subjects = (await getVisibleSubjects())
  .map((subject) => ({
    ...subject,
    meta: getSubjectMeta(subject.data.slug),
  }))
  .filter((subject) => subject.meta !== null);
---

<BaseLayout
  title="Fachbereiche – Schlaufuchs"
  description="Übersicht über die fünf Hauptfächer mit direkten Einstiegen zu den Fachseiten."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Hauptfächer</p>
      <h1>Fachbereiche mit klarer Struktur</h1>
      <p class="lead">Wähle ein Fach und gehe direkt in die passende Fachseite.</p>
    </div>

    <div class="hero-link" data-present="hide">
      <a href={`${base}fachbereiche`}>Alle Fachbereiche ansehen</a>
    </div>
  </section>

  <section class="grid">
    {subjects.map((subject) => (
      <a class={`card ${subject.meta!.tone}`} href={`${base}fachbereiche/${subject.data.slug}`}>
        <div class="card-top">
          <h2>{subject.data.title}</h2>
          <span class="card-arrow">→</span>
        </div>
        <p>{subject.data.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 1rem 0 0.4rem;
  }

  .hero-copy {
    max-width: 42rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.3rem, 4.4vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text-soft);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .hero-link a {
    color: var(--text-strong);
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.6rem;
  }

  .card {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    min-height: 15rem;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .card.math { background: linear-gradient(135deg, rgba(93,113,175,0.18), rgba(232,237,248,0.82)); }
  .card.web { background: linear-gradient(135deg, rgba(173,144,156,0.16), rgba(245,239,241,0.84)); }
  .card.cs { background: linear-gradient(135deg, rgba(95,139,158,0.16), rgba(235,244,247,0.84)); }
  .card.linux { background: linear-gradient(135deg, rgba(175,163,122,0.16), rgba(242,239,230,0.84)); }
  .card.ee { background: linear-gradient(135deg, rgba(173,147,144,0.15), rgba(244,236,235,0.84)); }

  :global(html[data-theme="dark"]) .card.math { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .card.web { background: linear-gradient(135deg, rgba(96,72,104,0.24), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .card.cs { background: linear-gradient(135deg, rgba(28,71,87,0.30), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .card.linux { background: linear-gradient(135deg, rgba(84,76,44,0.22), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .card.ee { background: linear-gradient(135deg, rgba(83,60,58,0.22), rgba(42,29,31,0.94)); }

  .card-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.6vw, 2.15rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .card-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  :global(html[data-theme="dark"]) .card-arrow {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.08);
  }

  .card p {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
