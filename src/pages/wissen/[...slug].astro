---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";
import { withBase } from "../../utils/base";

export async function getStaticPaths() {
  const articles = await getVisibleArticles();

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";

const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
const entryTags = entry.data.tags ?? [];

const scoreByTopicFit = (item: CollectionEntry<"articles"> | CollectionEntry<"exercises">) => {
  const sameSection = item.data.section === entry.data.section ? 3 : 0;
  const itemTags = "tags" in item.data && Array.isArray(item.data.tags) ? item.data.tags : [];
  const sharedTags = itemTags.filter((tag) => entryTags.includes(tag)).length;
  return sameSection + sharedTags;
};

const relatedArticles = allArticles
  .filter((item) => item.id !== entry.id && resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => scoreByTopicFit(b) - scoreByTopicFit(a))
  .slice(0, 3);

const relatedExercises = allExercises
  .filter((item) => resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => scoreByTopicFit(b) - scoreByTopicFit(a))
  .slice(0, 6);
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <nav class="breadcrumb" aria-label="Brotkrumen">
    <a href={withBase()}>Start</a>
    <span>›</span>
    <a href={withBase("fachbereiche")}>Fachbereiche</a>
    <span>›</span>
    <a href={withBase(`fachbereiche/${subjectSlug}`)}>{subjectTitle}</a>
    <span>›</span>
    <span aria-current="page">Wissensseite</span>
  </nav>

  <section class="article-hero">
    <div class="hero-copy">
      <p class="eyebrow">Wissensseite · {subjectTitle}</p>
      <div class="hero-meta-row" data-present="hide">
        <span class="meta-chip">{entry.data.section}</span>
        <span class="meta-chip">{levelLabels[entry.data.level]}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </div>
  </section>

  <section class="article-shell">
    <article class="article-content">
      <Content />
    </article>
  </section>

  {relatedExercises.length > 0 && (
    <section class="related-section">
      <div class="section-head">
        <div>
          <p class="section-kicker">Aufgaben</p>
          <h2>Passende Aufgaben zu diesem Thema</h2>
        </div>
      </div>

      <div class="task-grid">
        {relatedExercises.map((item) => (
          <article class="task-card">
            <div class="task-top">
              <h3>{item.data.title}</h3>
              <span>{levelLabels[item.data.level]}</span>
            </div>
            <p>{item.data.description}</p>
            <a href={withBase(`aufgaben/${item.id}`)}>Aufgabe öffnen →</a>
          </article>
        ))}
      </div>
    </section>
  )}

  {relatedArticles.length > 0 && (
    <section class="related-section" data-present="hide">
      <div class="section-head">
        <div>
          <p class="section-kicker">Weiterlesen</p>
          <h2>Weitere Wissensseiten in diesem Bereich</h2>
        </div>
      </div>

      <div class="task-grid">
        {relatedArticles.map((item) => (
          <article class="task-card">
            <div class="task-top">
              <h3>{item.data.title}</h3>
              <span>{item.data.section}</span>
            </div>
            <p>{item.data.description}</p>
            <a href={withBase(`wissen/${item.id}`)}>Wissensseite öffnen →</a>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--text-soft);
    font-size: 0.94rem;
  }

  .breadcrumb a {
    color: var(--text-soft);
  }

  .breadcrumb a:hover {
    color: var(--text-strong);
  }

  .article-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.9rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.12rem 0.72rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4.1rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .article-shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .article-content {
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .related-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.7rem;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.7vw, 2.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .task-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .task-card {
    display: grid;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .task-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .task-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .task-top span {
    color: var(--text-soft);
    font-size: 0.86rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .task-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
  }

  .task-card a {
    color: var(--text-strong);
    font-weight: 700;
  }

  .article-content :global(h2) {
    margin-top: 1.75rem;
    color: var(--text-strong);
    font-size: 1.55rem;
    line-height: 1.15;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  .article-content :global(ul) {
    padding-left: 1.2rem;
  }

  @media (max-width: 980px) {
    .task-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
