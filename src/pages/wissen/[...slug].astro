---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

const base = import.meta.env.BASE_URL;

const subjectTitles: Record<string, string> = {
  mathematik: "Mathematik",
  informatik: "Informatik",
  elektrotechnik: "Elektrotechnik",
  linux: "Linux",
  "web-development": "Web Development",
  "daten-und-signale": "Elektrotechnik",
};

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitles[entry.data.subject] ?? "Fachbereich";
const subjectSlug = entry.data.subject === "daten-und-signale" ? "elektrotechnik" : entry.data.subject;
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <section class="article-hero">
    <div class="hero-copy">
      <p class="eyebrow">Wissensseite · {subjectTitle}</p>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </div>

    <div class="hero-meta">
      <article class="meta-card">
        <span>Fachbereich</span>
        <strong>{subjectTitle}</strong>
      </article>
      <article class="meta-card">
        <span>Niveau</span>
        <strong>{entry.data.level}</strong>
      </article>
      <article class="meta-card">
        <span>Themenblock</span>
        <strong>{entry.data.section}</strong>
      </article>
    </div>
  </section>

  <section class="article-shell">
    <article class="article-content">
      <Content />
    </article>

    <aside class="article-aside">
      <div class="aside-card">
        <h2>Im Fachkontext</h2>
        <p>Diese Wissensseite gehört zum Fachbereich {subjectTitle} und ist Teil der sichtbaren Fach- und Themenstruktur der Plattform.</p>
        <a href={`${base}fachbereiche/${subjectSlug}`}>Zum Fachbereich →</a>
      </div>

      <div class="aside-card learn-mode-only">
        <h2>Im Lernmodus nutzen</h2>
        <p>Im Lernmodus wird diese Wissensseite stärker als Arbeitsgrundlage gelesen: erst Überblick gewinnen, dann Beispiele prüfen und danach passende Aufgaben ergänzen.</p>
        <a href={`${base}aufgaben`}>Passende Aufgaben öffnen →</a>
      </div>

      {entry.data.tags.length > 0 && (
        <div class="aside-card">
          <h2>Tags</h2>
          <ul class="tag-list">
            {entry.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
      )}
    </aside>
  </section>
</BaseLayout>

<style>
  .article-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 22rem);
    gap: 1rem;
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4.1rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .hero-meta {
    display: grid;
    gap: 0.8rem;
  }

  .meta-card,
  .aside-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .meta-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.15rem;
  }

  .meta-card span {
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta-card strong {
    color: var(--text-strong);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 20rem);
    gap: 1rem;
    margin-top: 1.6rem;
  }

  .article-content,
  .aside-card {
    padding: 1.4rem;
  }

  .article-content {
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .article-aside {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .learn-mode-only {
    display: none;
  }

  :global(html[data-learn-mode="on"]) .learn-mode-only {
    display: block;
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"][data-learn-mode="on"]) .learn-mode-only {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  .aside-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
  }

  .aside-card p {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .aside-card a {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }

  .tag-list li {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .article-content :global(h2) {
    margin-top: 1.75rem;
    color: var(--text-strong);
    font-size: 1.55rem;
    line-height: 1.15;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  .article-content :global(ul) {
    padding-left: 1.2rem;
  }

  @media (max-width: 980px) {
    .article-hero,
    .article-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
