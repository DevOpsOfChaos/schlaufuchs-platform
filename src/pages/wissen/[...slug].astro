---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const articles = await getVisibleArticles();

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";

const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);

const relatedArticles = allArticles
  .filter((item) => item.id !== entry.id && resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => Number(b.data.section === entry.data.section) - Number(a.data.section === entry.data.section))
  .slice(0, 3);

const relatedExercises = allExercises
  .filter((item) => resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => Number(b.data.section === entry.data.section) - Number(a.data.section === entry.data.section))
  .slice(0, 3);
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <nav class="breadcrumb" aria-label="Brotkrumen">
    <a href={`${base}`}>Start</a>
    <span>›</span>
    <a href={`${base}fachbereiche`}>Fachbereiche</a>
    <span>›</span>
    <a href={`${base}fachbereiche/${subjectSlug}`}>{subjectTitle}</a>
    <span>›</span>
    <span aria-current="page">Wissensseite</span>
  </nav>

  <section class="article-hero">
    <div class="hero-copy">
      <p class="eyebrow">Wissensseite · {subjectTitle}</p>
      <div class="hero-meta-row" data-present="hide">
        <span class="meta-chip">{entry.data.section}</span>
        <span class="meta-chip">{levelLabels[entry.data.level]}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </div>

    <div class="hero-meta" data-present="hide">
      <article class="meta-card">
        <span>Fachbereich</span>
        <strong>{subjectTitle}</strong>
      </article>
      <article class="meta-card">
        <span>Niveau</span>
        <strong>{levelLabels[entry.data.level]}</strong>
      </article>
      <article class="meta-card">
        <span>Themenblock</span>
        <strong>{entry.data.section}</strong>
      </article>
    </div>
  </section>

  <section class="article-shell">
    <article class="article-content">
      <Content />
    </article>

    <aside class="article-aside" data-present="hide">
      <div class="aside-card">
        <h2>Im Fachkontext</h2>
        <p>Diese Wissensseite gehört zum Fachbereich {subjectTitle} und ist Teil der sichtbaren Fach- und Themenstruktur der Plattform.</p>
        <a href={`${base}fachbereiche/${subjectSlug}`}>Zum Fachbereich →</a>
      </div>

      <div class="aside-card learn-mode-only">
        <h2>Im Lernmodus nutzen</h2>
        <p>Im Lernmodus wird diese Wissensseite stärker als Arbeitsgrundlage gelesen: erst Überblick gewinnen, dann Beispiele prüfen und danach passende Aufgaben ergänzen.</p>
        <a href={`${base}aufgaben`}>Passende Aufgaben öffnen →</a>
      </div>

      {relatedExercises.length > 0 && (
        <div class="aside-card">
          <h2>Passende Aufgaben</h2>
          <ul class="related-list">
            {relatedExercises.map((item) => (
              <li>
                <a href={`${base}aufgaben/${item.id}`}>{item.data.title}</a>
                <small>{levelLabels[item.data.level]}</small>
              </li>
            ))}
          </ul>
        </div>
      )}

      {relatedArticles.length > 0 && (
        <div class="aside-card">
          <h2>Weitere Wissensseiten</h2>
          <ul class="related-list">
            {relatedArticles.map((item) => (
              <li>
                <a href={`${base}wissen/${item.id}`}>{item.data.title}</a>
                <small>{item.data.section}</small>
              </li>
            ))}
          </ul>
        </div>
      )}

      {entry.data.tags.length > 0 && (
        <div class="aside-card">
          <h2>Tags</h2>
          <ul class="tag-list">
            {entry.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
      )}
    </aside>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--text-soft);
    font-size: 0.94rem;
  }

  .breadcrumb a {
    color: var(--text-soft);
  }

  .breadcrumb a:hover {
    color: var(--text-strong);
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 22rem);
    gap: 1rem;
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.9rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.12rem 0.72rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4.1rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  :global(html[data-presentation-mode="on"]) h1 {
    font-size: clamp(2.8rem, 5.4vw, 5rem);
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  :global(html[data-presentation-mode="on"]) .lead {
    font-size: 1.18rem;
    line-height: 1.85;
    max-width: 60rem;
  }

  .hero-meta {
    display: grid;
    gap: 0.8rem;
  }

  .meta-card,
  .aside-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .meta-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.15rem;
  }

  .meta-card span {
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta-card strong {
    color: var(--text-strong);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 20rem);
    gap: 1rem;
    margin-top: 1.6rem;
  }

  .article-content,
  .aside-card {
    padding: 1.4rem;
  }

  .article-content {
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  :global(html[data-presentation-mode="on"]) .article-content {
    padding: 1.9rem 2rem;
  }

  .article-aside {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .learn-mode-only {
    display: none;
  }

  :global(html[data-learn-mode="on"]) .learn-mode-only {
    display: block;
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"][data-learn-mode="on"]) .learn-mode-only {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  :global(html[data-presentation-mode="on"]) .article-shell {
    grid-template-columns: 1fr;
  }

  .aside-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
  }

  .aside-card p {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .aside-card a {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }

  .tag-list li {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .related-list {
    list-style: none;
    display: grid;
    gap: 0.75rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }

  .related-list li {
    display: grid;
    gap: 0.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .related-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .related-list a {
    margin-top: 0;
    line-height: 1.4;
  }

  .related-list small {
    color: var(--text-soft);
  }

  .article-content :global(h2) {
    margin-top: 1.75rem;
    color: var(--text-strong);
    font-size: 1.55rem;
    line-height: 1.15;
  }

  :global(html[data-presentation-mode="on"]) .article-content :global(h2) {
    font-size: 2rem;
    margin-top: 2rem;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  :global(html[data-presentation-mode="on"]) .article-content :global(p),
  :global(html[data-presentation-mode="on"]) .article-content :global(li) {
    font-size: 1.12rem;
    line-height: 1.9;
  }

  .article-content :global(ul) {
    padding-left: 1.2rem;
  }

  @media (max-width: 980px) {
    .article-hero,
    .article-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
