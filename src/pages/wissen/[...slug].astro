---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";
import {
  getSectionDisplayLabel,
  getTopicDisplayLabel,
  getTopicOverviewPath,
  getTopicTail,
  humanizeTopicSegment,
  rankTopicMatches,
} from "../../data/topics";
import { withBase } from "../../utils/base";
import PageTrail from "../../components/content/PageTrail.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";
import PracticeIdeas from "../../components/content/PracticeIdeas.astro";
import CommonMistakes from "../../components/content/CommonMistakes.astro";
import KeyTakeaways from "../../components/content/KeyTakeaways.astro";
import RecognizeSignals from "../../components/content/RecognizeSignals.astro";
import SelfCheckChecklist from "../../components/content/SelfCheckChecklist.astro";
import LinuxLearningShell from "../../components/interactive/LinuxLearningShell.astro";
import { getLinuxShellScenario } from "../../data/interactive/linuxShellScenarios";

export async function getStaticPaths() {
  const articles = await getVisibleArticles();
  return articles.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";
const topicTail = getTopicTail(entry);
const topicBranch = getTopicOverviewPath(entry);
const practiceIdeas = Array.isArray(entry.data.practiceIdeas) ? entry.data.practiceIdeas.filter(Boolean) : [];
const commonMistakes = Array.isArray(entry.data.commonMistakes) ? entry.data.commonMistakes.filter(Boolean) : [];
const keyTakeaways = Array.isArray(entry.data.keyTakeaways) ? entry.data.keyTakeaways.filter(Boolean) : [];
const recognizeSignals = Array.isArray(entry.data.recognizeSignals) ? entry.data.recognizeSignals.filter(Boolean) : [];
const selfCheckPoints = Array.isArray(entry.data.selfCheckPoints) ? entry.data.selfCheckPoints.filter(Boolean) : [];

const allExercises = await getVisibleExercises();
const entryTopicLabel = getTopicDisplayLabel(entry);
const entrySectionLabel = getSectionDisplayLabel(entry.data.section);

const rankedExercises = rankTopicMatches(
  entry,
  allExercises.filter((item) => resolvePrimarySubjectSlug(item.data.subject) === subjectSlug),
  { minimumScore: 6 },
);

const relatedExercises = rankedExercises.map(({ entry }) => entry).slice(0, 6);

const breadcrumbSegments = topicBranch.map((segment, index) => ({
  label: humanizeTopicSegment(segment),
  href: withBase(`fachbereiche/${subjectSlug}/${topicBranch.slice(0, index + 1).join("/")}`),
}));

const trail = [{ label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) }, ...breadcrumbSegments];

const backHref = breadcrumbSegments.length > 0 ? breadcrumbSegments[breadcrumbSegments.length - 1].href : withBase(`fachbereiche/${subjectSlug}`);
const topicPathHref = topicBranch.length > 0 ? withBase(`fachbereiche/${subjectSlug}/${topicBranch.join("/")}`) : withBase(`fachbereiche/${subjectSlug}`);
const shellScenario = subjectSlug === "linux" ? getLinuxShellScenario(topicTail.join("/")) : null;

const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <div class="page-shell">
    <PageTrail backHref={backHref} trail={trail} />

    <section class="article-hero">
      <p class="eyebrow">Wissensseite</p>
      <div class="hero-meta-row">
        <span class="meta-chip">{subjectTitle}</span>
        <span class="meta-chip">{levelLabels[entry.data.level]}</span>
        <span class="meta-chip">{entrySectionLabel}</span>
        <span class="meta-chip">{entryTopicLabel}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
      <a class="topic-link" href={topicPathHref}>Zum Fachthema →</a>
    </section>

    <section class="article-shell">
      <article class="article-content">
        <Content />
      </article>
    </section>

    {shellScenario && (
      <section class="interactive-section wide-bleed">
        <SectionHeading kicker="Ausprobieren" title="Direkt in der Linux-Lernshell üben" />
        <LinuxLearningShell scenario={shellScenario} />
      </section>
    )}

    <PracticeIdeas items={practiceIdeas} />

    {(recognizeSignals.length > 0 || selfCheckPoints.length > 0) && (
      <section class="signals-grid wide-bleed">
        <RecognizeSignals items={recognizeSignals} />
        <SelfCheckChecklist items={selfCheckPoints} />
      </section>
    )}

    {(commonMistakes.length > 0 || keyTakeaways.length > 0) && (
      <section class="summary-grid wide-bleed">
        <CommonMistakes items={commonMistakes} />
        <KeyTakeaways items={keyTakeaways} />
      </section>
    )}

    {relatedExercises.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Aufgaben" title="Passende Aufgaben" />
        <div class="related-grid">
          {relatedExercises.map((item) => (
            <ResourceCard
              title={item.data.title}
              description={item.data.description}
              meta={levelLabels[item.data.level]}
              href={withBase(`aufgaben/${item.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell { display: grid; gap: 1.2rem; }
  .eyebrow { margin: 0 0 0.8rem; color: var(--text-soft); font-size: 0.92rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-meta-row { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-bottom: 0.95rem; }
  .meta-chip { display: inline-flex; align-items: center; min-height: 2rem; padding: 0.12rem 0.72rem; border-radius: 999px; border: 1px solid var(--border); background: var(--surface); color: var(--text-strong); font-size: 0.84rem; font-weight: 700; }
  h1 { margin: 0; color: var(--text-strong); font-size: clamp(2.45rem, 4.8vw, 4.2rem); line-height: 0.98; letter-spacing: -0.045em; }
  .lead { margin: 1rem 0 0; color: var(--text); line-height: 1.8; font-size: 1.07rem; max-width: 62rem; }
  .topic-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.55rem;
    padding: 0 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
    width: fit-content;
    margin-top: 0.8rem;
  }
  .article-shell, .related-section, .interactive-section { display: grid; gap: 1rem; }
  .article-content { padding: clamp(1.35rem, 2vw, 2rem); border: 1px solid var(--border); border-radius: 30px; background: var(--card-bg); box-shadow: var(--shadow-card); overflow: hidden; }
  .summary-grid, .signals-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .related-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .article-content :global(h2) { margin-top: 1.8rem; color: var(--text-strong); font-size: clamp(1.45rem, 2.4vw, 1.85rem); line-height: 1.15; }
  .article-content :global(h2:first-child) { margin-top: 0; }
  .article-content :global(h3) { margin-top: 1.2rem; color: var(--text-strong); font-size: 1.12rem; line-height: 1.2; }
  .article-content :global(p), .article-content :global(li) { color: var(--text); line-height: 1.84; font-size: 1rem; }
  .article-content :global(ul), .article-content :global(ol) { padding-left: 1.2rem; }
  .article-content :global(pre) { overflow-x: auto; }
  @media (max-width: 980px) { .summary-grid, .signals-grid, .related-grid { grid-template-columns: 1fr; } }
</style>
