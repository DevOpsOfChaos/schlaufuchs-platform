---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleArticles, getVisibleExercises, getVisibleSubjects, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug } from "../../data/subjects";
import { getTopicSnapshot, getTopicDisplayLabel } from "../../data/topics";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";

const [subjects, articles, exercises] = await Promise.all([
  getVisibleSubjects(),
  getVisibleArticles(),
  getVisibleExercises(),
]);

const grouped = subjects
  .map((subject) => {
    const entries = articles
      .filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subject.data.slug)
      .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));
    const exerciseEntries = exercises
      .filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subject.data.slug)
      .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));
    const topicHotspots = getTopicSnapshot(entries).slice(0, 3).map((item) => ({
      ...item,
      href: withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`),
    }));
    return {
      subject,
      entries,
      exerciseEntries,
      topicHotspots,
      subjectHref: withBase(`fachbereiche/${subject.data.slug}`),
      firstEntry: entries[0] ?? null,
      firstExercise: exerciseEntries[0] ?? null,
      firstTopicHref: topicHotspots[0]?.href ?? withBase(`fachbereiche/${subject.data.slug}`),
    };
  })
  .filter((group) => group.entries.length > 0);

const featuredEntries = grouped
  .flatMap(({ subject, entries }) => entries.slice(0, 3).map((entry) => ({ subject, entry })))
  .slice(0, 8);

const totalTopicPaths = grouped.reduce((sum, group) => sum + group.topicHotspots.length, 0);
const subjectLinks = grouped.map((group) => ({
  title: group.subject.data.title,
  href: group.subjectHref,
  count: group.entries.length,
}));

const sectionLinks = [
  { label: "Fächer", href: "#faecher" },
  { label: "Startpunkte", href: "#startpunkte" },
  { label: "Direkt lesen", href: "#schnelleinstieg" },
];

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout
  title="Wissen – Schlaufuchs"
  description="Direkter Zugang zu Wissensseiten aus Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <div class="page-shell">
    <section class="hero">
      <div>
        <p class="eyebrow">Wissen</p>
        <h1>Alle Wissensseiten im Überblick</h1>
        <p class="lead">Hier kommst du direkt zu echten Fachinfos. Du kannst über Fachbereiche einsteigen, einen Themenpfad öffnen oder sofort eine konkrete Wissensseite lesen.</p>
      </div>

      <div class="hero-stats">
        <article>
          <strong>{articles.length}</strong>
          <span>Wissensseiten</span>
        </article>
        <article>
          <strong>{grouped.length}</strong>
          <span>aktive Fachbereiche</span>
        </article>
        <article>
          <strong>{totalTopicPaths}</strong>
          <span>sichtbare Schwerpunktpfade</span>
        </article>
      </div>
    </section>

    <section class="compact-block" aria-label="Schnellsprünge">
      <div class="section-jump-row">
        {sectionLinks.map((item) => <a class="jump-chip" href={item.href}>{item.label}</a>)}
        <a class="jump-chip muted" href={withBase("aufgaben")}>Zu den Aufgaben →</a>
      </div>
    </section>

    {subjectLinks.length > 0 && (
      <section class="section-block compact-block" id="faecher">
        <SectionHeading kicker="Fächer" title="Spring direkt in einen Fachbereich" />
        <div class="subject-strip">
          {subjectLinks.map((item) => (
            <a class="subject-strip-chip" href={item.href}>{item.title} · {item.count}</a>
          ))}
        </div>
      </section>
    )}

    {grouped.length > 0 && (
      <section class="section-block" id="startpunkte">
        <SectionHeading kicker="Startpunkte" title="So kannst du in einen Fachbereich einsteigen" />
        <div class="subject-grid">
          {grouped.map((group) => (
            <article class="subject-card">
              <div class="subject-card-top">
                <h2>{group.subject.data.title}</h2>
                <span class="count-pill">{group.entries.length}</span>
              </div>
              <p class="subject-copy">{group.subject.data.description}</p>
              <p class="subject-meta">{group.topicHotspots.length} Schwerpunktpfade · erste Wissensseite: {group.firstEntry?.data.title ?? "–"}</p>
              <div class="subject-actions">
                <a href={group.subjectHref}>Zum Fachbereich →</a>
                <a class="secondary-link" href={group.firstTopicHref}>Zum stärksten Themenpfad →</a>
                {group.firstEntry && <a class="secondary-link" href={withBase(`wissen/${group.firstEntry.id}`)}>Direkt zur Wissensseite →</a>}
                {group.firstExercise && <a class="secondary-link" href={withBase(`aufgaben/${group.firstExercise.id}`)}>Passende Aufgabe öffnen →</a>}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {featuredEntries.length > 0 && (
      <section class="section-block" id="schnelleinstieg">
        <SectionHeading kicker="Schnelleinstieg" title="Direkt zu echten Inhaltsseiten" />
        <div class="card-grid">
          {featuredEntries.map(({ subject, entry }) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${subject.data.title} · ${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
              href={withBase(`wissen/${entry.id}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    )}

    {grouped.map(({ subject, entries, topicHotspots, firstEntry, firstExercise }) => (
      <section class="section-block">
        <SectionHeading kicker={subject.data.title} title={`Wissensseiten in ${subject.data.title}`} actionHref={withBase(`fachbereiche/${subject.data.slug}`)} actionLabel="Zum Fachbereich →" />
        <p class="group-intro">{subject.data.description}</p>
        <div class="group-actions">
          {topicHotspots.slice(0, 3).map((item) => (
            <a class="hotspot-chip" href={item.href}>{item.title} · {item.count}</a>
          ))}
          {firstEntry && <a class="jump-chip" href={withBase(`wissen/${firstEntry.id}`)}>Direkt lesen →</a>}
          {firstExercise && <a class="jump-chip muted" href={withBase(`aufgaben/${firstExercise.id}`)}>Passende Aufgabe →</a>}
        </div>
        <div class="card-grid">
          {entries.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${levelLabels[entry.data.level]} · ${getTopicDisplayLabel(entry)}`}
              href={withBase(`wissen/${entry.id}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .page-shell,
  .hero,
  .section-block {
    display: grid;
    gap: 1rem;
  }

  .hero {
    gap: 1.2rem;
  }

  .section-block {
    margin-top: 1.1rem;
  }

  .compact-block {
    margin-top: 0.2rem;
  }

  .eyebrow {
    margin: 0 0 .75rem;
    color: var(--text-soft);
    font-size: .92rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: .98;
    letter-spacing: -.045em;
  }

  .lead,
  .group-intro,
  .subject-copy {
    margin: 0;
    max-width: 56rem;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .hero-stats,
  .subject-grid,
  .group-actions,
  .subject-strip,
  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-stats {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .hero-stats article,
  .subject-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .hero-stats strong {
    color: var(--text-strong);
    font-size: 1.45rem;
    line-height: 1;
  }

  .hero-stats span,
  .subject-meta {
    color: var(--text-soft);
    line-height: 1.45;
  }

  .section-jump-row,
  .subject-strip,
  .group-actions,
  .subject-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .subject-grid,
  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .subject-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .subject-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.18rem;
    line-height: 1.18;
  }

  .count-pill,
  .jump-chip,
  .subject-strip-chip,
  .hotspot-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  .count-pill {
    min-width: 2.35rem;
  }

  .jump-chip.muted {
    background: color-mix(in oklab, var(--surface) 88%, var(--surface-2) 12%);
  }

  .subject-actions a,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.3rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  @media (max-width: 980px) {
    .hero-stats,
    .subject-grid,
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
