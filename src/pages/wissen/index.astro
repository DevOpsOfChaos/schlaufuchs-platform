---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleArticles, getVisibleSubjects, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug } from "../../data/subjects";
import { getTopicSnapshot, getTopicTail, humanizeTopicSegment } from "../../data/topics";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";

const [subjects, articles] = await Promise.all([getVisibleSubjects(), getVisibleArticles()]);

const grouped = subjects
  .map((subject) => {
    const entries = articles
      .filter((entry) => resolvePrimarySubjectSlug(entry.data.subject) === subject.data.slug)
      .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));
    return {
      subject,
      entries,
      topicHotspots: getTopicSnapshot(entries).slice(0, 3).map((item) => ({
        ...item,
        href: withBase(`fachbereiche/${subject.data.slug}/${item.path.join("/")}`),
      })),
    };
  })
  .filter((group) => group.entries.length > 0);

const featuredEntries = grouped.flatMap(({ subject, entries }) =>
  entries.slice(0, 3).map((entry) => ({ subject, entry })),
).slice(0, 8);

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout
  title="Wissen – Schlaufuchs"
  description="Direkter Zugang zu Wissensseiten aus Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <div class="page-shell">
    <section class="hero">
      <p class="eyebrow">Wissen</p>
      <h1>Alle Wissensseiten im Überblick</h1>
      <p class="lead">Hier kommst du direkt zu echten Fachinfos. Du kannst über Fachbereiche einsteigen oder dir sofort passende Wissensseiten ansehen.</p>
    </section>

    {featuredEntries.length > 0 && (
      <section class="section-block">
        <SectionHeading kicker="Schnelleinstieg" title="Direkt zu echten Inhaltsseiten" />
        <div class="card-grid">
          {featuredEntries.map(({ subject, entry }) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${subject.data.title} · ${levelLabels[entry.data.level]}`}
              href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    )}

    {grouped.map(({ subject, entries, topicHotspots }) => (
      <section class="section-block">
        <SectionHeading kicker={subject.data.title} title={`Wissensseiten in ${subject.data.title}`} actionHref={withBase(`fachbereiche/${subject.data.slug}`)} actionLabel="Zum Fachbereich →" />
        {topicHotspots.length > 0 && (
          <div class="hotspot-row">
            {topicHotspots.map((item) => <a class="hotspot-chip" href={item.href}>{item.title} · {item.count}</a>)}
          </div>
        )}
        <div class="card-grid">
          {entries.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={humanizeTopicSegment(getTopicTail(entry).at(-1) ?? entry.data.section)}
              href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .page-shell,.hero,.section-block { display:grid; gap:1rem; }
  .section-block { margin-top:1.1rem; }
  .eyebrow { margin:0 0 .75rem; color:var(--text-soft); font-size:.92rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; }
  h1 { margin:0; color:var(--text-strong); font-size:clamp(2.4rem,4.6vw,4rem); line-height:.98; letter-spacing:-.045em; }
  .lead { margin:1rem 0 0; max-width:56rem; color:var(--text); line-height:1.75; font-size:1.05rem; }
  .hotspot-row,
  .card-grid { display:grid; gap:1rem; }
  .hotspot-row { display:flex; flex-wrap:wrap; gap:.7rem; }
  .hotspot-chip {
    display:inline-flex; align-items:center; min-height:2.45rem; padding:0 .85rem; border-radius:999px;
    border:1px solid var(--border); background:var(--surface); color:var(--text-strong); font-weight:700; box-shadow:var(--shadow-soft);
  }
  .card-grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
  @media (max-width:980px) { .card-grid { grid-template-columns:1fr; } }
</style>
