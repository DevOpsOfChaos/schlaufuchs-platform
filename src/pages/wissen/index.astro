---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleSubjects, levelLabels } from "../../data/content";
import { getTopicTail } from "../../data/topics";
import { withBase } from "../../utils/base";

const [subjects, articles] = await Promise.all([getVisibleSubjects(), getVisibleArticles()]);

const subjectGroups = subjects
  .map((subject) => {
    const entries = articles
      .filter((entry) => entry.data.subject === subject.data.slug)
      .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));

    return {
      subject,
      entries,
    };
  })
  .filter((group) => group.entries.length > 0);

const featuredEntries = subjectGroups.flatMap((group) =>
  group.entries.slice(0, 2).map((entry) => ({
    entry,
    subject: group.subject,
  })),
);
---

<BaseLayout
  title="Wissen – Schlaufuchs"
  description="Direkter Zugang zu Fachinfos und Wissensseiten aus Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <section class="hero">
    <div>
      <p class="eyebrow">Wissen</p>
      <h1>Alle Fachinfos im Überblick</h1>
      <p class="lead">
        Hier findest du direkt die verfügbaren Wissensseiten und Inhaltsseiten. Du kannst entweder über die Fachbereiche oder direkt über die
        Fachinfos einsteigen.
      </p>
    </div>
  </section>

  {featuredEntries.length > 0 && (
    <section class="section-block">
      <div class="section-head">
        <div>
          <p class="section-kicker">Schnelleinstieg</p>
          <h2>Direkt zu echten Inhaltsseiten</h2>
        </div>
      </div>

      <div class="card-grid featured-grid">
        {featuredEntries.slice(0, 6).map(({ entry, subject }) => (
          <a class="info-card link-card" href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}>
            <div class="card-top">
              <h3>{entry.data.title}</h3>
              <span>{levelLabels[entry.data.level]}</span>
            </div>
            <p>{entry.data.description}</p>
            <small>{subject.data.title}</small>
          </a>
        ))}
      </div>
    </section>
  )}

  {subjectGroups.map(({ subject, entries }) => (
    <section class="section-block">
      <div class="section-head">
        <div>
          <p class="section-kicker">{subject.data.title}</p>
          <h2>Wissensseiten in {subject.data.title}</h2>
        </div>
        <a class="section-link" href={withBase(`fachbereiche/${subject.data.slug}`)}>Zum Fachbereich →</a>
      </div>

      <div class="card-grid">
        {entries.map((entry) => (
          <a class="info-card link-card" href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}>
            <div class="card-top">
              <h3>{entry.data.title}</h3>
              <span>{levelLabels[entry.data.level]}</span>
            </div>
            <p>{entry.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .hero,
  .section-block {
    display: grid;
    gap: 1rem;
  }

  .section-block {
    margin-top: 1.8rem;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    max-width: 50rem;
    color: var(--text);
    line-height: 1.72;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.8vw, 2.25rem);
    line-height: 1.05;
  }

  .section-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .featured-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .info-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.3rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .link-card {
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .link-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .info-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .card-top span,
  .info-card small {
    color: var(--text-soft);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .info-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.62;
  }

  @media (max-width: 980px) {
    .card-grid,
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
