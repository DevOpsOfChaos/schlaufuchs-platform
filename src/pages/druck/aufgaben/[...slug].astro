---
import "../../../styles/globals/base.css";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleExercises, levelLabels } from "../../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../../data/subjects";
import { siteConfig } from "../../../data/settings/site";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const exercises = await getVisibleExercises();

  return exercises.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"exercises"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";
const section = entry.data.section ?? "";
const exerciseUrl = `${base}aufgaben/${entry.id}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{`${entry.data.title} – Druckansicht – ${siteConfig.siteName}`}</title>
    <meta name="description" content={`${entry.data.description} – Druckansicht für PDF und Ausdruck.`} />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="print-page">
    <div class="print-toolbar screen-only">
      <a href={exerciseUrl}>Zur Aufgabenseite</a>
      <button type="button" onclick="window.print()">Als PDF speichern / drucken</button>
    </div>

    <main class="print-sheet">
      <header class="print-header">
        <p class="eyebrow">Schlaufuchs · Aufgabe</p>
        <h1>{entry.data.title}</h1>
        <p class="lead">{entry.data.description}</p>

        <div class="meta-row">
          <span>{subjectTitle}</span>
          <span>{levelLabels[entry.data.level]}</span>
          {section && <span>{section}</span>}
        </div>
      </header>

      <section class="print-body">
        <Content />
      </section>

      <footer class="print-footer">
        <p>Quelle: Schlaufuchs · {subjectTitle}</p>
        <p>{exerciseUrl}</p>
      </footer>
    </main>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    background: #eef2f7;
  }

  .print-page {
    color: #0f1726;
  }

  .print-toolbar {
    width: min(100% - 1.5rem, 64rem);
    margin: 1rem auto 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .print-toolbar a,
  .print-toolbar button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 38, 0.14);
    background: white;
    color: #0f1726;
    font: inherit;
    font-weight: 700;
    box-shadow: 0 10px 26px rgba(15, 23, 38, 0.08);
    cursor: pointer;
  }

  .print-sheet {
    width: min(100% - 1.5rem, 56rem);
    margin: 1rem auto 2rem;
    padding: 2.4rem 2.4rem 2rem;
    background: white;
    box-shadow: 0 22px 44px rgba(15, 23, 38, 0.10);
  }

  .print-header {
    padding-bottom: 1.4rem;
    border-bottom: 1px solid rgba(15, 23, 38, 0.12);
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: #526174;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: 2.3rem;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #0f1726;
  }

  .lead {
    margin: 0.9rem 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #304256;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .meta-row span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.12rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 38, 0.12);
    font-size: 0.84rem;
    font-weight: 700;
    color: #0f1726;
    background: #f8fafc;
  }

  .print-body {
    padding-top: 1.5rem;
  }

  .print-body :global(h2) {
    margin-top: 1.7rem;
    color: #0f1726;
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .print-body :global(h2:first-child) {
    margin-top: 0;
  }

  .print-body :global(p),
  .print-body :global(li) {
    color: #1f2f41;
    line-height: 1.72;
    font-size: 0.98rem;
  }

  .print-body :global(ul) {
    padding-left: 1.2rem;
  }

  .print-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.2rem;
    margin-top: 1.8rem;
    border-top: 1px solid rgba(15, 23, 38, 0.12);
    color: #526174;
    font-size: 0.9rem;
  }

  .print-footer p {
    margin: 0;
  }

  @media print {
    @page {
      size: A4;
      margin: 14mm;
    }

    :global(html),
    :global(body) {
      background: white;
    }

    .screen-only {
      display: none !important;
    }

    .print-sheet {
      width: 100%;
      margin: 0;
      padding: 0;
      box-shadow: none;
    }

    .print-body :global(a) {
      color: inherit;
      text-decoration: none;
    }
  }
</style>
