---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const exercises = await getCollection("exercises", ({ data }) => !data.draft);

  return exercises.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"exercises"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <section class="exercise-hero">
    <div class="hero-copy">
      <p class="eyebrow">Aufgabe · {subjectTitle}</p>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </div>

    <div class="hero-meta" data-present="hide">
      <article class="meta-card">
        <span>Fachbereich</span>
        <strong>{subjectTitle}</strong>
      </article>
      <article class="meta-card">
        <span>Niveau</span>
        <strong>{entry.data.level}</strong>
      </article>
    </div>
  </section>

  <section class="exercise-shell">
    <article class="exercise-content">
      <Content />
    </article>

    <aside class="exercise-aside" data-present="hide">
      <div class="aside-card">
        <h2>Im Fachkontext</h2>
        <p>Diese Aufgabe gehört zum Fachbereich {subjectTitle} und ergänzt die dort sichtbaren Wissensseiten und Themenbereiche.</p>
        <a href={`${base}fachbereiche/${subjectSlug}`}>Zum Fachbereich →</a>
      </div>

      <div class="aside-card learn-mode-only">
        <h2>Im Lernmodus nutzen</h2>
        <p>Im Lernmodus eignet sich diese Aufgabe besonders nach einem inhaltlichen Überblick: erst Begriffe und Beispiele prüfen, dann die Aufgabe gezielt zum Anwenden nutzen.</p>
        <a href={`${base}suchen`}>Zu Wissensseiten und Themen suchen →</a>
      </div>

      <div class="aside-card">
        <h2>Weitere Wege</h2>
        <ul class="link-list">
          <li><a href={`${base}aufgaben`}>Alle Aufgaben ansehen</a></li>
          <li><a href={`${base}suchen`}>Nach ähnlichen Themen suchen</a></li>
        </ul>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .exercise-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(15rem, 20rem);
    gap: 1rem;
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  :global(html[data-presentation-mode="on"]) h1 {
    font-size: clamp(2.8rem, 5.4vw, 4.8rem);
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  :global(html[data-presentation-mode="on"]) .lead {
    font-size: 1.18rem;
    line-height: 1.85;
    max-width: 60rem;
  }

  .hero-meta {
    display: grid;
    gap: 0.8rem;
  }

  .meta-card,
  .exercise-content,
  .aside-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .meta-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.15rem;
    border-radius: 22px;
  }

  .meta-card span {
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta-card strong {
    color: var(--text-strong);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .exercise-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 20rem);
    gap: 1rem;
    margin-top: 1.6rem;
  }

  :global(html[data-presentation-mode="on"]) .exercise-shell {
    grid-template-columns: 1fr;
  }

  .exercise-content {
    padding: 1.4rem;
    border-radius: 28px;
    box-shadow: var(--shadow-card);
  }

  :global(html[data-presentation-mode="on"]) .exercise-content {
    padding: 1.9rem 2rem;
  }

  .exercise-aside {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .aside-card {
    padding: 1.35rem;
    border-radius: 22px;
  }

  .learn-mode-only {
    display: none;
  }

  :global(html[data-learn-mode="on"]) .learn-mode-only {
    display: block;
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"][data-learn-mode="on"]) .learn-mode-only {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  .aside-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
  }

  .aside-card p {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .aside-card a {
    color: var(--text-strong);
    font-weight: 700;
  }

  .link-list {
    list-style: none;
    margin: 0.9rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .exercise-content :global(h2) {
    margin-top: 1.75rem;
    color: var(--text-strong);
    font-size: 1.5rem;
    line-height: 1.15;
  }

  :global(html[data-presentation-mode="on"]) .exercise-content :global(h2) {
    font-size: 2rem;
    margin-top: 2rem;
  }

  .exercise-content :global(h2:first-child) {
    margin-top: 0;
  }

  .exercise-content :global(p),
  .exercise-content :global(li) {
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  :global(html[data-presentation-mode="on"]) .exercise-content :global(p),
  :global(html[data-presentation-mode="on"]) .exercise-content :global(li) {
    font-size: 1.12rem;
    line-height: 1.9;
  }

  .exercise-content :global(ul) {
    padding-left: 1.2rem;
  }

  @media (max-width: 980px) {
    .exercise-hero,
    .exercise-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
