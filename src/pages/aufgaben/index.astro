---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getExerciseGroups, getVisibleExercises, levelLabels } from "../../data/content";
import { getTopicDisplayLabel, getTopicOverviewPath, getTopicSnapshot, humanizeTopicSegment } from "../../data/topics";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";

const [groups, allExercises] = await Promise.all([getExerciseGroups(), getVisibleExercises()]);

const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;

const featuredExercises = allExercises.slice(0, 8).map((entry) => {
  const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? entry.data.subject;
  const branch = getTopicOverviewPath(entry);
  return {
    entry,
    subjectSlug,
    subjectTitle: subjectTitleMap[subjectSlug] ?? subjectTitleMap[entry.data.subject] ?? "Fachbereich",
    topicLabel: getTopicDisplayLabel(entry),
    topicHref: branch.length > 0 ? withBase(`fachbereiche/${subjectSlug}/${branch.join("/")}`) : withBase(`fachbereiche/${subjectSlug}`),
  };
});
---

<BaseLayout
  title="Aufgaben – Schlaufuchs"
  description="Alle Aufgaben im Überblick, geordnet nach Fachbereichen und Themenpfaden."
>
  <div class="page-shell">
    <section class="hero">
      <p class="eyebrow">Aufgaben</p>
      <h1>Alle Aufgaben ruhig und thematisch sortiert</h1>
      <p class="lead">
        Hier findest du alle Aufgaben nach Fachbereichen gesammelt. Innerhalb der Karten siehst du sofort Niveau und Themenbezug,
        damit du schneller passende Übungen findest.
      </p>
    </section>

    {featuredExercises.length > 0 && (
      <section class="section-block">
        <SectionHeading kicker="Schnelleinstieg" title="Direkt zu passenden Übungen" />
        <div class="card-grid">
          {featuredExercises.map(({ entry, subjectTitle, topicLabel }) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={`${subjectTitle} · ${levelLabels[entry.data.level]} · ${topicLabel}`}
              href={withBase(`aufgaben/${entry.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      </section>
    )}

    {groups.map((group) => {
      const hotspots = getTopicSnapshot(group.entries).slice(0, 3).map((item) => ({
        ...item,
        href: withBase(`fachbereiche/${group.slug}/${item.path.join("/")}`),
      }));
      return (
        <section class="section-block">
          <SectionHeading
            kicker={group.title}
            title={`Aufgaben in ${group.title}`}
            actionHref={withBase(`fachbereiche/${group.slug}`)}
            actionLabel="Zum Fachbereich →"
          />

          <p class="group-intro">{group.description}</p>
          {hotspots.length > 0 && (
            <div class="hotspot-row">
              {hotspots.map((item) => <a class="hotspot-chip" href={item.href}>{item.title} · {item.count}</a>)}
            </div>
          )}

          <div class="card-grid">
            {group.entries.map((entry) => {
              const branch = getTopicOverviewPath(entry);
              const topicHref = branch.length > 0 ? withBase(`fachbereiche/${group.slug}/${branch.join("/")}`) : withBase(`fachbereiche/${group.slug}`);
              const topicLabel = branch.length > 0 ? humanizeTopicSegment(branch.at(-1) ?? "") : getTopicDisplayLabel(entry);
              return (
                <article class="exercise-stack">
                  <ResourceCard
                    title={entry.data.title}
                    description={entry.data.description}
                    meta={`${levelLabels[entry.data.level]} · ${topicLabel}`}
                    href={withBase(`aufgaben/${entry.id}`)}
                    ctaLabel="Aufgabe öffnen →"
                    icon={taskIcon}
                    variant="task"
                  />
                  <a class="topic-link" href={topicHref}>Zum Themenpfad →</a>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page-shell,
  .hero,
  .section-block {
    display: grid;
    gap: 1rem;
  }

  .section-block {
    margin-top: 1.1rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead,
  .group-intro {
    margin: 0;
    max-width: 60rem;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.03rem;
  }

  .hotspot-row,
  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .hotspot-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .hotspot-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2.45rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .exercise-stack {
    display: grid;
    gap: 0.55rem;
  }

  .topic-link {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 2.7rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
    width: fit-content;
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
