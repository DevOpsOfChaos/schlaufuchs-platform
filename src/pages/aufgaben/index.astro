---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const allExercises = (await getCollection("exercises"))
  .filter((entry) => !entry.data.draft && entry.data.subject !== "daten-und-signale")
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));

const subjectMeta: Record<string, { title: string; description: string }> = {
  mathematik: {
    title: "Mathematik",
    description: "Funktionen, Analysis und klassische Rechenaufgaben.",
  },
  linux: {
    title: "Linux",
    description: "Shell, Rechte, SSH und erste Praxisaufgaben.",
  },
  "web-development": {
    title: "Web Development",
    description: "HTML, CSS, Layouts und kleine Code-Challenges.",
  },
  informatik: {
    title: "Informatik",
    description: "Programmstruktur, C-Grundlagen und Code-Leseaufgaben.",
  },
  elektrotechnik: {
    title: "Elektrotechnik",
    description: "Netzwerkanalyse, Dioden, Wechselstrom und Mikrocontroller.",
  },
};

const subjectOrder = ["mathematik", "linux", "web-development", "informatik", "elektrotechnik"];

const grouped = subjectOrder
  .map((slug) => {
    const entries = allExercises.filter((entry) => entry.data.subject === slug);
    return {
      slug,
      ...subjectMeta[slug],
      entries,
    };
  })
  .filter((group) => group.entries.length > 0);

const levelLabels = {
  einfach: "Einfach",
  mittel: "Mittel",
  fortgeschritten: "Fortgeschritten",
} as const;

const totalExercises = allExercises.length;
---

<BaseLayout
  title="Aufgaben und Übungen – Schlaufuchs"
  description="Globale Übersicht über Aufgaben, Übungen und Praxisformate auf Schlaufuchs."
>
  <section class="hub-hero">
    <div class="hero-copy">
      <p class="kicker">Üben und anwenden</p>
      <h1>Aufgaben und Übungen</h1>
      <p class="lead">
        Dieser Bereich bündelt die sichtbaren Übungen aus allen Hauptfächern. Der Aufgaben-Hub
        wächst schrittweise zu einer eigenen Ebene mit Rechenaufgaben, Diagnoseformaten,
        Code-Übungen und Praxisblöcken.
      </p>

      <div class="hero-actions" data-present="hide">
        <a class="hero-button primary" href={`${base}fachbereiche`}>Fachbereich wählen</a>
        <a class="hero-button secondary" href={`${base}suchen`}>In Aufgaben suchen</a>
      </div>
    </div>

    <div class="hero-stat" data-present="hide">
      <span>Live-Übungen</span>
      <strong>{totalExercises}</strong>
      <p>Alle Einträge verweisen direkt auf sichtbare Aufgabenseiten und bleiben über Fachbereiche mit dem Produkt verbunden.</p>
    </div>
  </section>

  <section class="hub-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Live im System</p>
        <h2>Aktuelle Aufgaben nach Fachbereich</h2>
        <p>Jeder Block zeigt die bereits sichtbaren Übungen des Fachs und führt weiter in den jeweiligen Fachbereich.</p>
      </div>
    </div>

    <div class="group-grid">
      {grouped.map((group) => (
        <article class="group-card">
          <div class="group-top">
            <div>
              <h3>{group.title}</h3>
              <p>{group.description}</p>
            </div>
            <span>{group.entries.length}</span>
          </div>

          <ul class="exercise-list">
            {group.entries.map((entry) => (
              <li>
                <div class="exercise-copy">
                  <a href={`${base}aufgaben/${entry.id}`}>{entry.data.title}</a>
                  <p>{entry.data.description}</p>
                </div>
                <small data-present="hide">{levelLabels[entry.data.level]}</small>
              </li>
            ))}
          </ul>

          <a class="group-link" href={`${base}fachbereiche/${group.slug}`}>Zum Fachbereich →</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hub-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(15rem, 20rem);
    gap: 1rem;
    align-items: start;
  }

  :global(html[data-presentation-mode="on"]) .hub-hero,
  :global(html[data-presentation-mode="on"]) .group-grid {
    grid-template-columns: 1fr;
  }

  .hero-copy,
  .hero-stat,
  .group-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    border-radius: 28px;
  }

  .hero-copy {
    padding: 2rem;
  }

  .hero-stat {
    display: grid;
    gap: 0.45rem;
    padding: 1.4rem;
  }

  .hero-stat span,
  .kicker,
  .section-kicker {
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-stat strong {
    color: var(--text-strong);
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .hero-stat p {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.8vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .lead {
    max-width: 48rem;
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.06rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.55rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    border-color: transparent;
    color: white;
  }

  .hero-button.secondary {
    color: var(--text-strong);
    background: var(--surface);
  }

  .hub-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.7vw, 2.3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-head p {
    margin: 0.75rem 0 0;
    max-width: 44rem;
    color: var(--text-soft);
    line-height: 1.62;
  }

  .group-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .group-card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
  }

  .group-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }

  .group-top h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.2rem;
  }

  .group-top p {
    margin: 0.55rem 0 0;
    color: var(--text);
    line-height: 1.6;
  }

  .group-top span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.1rem;
    min-height: 2.1rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    border: 1px solid var(--border);
  }

  .exercise-list {
    list-style: none;
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
  }

  .exercise-list li {
    display: flex;
    justify-content: space-between;
    gap: 0.9rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .exercise-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .exercise-copy a {
    color: var(--text-strong);
    font-weight: 650;
  }

  .exercise-list p {
    margin: 0.45rem 0 0;
    color: var(--text);
    line-height: 1.58;
  }

  .exercise-list small {
    color: var(--text-soft);
    font-weight: 700;
    flex-shrink: 0;
  }

  .group-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .hub-hero,
    .group-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
