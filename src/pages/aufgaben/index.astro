---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const pathways = [
  {
    title: "Zum Einstieg",
    description: "Kleine Aufgaben für ein schnelles Wiederholen und erstes Anwenden.",
    tags: ["einfach", "Grundlagen", "direkt starten"],
  },
  {
    title: "Zum Festigen",
    description: "Übungen mit etwas mehr Struktur, Rechentiefe oder Codeverständnis.",
    tags: ["mittel", "systematisch", "weiter üben"],
  },
  {
    title: "Zur Praxis",
    description: "Praxisnahe Aufgaben, Diagnoseformate und kleine Challenges.",
    tags: ["Praxis", "Challenge", "Transfer"],
  },
];

const subjects = [
  {
    title: "Mathematik",
    href: `${base}fachbereiche/mathematik`,
    description: "Funktionen, Analysis und klassische Rechenaufgaben.",
  },
  {
    title: "Linux",
    href: `${base}fachbereiche/linux`,
    description: "Shell, Rechte, SSH und erste Praxisaufgaben.",
  },
  {
    title: "Web Development",
    href: `${base}fachbereiche/web-development`,
    description: "HTML, CSS, Layouts und kleine Code-Challenges.",
  },
  {
    title: "Informatik",
    href: `${base}fachbereiche/informatik`,
    description: "Programmstruktur, C-Grundlagen und Code-Leseaufgaben.",
  },
  {
    title: "Elektrotechnik",
    href: `${base}fachbereiche/elektrotechnik`,
    description: "Netzwerkanalyse, Dioden, Wechselstrom und Mikrocontroller.",
  },
];
---

<BaseLayout
  title="Aufgaben und Übungen – Schlaufuchs"
  description="Globale Übersicht über Aufgaben, Übungen und Praxisformate auf Schlaufuchs."
>
  <section class="hub-hero">
    <p class="kicker">Üben und anwenden</p>
    <h1>Aufgaben und Übungen</h1>
    <p class="lead">
      Dieser Bereich bündelt Aufgaben aus allen Fachbereichen. Die ersten Übungswellen werden
      jetzt strukturiert aufgebaut – mit klaren Fachbezügen, Schwierigkeitsstufen und späterer
      Verknüpfung zu Wissensseiten.
    </p>

    <div class="hero-actions">
      <a class="hero-button primary" href={`${base}fachbereiche`}>Fachbereich wählen</a>
      <a class="hero-button secondary" href={`${base}suchen`}>In Aufgaben suchen</a>
    </div>
  </section>

  <section class="hub-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Formate</p>
        <h2>So soll Üben auf Schlaufuchs funktionieren</h2>
      </div>
    </div>

    <div class="pathway-grid">
      {pathways.map((item) => (
        <article class="pathway-card">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <ul>
            {item.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="hub-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Fachbereiche</p>
        <h2>Übungen nach Fach erkunden</h2>
        <p>Bis der globale Aufgaben-Hub dynamisch aus der Collection gespeist wird, führen die Fachseiten schon in die wichtigsten Übungsbereiche.</p>
      </div>
    </div>

    <div class="subject-grid">
      {subjects.map((subject) => (
        <a class="subject-card" href={subject.href}>
          <h3>{subject.title}</h3>
          <p>{subject.description}</p>
          <span>Zum Fachbereich →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hub-hero,
  .pathway-card,
  .subject-card {
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .hub-hero {
    padding: 2.4rem;
    border-radius: 30px;
  }

  .kicker,
  .section-kicker {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.8vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .lead {
    max-width: 48rem;
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.06rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.55rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    border-color: transparent;
    color: white;
  }

  .hero-button.secondary {
    color: var(--text-strong);
    background: var(--surface);
  }

  .hub-section {
    display: grid;
    gap: 1.1rem;
    margin-top: 1.65rem;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.7vw, 2.3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-head p {
    margin: 0.75rem 0 0;
    max-width: 44rem;
    color: var(--text-soft);
    line-height: 1.62;
  }

  .pathway-grid,
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pathway-card,
  .subject-card {
    border-radius: 24px;
    padding: 1.4rem;
  }

  .pathway-card h3,
  .subject-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.15rem;
  }

  .pathway-card p,
  .subject-card p {
    margin: 0.75rem 0 0;
    color: var(--text);
    line-height: 1.68;
  }

  .pathway-card ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 0;
    padding: 0;
  }

  .pathway-card li {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .subject-card span {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .pathway-grid,
    .subject-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .hub-hero {
      padding: 1.6rem;
    }

    .pathway-grid,
    .subject-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
