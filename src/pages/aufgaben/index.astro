---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../utils/base";

const redirectHref = withBase("fachbereiche");
---

<BaseLayout title="Aufgaben – Schlaufuchs" description="Aufgaben findest du direkt in den Fachbereichen.">
  <script is:inline define:vars={{ redirectHref }}>
    window.location.replace(redirectHref);
  </script>

  <section class="redirect-shell">
    <p class="kicker">Weiterleitung</p>
    <h1>Aufgaben findest du direkt in den Fachbereichen.</h1>
    <a class="redirect-link" href={redirectHref}>Zu den Fachbereichen</a>
  </section>
</BaseLayout>

<style>
  .redirect-shell {
    display: grid;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1.08;
  }

  .redirect-link {
    color: var(--text-strong);
    font-weight: 700;
  }
</style>
