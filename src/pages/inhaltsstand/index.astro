---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getContentInventory } from "../../data/content";

const inventory = await getContentInventory();
const totalItems = inventory.totals.articles + inventory.totals.exercises + inventory.totals.news;
const topPriorities = inventory.prioritySubjects.slice(0, 3);
---

<BaseLayout title="Inhaltsstand – Schlaufuchs" description="Aktueller Stand der sichtbaren Inhalte nach Fachbereich.">
  <section class="inventory-hero">
    <div class="hero-copy">
      <p class="eyebrow">Inhaltsstand</p>
      <h1>Der aktuelle sichtbare Content ist noch nicht vollständig.</h1>
      <p class="lead">
        Diese Übersicht zeigt den aktuell sichtbaren Stand der Plattform nach Fachbereich und
        Collection. So lässt sich der nächste Inhaltsblock gezielt statt nach Gefühl ausbauen.
      </p>
    </div>

    <div class="hero-stats">
      <article class="stat-card">
        <span>Fachbereiche</span>
        <strong>{inventory.totals.subjects}</strong>
      </article>
      <article class="stat-card">
        <span>Wissensseiten</span>
        <strong>{inventory.totals.articles}</strong>
      </article>
      <article class="stat-card">
        <span>Aufgaben</span>
        <strong>{inventory.totals.exercises}</strong>
      </article>
      <article class="stat-card">
        <span>News</span>
        <strong>{inventory.totals.news}</strong>
      </article>
      <article class="stat-card">
        <span>Abgedeckte Fächer</span>
        <strong>{inventory.totals.coveredSubjects}</strong>
      </article>
      <article class="stat-card total">
        <span>Sichtbare Inhalte</span>
        <strong>{totalItems}</strong>
      </article>
    </div>
  </section>

  <section class="inventory-section priority-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Nächste Wellen</p>
        <h2>Was jetzt am meisten fehlt</h2>
      </div>
    </div>

    <div class="priority-grid">
      {topPriorities.map((entry, index) => (
        <article class="priority-card">
          <span class="priority-rank">0{index + 1}</span>
          <h3>{entry.title}</h3>
          <p class="priority-status">{entry.status.label}</p>
          <p>{entry.status.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="inventory-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Nach Fachbereich</p>
        <h2>Wissensseiten und Aufgaben pro Hauptfach</h2>
      </div>
    </div>

    <div class="inventory-grid">
      {inventory.bySubject.map((entry) => (
        <article class={`inventory-card tone-${entry.status.key}`}>
          <div class="card-top">
            <h3>{entry.title}</h3>
            <span class="status-badge">{entry.status.label}</span>
          </div>
          <p class="status-copy">{entry.status.detail}</p>
          <dl>
            <div>
              <dt>Wissensseiten</dt>
              <dd>{entry.articleCount}</dd>
            </div>
            <div>
              <dt>Aufgaben</dt>
              <dd>{entry.exerciseCount}</dd>
            </div>
            <div>
              <dt>Gesamt</dt>
              <dd>{entry.totalCount}</dd>
            </div>
          </dl>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .inventory-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 24rem);
    gap: 1rem;
    align-items: start;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
    max-width: 14ch;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.75;
    font-size: 1.05rem;
    max-width: 48rem;
  }

  .hero-stats,
  .inventory-grid,
  .priority-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-card,
  .inventory-card,
  .priority-card {
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    padding: 1.35rem;
  }

  .stat-card span {
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .stat-card strong {
    display: block;
    margin-top: 0.35rem;
    color: var(--text-strong);
    font-size: 2.3rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .stat-card.total {
    grid-column: 1 / -1;
  }

  .inventory-section {
    margin-top: 1.8rem;
    display: grid;
    gap: 1rem;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .priority-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .priority-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.08), rgba(240,244,255,0.86));
  }

  :global(html[data-theme="dark"]) .priority-card {
    background: linear-gradient(135deg, rgba(79,70,229,0.16), rgba(18,27,46,0.94));
  }

  .priority-rank,
  .status-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .priority-card h3,
  .inventory-card h3 {
    margin: 0.85rem 0 0;
    color: var(--text-strong);
    font-size: 1.2rem;
  }

  .priority-status {
    margin: 0.55rem 0 0;
    color: var(--text-strong);
    font-weight: 700;
  }

  .priority-card p,
  .status-copy {
    margin: 0.65rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .inventory-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .inventory-card dl {
    margin: 1rem 0 0;
    display: grid;
    gap: 0.8rem;
  }

  .inventory-card dl div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .inventory-card dl div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .inventory-card dt {
    color: var(--text-soft);
  }

  .inventory-card dd {
    margin: 0;
    color: var(--text-strong);
    font-weight: 700;
  }

  .tone-balanced {
    border-color: color-mix(in oklab, var(--border) 72%, #16a34a 28%);
  }

  .tone-imbalanced,
  .tone-missing_exercises,
  .tone-missing_articles,
  .tone-empty {
    border-color: color-mix(in oklab, var(--border) 72%, #f59e0b 28%);
  }

  .tone-empty {
    border-color: color-mix(in oklab, var(--border) 68%, #ef4444 32%);
  }

  @media (max-width: 980px) {
    .inventory-hero,
    .inventory-grid,
    .priority-grid {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
