---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleSubjects } from "../data/content";
import { getSubjectMeta } from "../data/subjects";

const base = import.meta.env.BASE_URL;

const subjects = (await getVisibleSubjects())
  .map((subject) => ({
    title: subject.data.title,
    description: subject.data.description,
    href: `${base}fachbereiche/${subject.data.slug}`,
    meta: getSubjectMeta(subject.data.slug),
  }))
  .filter((subject) => subject.meta !== null)
  .map((subject) => ({
    ...subject,
    tone: subject.meta!.tone,
  }));
---

<BaseLayout
  title="Schlaufuchs – Freie Plattform für Technik, Mathematik und Praxis"
  description="Freie Plattform für Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-kicker">Freie Wissens- und Aufgabenplattform</p>
      <h1>Fachbereiche, Wissen und Aufgaben an einem Ort.</h1>
      <p class="hero-lead">
        Schlaufuchs bündelt Mathematik, Informatik, Elektrotechnik, Linux und Web Development in klaren Fachbereichen.
      </p>

      <a class="hero-search" href={`${base}suchen`} aria-label="Suche öffnen">
        <span class="hero-search-icon">⌕</span>
        <span>Themen, Aufgaben und Wissensseiten durchsuchen ...</span>
      </a>

      <div class="hero-actions">
        <a class="hero-button primary" href={`${base}fachbereiche`}>Fachbereiche öffnen</a>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Hauptfächer</p>
        <h2>Direkt in die Fachbereiche</h2>
      </div>
      <a class="section-link" href={`${base}fachbereiche`}>Alle Fachbereiche ansehen</a>
    </div>

    <div class="topic-grid">
      {subjects.map((subject) => (
        <a class={`topic-card ${subject.tone}`} href={subject.href}>
          <div class="topic-top">
            <h3>{subject.title}</h3>
            <span class="topic-arrow" aria-hidden="true">→</span>
          </div>
          <p>{subject.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 1rem;
    padding: 2.25rem;
    border: 1px solid var(--border);
    border-radius: 32px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .hero-kicker,
  .section-kicker {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    color: var(--text-strong);
    font-size: clamp(2.6rem, 4.8vw, 4.6rem);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  .hero-lead {
    max-width: 44rem;
    margin: 1rem 0 0;
    color: var(--text);
    font-size: 1.08rem;
    line-height: 1.72;
  }

  .hero-search {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    width: min(100%, 44rem);
    margin-top: 1.1rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--surface);
    color: var(--text-soft);
    box-shadow: var(--shadow-soft);
  }

  .hero-search-icon {
    font-size: 1.1rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.45rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .home-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.7rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 2.8vw, 2.35rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .section-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .topic-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.35rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .topic-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
  }

  .topic-card.math { background: linear-gradient(135deg, rgba(93,113,175,0.18), rgba(232,237,248,0.82)); }
  .topic-card.web { background: linear-gradient(135deg, rgba(173,144,156,0.16), rgba(245,239,241,0.84)); }
  .topic-card.cs { background: linear-gradient(135deg, rgba(95,139,158,0.16), rgba(235,244,247,0.84)); }
  .topic-card.linux { background: linear-gradient(135deg, rgba(175,163,122,0.16), rgba(242,239,230,0.84)); }
  .topic-card.ee { background: linear-gradient(135deg, rgba(173,147,144,0.15), rgba(244,236,235,0.84)); }

  :global(html[data-theme="dark"]) .topic-card.math { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.web { background: linear-gradient(135deg, rgba(96,72,104,0.24), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.cs { background: linear-gradient(135deg, rgba(28,71,87,0.30), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.linux { background: linear-gradient(135deg, rgba(84,76,44,0.22), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.ee { background: linear-gradient(135deg, rgba(83,60,58,0.22), rgba(42,29,31,0.94)); }

  .topic-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  :global(html[data-theme="dark"]) .topic-arrow {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.08);
  }

  @media (max-width: 980px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 1.7rem;
    }
  }
</style>
