---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleSubjects } from "../data/content";
import { getSubjectMeta } from "../data/subjects";
import { withBase, withBaseAsset } from "../utils/base";

const heroFox = withBaseAsset("assets/mascots/general.png");

const subjects = (await getVisibleSubjects())
  .map((subject) => ({
    title: subject.data.title,
    description: subject.data.description,
    href: withBase(`fachbereiche/${subject.data.slug}`),
    meta: getSubjectMeta(subject.data.slug),
  }))
  .filter((subject) => subject.meta !== null)
  .map((subject, index) => ({
    ...subject,
    tone: subject.meta!.tone,
    accent: (["a", "b", "c", "d", "e", "f"] as const)[index % 6],
  }));
---

<BaseLayout
  title="Schlaufuchs – Freie Plattform für Technik, Mathematik und Praxis"
  description="Freie Plattform für Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-kicker">Freie Wissens- und Aufgabenplattform</p>
      <h1>Fachbereiche, Wissen und Aufgaben an einem Ort.</h1>
      <p class="hero-lead">
        Schlaufuchs bündelt Mathematik, Informatik, Elektrotechnik, Linux und Web Development in klaren Fachbereichen.
      </p>

      <a class="hero-search" href={withBase("suchen")} aria-label="Suche öffnen">
        <span class="hero-search-icon">⌕</span>
        <span>Themen, Aufgaben und Erklärungen durchsuchen ...</span>
      </a>

      <div class="hero-actions">
        <a class="hero-button primary" href={withBase("fachbereiche")}>Fachbereiche öffnen</a>
      </div>
    </div>

    <div class="hero-mascot" aria-hidden="true" data-present="hide">
      <img src={heroFox} alt="" loading="eager" />
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Hauptfächer</p>
        <h2>Direkt in die Fachbereiche</h2>
      </div>
    </div>

    <div class="topic-grid">
      {subjects.map((subject) => (
        <a class={`topic-card ${subject.tone} accent-${subject.accent}`} href={subject.href} aria-label={subject.title}>
          <div class="topic-top">
            <h3>{subject.title}</h3>
            <span class="topic-arrow" aria-hidden="true">→</span>
          </div>
          <p>{subject.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 22rem);
    gap: 1rem;
    align-items: stretch;
    padding: 1.9rem 2rem;
    border: 1px solid var(--border);
    border-radius: 32px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 0.9rem;
    min-width: 0;
  }

  .hero-kicker,
  .section-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 9ch;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.4vw, 4.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .hero-lead {
    max-width: 36rem;
    margin: 0;
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .hero-search {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: min(100%, 36rem);
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--surface);
    color: var(--text-soft);
    box-shadow: var(--shadow-soft);
  }

  .hero-search-icon {
    font-size: 1rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.95rem;
    padding: 0 1.05rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: var(--accent);
    color: white;
    border-color: transparent;
  }

  .hero-mascot {
    display: grid;
    align-items: end;
    justify-items: center;
    min-height: 100%;
  }

  .hero-mascot img {
    width: min(100%, 20rem);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 18px 26px rgba(15,23,42,0.14));
  }

  :global(html[data-theme="dark"]) .hero-mascot img {
    filter: drop-shadow(0 24px 36px rgba(0,0,0,0.34));
  }

  .home-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 2.8vw, 2.35rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.85rem;
  }

  .topic-card {
    display: grid;
    gap: 0.75rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .topic-card:hover,
  .topic-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    filter: saturate(1.06);
    outline: none;
  }

  .topic-card.accent-a { background: linear-gradient(135deg, rgba(98,123,204,0.28), rgba(237,242,255,0.97)); }
  .topic-card.accent-b { background: linear-gradient(135deg, rgba(78,163,128,0.26), rgba(238,248,241,0.97)); }
  .topic-card.accent-c { background: linear-gradient(135deg, rgba(204,128,104,0.26), rgba(251,242,239,0.97)); }
  .topic-card.accent-d { background: linear-gradient(135deg, rgba(190,166,84,0.26), rgba(251,247,235,0.97)); }
  .topic-card.accent-e { background: linear-gradient(135deg, rgba(90,154,196,0.26), rgba(237,248,252,0.97)); }
  .topic-card.accent-f { background: linear-gradient(135deg, rgba(157,110,190,0.26), rgba(245,239,252,0.97)); }

  :global(html[data-theme="dark"]) .topic-card.accent-a { background: linear-gradient(135deg, rgba(66,92,180,0.34), rgba(21,29,56,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-b { background: linear-gradient(135deg, rgba(39,108,74,0.34), rgba(16,39,28,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-c { background: linear-gradient(135deg, rgba(116,63,47,0.34), rgba(45,26,23,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-d { background: linear-gradient(135deg, rgba(109,91,33,0.32), rgba(43,36,20,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-e { background: linear-gradient(135deg, rgba(29,90,116,0.34), rgba(17,36,45,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-f { background: linear-gradient(135deg, rgba(86,55,116,0.34), rgba(36,25,47,0.95)); }

  .topic-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.05rem;
    line-height: 1.18;
  }

  .topic-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.55;
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: minmax(0, 1fr) minmax(10rem, 14rem);
      padding: 1.5rem 1.6rem;
    }

    .hero-mascot img {
      width: min(100%, 14rem);
    }
  }

  @media (max-width: 780px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 1.3rem;
    }

    .hero-mascot {
      justify-items: end;
    }

    .hero-mascot img {
      width: min(100%, 11rem);
    }
  }
</style>
