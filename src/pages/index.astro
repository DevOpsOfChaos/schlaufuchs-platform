---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisibleSubjects } from "../data/content";
import { getSubjectMeta } from "../data/subjects";
import { withBase, withBaseAsset } from "../utils/base";

const heroFox = withBaseAsset("assets/mascots/general.png");

const subjects = (await getVisibleSubjects())
  .map((subject) => ({
    title: subject.data.title,
    description: subject.data.description,
    href: withBase(`fachbereiche/${subject.data.slug}`),
    meta: getSubjectMeta(subject.data.slug),
  }))
  .filter((subject) => subject.meta !== null)
  .map((subject) => ({
    ...subject,
    tone: subject.meta!.tone,
  }));
---

<BaseLayout
  title="Schlaufuchs – Freie Plattform für Technik, Mathematik und Praxis"
  description="Freie Plattform für Mathematik, Informatik, Elektrotechnik, Linux und Web Development."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-kicker">Freie Wissens- und Aufgabenplattform</p>
      <h1>Fachbereiche, Wissen und Aufgaben an einem Ort.</h1>
      <p class="hero-lead">
        Schlaufuchs bündelt Mathematik, Informatik, Elektrotechnik, Linux und Web Development in klaren Fachbereichen.
      </p>

      <a class="hero-search" href={withBase("suchen")} aria-label="Suche öffnen">
        <span class="hero-search-icon">⌕</span>
        <span>Themen, Aufgaben und Erklärungen durchsuchen ...</span>
      </a>

      <div class="hero-actions">
        <a class="hero-button primary" href={withBase("fachbereiche")}>Fachbereiche öffnen</a>
      </div>
    </div>

    <div class="hero-mascot" aria-hidden="true" data-present="hide">
      <img src={heroFox} alt="" loading="eager" />
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Hauptfächer</p>
        <h2>Direkt in die Fachbereiche</h2>
      </div>
    </div>

    <div class="topic-grid">
      {subjects.map((subject) => (
        <a class={`topic-card ${subject.tone}`} href={subject.href}>
          <div class="topic-top">
            <h3>{subject.title}</h3>
            <span class="topic-arrow" aria-hidden="true">→</span>
          </div>
          <p>{subject.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 13rem);
    gap: 1.15rem;
    align-items: center;
    padding: 1.35rem 1.45rem;
    border: 1px solid var(--border);
    border-radius: 30px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .hero-copy {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
  }

  .hero-kicker,
  .section-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 10ch;
    color: var(--text-strong);
    font-size: clamp(2.1rem, 4.1vw, 3.8rem);
    line-height: 0.97;
    letter-spacing: -0.045em;
  }

  .hero-lead {
    max-width: 36rem;
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.68;
  }

  .hero-search {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: min(100%, 36rem);
    margin-top: 0.15rem;
    padding: 0.82rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--surface);
    color: var(--text-soft);
    box-shadow: var(--shadow-soft);
  }

  .hero-search-icon {
    font-size: 1rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.85rem;
    padding: 0 1.05rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .hero-mascot {
    justify-self: end;
    align-self: end;
    display: flex;
    width: clamp(120px, 18vw, 190px);
    max-width: 20vw;
  }

  .hero-mascot img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 18px 24px rgba(15,23,42,0.14));
  }

  :global(html[data-theme="dark"]) .hero-mascot img {
    filter: drop-shadow(0 24px 36px rgba(0,0,0,0.34));
  }

  .home-section {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.35rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 2.6vw, 2.15rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .topic-card {
    display: grid;
    gap: 0.65rem;
    padding: 1.1rem 1.15rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.18rem;
    line-height: 1.15;
  }

  .topic-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.58;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-card.math { background: linear-gradient(135deg, rgba(93,113,175,0.24), rgba(232,237,248,0.9)); }
  .topic-card.web { background: linear-gradient(135deg, rgba(173,144,156,0.22), rgba(245,239,241,0.9)); }
  .topic-card.cs { background: linear-gradient(135deg, rgba(95,139,158,0.22), rgba(235,244,247,0.9)); }
  .topic-card.linux { background: linear-gradient(135deg, rgba(175,163,122,0.22), rgba(242,239,230,0.9)); }
  .topic-card.ee { background: linear-gradient(135deg, rgba(173,147,144,0.2), rgba(244,236,235,0.9)); }

  :global(html[data-theme="dark"]) .topic-card.math { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.web { background: linear-gradient(135deg, rgba(96,72,104,0.24), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.cs { background: linear-gradient(135deg, rgba(28,71,87,0.30), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.linux { background: linear-gradient(135deg, rgba(84,76,44,0.22), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.ee { background: linear-gradient(135deg, rgba(83,60,58,0.22), rgba(42,29,31,0.94)); }

  .topic-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  :global(html[data-theme="dark"]) .topic-arrow {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.08);
  }

  @media (min-width: 1220px) {
    .topic-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: minmax(0, 1fr) 8rem;
      padding: 1.15rem 1.2rem;
      gap: 0.9rem;
    }

    .hero-mascot {
      width: 8rem;
      max-width: none;
    }

    h1 {
      font-size: clamp(1.9rem, 4.8vw, 3rem);
      max-width: 9ch;
    }
  }

  @media (max-width: 720px) {
    .hero,
    .topic-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 1rem;
    }

    .hero-mascot {
      width: min(100%, 9rem);
      justify-self: center;
    }
  }
</style>
