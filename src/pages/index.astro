---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const subjects = [
  {
    title: "Mathematik",
    description: "Funktionen, Analysis, Algebra und Vektorgeometrie mit passenden Aufgaben und klaren Themenblöcken.",
    href: `${base}fachbereiche/mathematik`,
    icon: `${base}assets/icons/math.png`,
    tone: "math",
    highlights: ["Funktionen", "Analysis", "Vektorgeometrie"],
  },
  {
    title: "Informatik",
    description: "Algorithmisches Denken, Programmiergrundlagen und ein sauberer Einstieg in C und Python.",
    href: `${base}fachbereiche/informatik`,
    icon: `${base}assets/icons/informatik.png`,
    tone: "cs",
    highlights: ["Grundlagen", "Programmierung", "C"],
  },
  {
    title: "Elektrotechnik",
    description: "Signale, Schaltungen, Bauelemente und Mikrocontroller in klar gegliederten Themenbereichen.",
    href: `${base}fachbereiche/elektrotechnik`,
    icon: `${base}assets/icons/elektrotechnik.png`,
    tone: "ee",
    highlights: ["Signale", "Halbleiter", "Mikrocontroller"],
  },
  {
    title: "Linux",
    description: "Shell, Rechte, Benutzer, SSH und Shellskripte mit direktem Praxisbezug.",
    href: `${base}fachbereiche/linux`,
    icon: `${base}assets/icons/linux.png`,
    tone: "linux",
    highlights: ["Shell", "Rechte", "SSH"],
  },
  {
    title: "Web Development",
    description: "HTML, CSS und moderne Web-Grundlagen mit direkt sichtbaren Ergebnissen.",
    href: `${base}fachbereiche/web-development`,
    icon: `${base}assets/icons/html_css.png`,
    tone: "web",
    highlights: ["HTML", "CSS", "Layouts"],
  },
];

const quickPaths = [
  {
    title: "Fachbereiche entdecken",
    description: "Steige über klar gegliederte Fächer und Themenblöcke in die Plattform ein.",
    href: `${base}fachbereiche`,
    icon: "▣",
  },
  {
    title: "Aufgaben und Übungen",
    description: "Finde passende Aufgaben, Rechenwege, Code- und Praxisformate zu den Themen.",
    href: `${base}aufgaben`,
    icon: "◎",
  },
  {
    title: "Gezielt suchen",
    description: "Finde Seiten, Aufgaben und Themen schnell über die Suche.",
    href: `${base}suchen`,
    icon: "⌕",
  },
];

const focusAreas = [
  {
    title: "Informationen mit Struktur",
    description: "Fachbereiche, Wissensseiten und Themenblöcke bleiben klar gegliedert und direkt nutzbar.",
  },
  {
    title: "Aufgaben direkt dabei",
    description: "Aufgaben ergänzen die Themen sinnvoll, ohne die Grundseite zu überladen oder vom Stoff abzulenken.",
  },
  {
    title: "Lernmodus bei Bedarf",
    description: "Wer stärker lernorientiert arbeiten will, kann die zusätzliche Lernsicht gezielt einschalten.",
  },
];

const heroFox = `${base}assets/mascots/general.png`;
---

<BaseLayout
  title="Schlaufuchs – Freie Plattform für Technik, Mathematik und Praxis"
  description="Freie Plattform für Mathematik, Informatik, Elektrotechnik, Linux und Web Development – mit klaren Fachbereichen, Wissensseiten und Aufgaben."
>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="hero-kicker">Freie Wissens- und Aufgabenplattform</p>
      <h1>Fachinformationen finden. Aufgaben nutzen. Inhalte klar ordnen.</h1>
      <p class="hero-lead">
        Schlaufuchs bündelt Mathematik, Informatik, Elektrotechnik, Linux und Web Development
        in klaren Fachbereichen – mit verständlichen Wissensseiten, passenden Aufgaben und einer
        ruhigen, modernen Oberfläche.
      </p>

      <div class="hero-actions">
        <a class="hero-button primary" href={`${base}fachbereiche`}>Fachbereiche entdecken</a>
        <a class="hero-button secondary" href={`${base}aufgaben`} data-present="hide">Zu Aufgaben und Übungen</a>
      </div>

      <a class="hero-search" href={`${base}suchen`} aria-label="Suche öffnen" data-present="hide">
        <span class="hero-search-icon">⌕</span>
        <span>Themen, Aufgaben und Wissensseiten durchsuchen ...</span>
      </a>
    </div>

    <div class="hero-mascot" aria-hidden="true">
      <img src={heroFox} alt="" loading="eager" />
    </div>
  </section>

  <section class="home-section" data-present="hide">
    <div class="section-head">
      <div>
        <p class="section-kicker">Schnell starten</p>
        <h2>Drei gute Wege in die Plattform</h2>
        <p>Ob du ein Fach entdecken, direkt Aufgaben aufrufen oder gezielt suchen willst: der Einstieg soll sofort funktionieren.</p>
      </div>
    </div>

    <div class="path-grid">
      {quickPaths.map((path) => (
        <a class="path-card" href={path.href}>
          <div class="path-icon" aria-hidden="true">{path.icon}</div>
          <div class="path-copy">
            <h3>{path.title}</h3>
            <p>{path.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">Hauptfächer</p>
        <h2>Fachbereiche mit klarer Struktur</h2>
        <p>Jeder Fachbereich führt über Grundlagen, zentrale Themenblöcke und passende Aufgaben in die Tiefe.</p>
      </div>
      <a class="section-link" href={`${base}fachbereiche`}>Alle Fachbereiche ansehen</a>
    </div>

    <div class="topic-grid">
      {subjects.map((subject) => (
        <a class={`topic-card ${subject.tone}`} href={subject.href}>
          <div class="topic-top">
            <div class="topic-icon">
              <img src={subject.icon} alt="" loading="lazy" />
            </div>
            <div class="topic-arrow" aria-hidden="true">→</div>
          </div>

          <div class="topic-copy">
            <h3>{subject.title}</h3>
            <p>{subject.description}</p>
          </div>

          <ul class="topic-highlights">
            {subject.highlights.map((item) => <li>{item}</li>)}
          </ul>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section" data-present="hide">
    <article class="learn-mode-panel">
      <div class="learn-mode-copy">
        <p class="section-kicker">Optionaler Lernmodus</p>
        <h2>Die Grundseite bleibt klar – der Lernmodus ergänzt die stärkere Lernsicht.</h2>
        <p>
          Schlaufuchs startet bewusst als ruhige Informations- und Aufgabenplattform. Wenn du
          zusätzlich stärker lernorientiert arbeiten möchtest, kannst du den Lernmodus jederzeit
          einschalten und die Seite gezielter als Lernoberfläche nutzen.
        </p>
      </div>

      <div class="learn-mode-actions">
        <button type="button" class="hero-button primary" data-home-learn-activate>
          Lernmodus einschalten
        </button>
        <a class="hero-button secondary" href={`${base}fachbereiche`}>
          Erst in der Standardansicht bleiben
        </a>
      </div>
    </article>
  </section>

  <section class="home-section" data-present="hide">
    <div class="section-head">
      <div>
        <p class="section-kicker">Anspruch</p>
        <h2>Modern, klar und fachlich belastbar</h2>
        <p>Die Plattform verbindet ruhige Informationsstruktur, passende Aufgaben und eine zuschaltbare Lernsicht.</p>
      </div>
    </div>

    <div class="focus-grid">
      {focusAreas.map((item) => (
        <article class="focus-card">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    const activateLearnMode = () => {
      const root = document.documentElement;
      root.dataset.learnMode = "on";
      try {
        localStorage.setItem("schlaufuchs-learn-mode", "on");
        localStorage.removeItem("schlaufuchs-learn-prompt-dismissed");
      } catch {}
      window.dispatchEvent(new CustomEvent("learnmode-changed", { detail: "on" }));
    };

    document.querySelector("[data-home-learn-activate]")?.addEventListener("click", activateLearnMode);
  </script>
</BaseLayout>

<style>
  :global(:root) {
    --home-light-hero: radial-gradient(circle at top right, rgba(79, 70, 229, 0.10), transparent 34%),
      linear-gradient(135deg, rgba(244, 246, 252, 0.98), rgba(248, 250, 252, 0.98));
    --home-dark-hero: radial-gradient(circle at top right, rgba(80, 109, 255, 0.16), transparent 30%),
      linear-gradient(135deg, rgba(16, 22, 34, 0.98), rgba(11, 16, 26, 0.98));
  }

  .home-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.75rem;
    align-items: end;
    padding: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 32px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  :global(html[data-theme="light"]) .home-hero { background: var(--home-light-hero); }
  :global(html[data-theme="dark"]) .home-hero { background: var(--home-dark-hero); }

  .home-hero::after {
    content: "";
    position: absolute;
    right: -7rem;
    bottom: -8rem;
    width: 17rem;
    height: 17rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(79,70,229,0.12), rgba(2,132,199,0.08));
    pointer-events: none;
  }

  .hero-copy { position: relative; z-index: 1; min-width: 0; }
  .hero-kicker, .section-kicker {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 16ch;
    color: var(--text-strong);
    font-size: clamp(2.8rem, 5vw, 4.9rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .hero-lead {
    max-width: 42rem;
    margin: 1.15rem 0 0;
    color: var(--text);
    font-size: clamp(1.05rem, 1.6vw, 1.22rem);
    line-height: 1.75;
  }

  .hero-actions,
  .learn-mode-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0 1.2rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, background 140ms ease;
    cursor: pointer;
  }

  .hero-button:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-soft);
  }

  .hero-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    border-color: transparent;
  }

  .hero-button.secondary {
    background: rgba(255,255,255,0.42);
    color: var(--text-strong);
  }

  :global(html[data-theme="dark"]) .hero-button.secondary {
    background: rgba(255,255,255,0.06);
  }

  .hero-search {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    width: min(100%, 44rem);
    margin-top: 1.1rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255,255,255,0.38);
    color: var(--text-soft);
    box-shadow: var(--shadow-soft);
  }

  :global(html[data-theme="dark"]) .hero-search {
    background: rgba(13,18,28,0.72);
  }

  .hero-search-icon { font-size: 1.1rem; line-height: 1; flex-shrink: 0; }

  .hero-mascot {
    position: relative;
    z-index: 1;
    justify-self: end;
    align-self: end;
    display: flex;
    width: clamp(220px, 24vw, 320px);
    max-width: 31vw;
  }

  .hero-mascot img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 28px rgba(15,23,42,0.14));
  }

  :global(html[data-theme="dark"]) .hero-mascot img {
    filter: drop-shadow(0 24px 36px rgba(0,0,0,0.34));
  }

  .home-section {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.7rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-head h2,
  .learn-mode-copy h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.85rem, 2.8vw, 2.5rem);
    line-height: 1.04;
    letter-spacing: -0.035em;
  }

  .section-head p,
  .learn-mode-copy p {
    margin: 0.75rem 0 0;
    max-width: 46rem;
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.62;
  }

  .section-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  .path-grid,
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-card,
  .focus-card,
  .learn-mode-panel {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .learn-mode-panel {
    grid-template-columns: minmax(0, 1.4fr) auto;
    align-items: end;
    padding: 1.6rem;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(240,244,255,0.88));
  }

  :global(html[data-theme="dark"]) .learn-mode-panel {
    background: linear-gradient(135deg, rgba(79,70,229,0.18), rgba(18,27,46,0.94));
  }

  .path-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .path-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 16px;
    display: grid;
    place-items: center;
    background: var(--surface-2);
    color: var(--text-strong);
    font-size: 1.1rem;
    border: 1px solid var(--border);
  }

  .path-copy h3,
  .focus-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .path-copy p,
  .focus-card p {
    margin: 0.4rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .topic-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1.3rem;
    min-height: 18.25rem;
    padding: 1.6rem;
    border: 1px solid var(--border);
    border-radius: 26px;
    box-shadow: var(--shadow-soft);
  }

  .topic-card::after {
    content: "";
    position: absolute;
    right: -2rem;
    bottom: -2.3rem;
    width: 7rem;
    height: 7rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  .topic-card.math { background: linear-gradient(135deg, rgba(93,113,175,0.26), rgba(232,237,248,0.82)); }
  .topic-card.web { background: linear-gradient(135deg, rgba(173,144,156,0.22), rgba(245,239,241,0.86)); }
  .topic-card.cs { background: linear-gradient(135deg, rgba(95,139,158,0.20), rgba(235,244,247,0.84)); }
  .topic-card.linux { background: linear-gradient(135deg, rgba(175,163,122,0.20), rgba(242,239,230,0.84)); }
  .topic-card.ee { background: linear-gradient(135deg, rgba(173,147,144,0.18), rgba(244,236,235,0.84)); }

  :global(html[data-theme="dark"]) .topic-card.math { background: linear-gradient(135deg, rgba(72,95,164,0.38), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.web { background: linear-gradient(135deg, rgba(96,72,104,0.34), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.cs { background: linear-gradient(135deg, rgba(28,71,87,0.42), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.linux { background: linear-gradient(135deg, rgba(84,76,44,0.30), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.ee { background: linear-gradient(135deg, rgba(83,60,58,0.32), rgba(42,29,31,0.94)); }

  .topic-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .topic-icon {
    width: 3.8rem;
    height: 3.8rem;
    border-radius: 1rem;
    border: 1px solid rgba(148,163,184,0.18);
    background: rgba(255,255,255,0.34);
    display: grid;
    place-items: center;
    box-shadow: 0 14px 30px rgba(15,23,42,0.06);
  }

  :global(html[data-theme="dark"]) .topic-icon {
    border-color: rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.06);
  }

  .topic-icon img {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  .topic-arrow {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(148,163,184,0.16);
    background: rgba(255,255,255,0.3);
    color: var(--text-strong);
    font-size: 1rem;
  }

  :global(html[data-theme="dark"]) .topic-arrow {
    border-color: rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.08);
  }

  .topic-copy h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.55rem, 2vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .topic-copy p {
    margin: 0.85rem 0 0;
    color: var(--text);
    line-height: 1.66;
  }

  .topic-highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
  }

  .topic-highlights li {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.16);
    background: rgba(255,255,255,0.28);
    color: var(--text-strong);
    font-size: 0.92rem;
    font-weight: 600;
  }

  :global(html[data-theme="dark"]) .topic-highlights li {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.08);
  }

  @media (max-width: 1100px) {
    .topic-grid,
    .path-grid,
    .focus-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .home-hero,
    .learn-mode-panel {
      grid-template-columns: 1fr;
    }

    .home-hero {
      padding: 2rem 1.5rem 0;
    }

    .hero-mascot {
      width: min(100%, 18rem);
      max-width: none;
      justify-self: center;
    }
  }

  @media (max-width: 720px) {
    .topic-grid,
    .path-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }

    .hero-search {
      width: 100%;
    }

    .hero-mascot {
      width: min(100%, 11rem);
    }

    .section-link,
    .learn-mode-actions .hero-button {
      width: 100%;
    }
  }
</style>
