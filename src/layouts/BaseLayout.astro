---
import "../styles/globals/base.css";
import { siteConfig } from "../data/settings/site";
import Topbar from "../components/ui/Topbar.astro";
import Footer from "../components/ui/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="de" data-theme="dark" data-learn-mode="off">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <script is:inline>
      (() => {
        const root = document.documentElement;

        const themeKey = "schlaufuchs-theme";
        const storedTheme = localStorage.getItem(themeKey);
        const systemPrefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = storedTheme || (systemPrefersLight ? "light" : "dark");
        root.setAttribute("data-theme", theme);

        const learnKey = "schlaufuchs-learn-mode";
        const storedLearnMode = localStorage.getItem(learnKey);
        root.setAttribute("data-learn-mode", storedLearnMode === "on" ? "on" : "off");
      })();
    </script>
  </head>

  <body>
    <Topbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
