---
import "../styles/globals/base.css";
import { siteConfig } from "../data/settings/site";
import Topbar from "../components/ui/Topbar.astro";
import LearnModePrompt from "../components/ui/LearnModePrompt.astro";
import Footer from "../components/ui/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="de" data-theme="dark" data-learn-mode="off" data-presentation-mode="off">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const params = new URLSearchParams(window.location.search);

        const themeKey = "schlaufuchs-theme";
        const storedTheme = localStorage.getItem(themeKey);
        const systemPrefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = storedTheme || (systemPrefersLight ? "light" : "dark");
        root.setAttribute("data-theme", theme);

        const readModeParam = (value) => {
          if (value === "1" || value === "on" || value === "true") return "on";
          if (value === "0" || value === "off" || value === "false") return "off";
          return null;
        };

        const learnKey = "schlaufuchs-learn-mode";
        const learnParam = readModeParam(params.get("learn"));
        const storedLearnMode = localStorage.getItem(learnKey);
        const learnMode = learnParam ?? (storedLearnMode === "on" ? "on" : "off");
        root.setAttribute("data-learn-mode", learnMode);
        if (learnParam) {
          localStorage.setItem(learnKey, learnParam);
        }

        const presentationKey = "schlaufuchs-presentation-mode";
        const presentationParam = readModeParam(params.get("present"));
        const storedPresentationMode = localStorage.getItem(presentationKey);
        const presentationMode = presentationParam ?? (storedPresentationMode === "on" ? "on" : "off");
        root.setAttribute("data-presentation-mode", presentationMode);
        if (presentationParam) {
          localStorage.setItem(presentationKey, presentationParam);
        }

        window.addEventListener("keydown", (event) => {
          const target = event.target;
          const tagName = target instanceof HTMLElement ? target.tagName : "";
          const isTyping = target instanceof HTMLElement && (target.isContentEditable || ["INPUT", "TEXTAREA", "SELECT"].includes(tagName));
          if (isTyping || event.metaKey || event.ctrlKey || event.altKey) return;

          if (event.key === "l" || event.key === "L") {
            const next = root.dataset.learnMode === "on" ? "off" : "on";
            root.dataset.learnMode = next;
            try {
              localStorage.setItem(learnKey, next);
            } catch {}
            window.dispatchEvent(new CustomEvent("learnmode-changed", { detail: next }));
          }

          if (event.key === "p" || event.key === "P") {
            const next = root.dataset.presentationMode === "on" ? "off" : "on";
            root.dataset.presentationMode = next;
            try {
              localStorage.setItem(presentationKey, next);
            } catch {}
            window.dispatchEvent(new CustomEvent("presentationmode-changed", { detail: next }));
          }
        });
      })();
    </script>
  </head>

  <body>
    <Topbar />
    <LearnModePrompt />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
