---
import ActionIcon from "./ActionIcon.astro";

const presentIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <rect x="4" y="5" width="16" height="10" rx="1.6"></rect>
  <path d="M12 15v4M9 19h6"></path>
</svg>`;
---

<div class="presentation-toggle-shell" data-presentation-toggle>
  <ActionIcon
    label="Präsentationsmodus"
    tooltip="Präsentationsmodus aktivieren"
    icon={presentIcon}
    type="button"
  />
</div>

<script>
  const shell = document.querySelector("[data-presentation-toggle]");
  const button = shell?.querySelector("button");

  const renderPresentationMode = () => {
    if (!button || !window.schlaufuchsModes) return;
    const isOn = window.schlaufuchsModes.getPresentationMode();
    button.classList.toggle("active", isOn);
    button.setAttribute("aria-label", isOn ? "Präsentationsmodus deaktivieren" : "Präsentationsmodus aktivieren");
    button.setAttribute("data-tooltip", isOn ? "Präsentationsmodus deaktivieren" : "Präsentationsmodus aktivieren");
  };

  renderPresentationMode();

  button?.addEventListener("click", () => {
    window.schlaufuchsModes?.togglePresentationMode();
  });

  window.addEventListener("presentationmode-changed", renderPresentationMode);
</script>
