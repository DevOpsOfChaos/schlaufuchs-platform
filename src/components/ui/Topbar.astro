---
import { mainNavigation } from "../../data/navigation/main";
import ThemeToggle from "./ThemeToggle.astro";
import ActionIcon from "./ActionIcon.astro";

const base = import.meta.env.BASE_URL;
const logoSrc = `${base}assets/brand/logo_alpha.png`;
const pathname = Astro.url.pathname;

const normalizeHref = (href: string) => `${base}${href === "/" ? "" : href.replace(/^\//, "")}`;
const isActive = (href: string) => {
  const fullHref = normalizeHref(href);
  if (href === "/") return pathname === base || pathname === `${base}`;
  return pathname.startsWith(fullHref);
};

const searchIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <circle cx="11" cy="11" r="6.5"></circle>
  <path d="M16 16l4.5 4.5"></path>
</svg>`;

const learnIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M3 7.5 12 4l9 3.5L12 11 3 7.5Z"></path>
  <path d="M6 9.2v4.2c0 1.8 2.7 3.3 6 3.3s6-1.5 6-3.3V9.2"></path>
</svg>`;

const presentIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <rect x="4" y="5" width="16" height="10" rx="1.6"></rect>
  <path d="M12 15v4M9 19h6"></path>
</svg>`;
---

<header class="topbar-shell">
  <div class="topbar">
    <a class="brand" href={`${base}`} aria-label="Schlaufuchs Startseite">
      <div class="brand-mark">
        <img src={logoSrc} alt="" width="48" height="48" loading="eager" />
      </div>

      <div class="brand-copy">
        <strong>Schlaufuchs</strong>
        <span>Lernen, verstehen und gezielt wiederfinden</span>
      </div>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">
      <ul>
        {mainNavigation.map((item) => (
          <li>
            <a
              href={normalizeHref(item.href)}
              aria-label={item.label}
              title={item.label}
              data-tooltip={item.label}
              class:list={{ active: isActive(item.href) }}
            >
              <span class="nav-text">{item.label}</span>
              <span class="nav-short" aria-hidden="true">{item.shortLabel}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="actions">
      <ActionIcon
        label="Suche"
        tooltip="Suche öffnen"
        href={`${base}suchen`}
        icon={searchIcon}
      />
      <ActionIcon
        label="Lernmodus"
        tooltip="Lernmodus folgt später"
        icon={learnIcon}
        passive={true}
        type="button"
      />
      <ActionIcon
        label="Präsentationsmodus"
        tooltip="Präsentationsmodus folgt später"
        icon={presentIcon}
        passive={true}
        type="button"
      />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .topbar-shell { position: sticky; top: 0; z-index: 40; padding: 0.75rem 0 0; }
  .topbar {
    width: min(100% - 1rem, 110rem); min-height: 5rem; margin: 0 auto; padding: 0.85rem 1rem;
    border-radius: 999px; border: 1px solid var(--border); background: var(--topbar-bg);
    backdrop-filter: blur(18px); display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow-soft);
  }

  .brand { display: flex; align-items: center; gap: 0.85rem; min-width: 0; flex-shrink: 0; }
  .brand-mark {
    width: 3.1rem; height: 3.1rem; border-radius: 16px;
    background: linear-gradient(180deg, var(--surface-2) 0%, var(--surface-3) 100%);
    border: 1px solid var(--border); display: grid; place-items: center; overflow: hidden; flex-shrink: 0;
  }
  .brand-mark img { width: 100%; height: 100%; object-fit: cover; }
  .brand-copy { display: flex; flex-direction: column; min-width: 0; }
  .brand-copy strong { color: var(--text-strong); font-size: 1.05rem; line-height: 1.1; }
  .brand-copy span { color: var(--text-soft); font-size: 0.92rem; line-height: 1.2; white-space: nowrap; }

  .nav { flex: 1; min-width: 0; }
  .nav ul { list-style: none; display: flex; align-items: center; justify-content: center; gap: 0.45rem; margin: 0; padding: 0; overflow-x: auto; scrollbar-width: none; }
  .nav ul::-webkit-scrollbar { display: none; }

  .nav a {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center; min-height: 3rem; min-width: 3rem;
    padding: 0 1rem; border-radius: 999px; color: var(--text-muted); font-weight: 650; white-space: nowrap;
    transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    border: 1px solid transparent;
  }
  .nav a:hover { color: var(--text-strong); background: var(--surface); }
  .nav a.active {
    color: var(--text-strong);
    background: var(--surface);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-soft);
  }

  .nav a::after {
    content: attr(data-tooltip);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.55rem);
    transform: translateX(-50%) translateY(4px);
    min-width: max-content;
    max-width: 14rem;
    padding: 0.45rem 0.7rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    box-shadow: var(--shadow-soft);
    font-size: 0.84rem;
    line-height: 1.25;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 120ms ease,
      transform 120ms ease;
    z-index: 70;
  }

  .nav a:hover::after,
  .nav a:focus-visible::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .nav-short { display: none; font-size: 1rem; line-height: 1; }
  .actions { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }

  @media (max-width: 1320px) {
    .brand-copy span { display: none; }
    .nav-text { display: none; }
    .nav-short { display: inline; }
    .nav a { padding: 0 0.85rem; }
  }

  @media (max-width: 980px) {
    .topbar { border-radius: 28px; align-items: stretch; flex-direction: column; width: min(100% - 1rem, 100%); }
    .nav { width: 100%; }
    .nav ul { justify-content: flex-start; }
    .actions { width: 100%; justify-content: flex-end; }
    .brand-copy span { display: block; white-space: normal; }
  }

  @media (max-width: 720px) {
    .nav a::after {
      display: none;
    }
  }
</style>
