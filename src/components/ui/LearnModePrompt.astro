---
---

<div class="learn-prompt" data-learn-prompt hidden aria-live="polite">
  <p class="learn-prompt-kicker">Lernmodus</p>
  <p class="learn-prompt-copy">
    Schon ausprobiert? Den Lernmodus kannst du direkt hier einschalten.
  </p>

  <div class="learn-prompt-actions">
    <button type="button" class="learn-prompt-button primary" data-learn-activate>
      Einschalten
    </button>
    <button type="button" class="learn-prompt-button secondary" data-learn-dismiss>
      Später
    </button>
  </div>
</div>

<script>
  (() => {
    const prompt = document.querySelector("[data-learn-prompt]");
    if (!prompt || prompt.dataset.ready === "true") return;
    prompt.dataset.ready = "true";

    const toggleShell = document.querySelector("[data-learn-toggle]");
    const toggleButton = toggleShell?.querySelector("button");
    const activateButton = prompt.querySelector("[data-learn-activate]");
    const dismissButton = prompt.querySelector("[data-learn-dismiss]");
    let hideTimeout = 0;

    const clearHideTimeout = () => {
      if (hideTimeout) {
        window.clearTimeout(hideTimeout);
        hideTimeout = 0;
      }
    };

    const dismissPrompt = (persist = true) => {
      clearHideTimeout();
      if (!window.schlaufuchsModes) return;
      prompt.hidden = true;
      if (persist) {
        window.schlaufuchsModes.setLearnPromptDismissed(true);
      }
    };

    const positionPrompt = () => {
      if (!toggleButton || prompt.hidden) return;
      const rect = toggleButton.getBoundingClientRect();
      const width = Math.min(320, window.innerWidth - 16);
      const top = rect.bottom + 10;
      const minLeft = 8;
      const maxLeft = window.innerWidth - width - 8;
      const left = Math.min(Math.max(rect.right - width, minLeft), maxLeft);

      prompt.style.width = `${width}px`;
      prompt.style.top = `${top}px`;
      prompt.style.left = `${left}px`;
    };

    const scheduleAutoHide = () => {
      clearHideTimeout();
      hideTimeout = window.setTimeout(() => {
        dismissPrompt(true);
      }, 6500);
    };

    const renderPrompt = () => {
      if (!window.schlaufuchsModes || !toggleButton) return;
      const dismissed = window.schlaufuchsModes.isLearnPromptDismissed();
      const isLearnModeOn = window.schlaufuchsModes.getLearnMode();
      const shouldShow = !dismissed && !isLearnModeOn;

      prompt.hidden = !shouldShow;

      if (shouldShow) {
        positionPrompt();
        scheduleAutoHide();
      } else {
        clearHideTimeout();
      }
    };

    activateButton?.addEventListener("click", () => {
      if (!window.schlaufuchsModes) return;
      window.schlaufuchsModes.setLearnMode("on");
      window.schlaufuchsModes.setLearnPromptDismissed(true);
      dismissPrompt(false);
    });

    dismissButton?.addEventListener("click", () => {
      dismissPrompt(true);
    });

    prompt.addEventListener("mouseenter", clearHideTimeout);
    prompt.addEventListener("mouseleave", () => {
      if (!prompt.hidden) {
        scheduleAutoHide();
      }
    });

    window.addEventListener("learnmode-changed", renderPrompt);
    window.addEventListener("learnprompt-changed", renderPrompt);
    window.addEventListener("resize", positionPrompt);
    window.addEventListener("scroll", positionPrompt, { passive: true });

    renderPrompt();
  })();
</script>

<style>
  .learn-prompt {
    position: fixed;
    display: grid;
    gap: 0.7rem;
    padding: 0.9rem;
    border: 1px solid var(--border-strong);
    border-radius: 18px;
    background: color-mix(in oklab, var(--card-bg) 96%, #eef2ff 4%);
    box-shadow: var(--shadow-card);
    z-index: 36;
  }

  :global(html[data-theme="dark"]) .learn-prompt {
    background: color-mix(in oklab, var(--card-bg) 96%, #1d4ed8 4%);
  }

  .learn-prompt-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .learn-prompt-copy {
    margin: 0;
    color: var(--text-strong);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .learn-prompt-actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .learn-prompt-button {
    min-height: 2.45rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
  }

  .learn-prompt-button.primary {
    background: color-mix(in oklab, var(--surface-strong) 84%, #4f46e5 16%);
    color: white;
    border-color: transparent;
  }

  .learn-prompt-button.secondary {
    background: var(--surface);
    color: var(--text-strong);
  }
</style>
