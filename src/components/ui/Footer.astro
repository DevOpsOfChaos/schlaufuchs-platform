---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <p>© {year} Schlaufuchs</p>
    <p class="muted">Neustart-Plattform auf Astro-Basis</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.25rem 0 2rem;
  }

  .inner {
    width: min(var(--content-width), calc(100% - 2rem));
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    flex-wrap: wrap;
  }

  .muted {
    opacity: 0.9;
  }
</style>
