---
interface Props {
  variant?: "topics" | "articles" | "tasks";
  muted?: boolean;
}

const { variant = "topics", muted = false } = Astro.props as Props;
---

<section class={`area-surface ${variant} ${muted ? "muted" : ""}`}>
  <slot />
</section>

<style>
  .area-surface {
    display: grid;
    gap: 0.9rem;
    padding: 1.05rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    background: var(--card-bg);
  }

  .area-surface.topics {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(238, 244, 255, 0.98));
  }

  .area-surface.articles {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(242, 247, 255, 0.98));
  }

  .area-surface.tasks {
    background: linear-gradient(180deg, rgba(255, 250, 241, 0.96), rgba(249, 244, 229, 0.98));
    border-color: color-mix(in oklab, var(--border) 58%, rgba(201, 176, 77, 0.7) 42%);
  }

  :global(html[data-theme="dark"]) .area-surface.topics {
    background: color-mix(in oklab, var(--card-bg) 92%, white 8%);
  }

  :global(html[data-theme="dark"]) .area-surface.articles {
    background: color-mix(in oklab, var(--card-bg) 96%, var(--surface) 4%);
  }

  :global(html[data-theme="dark"]) .area-surface.tasks {
    background: linear-gradient(135deg, color-mix(in oklab, var(--card-bg) 88%, var(--surface) 12%), color-mix(in oklab, var(--card-bg) 94%, white 6%));
    border-color: color-mix(in oklab, var(--border) 68%, var(--border-strong) 32%);
  }

  .area-surface.muted {
    box-shadow: none;
  }
</style>
