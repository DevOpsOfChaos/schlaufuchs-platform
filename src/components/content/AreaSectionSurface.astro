---
interface Props {
  variant?: "topics" | "articles" | "tasks";
  muted?: boolean;
}

const { variant = "topics", muted = false } = Astro.props as Props;
---

<section class={`area-surface ${variant} ${muted ? "muted" : ""}`}>
  <slot />
</section>

<style>
  .area-surface {
    display: grid;
    gap: 1rem;
    padding: 1.15rem;
    border: 1px solid var(--border);
    border-radius: 30px;
    box-shadow: var(--shadow-soft);
    background: var(--card-bg);
  }

  .area-surface.topics {
    background: color-mix(in oklab, var(--card-bg) 92%, white 8%);
  }

  .area-surface.articles {
    background: color-mix(in oklab, var(--card-bg) 96%, var(--surface) 4%);
  }

  .area-surface.tasks {
    background: linear-gradient(135deg, color-mix(in oklab, var(--card-bg) 88%, var(--surface) 12%), color-mix(in oklab, var(--card-bg) 94%, white 6%));
    border-color: color-mix(in oklab, var(--border) 68%, var(--border-strong) 32%);
  }

  .area-surface.muted {
    box-shadow: none;
  }
</style>
