---
const { section } = Astro.props;
const base = import.meta.env.BASE_URL;
const mascotSrc = `${base}${section.mascot.replace(/^\//, "")}`;
---

<section class="section-hero">
  <div class="section-copy">
    <p class="eyebrow">{section.eyebrow}</p>
    <h1>{section.title}</h1>
    <p class="lead">{section.description}</p>
  </div>

  <div class="section-mascot" aria-hidden="true">
    <img src={mascotSrc} alt="" loading="eager" />
  </div>
</section>

<section class="topic-grid">
  {section.groups.map((group) => (
    <a class={`topic-card ${group.tone}`} href={`${base}${group.href.replace(/^\//, "")}`}>
      <h2>{group.title}</h2>
      <p>{group.text}</p>
      <div class="topic-arrow" aria-hidden="true">▶</div>
    </a>
  ))}
</section>

<style>
  .section-hero { position: relative; overflow: hidden; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1.2rem; align-items: end; padding: 2.1rem 2.1rem 0; border: 1px solid var(--border); border-radius: 28px; background: var(--card-bg); box-shadow: var(--shadow-card); }
  .section-hero::after { content: ""; position: absolute; right: -90px; bottom: -110px; width: 240px; height: 240px; border-radius: 50%; background: rgba(127, 140, 255, 0.12); }
  .section-copy { position: relative; z-index: 1; padding-bottom: 1.8rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--text-soft); }
  h1 { margin: 0; color: var(--text-strong); font-size: clamp(2.4rem, 4vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
  .lead { margin: 1rem 0 0; max-width: 42rem; color: var(--text-soft); line-height: 1.7; }
  .section-mascot { position: relative; z-index: 1; width: min(100%, 13rem); }
  .section-mascot img { width: 100%; display: block; object-fit: contain; }

  .topic-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.15rem; margin-top: 1.45rem; }
  .topic-card { position: relative; overflow: hidden; min-height: 15rem; padding: 1.6rem; border: 1px solid var(--border); border-radius: 24px; color: inherit; box-shadow: var(--shadow-soft); }
  .topic-card::after { content: ""; position: absolute; right: -2.25rem; bottom: -2.5rem; width: 7.8rem; height: 7.8rem; border-radius: 999px; background: rgba(255,255,255,0.07); pointer-events: none; }

  .topic-card.math-a { background: linear-gradient(135deg, rgba(93, 113, 175, 0.28), rgba(232, 237, 248, 0.76)); }
  .topic-card.math-b { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .topic-card.math-c { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }
  .topic-card.web-a { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }
  .topic-card.web-b { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .topic-card.web-c { background: linear-gradient(135deg, rgba(175, 163, 122, 0.20), rgba(242, 239, 230, 0.84)); }
  .topic-card.cs-a { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .topic-card.cs-b { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }
  .topic-card.cs-c { background: linear-gradient(135deg, rgba(175, 163, 122, 0.20), rgba(242, 239, 230, 0.84)); }
  .topic-card.linux-a { background: linear-gradient(135deg, rgba(175, 163, 122, 0.20), rgba(242, 239, 230, 0.84)); }
  .topic-card.linux-b { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .topic-card.linux-c { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }

  :global(html[data-theme="dark"]) .topic-card.math-a { background: linear-gradient(135deg, rgba(72, 95, 164, 0.36), rgba(22, 31, 58, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.math-b { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.math-c { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.web-a { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.web-b { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.web-c { background: linear-gradient(135deg, rgba(84, 76, 44, 0.30), rgba(42, 39, 28, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.cs-a { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.cs-b { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.cs-c { background: linear-gradient(135deg, rgba(84, 76, 44, 0.30), rgba(42, 39, 28, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.linux-a { background: linear-gradient(135deg, rgba(84, 76, 44, 0.30), rgba(42, 39, 28, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.linux-b { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .topic-card.linux-c { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }

  h2 { margin: 0; color: var(--text-strong); font-size: clamp(1.7rem, 2.2vw, 2rem); line-height: 1.05; }
  .topic-card p { margin: 0.75rem 0 0; color: var(--text); line-height: 1.62; max-width: 18rem; }
  .topic-arrow {
    position: absolute; right: 1.4rem; bottom: 1.2rem; width: 2.2rem; height: 2.2rem; border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.16); background: rgba(255,255,255,0.28); display: grid; place-items: center; color: var(--text-strong);
  }
  :global(html[data-theme="dark"]) .topic-arrow { border-color: rgba(255,255,255,0.12); background: rgba(255,255,255,0.10); }

  @media (max-width: 980px) {
    .section-hero { grid-template-columns: 1fr; padding: 1.8rem 1.4rem 0; }
    .section-copy { padding-bottom: 1rem; }
    .section-mascot { justify-self: center; width: min(100%, 10rem); }
    .topic-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .topic-card { min-height: 13rem; padding: 1.35rem; }
  }
</style>
