---
import Breadcrumbs from "../ui/Breadcrumbs.astro";

const { section, breadcrumbs = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const mascotSrc = `${base}${section.mascot.replace(/^\//, "")}`;

const pathname = Astro.url.pathname;
const clean = pathname.replace(/\/$/, "");
const parentPath = clean.split("/").slice(0, -1).join("/") || "/";
---

<section class="page-hero">
  <div class="page-copy">
    <Breadcrumbs items={breadcrumbs} />
    <div class="topline">
      <p class="eyebrow">{section.eyebrow}</p>
      <a class="back-link" href={parentPath}>← Zurück</a>
    </div>
    <h1>{section.title}</h1>
    <p class="lead">{section.description}</p>
  </div>
  <div class="page-mascot" aria-hidden="true">
    <img src={mascotSrc} alt="" loading="eager" />
  </div>
</section>

<section class="topic-grid">
  {section.groups.map((group, index) => (
    <a class={`topic-card ${group.tone}`} href={`${base}${group.href.replace(/^\//, "")}`}>
      <div class="topic-badge" aria-hidden="true">{["◈","◇","✦"][index % 3]}</div>
      <h2>{group.title}</h2>
      <p>{group.text}</p>
      <div class="topic-arrow" aria-hidden="true">▶</div>
    </a>
  ))}
</section>

<style>
  .page-hero { position: relative; overflow: hidden; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1.2rem; align-items: end; padding: 2.1rem 2.1rem 0; border: 1px solid var(--border); border-radius: 28px; background: var(--card-bg); box-shadow: var(--shadow-card); }
  .page-hero::after { content: ""; position: absolute; right: -90px; bottom: -110px; width: 240px; height: 240px; border-radius: 50%; background: rgba(127, 140, 255, 0.12); }
  .page-copy { position: relative; z-index: 1; padding-bottom: 1.8rem; }
  .topline { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .eyebrow { margin: 0; color: var(--text-soft); }
  .back-link { display: inline-flex; align-items: center; min-height: 2.5rem; padding: 0 0.9rem; border-radius: 999px; border: 1px solid var(--border); background: var(--surface); color: var(--text); box-shadow: var(--shadow-soft); }
  h1 { margin: 0.75rem 0 0; color: var(--text-strong); font-size: clamp(2.4rem, 4vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
  .lead { margin: 1rem 0 0; max-width: 42rem; color: var(--text-soft); line-height: 1.7; }
  .page-mascot { position: relative; z-index: 1; width: min(100%, 13rem); }
  .page-mascot img { width: 100%; display: block; object-fit: contain; }

  .topic-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.15rem; margin-top: 1.45rem; }
  .topic-card { position: relative; overflow: hidden; min-height: 15rem; padding: 1.6rem; border: 1px solid var(--border); border-radius: 24px; color: inherit; box-shadow: var(--shadow-soft); }
  .topic-card::after { content: ""; position: absolute; right: -2.25rem; bottom: -2.5rem; width: 7.8rem; height: 7.8rem; border-radius: 999px; background: rgba(255,255,255,0.07); pointer-events: none; }
  .topic-card.math-a,.topic-card.web-a,.topic-card.cs-a,.topic-card.linux-a,.topic-card.ee-a { background: linear-gradient(135deg, rgba(93,113,175,.28), rgba(232,237,248,.76)); }
  .topic-card.math-b,.topic-card.web-b,.topic-card.cs-b,.topic-card.linux-b,.topic-card.ee-b { background: linear-gradient(135deg, rgba(95,139,158,.20), rgba(235,244,247,.82)); }
  .topic-card.math-c,.topic-card.web-c,.topic-card.cs-c,.topic-card.linux-c,.topic-card.ee-c { background: linear-gradient(135deg, rgba(173,144,156,.22), rgba(245,239,241,.84)); }
  :global(html[data-theme="dark"]) .topic-card.math-a,:global(html[data-theme="dark"]) .topic-card.web-a,:global(html[data-theme="dark"]) .topic-card.cs-a,:global(html[data-theme="dark"]) .topic-card.linux-a,:global(html[data-theme="dark"]) .topic-card.ee-a { background: linear-gradient(135deg, rgba(72,95,164,.36), rgba(22,31,58,.92)); }
  :global(html[data-theme="dark"]) .topic-card.math-b,:global(html[data-theme="dark"]) .topic-card.web-b,:global(html[data-theme="dark"]) .topic-card.cs-b,:global(html[data-theme="dark"]) .topic-card.linux-b,:global(html[data-theme="dark"]) .topic-card.ee-b { background: linear-gradient(135deg, rgba(28,71,87,.40), rgba(18,37,45,.92)); }
  :global(html[data-theme="dark"]) .topic-card.math-c,:global(html[data-theme="dark"]) .topic-card.web-c,:global(html[data-theme="dark"]) .topic-card.cs-c,:global(html[data-theme="dark"]) .topic-card.linux-c,:global(html[data-theme="dark"]) .topic-card.ee-c { background: linear-gradient(135deg, rgba(96,72,104,.34), rgba(49,38,43,.92)); }
  .topic-badge { width: 2.5rem; height: 2.5rem; display: grid; place-items: center; border-radius: 999px; border: 1px solid rgba(148,163,184,.16); background: rgba(255,255,255,.24); color: var(--text-strong); }
  :global(html[data-theme="dark"]) .topic-badge { border-color: rgba(255,255,255,.1); background: rgba(255,255,255,.08); }
  h2 { margin: 1rem 0 0; color: var(--text-strong); font-size: clamp(1.7rem, 2.2vw, 2rem); line-height: 1.05; }
  .topic-card p { margin: .75rem 0 0; color: var(--text); line-height: 1.62; max-width: 18rem; }
  .topic-arrow { position: absolute; right: 1.4rem; bottom: 1.2rem; width: 2.2rem; height: 2.2rem; border-radius: 999px; border: 1px solid rgba(148,163,184,.16); background: rgba(255,255,255,.28); display: grid; place-items: center; color: var(--text-strong); }
  :global(html[data-theme="dark"]) .topic-arrow { border-color: rgba(255,255,255,.12); background: rgba(255,255,255,.10); }
  @media (max-width: 980px) { .page-hero { grid-template-columns: 1fr; padding: 1.8rem 1.4rem 0; } .page-copy { padding-bottom: 1rem; } .page-mascot { justify-self: center; width: min(100%, 10rem); } .topic-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .topline { align-items: flex-start; flex-direction: column; } .topic-card { min-height: 13rem; padding: 1.35rem; } }
</style>
