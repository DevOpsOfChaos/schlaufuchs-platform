---
import Breadcrumbs from "../ui/Breadcrumbs.astro";
import FakeTerminal from "./FakeTerminal.astro";
import ArticleQuiz from "./ArticleQuiz.astro";
import { articleEnhancements } from "../../data/articleEnhancements";

const {
  entry,
  Content,
  headings = [],
  breadcrumbs = [],
  prevLink = null,
  nextLink = null,
} = Astro.props;

const subjectLabelMap = {
  mathematik: "Mathematik",
  informatik: "Informatik",
  linux: "Linux",
  "web-development": "Web Development",
  elektrotechnik: "Elektrotechnik",
  "daten-und-signale": "Daten & Signale",
};

const subjectLabel = subjectLabelMap[entry.data.subject] ?? entry.data.subject;
const articleKey = entry.id.replace(/\.(md|mdx)$/i, "");
const enhancement = articleEnhancements[articleKey];
---

<section class="article-hero">
  <div class="article-copy">
    <Breadcrumbs items={breadcrumbs} />
    <div class="meta-row">
      <span>{subjectLabel}</span>
      <span>{entry.data.level}</span>
      <span>{entry.data.section}</span>
    </div>
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.description}</p>
  </div>
</section>

<div class="article-shell">
  <article class="article-body">
    <Content />

    {enhancement?.interactive?.type === "fake-terminal" && (
      <FakeTerminal config={enhancement.interactive} />
    )}

    {enhancement?.takeaway && (
      <section class="takeaway-card">
        <p class="eyebrow">Merksatz</p>
        <strong>{enhancement.takeaway}</strong>
      </section>
    )}

    {enhancement?.quiz && <ArticleQuiz quiz={enhancement.quiz} />}
  </article>

  <aside class="article-aside">
    {headings.length > 0 && (
      <section class="aside-card">
        <h2>Inhalt</h2>
        <nav>
          <ul>
            {headings.filter((heading) => heading.depth <= 2).map((heading) => (
              <li>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </section>
    )}

    {entry.data.tags?.length > 0 && (
      <section class="aside-card">
        <h2>Tags</h2>
        <div class="tag-list">
          {entry.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </section>
    )}

    {(prevLink || nextLink) && (
      <section class="aside-card nav-card">
        {prevLink && (
          <a href={prevLink.href}>
            <small>Vorherige Info</small>
            <strong>{prevLink.title}</strong>
          </a>
        )}
        {nextLink && (
          <a href={nextLink.href}>
            <small>Nächste Info</small>
            <strong>{nextLink.title}</strong>
          </a>
        )}
      </section>
    )}
  </aside>
</div>

<style>
  .article-hero {
    padding: 0.35rem 0 0;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 0 0 0.9rem;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    line-height: 1.04;
    max-width: 14ch;
  }

  .lead {
    max-width: 48rem;
    margin: 1rem 0 0;
    color: var(--text-soft);
    line-height: 1.72;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 19rem;
    gap: 1.25rem;
    margin-top: 1.4rem;
    align-items: start;
  }

  .article-body {
    padding: 1.55rem 1.6rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .article-body :global(h1:first-child) {
    display: none;
  }

  .article-body :global(h2) {
    margin: 2rem 0 0.85rem;
    color: var(--text-strong);
    font-size: clamp(1.55rem, 2vw, 1.9rem);
    line-height: 1.12;
  }

  .article-body :global(h3) {
    margin: 1.5rem 0 0.7rem;
    color: var(--text-strong);
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .article-body :global(p),
  .article-body :global(li) {
    color: var(--text);
    line-height: 1.72;
  }

  .article-body :global(figure) {
    margin: 1.4rem 0 1.8rem;
  }

  .article-body :global(img) {
    display: block;
    width: min(100%, 760px);
    height: auto;
    margin: 0;
    border-radius: 22px;
    border: 1px solid var(--border);
    background: #ffffff;
    box-shadow: var(--shadow-soft);
  }

  .article-body :global(code) {
    padding: 0.14rem 0.42rem;
    border-radius: 8px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(15, 23, 42, 0.04);
    color: #1d4ed8;
    font-size: 0.94em;
  }

  .article-body :global(pre) {
    width: fit-content;
    max-width: 100%;
    margin: 0.9rem 0 1.15rem;
    overflow-x: auto;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: rgba(15, 23, 42, 0.05);
    box-shadow: var(--shadow-soft);
  }

  .article-body :global(pre code) {
    display: block;
    min-width: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: #6d28d9;
    font-size: 0.98rem;
    line-height: 1.7;
  }

  :global(html[data-theme="dark"]) .article-body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
    color: #93c5fd;
  }

  :global(html[data-theme="dark"]) .article-body :global(pre) {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme="dark"]) .article-body :global(pre code) {
    color: #c4b5fd;
  }

  .takeaway-card {
    margin-top: 1.6rem;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    border: 1px solid var(--border);
    background: linear-gradient(135deg, rgba(93,113,175,.16), rgba(232,237,248,.46));
    box-shadow: var(--shadow-soft);
  }

  :global(html[data-theme="dark"]) .takeaway-card {
    background: linear-gradient(135deg, rgba(72,95,164,.26), rgba(22,31,58,.78));
  }

  .takeaway-card .eyebrow {
    margin: 0 0 0.45rem;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .takeaway-card strong {
    color: var(--text-strong);
    line-height: 1.65;
  }

  .article-aside {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .aside-card {
    padding: 1rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .aside-card h2 {
    margin: 0 0 0.8rem;
    font-size: 1rem;
    color: var(--text-strong);
  }

  .aside-card ul {
    margin: 0;
    padding-left: 1rem;
  }

  .aside-card li + li {
    margin-top: 0.45rem;
  }

  .aside-card a {
    color: var(--text);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tag-list span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.92rem;
  }

  .nav-card {
    display: grid;
    gap: 0.85rem;
  }

  .nav-card small {
    display: block;
    color: var(--text-soft);
  }

  .nav-card strong {
    display: block;
    margin-top: 0.3rem;
    color: var(--text-strong);
  }

  @media (max-width: 1080px) {
    .article-shell {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .article-body {
      padding: 1.2rem;
    }

    .article-aside {
      grid-template-columns: 1fr;
    }
  }
</style>
