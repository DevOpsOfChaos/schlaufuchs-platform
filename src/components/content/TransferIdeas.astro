---
interface Props {
  items: string[];
}

const { items } = Astro.props as Props;
---

{items.length > 0 && (
  <section class="transfer-box">
    <p class="box-kicker">Transfer</p>
    <h2>So ziehst du das Thema weiter</h2>
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </section>
)}

<style>
  .transfer-box {
    display: grid;
    gap: 0.8rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: color-mix(in oklab, var(--card-bg) 96%, #f5f3ff 4%);
    box-shadow: var(--shadow-soft);
  }

  .box-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--text);
    line-height: 1.68;
  }

  li::before {
    content: "↗";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 800;
  }
</style>
