---
const { section } = Astro.props;
const base = import.meta.env.BASE_URL;
const mascotSrc = `${base}${section.mascot.replace(/^\//, "")}`;
---

<section class="section-hero">
  <div class="section-copy">
    <p class="eyebrow">{section.eyebrow}</p>
    <h1>{section.title}</h1>
    <p class="lead">{section.description}</p>
  </div>

  <div class="section-mascot" aria-hidden="true">
    <img src={mascotSrc} alt="" loading="eager" />
  </div>
</section>

<section class="group-grid">
  {section.groups.map((group) => (
    <article class={`group-card ${group.tone}`}>
      <h2>{group.title}</h2>
      <div class="item-list">
        {group.items.map((item) => (
          <a href={`${base}${item.href.replace(/^\//, "")}`}>{item.label}</a>
        ))}
      </div>
    </article>
  ))}
</section>

<style>
  .section-hero { position: relative; overflow: hidden; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1.2rem; align-items: end; padding: 2.1rem 2.1rem 0; border: 1px solid var(--border); border-radius: 28px; background: var(--card-bg); box-shadow: var(--shadow-card); }
  .section-hero::after { content: ""; position: absolute; right: -90px; bottom: -110px; width: 240px; height: 240px; border-radius: 50%; background: rgba(127, 140, 255, 0.12); }
  .section-copy { position: relative; z-index: 1; padding-bottom: 1.8rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--text-soft); }
  h1 { margin: 0; color: var(--text-strong); font-size: clamp(2.4rem, 4vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
  .lead { margin: 1rem 0 0; max-width: 42rem; color: var(--text-soft); line-height: 1.7; }
  .section-mascot { position: relative; z-index: 1; width: min(100%, 13rem); }
  .section-mascot img { width: 100%; display: block; object-fit: contain; }

  .group-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.15rem; margin-top: 1.45rem; }
  .group-card { position: relative; overflow: hidden; min-height: 18rem; padding: 1.7rem; border: 1px solid var(--border); border-radius: 24px; box-shadow: var(--shadow-soft); }
  .group-card::after { content: ""; position: absolute; right: -2.25rem; bottom: -2.5rem; width: 7.8rem; height: 7.8rem; border-radius: 999px; background: rgba(255,255,255,0.07); pointer-events: none; }

  .group-card.math-a { background: linear-gradient(135deg, rgba(93, 113, 175, 0.28), rgba(232, 237, 248, 0.76)); }
  .group-card.math-b { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .group-card.math-c { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }
  :global(html[data-theme="dark"]) .group-card.math-a { background: linear-gradient(135deg, rgba(72, 95, 164, 0.36), rgba(22, 31, 58, 0.92)); }
  :global(html[data-theme="dark"]) .group-card.math-b { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .group-card.math-c { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }

  h2 { margin: 0; color: var(--text-strong); font-size: clamp(1.8rem, 2.2vw, 2.2rem); line-height: 1.05; }
  .item-list { display: grid; gap: 0.7rem; margin-top: 1.2rem; }
  .item-list a { display: inline-flex; align-items: center; min-height: 2.8rem; padding: 0 0.95rem; border-radius: 999px; border: 1px solid rgba(148,163,184,0.16); background: rgba(255,255,255,0.24); color: var(--text-strong); width: fit-content; max-width: 100%; }
  :global(html[data-theme="dark"]) .item-list a { border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.08); }

  @media (max-width: 980px) {
    .section-hero { grid-template-columns: 1fr; padding: 1.8rem 1.4rem 0; }
    .section-copy { padding-bottom: 1rem; }
    .section-mascot { justify-self: center; width: min(100%, 10rem); }
    .group-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .group-card { min-height: 14rem; padding: 1.4rem; }
    .item-list a { width: 100%; }
  }
</style>
