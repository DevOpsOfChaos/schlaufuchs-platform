---
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  targetHref: string;
}

const { title, description, targetHref } = Astro.props as Props;
---

<BaseLayout title={`${title} – Fachinfo`} description={description}>
  <script is:inline define:vars={{ targetHref }}>
    window.location.replace(targetHref);
  </script>

  <section class="leaf-shell">
    <p class="eyebrow">Weiterleitung</p>
    <h1>{title}</h1>
    <p class="lead">Die ausführliche Wissensseite wird geöffnet, damit du direkt auf der zentralen Wissensansicht landest.</p>
    <a class="leaf-link" href={targetHref}>Zur Wissensseite →</a>
  </section>
</BaseLayout>

<style>
  .leaf-shell {
    display: grid;
    gap: 1rem;
    padding: clamp(1.4rem, 2vw, 2rem);
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .lead {
    margin: 0;
    max-width: 48rem;
    color: var(--text);
    line-height: 1.75;
  }

  .leaf-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.9rem;
    width: fit-content;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }
</style>
