---
interface Props {
  kicker?: string;
  title: string;
  body: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  kicker = "Hinweis",
  title,
  body,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props as Props;
---

<section class="empty-card">
  <p class="empty-kicker">{kicker}</p>
  <h2>{title}</h2>
  <p>{body}</p>

  {(primaryHref || secondaryHref) && (
    <div class="empty-actions">
      {primaryHref && primaryLabel && <a class="empty-link" href={primaryHref}>{primaryLabel}</a>}
      {secondaryHref && secondaryLabel && <a class="empty-link secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</section>

<style>
  .empty-card {
    display: grid;
    gap: 0.95rem;
    padding: 1.25rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .empty-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.4rem, 2.3vw, 1.8rem);
    line-height: 1.1;
  }

  p {
    margin: 0;
    color: var(--text);
    line-height: 1.72;
  }

  .empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .empty-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.8rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .empty-link.secondary {
    background: transparent;
    box-shadow: none;
  }

  .empty-link:hover,
  .empty-link:focus-visible {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    outline: none;
  }
</style>
