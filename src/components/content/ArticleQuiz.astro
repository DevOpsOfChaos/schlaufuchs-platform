---
const { quiz } = Astro.props;
---

<section class="learn-quiz-shell" data-article-quiz>
  <div class="learn-entry">
    <p class="eyebrow">Lernmodus</p>
    <h2>{quiz.title}</h2>
    <p class="lead">{quiz.description}</p>
    <button type="button" class="start-button" data-start-quiz>Kurztest starten</button>
  </div>

  <div class="quiz-overlay" hidden data-quiz-overlay>
    <div class="quiz-dialog" data-quiz-dialog>
      <div class="quiz-dialog-head">
        <div>
          <p class="eyebrow">Lernmodus aktiv</p>
          <h2>{quiz.title}</h2>
        </div>
        <button type="button" class="close-button" data-close-quiz>Test verlassen</button>
      </div>

      <div class="quiz-question-list">
        {quiz.questions.map((question, index) => (
          <fieldset
            class="quiz-question"
            data-question
            data-correct-index={question.correctIndex}
            data-correct-explanation={question.correctExplanation}
            data-wrong-explanation={question.wrongExplanation}
          >
            <legend>{index + 1}. {question.prompt}</legend>

            <div class="options">
              {question.options.map((option, optionIndex) => (
                <label class="option-row">
                  <input
                    type="radio"
                    name={`quiz-${index}`}
                    value={optionIndex}
                  />
                  <span>{option}</span>
                </label>
              ))}
            </div>

            <div class="result-box" hidden data-result-box></div>
          </fieldset>
        ))}
      </div>

      <div class="quiz-actions">
        <button type="button" class="evaluate-button" data-evaluate-quiz>Auswerten</button>
      </div>
    </div>
  </div>
</section>

<script>
  const syncQuizVisibility = () => {
    document.querySelectorAll("[data-article-quiz]").forEach((root) => {
      const learnOn = document.documentElement.dataset.learnMode === "on";
      root.toggleAttribute("hidden", !learnOn);
      if (!learnOn) {
        const overlay = root.querySelector("[data-quiz-overlay]");
        if (overlay) overlay.hidden = true;
        document.body.style.overflow = "";
      }
    });
  };

  syncQuizVisibility();
  window.addEventListener("learnmode-changed", syncQuizVisibility);

  document.querySelectorAll("[data-article-quiz]").forEach((root) => {
    const start = root.querySelector("[data-start-quiz]");
    const close = root.querySelector("[data-close-quiz]");
    const evaluate = root.querySelector("[data-evaluate-quiz]");
    const overlay = root.querySelector("[data-quiz-overlay]");
    const questions = Array.from(root.querySelectorAll("[data-question]"));

    const closeQuiz = () => {
      if (overlay) overlay.hidden = true;
      document.body.style.overflow = "";
    };

    const openQuiz = () => {
      if (overlay) overlay.hidden = false;
      document.body.style.overflow = "hidden";
    };

    start?.addEventListener("click", openQuiz);
    close?.addEventListener("click", closeQuiz);

    overlay?.addEventListener("click", (event) => {
      if (event.target === overlay) closeQuiz();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && overlay && !overlay.hidden) {
        closeQuiz();
      }
    });

    evaluate?.addEventListener("click", () => {
      questions.forEach((question) => {
        const selected = question.querySelector("input[type='radio']:checked");
        const result = question.querySelector("[data-result-box]");
        if (!result) return;

        const correctIndex = Number(question.getAttribute("data-correct-index"));
        const correctExplanation = question.getAttribute("data-correct-explanation") || "";
        const wrongExplanation = question.getAttribute("data-wrong-explanation") || "";

        if (!selected) {
          result.hidden = false;
          result.className = "result-box pending";
          result.textContent = "Bitte wähle zuerst eine Antwort aus.";
          return;
        }

        const chosen = Number(selected.value);
        const isCorrect = chosen === correctIndex;

        result.hidden = false;
        result.className = isCorrect ? "result-box correct" : "result-box wrong";
        result.textContent = isCorrect
          ? `Richtig. ${correctExplanation}`
          : `Falsch. ${wrongExplanation}`;
      });
    });
  });
</script>

<style>
  .learn-quiz-shell { margin-top: 1.6rem; }
  .learn-entry { padding: 1.15rem 1.2rem; border-radius: 24px; border: 1px solid var(--border); background: var(--card-bg); box-shadow: var(--shadow-soft); }
  .eyebrow { margin: 0 0 0.4rem; color: var(--text-soft); font-size: 0.92rem; }
  .learn-entry h2, .quiz-dialog h2 { margin: 0; color: var(--text-strong); font-size: 1.4rem; line-height: 1.15; }
  .lead { margin: 0.8rem 0 0; color: var(--text-soft); line-height: 1.65; }
  .start-button, .close-button, .evaluate-button { min-height: 2.8rem; padding: 0 1rem; border-radius: 14px; border: 1px solid var(--border); background: var(--surface); color: var(--text-strong); box-shadow: var(--shadow-soft); font: inherit; cursor: pointer; }
  .start-button { margin-top: 1rem; }
  .quiz-overlay { position: fixed; inset: 0; z-index: 120; display: grid; place-items: center; padding: 1.2rem; background: rgba(2, 8, 23, 0.76); backdrop-filter: blur(8px); }
  .quiz-dialog { width: min(100%, 56rem); max-height: min(88vh, 58rem); overflow: auto; padding: 1.2rem; border-radius: 26px; border: 1px solid var(--border); background: var(--card-bg); box-shadow: var(--shadow-card); }
  .quiz-dialog-head { display: flex; align-items: start; justify-content: space-between; gap: 1rem; }
  .quiz-question-list { display: grid; gap: 1rem; margin-top: 1rem; }
  .quiz-question { margin: 0; padding: 1rem; border-radius: 20px; border: 1px solid var(--border); background: var(--surface); }
  .quiz-question legend { padding: 0; color: var(--text-strong); font-weight: 700; margin-bottom: 0.8rem; }
  .options { display: grid; gap: 0.7rem; }
  .option-row { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 0.7rem; align-items: start; color: var(--text); }
  .result-box { margin-top: 0.9rem; padding: 0.85rem 0.95rem; border-radius: 16px; line-height: 1.6; }
  .result-box.pending { background: rgba(148, 163, 184, 0.12); color: var(--text); }
  .result-box.correct { background: rgba(34, 197, 94, 0.14); color: var(--text-strong); }
  .result-box.wrong { background: rgba(239, 68, 68, 0.14); color: var(--text-strong); }
  .quiz-actions { display: flex; justify-content: flex-end; margin-top: 1rem; }
  @media (max-width: 720px) {
    .quiz-dialog-head { flex-direction: column; }
    .quiz-actions { justify-content: stretch; }
    .evaluate-button { width: 100%; }
  }
</style>
