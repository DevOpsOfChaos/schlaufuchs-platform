---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
  ctaLabel: string;
  icon: string;
  variant?: "task" | "article" | "topic";
  accent?: "a" | "b" | "c" | "d";
  compact?: boolean;
}

const {
  title,
  description,
  meta,
  href,
  ctaLabel,
  icon,
  variant = "article",
  accent = "a",
  compact = false,
} = Astro.props as Props;

const eyebrowMap = {
  task: "Aufgabe",
  article: "Erklärung",
  topic: "Thema",
} as const;

const arrowIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M5 12h14"></path>
  <path d="m13 6 6 6-6 6"></path>
</svg>`;
---

<article class:list={["resource-card", variant, `accent-${accent}`, compact ? "compact" : undefined]}>
  <div class:list={["icon-badge", variant === "article" ? "secondary" : undefined]} aria-hidden="true" set:html={icon} />
  <div class="resource-copy">
    <div class="resource-topline">
      <p class="eyebrow">{eyebrowMap[variant]}</p>
      <span class="meta-chip">{meta}</span>
    </div>

    <div class="resource-main">
      <h3>{title}</h3>
      {!compact && <p>{description}</p>}
    </div>

    <a class="resource-link" href={href}>
      <span>{ctaLabel}</span>
      <span class="cta-icon" aria-hidden="true" set:html={arrowIcon} />
    </a>
  </div>
</article>

<style>
  .resource-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .resource-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .resource-card.article.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.14), rgba(244,247,255,0.96)); }
  .resource-card.article.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.14), rgba(243,249,244,0.96)); }
  .resource-card.article.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.14), rgba(251,245,243,0.96)); }
  .resource-card.article.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.14), rgba(250,247,239,0.96)); }

  .resource-card.task.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.18), rgba(240,244,255,0.96)); }
  .resource-card.task.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.18), rgba(239,247,241,0.96)); }
  .resource-card.task.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.18), rgba(250,242,239,0.96)); }
  .resource-card.task.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.18), rgba(249,244,233,0.96)); }

  :global(html[data-theme="dark"]) .resource-card.article.accent-a,
  :global(html[data-theme="dark"]) .resource-card.task.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.24), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-b,
  :global(html[data-theme="dark"]) .resource-card.task.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.22), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-c,
  :global(html[data-theme="dark"]) .resource-card.task.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.22), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-d,
  :global(html[data-theme="dark"]) .resource-card.task.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.20), rgba(44,37,21,0.94)); }

  .resource-card.compact {
    gap: 0.8rem;
    padding: 0.95rem 1rem;
  }

  .icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 18px;
    background: color-mix(in oklab, var(--surface-strong) 84%, #4f46e5 16%);
    color: white;
    flex-shrink: 0;
    box-shadow: var(--shadow-soft);
  }

  .icon-badge.secondary {
    background: rgba(255,255,255,0.42);
    color: var(--text-strong);
    border: 1px solid rgba(148,163,184,0.18);
  }

  .icon-badge :global(svg),
  .cta-icon :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .resource-copy {
    display: grid;
    gap: 0.7rem;
    min-width: 0;
    align-content: start;
  }

  .resource-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.08rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.18);
    background: rgba(255,255,255,0.34);
    color: var(--text-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .resource-main {
    display: grid;
    gap: 0.45rem;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.02rem;
    line-height: 1.22;
  }

  p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.96rem;
  }

  .resource-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-strong);
    font-weight: 700;
    margin-top: 0.1rem;
    font-size: 0.95rem;
  }

  .cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.3rem;
    height: 1.3rem;
    border-radius: 999px;
  }

  @media (max-width: 720px) {
    .resource-card {
      grid-template-columns: 1fr;
    }

    .icon-badge {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>
