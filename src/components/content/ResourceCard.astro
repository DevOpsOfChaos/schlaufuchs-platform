---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
  ctaLabel: string;
  icon: string;
  variant?: "task" | "article" | "topic";
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
  compact?: boolean;
}

const {
  title,
  description,
  meta,
  href,
  icon,
  variant = "article",
  accent = "a",
  compact = false,
} = Astro.props as Props;
---

<a class:list={["resource-card", variant, `accent-${accent}`, compact ? "compact" : undefined]} href={href}>
  <span class:list={["icon-badge", variant === "article" ? "secondary" : undefined]} aria-hidden="true" set:html={icon} />
  <div class="resource-copy">
    <p class="meta-line">{meta}</p>
    <h3>{title}</h3>
    {!compact && <p class="description">{description}</p>}
  </div>
  <span class="card-arrow" aria-hidden="true">→</span>
</a>

<style>
  .resource-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.95rem;
    align-items: start;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .resource-card:hover,
  .resource-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    outline: none;
  }

  .resource-card:hover .card-arrow,
  .resource-card:focus-visible .card-arrow {
    transform: translateX(2px);
    border-color: rgba(148, 163, 184, 0.34);
  }

  .resource-card.article.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.28), rgba(240,244,255,0.98)); }
  .resource-card.article.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.28), rgba(238,248,240,0.98)); }
  .resource-card.article.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.28), rgba(251,240,236,0.98)); }
  .resource-card.article.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.28), rgba(249,244,231,0.98)); }
  .resource-card.article.accent-e { background: linear-gradient(135deg, rgba(98,166,178,0.28), rgba(235,247,249,0.98)); }
  .resource-card.article.accent-f { background: linear-gradient(135deg, rgba(160,120,176,0.28), rgba(246,238,250,0.98)); }

  .resource-card.task.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.34), rgba(234,240,255,0.98)); }
  .resource-card.task.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.34), rgba(232,246,236,0.98)); }
  .resource-card.task.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.34), rgba(248,237,233,0.98)); }
  .resource-card.task.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.34), rgba(247,241,227,0.98)); }
  .resource-card.task.accent-e { background: linear-gradient(135deg, rgba(98,166,178,0.34), rgba(231,245,247,0.98)); }
  .resource-card.task.accent-f { background: linear-gradient(135deg, rgba(160,120,176,0.34), rgba(243,235,248,0.98)); }

  :global(html[data-theme="dark"]) .resource-card.article.accent-a,
  :global(html[data-theme="dark"]) .resource-card.task.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.32), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-b,
  :global(html[data-theme="dark"]) .resource-card.task.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.30), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-c,
  :global(html[data-theme="dark"]) .resource-card.task.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.30), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-d,
  :global(html[data-theme="dark"]) .resource-card.task.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.28), rgba(44,37,21,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-e,
  :global(html[data-theme="dark"]) .resource-card.task.accent-e { background: linear-gradient(135deg, rgba(38,92,106,0.30), rgba(18,41,48,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-f,
  :global(html[data-theme="dark"]) .resource-card.task.accent-f { background: linear-gradient(135deg, rgba(94,66,108,0.30), rgba(38,25,47,0.94)); }

  .resource-card.compact {
    gap: 0.8rem;
    padding: 0.95rem 1rem;
  }

  .icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 18px;
    background: color-mix(in oklab, var(--surface-strong) 84%, #4f46e5 16%);
    color: white;
    box-shadow: var(--shadow-soft);
    flex-shrink: 0;
  }

  .icon-badge.secondary {
    background: rgba(255,255,255,0.42);
    color: var(--text-strong);
    border: 1px solid rgba(148,163,184,0.2);
  }

  .icon-badge :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .resource-copy {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
    align-content: start;
  }

  .meta-line {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.06rem;
    line-height: 1.24;
  }

  .description {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
    font-size: 0.96rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.18);
    background: rgba(255,255,255,0.28);
    color: var(--text-strong);
    font-weight: 700;
    transition: transform 140ms ease, border-color 140ms ease;
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .resource-card {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .card-arrow {
      grid-column: 2;
      justify-self: end;
      margin-top: -0.15rem;
    }

    .icon-badge {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>
