---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
  ctaLabel: string;
  icon: string;
  variant?: "task" | "article" | "topic";
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  meta,
  href,
  ctaLabel,
  icon,
  variant = "article",
  accent = "a",
} = Astro.props as Props;

const eyebrowMap = {
  task: "Aufgabe",
  article: "Wissensseite",
  topic: "Thema",
} as const;

const arrowIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M5 12h14"></path>
  <path d="m13 6 6 6-6 6"></path>
</svg>`;
---

<article class:list={["resource-card", variant, `accent-${accent}`]}>
  <div class:list={["icon-badge", variant === "article" ? "secondary" : undefined]} aria-hidden="true" set:html={icon} />
  <div class="resource-copy">
    <div class="resource-topline">
      <p class="eyebrow">{eyebrowMap[variant]}</p>
      <span class="meta-chip">{meta}</span>
    </div>

    <div class="resource-main">
      <h3>{title}</h3>
      <p>{description}</p>
    </div>

    <a class="resource-link" href={href}>
      <span>{ctaLabel}</span>
      <span class="cta-icon" aria-hidden="true" set:html={arrowIcon} />
    </a>
  </div>
</article>

<style>
  .resource-card { display:grid; grid-template-columns:auto minmax(0,1fr); gap:1rem; padding:1.1rem 1.15rem; border:1px solid var(--border); border-radius:26px; background:var(--card-bg); box-shadow:var(--shadow-soft); transition:transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease; }
  .resource-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-card); border-color:var(--border-strong); }
  .resource-card.article.accent-a { background:linear-gradient(135deg, rgba(93,113,175,0.12), rgba(232,237,248,0.96)); }
  .resource-card.article.accent-b { background:linear-gradient(135deg, rgba(117,156,124,0.12), rgba(236,245,238,0.96)); }
  .resource-card.article.accent-c { background:linear-gradient(135deg, rgba(186,138,123,0.12), rgba(247,239,235,0.96)); }
  .resource-card.article.accent-d { background:linear-gradient(135deg, rgba(176,160,104,0.12), rgba(245,241,228,0.96)); }
  .resource-card.task { position:relative; overflow:hidden; }
  .resource-card.task::before { content:""; position:absolute; inset:0 auto 0 0; width:.34rem; border-radius:999px; }
  .resource-card.task.accent-a { background:linear-gradient(135deg, rgba(93,113,175,0.14), rgba(232,237,248,0.96)); }
  .resource-card.task.accent-a::before { background:#5d71af; }
  .resource-card.task.accent-b { background:linear-gradient(135deg, rgba(117,156,124,0.14), rgba(236,245,238,0.96)); }
  .resource-card.task.accent-b::before { background:#759c7c; }
  .resource-card.task.accent-c { background:linear-gradient(135deg, rgba(186,138,123,0.14), rgba(247,239,235,0.96)); }
  .resource-card.task.accent-c::before { background:#ba8a7b; }
  .resource-card.task.accent-d { background:linear-gradient(135deg, rgba(176,160,104,0.14), rgba(245,241,228,0.96)); }
  .resource-card.task.accent-d::before { background:#b0a068; }

  :global(html[data-theme="dark"]) .resource-card.article.accent-a { background:linear-gradient(135deg, rgba(72,95,164,0.26), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-b { background:linear-gradient(135deg, rgba(52,93,67,0.24), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-c { background:linear-gradient(135deg, rgba(110,71,58,0.24), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.article.accent-d { background:linear-gradient(135deg, rgba(92,80,36,0.22), rgba(44,37,21,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.task.accent-a { background:linear-gradient(135deg, rgba(72,95,164,0.28), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.task.accent-b { background:linear-gradient(135deg, rgba(52,93,67,0.26), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.task.accent-c { background:linear-gradient(135deg, rgba(110,71,58,0.26), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .resource-card.task.accent-d { background:linear-gradient(135deg, rgba(92,80,36,0.24), rgba(44,37,21,0.94)); }

  .icon-badge { display:inline-flex; align-items:center; justify-content:center; width:3rem; height:3rem; border-radius:18px; background:color-mix(in oklab, var(--surface-strong) 84%, #4f46e5 16%); color:white; flex-shrink:0; box-shadow:var(--shadow-soft); }
  .icon-badge.secondary { background:rgba(255,255,255,.42); color:var(--text-strong); border:1px solid rgba(148, 163, 184, .18); }
  .icon-badge :global(svg), .cta-icon :global(svg) { width:1.15rem; height:1.15rem; stroke:currentColor; fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; }
  .resource-copy { display:grid; gap:.8rem; min-width:0; align-content:start; }
  .resource-topline { display:flex; align-items:center; justify-content:space-between; gap:.8rem; flex-wrap:wrap; }
  .eyebrow { margin:0; color:var(--text-soft); font-size:.77rem; font-weight:800; letter-spacing:.05em; text-transform:uppercase; }
  .meta-chip { display:inline-flex; align-items:center; min-height:1.9rem; padding:.1rem .65rem; border-radius:999px; border:1px solid rgba(148, 163, 184, .18); background:rgba(255,255,255,.28); color:var(--text-strong); font-size:.82rem; font-weight:700; }
  .resource-main { display:grid; gap:.5rem; }
  h3 { margin:0; color:var(--text-strong); font-size:1.06rem; line-height:1.24; }
  p { margin:0; color:var(--text); line-height:1.62; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .resource-link { display:inline-flex; align-items:center; gap:.45rem; color:var(--text-strong); font-weight:700; margin-top:.1rem; }
  .cta-icon { display:inline-flex; align-items:center; justify-content:center; width:1.35rem; height:1.35rem; border-radius:999px; }
  @media (max-width:720px){ .resource-card { grid-template-columns:1fr; } .icon-badge { width:2.8rem; height:2.8rem; } }
</style>
