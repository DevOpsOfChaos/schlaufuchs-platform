---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
  ctaLabel: string;
  icon: string;
  variant?: "task" | "article" | "topic";
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
  compact?: boolean;
}

const {
  title,
  description,
  meta,
  href,
  ctaLabel,
  icon,
  variant = "article",
  accent = "a",
  compact = false,
} = Astro.props as Props;

const eyebrowMap = {
  task: "Aufgabe",
  article: "Erklärung",
  topic: "Thema",
} as const;
---

<a class:list={["resource-card", variant, `accent-${accent}`, compact ? "compact" : undefined]} href={href} aria-label={`${title} – ${description}`}>
  <div class:list={["icon-badge", variant === "article" ? "secondary" : undefined]} aria-hidden="true" set:html={icon} />
  <div class="resource-copy">
    <div class="resource-topline">
      <p class="eyebrow">{eyebrowMap[variant]}</p>
      <span class="meta-chip">{meta}</span>
    </div>

    <div class="resource-main">
      <h3>{title}</h3>
      {!compact && <p>{description}</p>}
    </div>
  </div>
  <span class="resource-arrow" aria-hidden="true">→</span>
</a>

<style>
  .resource-card {
    --accent-rgb: 86, 110, 214;
    --accent-surface: 239, 244, 255;
    --accent-dark: 24, 32, 64;

    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
    min-height: 100%;
    padding: 0.92rem 0.98rem;
    border: 1px solid rgba(var(--accent-rgb), 0.18);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    overflow: hidden;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .resource-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.74);
    opacity: 0.8;
    pointer-events: none;
  }

  .resource-card.article {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.28), rgba(var(--accent-surface), 0.98));
  }

  .resource-card.task,
  .resource-card.topic {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.42), rgba(var(--accent-surface), 0.92));
    border-color: rgba(var(--accent-rgb), 0.26);
  }

  .resource-card.task::before,
  .resource-card.topic::before {
    opacity: 1;
  }

  :global(html[data-theme="dark"]) .resource-card.article {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.34), rgba(var(--accent-dark), 0.94));
    border-color: rgba(var(--accent-rgb), 0.24);
  }

  :global(html[data-theme="dark"]) .resource-card.task,
  :global(html[data-theme="dark"]) .resource-card.topic {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.48), rgba(var(--accent-dark), 0.88));
    border-color: rgba(var(--accent-rgb), 0.34);
  }

  .resource-card:hover,
  .resource-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: rgba(var(--accent-rgb), 0.34);
    filter: saturate(1.06);
    outline: none;
  }

  .resource-card:hover .resource-arrow,
  .resource-card:focus-visible .resource-arrow {
    transform: translateX(2px);
  }

  .resource-card.accent-a {
    --accent-rgb: 86, 110, 214;
    --accent-surface: 239, 244, 255;
    --accent-dark: 24, 32, 64;
  }

  .resource-card.accent-b {
    --accent-rgb: 53, 154, 109;
    --accent-surface: 236, 248, 241;
    --accent-dark: 15, 44, 30;
  }

  .resource-card.accent-c {
    --accent-rgb: 214, 116, 82;
    --accent-surface: 252, 241, 236;
    --accent-dark: 52, 27, 22;
  }

  .resource-card.accent-d {
    --accent-rgb: 188, 152, 54;
    --accent-surface: 250, 245, 228;
    --accent-dark: 48, 38, 16;
  }

  .resource-card.accent-e {
    --accent-rgb: 55, 140, 186;
    --accent-surface: 235, 247, 252;
    --accent-dark: 17, 39, 49;
  }

  .resource-card.accent-f {
    --accent-rgb: 152, 90, 196;
    --accent-surface: 246, 239, 252;
    --accent-dark: 41, 24, 55;
  }

  .resource-card.compact {
    gap: 0.72rem;
    padding: 0.88rem 0.94rem;
  }

  .icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 18px;
    background: rgba(var(--accent-rgb), 0.78);
    color: white;
    flex-shrink: 0;
    box-shadow: var(--shadow-soft);
  }

  .icon-badge.secondary {
    background: rgba(255, 255, 255, 0.32);
    color: var(--text-strong);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  :global(html[data-theme="dark"]) .icon-badge.secondary {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .icon-badge :global(svg) {
    width: 1.02rem;
    height: 1.02rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .resource-copy {
    display: grid;
    gap: 0.42rem;
    min-width: 0;
  }

  .resource-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.68rem;
    padding: 0.06rem 0.52rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.24);
    color: var(--text-strong);
    font-size: 0.76rem;
    font-weight: 700;
  }

  :global(html[data-theme="dark"]) .meta-chip {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .resource-main {
    display: grid;
    gap: 0.32rem;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 0.98rem;
    line-height: 1.22;
  }

  p {
    margin: 0;
    color: var(--text);
    line-height: 1.56;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.92rem;
  }

  .resource-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.05rem;
    height: 2.05rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
    pointer-events: none;
    transition: transform 140ms ease;
  }

  :global(html[data-theme="dark"]) .resource-arrow {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 720px) {
    .resource-card {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .resource-arrow {
      display: none;
    }
  }
</style>
