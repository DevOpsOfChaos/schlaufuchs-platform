---
const base = import.meta.env.BASE_URL ?? "/";
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const defaultFallbackImageSrc = `${normalizedBase}assets/mascots/math.png`;

interface Props {
  title: string;
  scopeLabel: string;
  imageSrc?: string;
  imageAlt?: string;
  tone?: string;
  showSearch?: boolean;
  searchPlaceholder?: string;
  inputName?: string;
  searchHint?: string;
  fallbackImageSrc?: string;
}

const {
  title,
  scopeLabel,
  imageSrc,
  imageAlt = "",
  tone = "math",
  showSearch = false,
  searchPlaceholder = "",
  inputName = "area-search",
  searchHint = "",
  fallbackImageSrc = defaultFallbackImageSrc,
} = Astro.props as Props;
---

<section class={`area-hero ${tone}`}>
  <div class="hero-copy">
    <p class="eyebrow">{scopeLabel}</p>
    <h1>{title}</h1>

    {showSearch && (
      <>
        <label class="search-shell" data-area-search-label>
          <span class="sr-only">{searchPlaceholder}</span>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="6.5"></circle>
            <path d="M16 16l4.5 4.5"></path>
          </svg>
          <input data-area-search-input name={inputName} type="search" placeholder={searchPlaceholder} autocomplete="off" />
        </label>
        {searchHint && <p class="search-hint">{searchHint}</p>}
      </>
    )}
  </div>

  <div class="hero-visual" data-image-missing={imageSrc ? undefined : "true"} aria-hidden={imageSrc ? undefined : "true"}>
    {imageSrc && (
      <img
        src={imageSrc}
        alt={imageAlt}
        loading="eager"
        fetchpriority="high"
        data-fallback-src={fallbackImageSrc}
        onerror="const fallback=this.dataset.fallbackSrc; if (fallback && this.getAttribute('src') !== fallback) { this.setAttribute('src', fallback); return; } this.hidden=true; this.parentElement?.setAttribute('data-image-missing','true');"
      />
    )}
    <div class="image-placeholder"></div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .area-hero {
    --tone-rgb: 93, 113, 175;
    --tone-surface: 232, 237, 248;
    --tone-dark: 22, 31, 58;

    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(11.5rem, 28vw, 16rem);
    gap: 1rem;
    align-items: center;
    min-height: 10.5rem;
    padding: 0.95rem 1.05rem;
    border: 1px solid rgba(var(--tone-rgb), 0.18);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(145deg, rgba(var(--tone-rgb), 0.34), rgba(var(--tone-surface), 0.96));
  }

  .area-hero.math { --tone-rgb: 93, 113, 175; --tone-surface: 232, 237, 248; --tone-dark: 22, 31, 58; }
  .area-hero.web { --tone-rgb: 173, 118, 146; --tone-surface: 245, 237, 241; --tone-dark: 51, 35, 44; }
  .area-hero.cs { --tone-rgb: 73, 143, 171; --tone-surface: 234, 244, 248; --tone-dark: 17, 39, 49; }
  .area-hero.linux { --tone-rgb: 173, 156, 86; --tone-surface: 246, 241, 224; --tone-dark: 44, 40, 24; }
  .area-hero.ee { --tone-rgb: 179, 112, 94; --tone-surface: 247, 237, 234; --tone-dark: 47, 28, 27; }

  :global(html[data-theme="dark"]) .area-hero {
    background: linear-gradient(145deg, rgba(var(--tone-rgb), 0.42), rgba(var(--tone-dark), 0.92));
    border-color: rgba(var(--tone-rgb), 0.24);
  }

  .hero-copy {
    display: grid;
    gap: 0.7rem;
    align-content: start;
    min-width: 0;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 11ch;
  }

  .search-shell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.7rem;
    min-height: 3.15rem;
    padding: 0 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.24);
    box-shadow: var(--shadow-soft);
  }

  :global(html[data-theme="dark"]) .search-shell {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .search-shell svg {
    width: 1.05rem;
    height: 1.05rem;
    stroke: var(--text-soft);
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-shell input {
    min-width: 0;
    border: 0;
    outline: none;
    background: transparent;
    color: var(--text-strong);
    font: inherit;
  }

  .search-shell input::placeholder {
    color: var(--text-soft);
  }

  .search-hint {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .hero-visual {
    display: grid;
    align-self: stretch;
    align-items: end;
    justify-items: center;
    min-height: 0;
    overflow: hidden;
    padding-right: 0.15rem;
  }

  .hero-visual img {
    width: auto;
    max-width: 100%;
    max-height: 13.75rem;
    height: auto;
    display: block;
    object-fit: contain;
    object-position: center bottom;
  }

  .image-placeholder {
    display: none;
    width: 100%;
    max-width: 11.5rem;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.14);
  }

  .hero-visual[data-image-missing="true"] .image-placeholder {
    display: block;
  }

  .hero-visual[data-image-missing="true"] img {
    display: none;
  }

  :global(html[data-theme="dark"]) .image-placeholder {
    background: rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 1040px) {
    .area-hero {
      grid-template-columns: minmax(0, 1fr) clamp(10rem, 24vw, 13rem);
      min-height: 10rem;
      gap: 0.85rem;
      padding: 0.92rem 0.98rem;
    }

    h1 {
      font-size: clamp(1.85rem, 4.3vw, 2.8rem);
      max-width: 10ch;
    }

    .hero-visual img {
      max-height: 11.4rem;
    }

    .image-placeholder {
      max-width: 9.75rem;
    }
  }

  @media (max-width: 760px) {
    .area-hero {
      grid-template-columns: minmax(0, 1fr) 9.2rem;
      min-height: 8.8rem;
    }

    .hero-visual img {
      max-height: 9.1rem;
    }

    .image-placeholder {
      max-width: 8.3rem;
    }
  }

  @media (max-width: 620px) {
    .area-hero {
      grid-template-columns: 1fr;
      padding: 0.92rem;
    }

    .hero-visual {
      justify-items: start;
      min-height: 6.1rem;
    }

    .hero-visual img {
      max-height: 8rem;
    }

    .image-placeholder {
      max-width: 7.5rem;
    }
  }
</style>
