---
interface Props {
  title: string;
  scopeLabel: string;
  searchPlaceholder: string;
  imageSrc?: string;
  imageAlt?: string;
  tone?: string;
  inputName?: string;
  searchHint?: string;
}

const {
  title,
  scopeLabel,
  searchPlaceholder,
  imageSrc,
  imageAlt = "",
  tone = "math",
  inputName = "area-search",
  searchHint = "",
} = Astro.props as Props;
---

<section class={`area-hero ${tone}`}>
  <div class="hero-copy">
    <p class="eyebrow">{scopeLabel}</p>
    <h1>{title}</h1>
    <label class="search-shell" data-area-search-label>
      <span class="sr-only">{searchPlaceholder}</span>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="6.5"></circle>
        <path d="M16 16l4.5 4.5"></path>
      </svg>
      <input data-area-search-input name={inputName} type="search" placeholder={searchPlaceholder} autocomplete="off" />
    </label>
    {searchHint && <p class="search-hint">{searchHint}</p>}
  </div>

  <div class="hero-visual" aria-hidden={imageSrc ? undefined : "true"}>
    {imageSrc ? <img src={imageSrc} alt={imageAlt} loading="eager" /> : <div class="image-placeholder"></div>}
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .area-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(13rem, 17rem);
    gap: 1rem 1.2rem;
    align-items: center;
    padding: 1.2rem 1.25rem;
    border: 1px solid var(--border-strong);
    border-radius: 30px;
    box-shadow: var(--shadow-soft);
  }

  .hero-copy {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.15rem, 4vw, 3.5rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .search-shell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.8rem;
    min-height: 3.55rem;
    padding: 0 1rem;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(10px);
  }

  .search-shell svg {
    width: 1.15rem;
    height: 1.15rem;
    stroke: var(--text-soft);
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-shell input {
    min-width: 0;
    border: 0;
    outline: none;
    background: transparent;
    color: var(--text-strong);
    font: inherit;
  }

  .search-shell input::placeholder {
    color: var(--text-soft);
  }

  .search-hint {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
    max-width: 40rem;
  }

  .hero-visual {
    display: grid;
    place-items: end center;
    min-height: 13.5rem;
    overflow: hidden;
  }

  .hero-visual img,
  .image-placeholder {
    width: 100%;
    max-width: 16rem;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .area-hero.math { background: linear-gradient(135deg, rgba(90, 113, 209, 0.26), rgba(235, 241, 255, 0.95)); }
  .area-hero.web { background: linear-gradient(135deg, rgba(197, 140, 167, 0.24), rgba(252, 239, 246, 0.95)); }
  .area-hero.cs { background: linear-gradient(135deg, rgba(96, 153, 176, 0.24), rgba(234, 247, 250, 0.95)); }
  .area-hero.linux { background: linear-gradient(135deg, rgba(190, 171, 88, 0.26), rgba(250, 245, 226, 0.96)); }
  .area-hero.ee { background: linear-gradient(135deg, rgba(205, 143, 124, 0.24), rgba(252, 239, 234, 0.95)); }

  :global(html[data-theme="dark"]) .area-hero.math { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .area-hero.web { background: linear-gradient(135deg, rgba(96,72,104,0.24), rgba(49,38,43,0.94)); }
  :global(html[data-theme="dark"]) .area-hero.cs { background: linear-gradient(135deg, rgba(28,71,87,0.30), rgba(18,37,45,0.94)); }
  :global(html[data-theme="dark"]) .area-hero.linux { background: linear-gradient(135deg, rgba(84,76,44,0.22), rgba(42,39,28,0.94)); }
  :global(html[data-theme="dark"]) .area-hero.ee { background: linear-gradient(135deg, rgba(83,60,58,0.22), rgba(42,29,31,0.94)); }

  @media (max-width: 980px) {
    .area-hero {
      grid-template-columns: 1fr;
      padding: 1.05rem;
    }

    .hero-visual {
      min-height: 9rem;
      place-items: center;
    }

    .hero-visual img,
    .image-placeholder {
      max-width: 11rem;
    }
  }
</style>
