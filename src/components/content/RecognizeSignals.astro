---
interface Props {
  items: string[];
}

const { items } = Astro.props as Props;
---

{items.length > 0 && (
  <section class="signals-box">
    <p class="box-kicker">Erkennen</p>
    <h3>Woran du das Thema merkst</h3>
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </section>
)}

<style>
  .signals-box {
    display:grid;
    gap:.75rem;
    padding: 1.15rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(117,156,124,0.14), rgba(240,248,241,0.96));
    box-shadow: var(--shadow-soft);
  }

  .box-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.15;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  li {
    position: relative;
    padding-left: 1rem;
    color: var(--text);
    line-height: 1.6;
  }

  li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--text-strong);
    font-weight: 800;
  }
</style>
