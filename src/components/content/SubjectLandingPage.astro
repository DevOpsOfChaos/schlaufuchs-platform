---
const { subject } = Astro.props;
const base = import.meta.env.BASE_URL;
const mascotSrc = `${base}${subject.mascot.replace(/^\//, "")}`;
const iconSrc = `${base}${subject.icon.replace(/^\//, "")}`;
---

<section class={`subject-hero ${subject.accent}`}>
  <div class="subject-copy">
    <p class="eyebrow">{subject.eyebrow}</p>
    <div class="title-row">
      <div class="title-icon">
        <img src={iconSrc} alt="" loading="eager" />
      </div>
      <h1>{subject.title}</h1>
    </div>
    <p class="lead">{subject.description}</p>
    <p class="intro">{subject.intro}</p>

    <div class="actions">
      {subject.links.map((link) => (
        <a href={`${base}${link.href.replace(/^\//, "")}`}>{link.label}</a>
      ))}
    </div>
  </div>

  <div class="subject-mascot" aria-hidden="true">
    <img src={mascotSrc} alt="" loading="eager" />
  </div>
</section>

<section class="subject-grid">
  {subject.highlights.map((item, index) => (
    <article class="info-card">
      <p class="card-index">0{index + 1}</p>
      <h2>{item}</h2>
      <p>
        Dieser Bereich wird jetzt im gleichen Stil wie die Startseite aufgebaut und später
        mit echten Info- und Übungsseiten gefüllt.
      </p>
    </article>
  ))}
</section>

<style>
  .subject-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: end;
    padding: 2.2rem 2.2rem 0;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
  }

  .subject-hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -110px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: rgba(127, 140, 255, 0.12);
  }

  .subject-copy {
    position: relative;
    z-index: 1;
    padding-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    color: var(--text-soft);
    font-size: 1rem;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .title-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
    display: grid;
    place-items: center;
    border: 1px solid rgba(148,163,184,0.18);
    background: rgba(255,255,255,0.28);
    flex-shrink: 0;
  }

  :global(html[data-theme="dark"]) .title-icon {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.08);
  }

  .title-icon img {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .lead {
    max-width: 42rem;
    margin: 1.15rem 0 0;
    color: var(--text);
    font-size: clamp(1.08rem, 1.7vw, 1.22rem);
    line-height: 1.64;
  }

  .intro {
    max-width: 42rem;
    margin: 0.95rem 0 0;
    color: var(--text-soft);
    line-height: 1.7;
  }

  .actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.3);
    color: var(--text);
    box-shadow: var(--shadow-soft);
  }

  :global(html[data-theme="dark"]) .actions a {
    background: rgba(255,255,255,0.06);
  }

  .subject-mascot {
    position: relative;
    z-index: 1;
    justify-self: end;
    width: clamp(210px, 24vw, 320px);
    max-width: 30vw;
    align-self: end;
  }

  .subject-mascot img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 22px 30px rgba(15,23,42,0.14));
  }

  :global(html[data-theme="dark"]) .subject-mascot img {
    filter: drop-shadow(0 24px 36px rgba(0,0,0,0.34));
  }

  .subject-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .info-card {
    min-height: 14rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .card-index {
    margin: 0 0 1rem;
    color: var(--text-soft);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.45rem;
    line-height: 1.15;
  }

  .info-card p:last-child {
    margin: 0.9rem 0 0;
    color: var(--text-soft);
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .subject-hero {
      grid-template-columns: 1fr;
      padding: 1.8rem 1.4rem 0;
    }

    .subject-copy {
      padding-bottom: 1rem;
    }

    .subject-mascot {
      width: min(100%, 14rem);
      max-width: none;
      justify-self: center;
    }

    .subject-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .title-row {
      align-items: flex-start;
    }

    .title-icon {
      width: 3.2rem;
      height: 3.2rem;
    }

    .title-icon img {
      width: 1.55rem;
      height: 1.55rem;
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .actions a {
      justify-content: center;
    }

    .subject-mascot {
      width: min(100%, 11rem);
    }
  }
</style>
