---
interface Props {
  kicker: string;
  title: string;
  actionHref?: string;
  actionLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { kicker, title, actionHref, actionLabel, secondaryHref, secondaryLabel } = Astro.props as Props;
---

<div class="section-head">
  <div>
    <p class="section-kicker">{kicker}</p>
    <h2>{title}</h2>
  </div>
  {(actionHref || secondaryHref) && (
    <div class="action-row">
      {actionHref && actionLabel && <a class="section-link" href={actionHref}>{actionLabel}</a>}
      {secondaryHref && secondaryLabel && <a class="section-link secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</div>

<style>
  .section-head { display:flex; align-items:end; justify-content:space-between; gap:.9rem; flex-wrap:wrap; }
  .section-kicker { margin:0 0 .8rem; color:var(--text-soft); font-size:.92rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; }
  h2 { margin:0; color:var(--text-strong); font-size:clamp(1.7rem,2.7vw,2.2rem); line-height:1.05; letter-spacing:-.03em; }
  .action-row { display:flex; gap:.65rem; flex-wrap:wrap; }
  .section-link { display:inline-flex; align-items:center; min-height:2.8rem; padding:0 .95rem; border-radius:999px; border:1px solid var(--border); background:var(--surface); color:var(--text-strong); font-weight:700; box-shadow:var(--shadow-soft); }
  .section-link.secondary { background:transparent; }
</style>
