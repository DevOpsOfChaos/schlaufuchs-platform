---
interface Props {
  kicker: string;
  title: string;
  actionHref?: string;
  actionLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { kicker, title, actionHref, actionLabel, secondaryHref, secondaryLabel } = Astro.props as Props;
---

<div class="section-head">
  <div>
    <p class="section-kicker">{kicker}</p>
    <h2>{title}</h2>
  </div>
  {(actionHref || secondaryHref) && (
    <div class="action-row">
      {actionHref && actionLabel && <a class="section-link" href={actionHref}>{actionLabel}</a>}
      {secondaryHref && secondaryLabel && <a class="section-link secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</div>

<style>
  .section-head { display:flex; align-items:end; justify-content:space-between; gap:.85rem; flex-wrap:wrap; }
  .section-kicker { margin:0 0 .5rem; color:var(--text-soft); font-size:.84rem; font-weight:700; letter-spacing:.05em; text-transform:uppercase; }
  h2 { margin:0; color:var(--text-strong); font-size:clamp(1.45rem,2.2vw,1.9rem); line-height:1.08; letter-spacing:-.025em; }
  .action-row { display:flex; gap:.65rem; flex-wrap:wrap; }
  .section-link { display:inline-flex; align-items:center; min-height:2.55rem; padding:0 .85rem; border-radius:999px; border:1px solid var(--border); background:var(--surface); color:var(--text-strong); font-weight:700; box-shadow:var(--shadow-soft); transition:transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease; }
  .section-link.secondary { background:transparent; }
  .section-link:hover, .section-link:focus-visible { transform:translateY(-1px); box-shadow:var(--shadow-card); border-color:var(--border-strong); outline:none; }
</style>
