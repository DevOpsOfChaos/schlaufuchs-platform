---
const { groups } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="entry-grid">
  {groups.map((group) => (
    <article class={`entry-card ${group.tone}`}>
      <h2>{group.title}</h2>
      <p>{group.text}</p>

      <div class="entry-links">
        {group.links.map((link) => (
          <a href={`${base}${link.href.replace(/^\//, "")}`}>{link.label}</a>
        ))}
      </div>
    </article>
  ))}
</section>

<style>
  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
    margin-top: 1.4rem;
  }

  .entry-card {
    position: relative;
    overflow: hidden;
    min-height: 17rem;
    padding: 1.6rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
  }

  .entry-card::after {
    content: "";
    position: absolute;
    right: -2.25rem;
    bottom: -2.5rem;
    width: 7.8rem;
    height: 7.8rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.07);
    pointer-events: none;
  }

  .entry-card.linux-a { background: linear-gradient(135deg, rgba(175, 163, 122, 0.20), rgba(242, 239, 230, 0.84)); }
  .entry-card.linux-b { background: linear-gradient(135deg, rgba(95, 139, 158, 0.20), rgba(235, 244, 247, 0.82)); }
  .entry-card.linux-c { background: linear-gradient(135deg, rgba(173, 144, 156, 0.22), rgba(245, 239, 241, 0.84)); }

  :global(html[data-theme="dark"]) .entry-card.linux-a { background: linear-gradient(135deg, rgba(84, 76, 44, 0.30), rgba(42, 39, 28, 0.92)); }
  :global(html[data-theme="dark"]) .entry-card.linux-b { background: linear-gradient(135deg, rgba(28, 71, 87, 0.40), rgba(18, 37, 45, 0.92)); }
  :global(html[data-theme="dark"]) .entry-card.linux-c { background: linear-gradient(135deg, rgba(96, 72, 104, 0.34), rgba(49, 38, 43, 0.92)); }

  h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1.05;
  }

  p {
    margin: 0.9rem 0 0;
    color: var(--text);
    line-height: 1.65;
    max-width: 18rem;
  }

  .entry-links {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.15rem;
  }

  .entry-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2.8rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.16);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    width: fit-content;
    max-width: 100%;
  }

  :global(html[data-theme="dark"]) .entry-links a {
    border-color: rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 980px) {
    .entry-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .entry-card { min-height: 14rem; padding: 1.4rem; }
    .entry-links a { width: 100%; }
  }
</style>
