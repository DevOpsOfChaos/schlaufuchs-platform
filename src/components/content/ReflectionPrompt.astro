---
interface Props {
  prompt?: string;
}

const { prompt = "Was nimmst du aus dieser Aufgabe für ähnliche Themen mit?" } = Astro.props as Props;
---

<section class="reflection-box">
  <p class="box-kicker">Reflexion</p>
  <h3>Zum Schluss kurz nachdenken</h3>
  <p>{prompt}</p>
</section>

<style>
  .reflection-box {
    display: grid;
    gap: 0.75rem;
    padding: 1.15rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(186,138,123,0.14), rgba(250,242,238,0.96));
    box-shadow: var(--shadow-soft);
  }

  .box-kicker {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.15;
  }

  p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
  }
</style>
