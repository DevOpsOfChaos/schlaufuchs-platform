---
interface Props { title?: string; items: string[]; }
const { title = "Direkt ausprobieren", items } = Astro.props as Props;
---

{items.length > 0 && (
  <section class="practice-panel">
    <p class="panel-kicker">Praxis</p>
    <h3>{title}</h3>
    <div class="panel-grid">
      {items.map((item, index) => (
        <article class={`practice-card accent-${["a", "b", "c", "d"][index % 4]}`}>
          <span class="practice-index">{index + 1}</span>
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .practice-panel { display:grid; gap:.8rem; }
  h3 { margin:0; color:var(--text-strong); font-size:1.08rem; line-height:1.15; }
  .panel-kicker { margin:0; color:var(--text-soft); font-size:.8rem; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
  .panel-grid { display:grid; gap:.8rem; }
  .practice-card { display:grid; grid-template-columns:auto 1fr; gap:.8rem; align-items:flex-start; padding:1rem; border:1px solid var(--border); border-radius:22px; box-shadow:var(--shadow-soft); }
  .practice-card.accent-a { background:linear-gradient(135deg, rgba(93,113,175,0.16), rgba(238,243,255,0.96)); }
  .practice-card.accent-b { background:linear-gradient(135deg, rgba(117,156,124,0.15), rgba(240,248,241,0.96)); }
  .practice-card.accent-c { background:linear-gradient(135deg, rgba(186,138,123,0.15), rgba(250,242,238,0.96)); }
  .practice-card.accent-d { background:linear-gradient(135deg, rgba(176,160,104,0.15), rgba(249,245,233,0.96)); }
  .practice-index { display:inline-grid; place-items:center; width:1.85rem; height:1.85rem; border-radius:999px; background:rgba(255,255,255,0.42); border:1px solid rgba(148,163,184,0.18); color:var(--text-strong); font-weight:800; }
  .practice-card p { margin:0; color:var(--text); line-height:1.62; }
</style>
