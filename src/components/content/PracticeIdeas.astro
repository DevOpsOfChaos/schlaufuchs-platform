---
interface Props {
  title?: string;
  items: string[];
}

const { title = "Direkt ausprobieren", items } = Astro.props as Props;
const accents = ["a", "b", "c", "d"] as const;
---

{items.length > 0 && (
  <section class="practice-panel">
    <p class="panel-kicker">Praxis</p>
    <h3>{title}</h3>
    <div class="panel-grid">
      {items.map((item, index) => (
        <article class={`practice-card accent-${accents[index % accents.length]}`}>
          <span class="practice-index">{index + 1}</span>
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .practice-panel { display:grid; gap:.8rem; }
  .panel-kicker { margin:0; color:var(--text-soft); font-size:.8rem; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
  h3 { margin:0; color:var(--text-strong); font-size:1.08rem; line-height:1.15; }
  .panel-grid { display:grid; gap:.8rem; }
  .practice-card {
    display:grid;
    grid-template-columns:auto 1fr;
    gap:.8rem;
    align-items:flex-start;
    padding:1rem;
    border:1px solid var(--border);
    border-radius:22px;
    box-shadow:var(--shadow-soft);
  }
  .practice-card.accent-a { background:linear-gradient(145deg, rgba(93,113,175,0.18), rgba(238,243,255,0.98)); }
  .practice-card.accent-b { background:linear-gradient(145deg, rgba(117,156,124,0.18), rgba(240,248,241,0.98)); }
  .practice-card.accent-c { background:linear-gradient(145deg, rgba(186,138,123,0.18), rgba(250,242,238,0.98)); }
  .practice-card.accent-d { background:linear-gradient(145deg, rgba(176,160,104,0.18), rgba(249,245,233,0.98)); }
  :global(html[data-theme="dark"]) .practice-card.accent-a { background:linear-gradient(145deg, rgba(86,110,214,0.34), rgba(24,32,64,0.92)); }
  :global(html[data-theme="dark"]) .practice-card.accent-b { background:linear-gradient(145deg, rgba(53,154,109,0.34), rgba(15,44,30,0.92)); }
  :global(html[data-theme="dark"]) .practice-card.accent-c { background:linear-gradient(145deg, rgba(214,116,82,0.34), rgba(52,27,22,0.92)); }
  :global(html[data-theme="dark"]) .practice-card.accent-d { background:linear-gradient(145deg, rgba(188,152,54,0.34), rgba(48,38,16,0.92)); }
  .practice-index {
    display:inline-grid;
    place-items:center;
    width:1.85rem;
    height:1.85rem;
    border-radius:999px;
    background:rgba(255,255,255,0.36);
    border:1px solid rgba(148,163,184,0.18);
    color:var(--text-strong);
    font-weight:800;
  }
  :global(html[data-theme="dark"]) .practice-index { background:rgba(255,255,255,0.12); border-color:rgba(255,255,255,0.12); }
  .practice-card p { margin:0; color:var(--text); line-height:1.62; }
</style>
