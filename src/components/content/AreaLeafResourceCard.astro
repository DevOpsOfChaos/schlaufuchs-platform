---
interface Props {
  title: string;
  description: string;
  href: string;
  meta: string;
  ctaLabel: string;
  variant?: "article" | "task";
  searchText?: string;
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
  compact?: boolean;
}

const {
  title,
  description,
  href,
  meta,
  ctaLabel,
  variant = "article",
  searchText = "",
  accent = "a",
  compact = false,
} = Astro.props as Props;
---

<a class={`leaf-card ${variant} accent-${accent} ${compact ? "compact" : ""}`} href={href} data-search-item data-search-text={searchText} aria-label={`${title} – ${description}`}>
  <div class="leaf-copy">
    <p class="leaf-meta">{meta}</p>
    <h3>{title}</h3>
    {!compact && <p class="leaf-description">{description}</p>}
  </div>
  <span class="leaf-arrow" aria-hidden="true">→</span>
</a>

<style>
  .leaf-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
    padding: 0.95rem 1rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .leaf-card:hover,
  .leaf-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    filter: saturate(1.06);
    outline: none;
  }

  .leaf-card.article.accent-a { background: linear-gradient(135deg, rgba(98,123,204,0.30), rgba(241,245,255,0.97)); }
  .leaf-card.article.accent-b { background: linear-gradient(135deg, rgba(78,163,128,0.28), rgba(240,248,242,0.97)); }
  .leaf-card.article.accent-c { background: linear-gradient(135deg, rgba(204,128,104,0.28), rgba(252,244,241,0.97)); }
  .leaf-card.article.accent-d { background: linear-gradient(135deg, rgba(190,166,84,0.28), rgba(252,248,236,0.97)); }
  .leaf-card.article.accent-e { background: linear-gradient(135deg, rgba(90,154,196,0.28), rgba(239,248,252,0.97)); }
  .leaf-card.article.accent-f { background: linear-gradient(135deg, rgba(157,110,190,0.28), rgba(246,240,252,0.97)); }

  .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(98,123,204,0.34), rgba(238,243,255,0.97)); }
  .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(78,163,128,0.32), rgba(237,246,239,0.97)); }
  .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(204,128,104,0.32), rgba(251,241,237,0.97)); }
  .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(190,166,84,0.32), rgba(249,244,231,0.97)); }
  .leaf-card.task.accent-e { background: linear-gradient(135deg, rgba(90,154,196,0.32), rgba(236,246,251,0.97)); }
  .leaf-card.task.accent-f { background: linear-gradient(135deg, rgba(157,110,190,0.32), rgba(244,237,251,0.97)); }

  :global(html[data-theme="dark"]) .leaf-card.article.accent-a,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(66,92,180,0.34), rgba(21,29,56,0.95)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-b,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(39,108,74,0.34), rgba(16,39,28,0.95)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-c,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(116,63,47,0.34), rgba(45,26,23,0.95)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-d,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(109,91,33,0.32), rgba(43,36,20,0.95)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-e,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-e { background: linear-gradient(135deg, rgba(29,90,116,0.34), rgba(17,36,45,0.95)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-f,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-f { background: linear-gradient(135deg, rgba(86,55,116,0.34), rgba(36,25,47,0.95)); }

  .leaf-copy {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .leaf-card.compact {
    gap: 0.7rem;
    padding: 0.9rem 0.95rem;
  }

  .leaf-meta {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.02rem;
    line-height: 1.22;
  }

  .leaf-description {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
    font-size: 0.94rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .leaf-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.28);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
