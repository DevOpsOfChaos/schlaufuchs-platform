---
interface Props {
  title: string;
  description: string;
  href: string;
  meta: string;
  ctaLabel: string;
  variant?: "article" | "task";
  searchText?: string;
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
  compact?: boolean;
}

const {
  title,
  description,
  href,
  meta,
  variant = "article",
  searchText = "",
  accent = "a",
  compact = false,
} = Astro.props as Props;
---

<a class={`leaf-card ${variant} accent-${accent} ${compact ? "compact" : ""}`} href={href} data-search-item data-search-text={searchText}>
  <p class="leaf-meta">{meta}</p>
  <h3>{title}</h3>
  {!compact && <p class="leaf-description">{description}</p>}
  <span class="leaf-arrow" aria-hidden="true">→</span>
</a>

<style>
  .leaf-card {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .leaf-card:hover,
  .leaf-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    outline: none;
  }

  .leaf-card:hover .leaf-arrow,
  .leaf-card:focus-visible .leaf-arrow {
    transform: translateX(2px);
    border-color: rgba(148, 163, 184, 0.34);
  }

  .leaf-card.article.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.28), rgba(240,244,255,0.98)); }
  .leaf-card.article.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.28), rgba(238,248,240,0.98)); }
  .leaf-card.article.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.28), rgba(251,240,236,0.98)); }
  .leaf-card.article.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.28), rgba(249,244,231,0.98)); }
  .leaf-card.article.accent-e { background: linear-gradient(135deg, rgba(98,166,178,0.28), rgba(235,247,249,0.98)); }
  .leaf-card.article.accent-f { background: linear-gradient(135deg, rgba(160,120,176,0.28), rgba(246,238,250,0.98)); }

  .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.34), rgba(234,240,255,0.98)); }
  .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.34), rgba(232,246,236,0.98)); }
  .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.34), rgba(248,237,233,0.98)); }
  .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.34), rgba(247,241,227,0.98)); }
  .leaf-card.task.accent-e { background: linear-gradient(135deg, rgba(98,166,178,0.34), rgba(231,245,247,0.98)); }
  .leaf-card.task.accent-f { background: linear-gradient(135deg, rgba(160,120,176,0.34), rgba(243,235,248,0.98)); }

  :global(html[data-theme="dark"]) .leaf-card.article.accent-a,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.32), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-b,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.30), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-c,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.30), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-d,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.28), rgba(44,37,21,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-e,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-e { background: linear-gradient(135deg, rgba(38,92,106,0.30), rgba(18,41,48,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.article.accent-f,
  :global(html[data-theme="dark"]) .leaf-card.task.accent-f { background: linear-gradient(135deg, rgba(94,66,108,0.30), rgba(38,25,47,0.94)); }

  .leaf-card.compact {
    gap: 0.5rem;
    padding: 0.9rem 1rem;
  }

  .leaf-meta {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.06rem;
    line-height: 1.24;
  }

  .leaf-description {
    margin: 0;
    color: var(--text);
    line-height: 1.62;
    font-size: 0.96rem;
  }

  .leaf-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.3);
    color: var(--text-strong);
    font-weight: 700;
    transition: transform 140ms ease, border-color 140ms ease;
    justify-self: end;
    margin-top: 0.1rem;
  }
</style>
