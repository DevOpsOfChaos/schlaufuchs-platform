---
interface Props {
  title: string;
  description: string;
  href: string;
  meta: string;
  ctaLabel: string;
  variant?: "article" | "task";
  searchText?: string;
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  href,
  meta,
  ctaLabel,
  variant = "article",
  searchText = "",
  accent = "a",
} = Astro.props as Props;
---

<article class={`leaf-card ${variant} accent-${accent}`} data-search-item data-search-text={searchText}>
  <p class="leaf-meta">{meta}</p>
  <h3><a href={href}>{title}</a></h3>
  <p class="leaf-description">{description}</p>
  <a class="leaf-link" href={href}>{ctaLabel}</a>
</article>

<style>
  .leaf-card {
    display: grid;
    gap: 0.68rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
  }

  .leaf-card.article.accent-a { background: linear-gradient(135deg, rgba(93, 113, 210, 0.16), rgba(244, 247, 255, 0.98)); }
  .leaf-card.article.accent-b { background: linear-gradient(135deg, rgba(108, 172, 120, 0.15), rgba(244, 250, 245, 0.98)); }
  .leaf-card.article.accent-c { background: linear-gradient(135deg, rgba(209, 143, 113, 0.15), rgba(253, 244, 240, 0.98)); }
  .leaf-card.article.accent-d { background: linear-gradient(135deg, rgba(201, 176, 77, 0.16), rgba(252, 248, 236, 0.99)); }

  .leaf-card.task {
    position: relative;
    overflow: hidden;
    padding-left: 1.15rem;
    border-color: color-mix(in oklab, var(--border) 68%, var(--border-strong) 32%);
  }

  .leaf-card.task::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.34rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--text-strong) 62%, white 38%);
  }

  .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(93, 113, 210, 0.18), rgba(239, 243, 255, 0.98)); }
  .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(108, 172, 120, 0.18), rgba(239, 248, 241, 0.98)); }
  .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(209, 143, 113, 0.18), rgba(252, 241, 236, 0.98)); }
  .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(201, 176, 77, 0.19), rgba(250, 245, 230, 0.98)); }

  :global(html[data-theme="dark"]) .leaf-card.article {
    background: color-mix(in oklab, var(--card-bg) 94%, white 6%);
  }

  :global(html[data-theme="dark"]) .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.24), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.22), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.22), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.20), rgba(44,37,21,0.94)); }

  .leaf-meta {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .leaf-card.task .leaf-meta {
    color: var(--text-strong);
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.06rem;
    line-height: 1.25;
  }

  h3 a {
    color: inherit;
  }

  .leaf-description {
    margin: 0;
    color: var(--text);
    line-height: 1.62;
    font-size: 0.96rem;
  }

  .leaf-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  .leaf-card.task .leaf-link {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    width: fit-content;
    padding: 0 0.68rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.42);
  }
</style>
