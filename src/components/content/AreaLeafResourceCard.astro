---
interface Props {
  title: string;
  description: string;
  href: string;
  meta: string;
  ctaLabel: string;
  variant?: "article" | "task";
  searchText?: string;
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  href,
  meta,
  ctaLabel,
  variant = "article",
  searchText = "",
  accent = "a",
} = Astro.props as Props;
---

<article class={`leaf-card ${variant} accent-${accent}`} data-search-item data-search-text={searchText}>
  <p class="leaf-meta">{meta}</p>
  <h3><a href={href}>{title}</a></h3>
  <p class="leaf-description">{description}</p>
  <a class="leaf-link" href={href}>{ctaLabel}</a>
</article>

<style>
  .leaf-card {
    display: grid;
    gap: 0.7rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 22px;
    background: color-mix(in oklab, var(--card-bg) 94%, white 6%);
    box-shadow: var(--shadow-soft);
  }

  .leaf-card.article {
    background: color-mix(in oklab, var(--card-bg) 95%, white 5%);
  }

  .leaf-card.task {
    position: relative;
    overflow: hidden;
    padding-left: 1.2rem;
    border-color: color-mix(in oklab, var(--border) 72%, var(--border-strong) 28%);
  }

  .leaf-card.task::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.36rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--text-strong) 60%, white 40%);
  }

  .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.12), rgba(232,237,248,0.92)); }
  .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.12), rgba(236,245,238,0.92)); }
  .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.12), rgba(247,239,235,0.92)); }
  .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.12), rgba(245,241,228,0.92)); }

  :global(html[data-theme="dark"]) .leaf-card.task.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.24), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.22), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.22), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .leaf-card.task.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.20), rgba(44,37,21,0.94)); }

  .leaf-meta {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .leaf-card.task .leaf-meta {
    color: var(--text-strong);
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.12rem;
    line-height: 1.25;
  }

  h3 a {
    color: inherit;
  }

  .leaf-description {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
    font-size: 0.98rem;
  }

  .leaf-link {
    color: var(--text-strong);
    font-weight: 700;
  }

  .leaf-card.task .leaf-link {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    width: fit-content;
    padding: 0 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(255, 255, 255, 0.34);
  }
</style>
