---
interface Props {
  title: string;
  description: string;
  href: string;
  meta: string;
  ctaLabel: string;
  variant?: "article" | "task";
  searchText?: string;
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
  compact?: boolean;
}

const {
  title,
  description,
  href,
  meta,
  ctaLabel,
  variant = "article",
  searchText = "",
  accent = "a",
  compact = false,
} = Astro.props as Props;
---

<a
  class={`leaf-card ${variant} accent-${accent} ${compact ? "compact" : ""}`}
  href={href}
  data-search-item
  data-search-text={searchText}
  aria-label={`${title} – ${description}`}
>
  <div class="leaf-copy">
    <p class="leaf-meta">{meta}</p>
    <h3>{title}</h3>
    {!compact && <p class="leaf-description">{description}</p>}
  </div>
  <span class="leaf-arrow" aria-hidden="true">→</span>
</a>

<style>
  .leaf-card {
    --accent-rgb: 86, 110, 214;
    --accent-surface: 239, 244, 255;
    --accent-dark: 24, 32, 64;

    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.72rem;
    align-items: center;
    min-height: 100%;
    padding: 0.92rem 0.96rem;
    border: 1px solid rgba(var(--accent-rgb), 0.18);
    border-radius: 21px;
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    overflow: hidden;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .leaf-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.72);
    opacity: 0.78;
    pointer-events: none;
  }

  .leaf-card.article {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.28), rgba(var(--accent-surface), 0.98));
  }

  .leaf-card.task {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.42), rgba(var(--accent-surface), 0.92));
    border-color: rgba(var(--accent-rgb), 0.26);
  }

  .leaf-card.task::before {
    opacity: 1;
  }

  :global(html[data-theme="dark"]) .leaf-card.article {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.34), rgba(var(--accent-dark), 0.94));
    border-color: rgba(var(--accent-rgb), 0.24);
  }

  :global(html[data-theme="dark"]) .leaf-card.task {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.48), rgba(var(--accent-dark), 0.88));
    border-color: rgba(var(--accent-rgb), 0.34);
  }

  .leaf-card:hover,
  .leaf-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: rgba(var(--accent-rgb), 0.34);
    filter: saturate(1.06);
    outline: none;
  }

  .leaf-card:hover .leaf-arrow,
  .leaf-card:focus-visible .leaf-arrow {
    transform: translateX(2px);
  }

  .leaf-card.accent-a {
    --accent-rgb: 86, 110, 214;
    --accent-surface: 239, 244, 255;
    --accent-dark: 24, 32, 64;
  }

  .leaf-card.accent-b {
    --accent-rgb: 53, 154, 109;
    --accent-surface: 236, 248, 241;
    --accent-dark: 15, 44, 30;
  }

  .leaf-card.accent-c {
    --accent-rgb: 214, 116, 82;
    --accent-surface: 252, 241, 236;
    --accent-dark: 52, 27, 22;
  }

  .leaf-card.accent-d {
    --accent-rgb: 188, 152, 54;
    --accent-surface: 250, 245, 228;
    --accent-dark: 48, 38, 16;
  }

  .leaf-card.accent-e {
    --accent-rgb: 55, 140, 186;
    --accent-surface: 235, 247, 252;
    --accent-dark: 17, 39, 49;
  }

  .leaf-card.accent-f {
    --accent-rgb: 152, 90, 196;
    --accent-surface: 246, 239, 252;
    --accent-dark: 41, 24, 55;
  }

  .leaf-copy {
    display: grid;
    gap: 0.42rem;
    min-width: 0;
  }

  .leaf-card.compact {
    gap: 0.68rem;
    padding: 0.88rem 0.94rem;
  }

  .leaf-meta {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1rem;
    line-height: 1.22;
  }

  .leaf-description {
    margin: 0;
    color: var(--text);
    line-height: 1.56;
    font-size: 0.92rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .leaf-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.05rem;
    height: 2.05rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
    pointer-events: none;
    transition: transform 140ms ease;
  }

  :global(html[data-theme="dark"]) .leaf-arrow {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.12);
  }
</style>
