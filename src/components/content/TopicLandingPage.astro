---
import Breadcrumbs from "../ui/Breadcrumbs.astro";

const { page, breadcrumbs = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const mascotSrc = `${base}${page.mascot.replace(/^\//, "")}`;

const pathname = Astro.url.pathname;
const clean = pathname.replace(/\/$/, "");
const parentPath = clean.split("/").slice(0, -1).join("/") || "/";
const currentTitle = page.title;
---

<section class="page-hero">
  <div class="page-copy">
    <Breadcrumbs items={breadcrumbs} />
    <div class="hero-nav">
      <a class="back-link" href={parentPath}>← Zurück</a>
      <span class="current-page">{currentTitle}</span>
    </div>
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p class="lead">{page.description}</p>
  </div>
  <div class="page-mascot" aria-hidden="true">
    <img src={mascotSrc} alt="" loading="eager" />
  </div>
</section>

<section class="card-grid">
  {page.groups.map((group) => (
    <a class={`card ${group.tone}`} href={`${base}${group.href.replace(/^\//, "")}`}>
      <h2>{group.title}</h2>
      <p>{group.text}</p>
      <div class="arrow" aria-hidden="true">▶</div>
    </a>
  ))}
</section>

<style>
  .page-hero { position: relative; overflow: hidden; display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 1.2rem; align-items: end; padding: 2.1rem 2.1rem 0; border: 1px solid var(--border); border-radius: 28px; background: var(--card-bg); box-shadow: var(--shadow-card); }
  .page-hero::after { content:""; position:absolute; right:-90px; bottom:-110px; width:240px; height:240px; border-radius:50%; background: rgba(127,140,255,.12); }
  .page-copy { position: relative; z-index: 1; padding-bottom: 1.8rem; }
  .hero-nav { display: flex; align-items: center; gap: 0.75rem; margin: 0 0 1rem; }
  .back-link { display: inline-flex; align-items: center; min-height: 2.5rem; padding: 0 0.9rem; border-radius: 999px; border: 1px solid var(--border); background: var(--surface); color: var(--text); box-shadow: var(--shadow-soft); }
  .current-page { color: var(--text-soft); font-size: 0.95rem; }
  .eyebrow { margin:0; color: var(--text-soft); }
  h1 { margin:0.75rem 0 0; color: var(--text-strong); font-size: clamp(2.4rem,4vw,3.8rem); line-height:1.02; letter-spacing:-.04em; }
  .lead { margin:1rem 0 0; max-width: 42rem; color: var(--text-soft); line-height:1.7; }
  .page-mascot { position: relative; z-index:1; width:min(100%,13rem); }
  .page-mascot img { width:100%; display:block; object-fit:contain; }
  .card-grid { display:grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap:1.15rem; margin-top:1.45rem; }
  .card { position:relative; overflow:hidden; min-height:15rem; padding:1.6rem; border:1px solid var(--border); border-radius:24px; color:inherit; box-shadow:var(--shadow-soft); }
  .card::after { content:""; position:absolute; right:-2.25rem; bottom:-2.5rem; width:7.8rem; height:7.8rem; border-radius:999px; background:rgba(255,255,255,.07); pointer-events:none; }
  .card.math-a,.card.web-a,.card.cs-a,.card.linux-a,.card.ee-a { background: linear-gradient(135deg, rgba(93,113,175,.28), rgba(232,237,248,.76)); }
  .card.math-b,.card.web-b,.card.cs-b,.card.linux-b,.card.ee-b { background: linear-gradient(135deg, rgba(95,139,158,.20), rgba(235,244,247,.82)); }
  .card.math-c,.card.web-c,.card.cs-c,.card.linux-c,.card.ee-c { background: linear-gradient(135deg, rgba(173,144,156,.22), rgba(245,239,241,.84)); }
  :global(html[data-theme="dark"]) .card.math-a,:global(html[data-theme="dark"]) .card.web-a,:global(html[data-theme="dark"]) .card.cs-a,:global(html[data-theme="dark"]) .card.linux-a,:global(html[data-theme="dark"]) .card.ee-a { background: linear-gradient(135deg, rgba(72,95,164,.36), rgba(22,31,58,.92)); }
  :global(html[data-theme="dark"]) .card.math-b,:global(html[data-theme="dark"]) .card.web-b,:global(html[data-theme="dark"]) .card.cs-b,:global(html[data-theme="dark"]) .card.linux-b,:global(html[data-theme="dark"]) .card.ee-b { background: linear-gradient(135deg, rgba(28,71,87,.40), rgba(18,37,45,.92)); }
  :global(html[data-theme="dark"]) .card.math-c,:global(html[data-theme="dark"]) .card.web-c,:global(html[data-theme="dark"]) .card.cs-c,:global(html[data-theme="dark"]) .card.linux-c,:global(html[data-theme="dark"]) .card.ee-c { background: linear-gradient(135deg, rgba(96,72,104,.34), rgba(49,38,43,.92)); }
  h2 { margin:0; color:var(--text-strong); font-size: clamp(1.7rem,2.2vw,2rem); line-height:1.05; }
  .card p { margin:.75rem 0 0; color:var(--text); line-height:1.62; max-width:18rem; }
  .arrow { position:absolute; right:1.4rem; bottom:1.2rem; width:2.2rem; height:2.2rem; border-radius:999px; border:1px solid rgba(148,163,184,.16); background:rgba(255,255,255,.28); display:grid; place-items:center; color:var(--text-strong); }
  :global(html[data-theme="dark"]) .arrow { border-color: rgba(255,255,255,.12); background: rgba(255,255,255,.10); }
  @media (max-width: 980px) { .page-hero { grid-template-columns:1fr; padding:1.8rem 1.4rem 0; } .page-copy { padding-bottom:1rem; } .page-mascot { justify-self:center; width:min(100%,10rem); } .card-grid { grid-template-columns:1fr; } }
  @media (max-width: 640px) { .hero-nav { align-items: flex-start; flex-direction: column; } .card { min-height:13rem; padding:1.35rem; } }
</style>
