---
interface Props {
  title: string;
  description: string;
  href: string;
  tone?: string;
  icon: string;
  searchText?: string;
  eyebrow?: string;
  chips?: string[];
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  href,
  tone = "math",
  icon,
  searchText = "",
  eyebrow = "Thema",
  chips = [],
  accent = "a",
} = Astro.props as Props;
---

<a class={`topic-card ${tone} accent-${accent}`} href={href} data-search-item data-search-text={searchText}>
  <div class="topic-card-top">
    <span class="topic-symbol" aria-hidden="true" set:html={icon}></span>
    <div class="topic-copy">
      <h2>{title}</h2>
      {chips.length > 0 && (
        <div class="topic-chips" aria-hidden="true">
          {chips.slice(0, 3).map((chip) => <span>{chip}</span>)}
        </div>
      )}
    </div>
    <span class="topic-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .topic-card {
    display: grid;
    gap: 0.75rem;
    padding: 1.05rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-card.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.26), rgba(232,237,248,0.9)); }
  .topic-card.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.24), rgba(236,245,238,0.9)); }
  .topic-card.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.24), rgba(247,239,235,0.9)); }
  .topic-card.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.24), rgba(245,241,228,0.92)); }

  :global(html[data-theme="dark"]) .topic-card.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.28), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.28), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.25), rgba(44,37,21,0.94)); }

  .topic-card-top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: start;
  }

  .topic-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.34);
    flex-shrink: 0;
  }

  .topic-symbol :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .topic-copy {
    display: grid;
    gap: 0.55rem;
    min-width: 0;
  }

  .topic-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
  }

  .topic-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .topic-chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    padding: 0 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(255, 255, 255, 0.34);
    color: var(--text-strong);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.28);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 760px) {
    .topic-card {
      padding: 0.95rem 1rem;
    }

    .topic-card h2 {
      font-size: 1.25rem;
    }
  }
</style>
