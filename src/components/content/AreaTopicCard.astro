---
interface Props {
  title: string;
  description: string;
  href: string;
  tone?: string;
  icon: string;
  searchText?: string;
  eyebrow?: string;
  chips?: string[];
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  href,
  tone = "math",
  icon,
  searchText = "",
  eyebrow = "Thema",
  chips = [],
  accent = "a",
} = Astro.props as Props;
---

<a class={`topic-card ${tone} accent-${accent}`} href={href} data-search-item data-search-text={searchText}>
  <div class="topic-card-top">
    <span class="topic-symbol" aria-hidden="true" set:html={icon}></span>
    <div class="topic-copy">
      <p class="topic-eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
    </div>
  </div>
  {chips.length > 0 && (
    <div class="topic-chips" aria-hidden="true">
      {chips.slice(0, 4).map((chip) => <span>{chip}</span>)}
    </div>
  )}
  <p>{description}</p>
</a>

<style>
  .topic-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.2rem;
    border: 1px solid var(--border-strong);
    border-radius: 26px;
    box-shadow: var(--shadow-soft);
    min-height: 13.25rem;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-card.accent-a { background: linear-gradient(135deg, rgba(93, 113, 210, 0.26), rgba(240, 244, 255, 0.96)); }
  .topic-card.accent-b { background: linear-gradient(135deg, rgba(108, 172, 120, 0.24), rgba(240, 249, 242, 0.96)); }
  .topic-card.accent-c { background: linear-gradient(135deg, rgba(209, 143, 113, 0.24), rgba(252, 241, 236, 0.96)); }
  .topic-card.accent-d { background: linear-gradient(135deg, rgba(201, 176, 77, 0.26), rgba(250, 245, 229, 0.98)); }

  :global(html[data-theme="dark"]) .topic-card.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.28), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.28), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.25), rgba(44,37,21,0.94)); }

  .topic-card-top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: start;
  }

  .topic-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.55rem;
    height: 2.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }

  .topic-symbol :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .topic-copy {
    display: grid;
    gap: 0.3rem;
  }

  .topic-eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .topic-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.45rem, 2.3vw, 1.8rem);
    line-height: 1.06;
    letter-spacing: -0.035em;
  }

  .topic-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .topic-chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0 0.62rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.42);
    color: var(--text-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .topic-card > p:last-child {
    margin: 0;
    color: var(--text);
    line-height: 1.62;
    font-size: 0.97rem;
  }
</style>
