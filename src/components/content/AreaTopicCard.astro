---
interface Props {
  title: string;
  description: string;
  href: string;
  tone?: string;
  icon: string;
  searchText?: string;
  eyebrow?: string;
  chips?: string[];
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
}

const {
  title,
  description,
  href,
  tone = "math",
  icon,
  searchText = "",
  eyebrow = "Thema",
  chips = [],
  accent = "a",
} = Astro.props as Props;
---

<a
  class={`topic-card ${tone} accent-${accent}`}
  href={href}
  data-search-item
  data-search-text={searchText}
  aria-label={`${title} – ${description}`}
>
  <div class="topic-card-top">
    <span class="topic-symbol" aria-hidden="true" set:html={icon}></span>
    <div class="topic-copy">
      <p class="topic-eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      <p class="topic-description">{description}</p>
      {chips.length > 0 && (
        <div class="topic-chips" aria-hidden="true">
          {chips.slice(0, 3).map((chip) => <span>{chip}</span>)}
        </div>
      )}
    </div>
    <span class="topic-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .topic-card {
    --accent-rgb: 86, 110, 214;
    --accent-surface: 239, 244, 255;
    --accent-dark: 24, 32, 64;

    position: relative;
    display: grid;
    gap: 0.78rem;
    min-height: 10.2rem;
    padding: 1.08rem 1.08rem 1.02rem;
    border: 1px solid rgba(var(--accent-rgb), 0.2);
    border-radius: 22px;
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    overflow: hidden;
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.34), rgba(var(--accent-surface), 0.97));
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .topic-card::after {
    content: "";
    position: absolute;
    right: -1.2rem;
    bottom: -2.4rem;
    width: 6rem;
    height: 6rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    filter: blur(6px);
    pointer-events: none;
  }

  .topic-card:hover,
  .topic-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: rgba(var(--accent-rgb), 0.34);
    filter: saturate(1.06);
    outline: none;
  }

  .topic-card:hover .topic-arrow,
  .topic-card:focus-visible .topic-arrow {
    transform: translateX(2px);
  }

  .topic-card.accent-a { --accent-rgb: 86, 110, 214; --accent-surface: 239, 244, 255; --accent-dark: 24, 32, 64; }
  .topic-card.accent-b { --accent-rgb: 53, 154, 109; --accent-surface: 236, 248, 241; --accent-dark: 15, 44, 30; }
  .topic-card.accent-c { --accent-rgb: 214, 116, 82; --accent-surface: 252, 241, 236; --accent-dark: 52, 27, 22; }
  .topic-card.accent-d { --accent-rgb: 188, 152, 54; --accent-surface: 250, 245, 228; --accent-dark: 48, 38, 16; }
  .topic-card.accent-e { --accent-rgb: 55, 140, 186; --accent-surface: 235, 247, 252; --accent-dark: 17, 39, 49; }
  .topic-card.accent-f { --accent-rgb: 152, 90, 196; --accent-surface: 246, 239, 252; --accent-dark: 41, 24, 55; }

  :global(html[data-theme="dark"]) .topic-card {
    background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.42), rgba(var(--accent-dark), 0.92));
    border-color: rgba(var(--accent-rgb), 0.28);
  }

  .topic-card-top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.86rem;
    align-items: start;
  }

  .topic-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.26);
    flex-shrink: 0;
  }

  .topic-symbol :global(svg) {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .topic-copy {
    display: grid;
    gap: 0.46rem;
    min-width: 0;
  }

  .topic-eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .topic-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.12rem, 1.45vw, 1.36rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .topic-description {
    margin: 0;
    color: var(--text);
    line-height: 1.56;
    font-size: 0.92rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .topic-chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.28);
    color: var(--text-strong);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.95rem;
    height: 1.95rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
    align-self: center;
    pointer-events: none;
    transition: transform 140ms ease;
  }

  :global(html[data-theme="dark"]) .topic-symbol,
  :global(html[data-theme="dark"]) .topic-chips span,
  :global(html[data-theme="dark"]) .topic-arrow {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.12);
  }
</style>
