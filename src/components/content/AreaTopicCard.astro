---
interface Props {
  title: string;
  description: string;
  href: string;
  tone?: string;
  icon: string;
  searchText?: string;
  eyebrow?: string;
  chips?: string[];
  accent?: "a" | "b" | "c" | "d" | "e" | "f";
}

const {
  title,
  description,
  href,
  tone = "math",
  icon,
  searchText = "",
  eyebrow = "Thema",
  chips = [],
  accent = "a",
} = Astro.props as Props;
---

<a class={`topic-card ${tone} accent-${accent}`} href={href} data-search-item data-search-text={searchText} aria-label={`${title} – ${description}`}>
  <div class="topic-card-top">
    <span class="topic-symbol" aria-hidden="true" set:html={icon}></span>
    <div class="topic-copy">
      <p class="topic-eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      {chips.length > 0 && (
        <div class="topic-chips" aria-hidden="true">
          {chips.slice(0, 3).map((chip) => <span>{chip}</span>)}
        </div>
      )}
    </div>
    <span class="topic-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .topic-card {
    display: grid;
    gap: 0.75rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, filter 140ms ease;
  }

  .topic-card:hover,
  .topic-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
    filter: saturate(1.06);
    outline: none;
  }

  .topic-card.accent-a { background: linear-gradient(135deg, rgba(98,123,204,0.34), rgba(234,240,255,0.96)); }
  .topic-card.accent-b { background: linear-gradient(135deg, rgba(78,163,128,0.30), rgba(235,248,240,0.96)); }
  .topic-card.accent-c { background: linear-gradient(135deg, rgba(204,128,104,0.30), rgba(252,242,238,0.96)); }
  .topic-card.accent-d { background: linear-gradient(135deg, rgba(190,166,84,0.30), rgba(251,247,232,0.97)); }
  .topic-card.accent-e { background: linear-gradient(135deg, rgba(90,154,196,0.30), rgba(235,247,252,0.96)); }
  .topic-card.accent-f { background: linear-gradient(135deg, rgba(157,110,190,0.30), rgba(245,238,251,0.96)); }

  :global(html[data-theme="dark"]) .topic-card.accent-a { background: linear-gradient(135deg, rgba(66,92,180,0.34), rgba(21,29,56,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-b { background: linear-gradient(135deg, rgba(39,108,74,0.34), rgba(16,39,28,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-c { background: linear-gradient(135deg, rgba(116,63,47,0.34), rgba(45,26,23,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-d { background: linear-gradient(135deg, rgba(109,91,33,0.32), rgba(43,36,20,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-e { background: linear-gradient(135deg, rgba(29,90,116,0.34), rgba(17,36,45,0.95)); }
  :global(html[data-theme="dark"]) .topic-card.accent-f { background: linear-gradient(135deg, rgba(86,55,116,0.34), rgba(36,25,47,0.95)); }

  .topic-card-top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: start;
  }

  .topic-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.34);
    flex-shrink: 0;
  }

  .topic-symbol :global(svg) {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .topic-copy {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .topic-eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .topic-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.15rem, 1.6vw, 1.45rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .topic-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .topic-chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.55rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.34);
    color: var(--text-strong);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.28);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
    align-self: center;
  }
</style>
