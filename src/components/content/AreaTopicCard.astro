---
interface Props {
  title: string;
  description: string;
  href: string;
  tone?: string;
  icon: string;
  searchText?: string;
  eyebrow?: string;
  chips?: string[];
  accent?: "a" | "b" | "c" | "d";
}

const {
  title,
  description,
  href,
  tone = "math",
  icon,
  searchText = "",
  eyebrow = "Thema",
  chips = [],
  accent = "a",
} = Astro.props as Props;
---

<a class={`topic-card ${tone} accent-${accent}`} href={href} data-search-item data-search-text={searchText}>
  <div class="topic-card-top">
    <span class="topic-symbol" aria-hidden="true" set:html={icon}></span>
    <div class="topic-copy">
      <p class="topic-eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
    </div>
  </div>
  {chips.length > 0 && (
    <div class="topic-chips" aria-hidden="true">
      {chips.slice(0, 4).map((chip) => <span>{chip}</span>)}
    </div>
  )}
  <p>{description}</p>
</a>

<style>
  .topic-card {
    display: grid;
    gap: 0.95rem;
    padding: 1.45rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    min-height: 15rem;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-card.accent-a { background: linear-gradient(135deg, rgba(93,113,175,0.18), rgba(232,237,248,0.88)); }
  .topic-card.accent-b { background: linear-gradient(135deg, rgba(117,156,124,0.18), rgba(236,245,238,0.88)); }
  .topic-card.accent-c { background: linear-gradient(135deg, rgba(186,138,123,0.18), rgba(247,239,235,0.88)); }
  .topic-card.accent-d { background: linear-gradient(135deg, rgba(176,160,104,0.18), rgba(245,241,228,0.90)); }

  :global(html[data-theme="dark"]) .topic-card.accent-a { background: linear-gradient(135deg, rgba(72,95,164,0.30), rgba(22,31,58,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-b { background: linear-gradient(135deg, rgba(52,93,67,0.28), rgba(20,39,28,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-c { background: linear-gradient(135deg, rgba(110,71,58,0.28), rgba(46,29,25,0.94)); }
  :global(html[data-theme="dark"]) .topic-card.accent-d { background: linear-gradient(135deg, rgba(92,80,36,0.25), rgba(44,37,21,0.94)); }

  .topic-card-top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
  }

  .topic-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.34);
    flex-shrink: 0;
  }

  .topic-symbol :global(svg) {
    width: 1.15rem;
    height: 1.15rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .topic-copy {
    display: grid;
    gap: 0.35rem;
  }

  .topic-eyebrow {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .topic-card h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.55rem, 2.45vw, 1.95rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  .topic-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .topic-chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.30);
    color: var(--text-strong);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .topic-card > p:last-child {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    font-size: 1rem;
  }
</style>
