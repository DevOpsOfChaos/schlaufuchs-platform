---
import type { LinuxShellScenario } from "../../data/interactive/linuxShellScenarios";

interface Props {
  scenario: LinuxShellScenario;
}

const { scenario } = Astro.props as Props;
const shellId = `linux-shell-${scenario.key.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
---

<section class="linux-shell-card" id={shellId}>
  <div class="shell-head">
    <div>
      <p class="shell-kicker">Interaktive Übung</p>
      <h2>{scenario.title}</h2>
    </div>
    <span class="shell-badge">Linux-Lernshell</span>
  </div>

  <p class="shell-intro">{scenario.intro}</p>

  {scenario.quickNotes && scenario.quickNotes.length > 0 && (
    <div class="shell-notes">
      <p>Worauf du hier achten kannst:</p>
      <ul>
        {scenario.quickNotes.map((note) => <li>{note}</li>)}
      </ul>
    </div>
  )}

  <div class="shell-suggestions">
    <p>Probiere zum Einstieg:</p>
    <ul>
      {scenario.suggestedCommands.map((command) => (
        <li><button type="button" class="command-chip" data-shell-command={command}><code>{command}</code></button></li>
      ))}
    </ul>
  </div>

  <div class="shell-window">
    <div class="shell-toolbar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="shell-toolbar-title">{scenario.prompt}:{scenario.startPath}</span>
    </div>

    <div class="shell-output" data-shell-output aria-live="polite"></div>

    <form class="shell-input-row" data-shell-form novalidate>
      <label class="shell-prompt" for={`${shellId}-input`}>{scenario.prompt}:{scenario.startPath}$</label>
      <input
        id={`${shellId}-input`}
        class="shell-input"
        data-shell-input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="Befehl eingeben und mit Enter ausführen"
      />
      <button type="submit" class="shell-submit" data-shell-submit>Befehl senden</button>
    </form>

    <div class="shell-hints">
      <span>Enter führt aus</span>
      <span>Esc leert die Eingabe</span>
      <span>Ctrl + L leert die Ausgabe</span>
      <span>↑ ↓ blättert durch den Verlauf</span>
    </div>
  </div>
</section>

<script is:inline define:vars={{ scenario, shellId }}>
  (() => {
    const root = document.getElementById(shellId);
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const outputEl = root.querySelector("[data-shell-output]");
    const formEl = root.querySelector("[data-shell-form]");
    const inputEl = root.querySelector("[data-shell-input]");
    const promptEl = root.querySelector(".shell-prompt");
    const quickButtons = [...root.querySelectorAll("[data-shell-command]")];
    if (!outputEl || !formEl || !inputEl || !promptEl) return;

    const initialEntries = scenario.entries.map((entry) => ({ ...entry }));
    let entries = scenario.entries.map((entry) => ({ ...entry }));
    let cwd = scenario.startPath;
    const history = [];
    let historyIndex = -1;

    const escapeHtml = (value) => value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");
    const normalizePath = (value) => {
      const parts = [];
      for (const part of value.split("/")) {
        if (!part || part === ".") continue;
        if (part === "..") { parts.pop(); continue; }
        parts.push(part);
      }
      return "/" + parts.join("/");
    };
    const resolvePath = (value, current = cwd) => {
      if (!value || value === "~") return "/home/fox";
      if (value.startsWith("/")) return normalizePath(value);
      return normalizePath(`${current}/${value}`);
    };
    const basename = (value) => normalizePath(value).split("/").filter(Boolean).at(-1) ?? "/";
    const dirname = (value) => {
      const normalized = normalizePath(value);
      if (normalized === "/") return "/";
      const parts = normalized.split("/").filter(Boolean);
      parts.pop();
      return "/" + parts.join("/");
    };
    const getEntry = (path) => entries.find((entry) => entry.path === path) ?? null;
    const isDir = (path) => getEntry(path)?.type === "dir";
    const listChildren = (path) => {
      const prefix = path === "/" ? "/" : `${path}/`;
      return entries
        .filter((entry) => entry.path.startsWith(prefix) && entry.path !== path)
        .filter((entry) => {
          const rest = entry.path.slice(prefix.length);
          return rest.length > 0 && !rest.includes("/");
        })
        .sort((a, b) => a.path.localeCompare(b.path, "de"));
    };
    const renderTree = (path, prefix = "") => {
      const children = listChildren(path);
      const lines = [];
      children.forEach((child, index) => {
        const last = index === children.length - 1;
        lines.push(`${prefix}${last ? "└──" : "├──"} ${basename(child.path)}${child.type === "dir" ? "/" : ""}`);
        if (child.type === "dir") lines.push(...renderTree(child.path, `${prefix}${last ? "    " : "│   "}`));
      });
      return lines;
    };
    const appendLine = (html, type = "output") => {
      const line = document.createElement("div");
      line.className = `shell-line ${type}`;
      line.innerHTML = html;
      outputEl.appendChild(line);
      outputEl.scrollTop = outputEl.scrollHeight;
    };
    const updatePrompt = () => { promptEl.textContent = `${scenario.prompt}:${cwd}$`; };
    const resetShell = () => {
      entries = initialEntries.map((entry) => ({ ...entry }));
      cwd = scenario.startPath;
      history.length = 0;
      historyIndex = -1;
      outputEl.innerHTML = "";
      appendLine(escapeHtml(`Willkommen in der Linux-Lernshell: ${scenario.title}`));
      appendLine("Nutze <strong>help</strong> für die Befehlsübersicht.");
      updatePrompt();
      inputEl.focus();
    };

    const manuals = {
      pwd: "pwd zeigt das aktuelle Arbeitsverzeichnis an.",
      ls: "ls listet Inhalte eines Verzeichnisses auf.",
      cd: "cd wechselt in ein anderes Verzeichnis.",
      tree: "tree zeigt eine Verzeichnisstruktur an.",
      cat: "cat zeigt den Inhalt einer Datei an.",
      grep: "grep sucht in Zeilen nach einem Muster.",
      wc: "wc zählt Zeilen, Wörter und Zeichen.",
      head: "head zeigt den Anfang einer Datei.",
      tail: "tail zeigt das Ende einer Datei.",
      find: "find durchsucht ab einem Startpfad einen Verzeichnisbaum.",
      chmod: "chmod ändert numerische Rechte wie 640 oder 755.",
      help: "help zeigt die wichtigsten Befehle dieser Lernshell an.",
      history: "history zeigt die zuletzt genutzten Befehle an.",
      man: "man zeigt kurze Hilfetexte zu bekannten Befehlen.",
      basename: "basename zeigt den letzten Namensteil eines Pfades.",
      dirname: "dirname zeigt das übergeordnete Verzeichnis eines Pfades.",
      realpath: "realpath zeigt einen vollständigen, aufgelösten Pfad an.",
    };

    const runCommand = (rawCommand) => {
      const trimmed = rawCommand.trim();
      appendLine(`<span class="prompt">${escapeHtml(`${scenario.prompt}:${cwd}$`)}</span> <span class="command">${escapeHtml(trimmed)}</span>`, "command");
      if (!trimmed) return;
      const parts = trimmed.match(/"[^"]*"|'[^']*'|\S+/g)?.map((part) => part.replace(/^['"]|['"]$/g, "")) ?? [];
      const command = parts[0];
      const args = parts.slice(1);
      let result = "";
      if (command === "pwd") result = cwd;
      else if (command === "help") result = "pwd, ls, cd, tree, cat, head, tail, find, grep, wc, chmod, basename, dirname, realpath, history, man, clear, reset";
      else if (command === "history") result = history.length ? history.map((item, index) => `${index + 1}  ${item}`).join("\n") : "Noch keine Befehle ausgeführt.";
      else if (command === "man") result = manuals[args[0]] ?? `Keine Handbuchseite für ${args[0]} vorhanden.`;
      else if (command === "clear") { outputEl.innerHTML = ""; return; }
      else if (command === "reset") { resetShell(); return; }
      else if (command === "cd") {
        const target = resolvePath(args[0] ?? "~");
        if (!isDir(target)) result = `cd: ${args[0] ?? "~"}: kein Verzeichnis`;
        else { cwd = target; updatePrompt(); }
      }
      else if (command === "ls") {
        const target = resolvePath(args.find((arg) => !arg.startsWith("-")) ?? ".");
        if (!isDir(target)) result = `ls: ${target}: kein Verzeichnis`;
        else result = listChildren(target).map((entry) => `${basename(entry.path)}${entry.type === "dir" ? "/" : ""}`).join("    ");
      }
      else if (command === "tree") {
        const target = resolvePath(args[0] ?? ".");
        if (!isDir(target)) result = `tree: ${args[0] ?? "."}: kein Verzeichnis`;
        else result = [target === "/" ? "/" : `${basename(target)}/`, ...renderTree(target)].join("\n");
      }
      else if (command === "basename") {
        result = basename(resolvePath(args[0] ?? "."));
      }
      else if (command === "dirname") {
        result = dirname(resolvePath(args[0] ?? "."));
      }
      else if (command === "realpath") {
        result = resolvePath(args[0] ?? ".");
      }
      else if (command === "cat") {
        const entry = getEntry(resolvePath(args[0] ?? ""));
        result = !entry || entry.type !== "file" ? `${args[0] ?? ""}: keine Datei` : entry.content ?? "";
      }
      else if (command === "head" || command === "tail") {
        const fileArg = args.find((arg, index) => arg && arg !== "-n" && args[index - 1] !== "-n");
        const entry = getEntry(resolvePath(fileArg ?? ""));
        if (!entry || entry.type !== "file") result = `${fileArg ?? ""}: keine Datei`;
        else {
          const countIndex = args.findIndex((arg) => arg === "-n");
          const count = Number(countIndex !== -1 ? args[countIndex + 1] ?? "10" : "10");
          const lines = String(entry.content ?? "").split("\n").filter((line) => line.length > 0);
          result = (command === "head" ? lines.slice(0, count) : lines.slice(Math.max(lines.length - count, 0))).join("\n");
        }
      }
      else if (command === "grep") {
        const pattern = args[0] ?? "";
        const entry = getEntry(resolvePath(args[1] ?? ""));
        if (!entry || entry.type !== "file") result = `${args[1] ?? ""}: keine Datei`;
        else result = String(entry.content ?? "").split("\n").filter((line) => line.includes(pattern)).join("\n") || `grep: keine Treffer für ${pattern}`;
      }
      else if (command === "wc") {
        const entry = getEntry(resolvePath(args[0] ?? ""));
        if (!entry || entry.type !== "file") result = `${args[0] ?? ""}: keine Datei`;
        else {
          const text = String(entry.content ?? "");
          const lines = text.trim().length ? text.trim().split(/\n/).length : 0;
          const words = text.trim().length ? text.trim().split(/\s+/).length : 0;
          result = `${lines} ${words} ${text.length} ${args[0]}`;
        }
      }
      else if (command === "find") {
        const start = resolvePath(args.find((arg, index) => index === 0 && !arg.startsWith("-")) ?? ".");
        const nameIndex = args.findIndex((arg) => arg === "-name");
        const typeIndex = args.findIndex((arg) => arg === "-type");
        const namePattern = nameIndex !== -1 ? (args[nameIndex + 1] ?? "") : "";
        const typeFilter = typeIndex !== -1 ? args[typeIndex + 1] ?? "" : "";
        if (!isDir(start)) result = `find: ${start}: kein Verzeichnis`;
        else {
          const prefix = start === "/" ? "/" : `${start}/`;
          const matches = entries
            .filter((entry) => entry.path.startsWith(prefix) && entry.path !== start)
            .filter((entry) => !typeFilter || (typeFilter === "f" ? entry.type === "file" : entry.type === "dir"))
            .filter((entry) => {
              if (!namePattern) return true;
              const base = basename(entry.path);
              const raw = namePattern.replaceAll("*", "");
              if (namePattern.startsWith("*") && namePattern.endsWith("*")) return base.includes(raw);
              if (namePattern.startsWith("*")) return base.endsWith(raw);
              if (namePattern.endsWith("*")) return base.startsWith(raw);
              return base === namePattern;
            })
            .map((entry) => entry.path);
          result = matches.join("\n") || "find: keine Treffer";
        }
      }
      else if (command === "chmod") {
        const entry = getEntry(resolvePath(args[1] ?? ""));
        if (!/^[0-7]{3}$/.test(args[0] ?? "")) result = "chmod: in dieser Lernshell werden numerische Rechte wie 640 oder 755 unterstützt";
        else if (!entry) result = `${args[1] ?? ""}: nicht gefunden`;
        else { entry.perms = args[0]; result = `Rechte von ${args[1]} auf ${args[0]} gesetzt.`; }
      }
      else result = `${command}: Befehl in dieser Lernshell nicht verfügbar`;
      if (result) appendLine(escapeHtml(String(result)).replaceAll("\n", "<br />"));
    };

    const executeInputCommand = () => {
      const rawValue = inputEl.value;
      const trimmedValue = rawValue.trim();
      if (trimmedValue) history.unshift(trimmedValue);
      historyIndex = -1;
      runCommand(rawValue);
      inputEl.value = "";
      inputEl.focus();
    };

    formEl.addEventListener("submit", (event) => {
      event.preventDefault();
      event.stopPropagation();
      executeInputCommand();
    });

    inputEl.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        event.stopPropagation();
        executeInputCommand();
      } else if (event.key === "ArrowUp") {
        if (history.length === 0) return;
        historyIndex = Math.min(historyIndex + 1, history.length - 1);
        inputEl.value = history[historyIndex] ?? "";
        event.preventDefault();
      } else if (event.key === "ArrowDown") {
        if (history.length === 0) return;
        historyIndex = Math.max(historyIndex - 1, -1);
        inputEl.value = historyIndex === -1 ? "" : history[historyIndex] ?? "";
        event.preventDefault();
      } else if (event.key === "Escape") {
        inputEl.value = "";
        event.preventDefault();
      } else if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "l") {
        outputEl.innerHTML = "";
        event.preventDefault();
      }
    });

    quickButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const command = button.getAttribute("data-shell-command") ?? "";
        if (!command) return;
        history.unshift(command);
        historyIndex = -1;
        runCommand(command);
        inputEl.focus();
      });
    });

    resetShell();
  })();
</script>

<style>
  .linux-shell-card { display:grid; gap:1rem; margin:1.6rem 0; padding:1.2rem; border:1px solid var(--border); border-radius:28px; background:color-mix(in oklab, var(--card-bg) 95%, #eef2ff 5%); box-shadow:var(--shadow-soft); }
  .shell-head { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
  .shell-kicker { margin:0 0 .6rem; color:var(--text-soft); font-size:.82rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; }
  .shell-head h2 { margin:0; color:var(--text-strong); font-size:clamp(1.45rem,2.2vw,1.85rem); line-height:1.1; }
  .shell-badge { display:inline-flex; align-items:center; min-height:2rem; padding:0 .75rem; border-radius:999px; border:1px solid var(--border); background:var(--surface); color:var(--text-strong); font-size:.84rem; font-weight:700; white-space:nowrap; }
  .shell-intro { margin:0; color:var(--text); line-height:1.72; }
  .shell-notes,.shell-suggestions { display:grid; gap:.65rem; padding:1rem; border:1px solid var(--border); border-radius:22px; background:var(--surface); }
  .shell-notes p,.shell-suggestions p { margin:0; color:var(--text-strong); }
  .shell-notes ul { margin:0; padding-left:1.1rem; display:grid; gap:.45rem; }
  .shell-suggestions ul { list-style:none; margin:0; padding:0; display:flex; flex-wrap:wrap; gap:.6rem; }
  .command-chip { min-height:2.15rem; padding:0 .8rem; border:1px solid var(--border); background:var(--card-bg); color:var(--text-strong); border-radius:999px; cursor:pointer; }
  .command-chip code { font-size:.9rem; }
  .command-chip:hover,.command-chip:focus-visible { border-color:var(--border-strong); box-shadow:var(--shadow-soft); outline:none; }
  .shell-window { overflow:hidden; border:1px solid color-mix(in oklab, var(--border) 70%, #0f172a 30%); border-radius:22px; background:#0b1220; color:#d7e2f0; }
  .shell-toolbar { display:flex; align-items:center; gap:.55rem; padding:.8rem 1rem; background:#111a2b; border-bottom:1px solid rgba(255,255,255,.08); }
  .dot { width:.75rem; height:.75rem; border-radius:999px; display:inline-block; }
  .dot.red { background:#ef4444; } .dot.yellow { background:#f59e0b; } .dot.green { background:#22c55e; }
  .shell-toolbar-title { margin-left:.3rem; color:rgba(231,240,255,.8); font-size:.9rem; }
  .shell-output { min-height:13rem; max-height:22rem; overflow:auto; padding:1rem; font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; font-size:.95rem; line-height:1.55; white-space:pre-wrap; word-break:break-word; }
  .shell-line + .shell-line { margin-top:.45rem; }
  .shell-line.command .prompt { color:#93c5fd; }
  .shell-line.command .command { color:#f8fafc; }
  .shell-input-row { display:grid; grid-template-columns:auto minmax(0,1fr) auto; gap:.7rem; align-items:center; padding:.95rem 1rem 1rem; border-top:1px solid rgba(255,255,255,.08); background:#0f172a; }
  .shell-prompt { color:#93c5fd; font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; font-size:.92rem; }
  .shell-input { min-width:0; border:0; outline:none; background:transparent; color:#f8fafc; font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; font-size:.95rem; }
  .shell-input::placeholder { color:rgba(226,232,240,.45); }
  .shell-submit { display:inline-flex; align-items:center; justify-content:center; min-height:2.4rem; padding:0 .9rem; border:1px solid rgba(255,255,255,.12); border-radius:999px; background:rgba(255,255,255,.08); color:#f8fafc; font-weight:700; cursor:pointer; white-space:nowrap; }
  .shell-submit:hover,.shell-submit:focus-visible { background:rgba(255,255,255,.14); border-color:rgba(255,255,255,.2); outline:none; }
  .shell-hints { display:flex; flex-wrap:wrap; gap:.6rem 1rem; padding:.75rem 1rem 1rem; border-top:1px solid rgba(255,255,255,.06); background:#0f172a; color:rgba(226,232,240,.72); font-size:.82rem; }
  @media (max-width:720px){ .linux-shell-card { padding:1rem; border-radius:24px; } .shell-output { min-height:12rem; font-size:.9rem; } .shell-input-row { grid-template-columns:1fr; } .shell-submit { width:100%; } .shell-hints { display:grid; gap:.35rem; } }
</style>
