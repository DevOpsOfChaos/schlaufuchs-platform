---
interface Props {
  caption?: string;
  wide?: boolean;
}

const { caption, wide = false } = Astro.props as Props;
---

<figure class:list={["content-media-frame", wide && "wide-bleed"]}>
  <div class="media-inner">
    <slot />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .content-media-frame {
    display: grid;
    gap: 0.75rem;
    margin: 1.4rem 0;
  }

  .media-inner {
    padding: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  figcaption {
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.55;
  }
</style>
