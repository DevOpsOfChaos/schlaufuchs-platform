---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
  ctaLabel: string;
  icon: string;
  variant?: "task" | "article" | "topic";
}

const {
  title,
  description,
  meta,
  href,
  ctaLabel,
  icon,
  variant = "article",
} = Astro.props as Props;
---

<article class:list={["resource-card", variant]}>
  <div class:list={["icon-badge", variant === "article" ? "secondary" : undefined]} aria-hidden="true" set:html={icon} />
  <div class="resource-copy">
    <div class="resource-top">
      <h3>{title}</h3>
      <span>{meta}</span>
    </div>
    <p>{description}</p>
    <a href={href}>{ctaLabel}</a>
  </div>
</article>

<style>
  .resource-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
    padding: 1.15rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 18px;
    background: color-mix(in oklab, var(--surface-strong) 86%, #4f46e5 14%);
    color: white;
    flex-shrink: 0;
    box-shadow: var(--shadow-soft);
  }

  .icon-badge.secondary {
    background: var(--surface);
    color: var(--text-strong);
    border: 1px solid var(--border);
  }

  .icon-badge :global(svg) {
    width: 1.2rem;
    height: 1.2rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .resource-copy {
    display: grid;
    gap: 0.7rem;
    min-width: 0;
  }

  .resource-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.06rem;
    line-height: 1.25;
  }

  span {
    color: var(--text-soft);
    font-size: 0.86rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  p {
    margin: 0;
    color: var(--text);
    line-height: 1.62;
  }

  a {
    color: var(--text-strong);
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .resource-card {
      grid-template-columns: 1fr;
    }

    .icon-badge {
      width: 2.7rem;
      height: 2.7rem;
    }
  }
</style>
