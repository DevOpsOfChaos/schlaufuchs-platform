      }
      if (command === "cmp") {
        if (args.length < 2) return "cmp: bitte zwei Dateien angeben";
        const first = getEntry(resolvePath(args[0], cwd));
        const second = getEntry(resolvePath(args[1], cwd));
        if (!first || first.type !== "file") return `cmp: ${args[0]}: keine Datei`;
        if (!second || second.type !== "file") return `cmp: ${args[1]}: keine Datei`;
        const a = normalizeStdout(first.content);
        const b = normalizeStdout(second.content);
        if (a === b) return "cmp: Dateien sind identisch";
        const maxLen = Math.max(a.length, b.length);
