---
import type { LinuxShellScenario } from "../../data/interactive/linuxShellScenarios";

interface Props {
  scenario: LinuxShellScenario;
}

const { scenario } = Astro.props as Props;
const shellId = `linux-shell-${scenario.key.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
const shellIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M5 7l4 4-4 4"></path>
  <path d="M12 15h7"></path>
  <rect x="3" y="4" width="18" height="16" rx="2"></rect>
</svg>`;
const bookIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M6 5.5A2.5 2.5 0 0 1 8.5 3H20v16H8.5A2.5 2.5 0 0 0 6 21.5V5.5Z"></path>
  <path d="M6 5.5V19"></path>
</svg>`;
---

<section class="linux-shell-card" data-linux-shell-root id={shellId}>
  <div class="shell-head">
    <div>
      <p class="shell-kicker">Interaktive Übung</p>
      <h2>{scenario.title}</h2>
    </div>
    <span class="shell-badge"><span class="badge-icon" set:html={shellIcon} />Linux-Lernshell</span>
  </div>

  <p class="shell-intro">{scenario.intro}</p>

  {scenario.quickNotes && scenario.quickNotes.length > 0 && (
    <div class="shell-notes">
      <p>Worauf du hier achten kannst:</p>
      <ul>
        {scenario.quickNotes.map((note) => <li>{note}</li>)}
      </ul>
    </div>
  )}

  {scenario.trySteps && scenario.trySteps.length > 0 && (
    <div class="shell-steps">
      <p>Ein guter Start in dieser Übung:</p>
      <ol>
        {scenario.trySteps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  )}

  <details class="shell-reference">
    <summary><span class="summary-icon" set:html={bookIcon} />Befehlsübersicht für diese Lernshell</summary>
    <p>Diese Lernshell ist absichtlich größer als ein enger Themen-Simulator. Viele typische Grundbefehle funktionieren hier parallel zum eigentlichen Seitenthema. Je nach Szenario sind außerdem passende Beispielbefehle und Dateien vorbereitet, damit du nicht bei null anfangen musst.</p>
    <div class="reference-grid">
      <article>
        <h3>Orientierung</h3>
        <p><code>pwd</code>, <code>ls</code>, <code>cd</code>, <code>tree</code>, <code>find</code>, <code>realpath</code>, <code>basename</code>, <code>dirname</code>, <code>readlink</code>, <code>hostname</code>, <code>uptime</code></p>
      </article>
      <article>
        <h3>Dateien</h3>
        <p><code>cat</code>, <code>less</code>, <code>head</code>, <code>tail</code>, <code>touch</code>, <code>mkdir</code>, <code>cp</code>, <code>mv</code>, <code>rm</code>, <code>file</code>, <code>stat</code>, <code>cmp</code>, <code>sha256sum</code>, <code>md5sum</code></p>
      </article>
      <article>
        <h3>Textarbeit</h3>
        <p><code>grep</code>, <code>wc</code>, <code>sort</code>, <code>uniq</code>, <code>cut</code>, <code>tr</code>, <code>nl</code>, <code>sed</code>, <code>awk</code>, <code>column</code>, <code>paste</code>, <code>echo</code>, <code>printf</code>, <code>tee</code>, <code>rev</code>, <code>fmt</code>, einfache Pipes mit <code>|</code> und Umleitungen mit <code>&gt;</code> / <code>&gt;&gt;</code></p>
      </article>
      <article>
        <h3>System und Hilfe</h3>
        <p><code>whoami</code>, <code>groups</code>, <code>id</code>, <code>which</code>, <code>man</code>, <code>--help</code>, <code>help</code>, <code>history</code>, <code>clear</code>, <code>reset</code>, <code>chmod</code>, <code>nano</code>, <code>uname</code>, <code>ps</code>, <code>date</code>, <code>env</code>, <code>printenv</code>, <code>df</code>, <code>du</code>, <code>readlink</code>, <code>ln -s</code>, <code>cal</code></p>
      </article>
    </div>
  <p class="shell-calm-note">Fehlermeldungen sind in dieser Lernshell bewusst ruhiger formuliert: Sie sollen dir zeigen, was fehlt oder nicht passt, ohne dich aus dem Lernfluss zu werfen.</p>
  </details>

  <div class="shell-suggestions">
    <div class="suggestions-head">
      <p>Probiere zum Einstieg:</p>
      <div class="toolbar-actions">
        <button type="button" class="mini-button" data-shell-clear>Ausgabe leeren</button>
        <button type="button" class="mini-button" data-shell-reset>Shell zurücksetzen</button>
      </div>
    </div>
    <ul>
      {scenario.suggestedCommands.map((command) => (
        <li>
          <button type="button" class="command-chip" data-shell-command={command}>
            <code>{command}</code>
          </button>
        </li>
      ))}
    </ul>
  </div>

  <div class="shell-window">
    <div class="shell-toolbar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="shell-toolbar-title">{scenario.prompt}:{scenario.startPath}</span>
    </div>

    <div class="shell-output" data-shell-output aria-live="polite"></div>

    <form class="shell-input-row" data-shell-form>
      <label class="shell-prompt" for={`${shellId}-input`}>{scenario.prompt}:{scenario.startPath}$</label>
      <input
        id={`${shellId}-input`}
        class="shell-input"
        data-shell-input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="Befehl eingeben und mit Enter ausführen"
      />
    </form>
  </div>
</section>

<script is:inline define:vars={{ scenario, shellId }}>
  (() => {
    const root = document.getElementById(shellId);
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const outputEl = root.querySelector("[data-shell-output]");
    const formEl = root.querySelector("[data-shell-form]");
    const inputEl = root.querySelector("[data-shell-input]");
    const promptEl = root.querySelector(".shell-prompt");
    const resetButton = root.querySelector("[data-shell-reset]");
    const clearButton = root.querySelector("[data-shell-clear]");
    const quickButtons = [...root.querySelectorAll("[data-shell-command]")];

    if (!outputEl || !formEl || !inputEl || !promptEl) return;

    const username = "fox";
    const groups = ["fox", "adm", "plugdev"];
    const commandHistory = [];
    let historyIndex = -1;

    const cloneEntries = (items) => items.map((entry) => ({ ...entry }));
    const initialEntries = cloneEntries(scenario.entries);
    let entries = cloneEntries(scenario.entries);
    let cwd = scenario.startPath;

    const manuals = {
      pwd: "pwd zeigt das aktuelle Arbeitsverzeichnis an.",
      ls: "ls listet Inhalte eines Verzeichnisses auf. Mit -l erhältst du eine längere Ansicht, mit -a auch versteckte Einträge.",
      cd: "cd wechselt in ein anderes Verzeichnis. cd .. geht eine Ebene nach oben, cd ~ ins Homeverzeichnis.",
      cat: "cat zeigt den Inhalt einer Datei an.",
      man: "man öffnet Handbuchtexte zu bekannten Befehlen in dieser Lernshell.",
      chmod: "chmod ändert in dieser Lernshell einfache numerische Rechte wie 640 oder 755.",
      nano: "nano simuliert hier das Öffnen einer Datei und erklärt die typische Arbeitsweise.",
      mkdir: "mkdir legt ein Verzeichnis im aktuellen Ordner an. Mit -p werden fehlende Zwischenordner ebenfalls angelegt.",
      touch: "touch legt eine leere Datei an, wenn sie noch nicht existiert.",
      tree: "tree zeigt die Verzeichnisstruktur unterhalb eines Pfades.",
      rm: "rm entfernt in dieser Lernshell Dateien oder leere Verzeichnisse. Mit -r werden auch Inhalte darunter gelöscht.",
      cp: "cp kopiert Dateien in dieser Lernshell an einen neuen Ort.",
      mv: "mv verschiebt oder benennt Dateien und leere Verzeichnisse um.",
      find: "find durchsucht ab einem Startpfad die Lernstruktur nach Namen.",
      grep: "grep sucht in Dateiinhalten nach einem Textmuster. Unterstützt hier einfache Varianten wie -n, -i, -v und -c.",
      awk: "awk liest zeilenweise Text und kann in dieser Lernshell einfache Felder wie {print $1} oder {print $2} ausgeben.",
      column: "column richtet einfache tabellarische Eingaben mit -t und optional -s lesbarer aus.",
      stat: "stat zeigt kompakte Metadaten zu Datei oder Verzeichnis.",
      head: "head zeigt die ersten Zeilen einer Datei.",
      tail: "tail zeigt die letzten Zeilen einer Datei.",
      whoami: "whoami zeigt den aktuellen Benutzer der Lernshell an.",
      groups: "groups zeigt die Gruppen des aktuellen Benutzers.",
      id: "id zeigt Benutzer- und Gruppeninformationen kompakt an.",
      file: "file beschreibt grob, um welchen Dateityp es sich handelt.",
      ps: "ps zeigt in dieser Lernshell eine kleine Beispiel-Prozessliste an.",
      reset: "reset stellt die Lernshell in den Ausgangszustand zurück.",
      clear: "clear leert die aktuelle Ausgabe.",
      help: "help zeigt die unterstützten Befehle dieser Lernshell an.",
      history: "history zeigt die zuletzt ausgeführten Befehle.",
      which: "which zeigt, ob ein Befehl in dieser Lernshell bekannt ist.",
      wc: "wc zählt in dieser Lernshell Zeilen, Wörter und Zeichen einer Datei oder einer Pipe-Ausgabe grob zusammen.",
      basename: "basename zeigt den letzten Teil eines Pfades an.",
      dirname: "dirname zeigt den übergeordneten Pfad an.",
      realpath: "realpath löst einen relativen Pfad in einen absoluten Pfad auf.",
      less: "less öffnet hier vereinfacht den Inhalt einer Datei in einer lesbaren Vorschau.",
      sort: "sort sortiert Zeilen alphabetisch. Mit -r wird die Reihenfolge umgekehrt und mit -u werden Dubletten nach dem Sortieren entfernt.",
      uniq: "uniq entfernt in dieser Lernshell gleiche aufeinanderfolgende Zeilen. Mit -c werden Mengen gezählt und mit -d nur doppelte Zeilen ausgegeben.",
      cut: "cut liest aus einfachen Trennzeichen-Dateien oder einer Pipe bestimmte Felder aus. Mit -c kannst du auch einfache Zeichenbereiche ausschneiden.",
      tr: "tr ersetzt in dieser Lernshell einfache Zeichen in einer Pipe oder in kurzem Text.",
      printf: "printf gibt formatierten Text aus und kann wie echo mit > in eine Datei schreiben.",
      echo: "echo gibt Text aus und kann mit > oder >> in eine Datei schreiben.",
      tee: "tee gibt den Eingabetext aus und kann ihn zusätzlich in eine Datei schreiben.",
      seq: "seq erzeugt einfache Zahlenfolgen.",
      date: "date zeigt in dieser Lernshell eine feste Beispielzeit an.",
      env: "env zeigt einige beispielhafte Umgebungsvariablen dieser Lernshell.",
      printenv: "printenv verhält sich in dieser Lernshell wie env und zeigt Umgebungsvariablen an.",
      df: "df zeigt vereinfacht die belegten und freien Dateisysteme an. Mit -h wirkt die Ausgabe lesbarer.",
      du: "du schätzt den Platzbedarf einer Datei oder eines Ordners. Mit -h wirkt die Ausgabe lesbarer.",
      readlink: "readlink zeigt in dieser Lernshell den Zielpfad eines symbolischen Links oder den aufgelösten Pfad an.",
      diff: "diff vergleicht zwei kurze Textdateien zeilenweise und markiert Unterschiede vereinfacht.",
      join: "join verbindet zwei einfache, sortierte Textlisten über ein gemeinsames erstes Feld.",
      xargs: "xargs übernimmt in dieser Lernshell einfache Eingaben aus einer Pipe und ruft damit einen Folge-Befehl auf.",
      ln: "ln -s legt in dieser Lernshell einen symbolischen Link an.",
      sleep: "sleep wartet in dieser Lernshell nicht wirklich, bestätigt aber die angegebene Zeit.",
      rmdir: "rmdir entfernt leere Verzeichnisse. Mit -p werden auch leere Elternordner bis zum ersten nichtleeren Ordner entfernt.",
      comm: "comm vergleicht zwei sortierte Dateien oder zwei sortierte Pipe-Ausgaben vereinfacht zeilenweise.",
      rev: "rev kehrt Zeichen in jeder Zeile um.",
      fmt: "fmt bricht längere Zeilen in dieser Lernshell vereinfacht auf eine ruhigere Breite um.",
    };

    const normalizePath = (value) => {
      const segments = [];
      const raw = value.split("/");
      for (const segment of raw) {
        if (!segment || segment === ".") continue;
        if (segment === "..") {
          segments.pop();
          continue;
        }
        segments.push(segment);
      }
      return "/" + segments.join("/");
    };

    const dirname = (value) => {
      const normalized = normalizePath(value);
      if (normalized === "/") return "/";
      const parts = normalized.split("/").filter(Boolean);
      parts.pop();
      return "/" + parts.join("/");
    };

    const basename = (value) => normalizePath(value).split("/").filter(Boolean).at(-1) ?? "/";

    const resolvePath = (value, current) => {
      if (!value || value === "~") return "/home/fox";
      if (value.startsWith("~")) return normalizePath(`/home/fox/${value.slice(2)}`);
      if (value.startsWith("/")) return normalizePath(value);
      return normalizePath(`${current}/${value}`);
    };

    const getEntry = (path) => entries.find((entry) => entry.path === path) ?? null;
    const isDir = (path) => getEntry(path)?.type === "dir";
    const hasChildren = (path) => entries.some((entry) => entry.path !== path && entry.path.startsWith(`${path === "/" ? "" : path}/`));

    const listChildren = (path, includeHidden = false) => {
      const prefix = path === "/" ? "/" : `${path}/`;
      return entries
        .filter((entry) => entry.path.startsWith(prefix) && entry.path !== path)
        .filter((entry) => {
          const rest = entry.path.slice(prefix.length);
          if (rest.length === 0 || rest.includes("/")) return false;
          if (!includeHidden && rest.startsWith(".")) return false;
          return true;
        })
        .sort((a, b) => a.path.localeCompare(b.path, "de"));
    };

    const escapeHtml = (value) =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");

    const appendLine = (html, type = "output") => {
      const line = document.createElement("div");
      line.className = `shell-line ${type}`;
      line.innerHTML = html;
      outputEl.appendChild(line);
      outputEl.scrollTop = outputEl.scrollHeight;
    };

    const formatPrompt = () => `${scenario.prompt}:${cwd}$`;
    const updatePrompt = () => {
      promptEl.textContent = formatPrompt();
    };

    const longPerms = (entry) => {
      const perms = (entry.perms ?? (entry.type === "dir" ? "755" : "644")).padStart(3, "0").slice(-3);
      const map = { "0": "---", "1": "--x", "2": "-w-", "3": "-wx", "4": "r--", "5": "r-x", "6": "rw-", "7": "rwx" };
      return `${entry.type === "dir" ? "d" : "-"}${map[perms[0]]}${map[perms[1]]}${map[perms[2]]}`;
    };

    const printTree = (path, prefix = "") => {
      const children = listChildren(path, true);
      const lines = [];
      children.forEach((child, index) => {
        const isLast = index === children.length - 1;
        const connector = isLast ? "└──" : "├──";
        const name = basename(child.path);
        lines.push(`${prefix}${connector} ${name}${child.type === "dir" ? "/" : ""}`);
        if (child.type === "dir") {
          lines.push(...printTree(child.path, `${prefix}${isLast ? "    " : "│   "}`));
        }
      });
      return lines;
    };

    const renderStat = (entry) => {
      const perms = entry.perms ?? (entry.type === "dir" ? "755" : "644");
      const contentLines = entry.content ? entry.content.split("\n").filter(Boolean).length : 0;
      return [
        `Pfad: ${entry.path}`,
        `Typ: ${entry.type === "dir" ? "Verzeichnis" : "Datei"}`,
        `Rechte: ${perms} (${longPerms(entry)})`,
        `Besitzer: ${username}`,
        `Gruppe: ${groups[0]}`,
        `Zeilen: ${entry.type === "file" ? contentLines : "-"}`,
      ].join("\n");
    };

    const parseNumberFlag = (args) => {
      const index = args.findIndex((arg) => arg === "-n");
      if (index === -1) return { count: 10, rest: args };
      const count = Number(args[index + 1] ?? "10");
      const rest = args.filter((_, i) => i !== index && i !== index + 1);
      return { count: Number.isFinite(count) ? count : 10, rest };
    };

    const normalizeStdout = (value) => {
      if (value == null) return "";
      return typeof value === "string" ? value : String(value);
    };

    const stripTrailingEmptyLine = (value) => {
      const parts = normalizeStdout(value).split("\n");
      if (parts.length > 0 && parts[parts.length - 1] === "") {
        parts.pop();
      }
      return parts;
    };

    const readFileArgOrStdin = (cmdName, args, stdin) => {
      const targetArg = args[0];
      if (!targetArg) {
        if (typeof stdin === "string") return { source: stdin, label: "stdin" };
        return { error: `${cmdName}: bitte Datei angeben` };
      }
      const entry = getEntry(resolvePath(targetArg, cwd));
      if (!entry || entry.type !== "file") return { error: `${cmdName}: ${targetArg}: keine Datei` };
      return { source: entry.content ?? "", label: targetArg };
    };

    const splitPipeline = (commandLine) => {
      const segments = [];
      let current = "";
      let quote = "";
      for (const ch of commandLine) {
        if ((ch === '"' || ch === "'") && (!quote || quote === ch)) {
          quote = quote === ch ? "" : ch;
          current += ch;
          continue;
        }
        if (ch === "|" && !quote) {
          segments.push(current.trim());
          current = "";
          continue;
        }
        current += ch;
      }
      if (current.trim()) segments.push(current.trim());
      return segments;
    };

    const executePipelineSegment = (segment, stdin = null) => {
      if (segment.endsWith(" --help")) {
        const baseCmd = segment.replace(/\s+--help$/, "");
        return manuals[baseCmd] ?? `Keine Kurzinfo für ${baseCmd} vorhanden.`;
      }

      const parts = segment.match(/"[^"]*"|'[^']*'|\S+/g) ?? [];
      const command = parts[0];
      const args = parts.slice(1).map((part) => part.replace(/^['"]|['"]$/g, ""));

      const readSource = (cmdName) => {
        const targetArg = args[0];
        if (!targetArg) {
          if (typeof stdin === "string") return { source: stdin, label: "stdin" };
          return { error: `${cmdName}: bitte Datei angeben` };
        }
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return { error: `${cmdName}: ${targetArg}: keine Datei` };
        return { source: entry.content ?? "", label: targetArg };
      };

      if (command === "echo" || command === "printf") {
        return args.length > 0 ? args.join(" ") : normalizeStdout(stdin);
      }
      if (command === "cat") {
        const sourceInfo = readSource("cat");
        return sourceInfo.error ?? normalizeStdout(sourceInfo.source);
      }
      if (command === "grep") {
        const showNumbers = args.includes("-n");
        const ignoreCase = args.includes("-i");
        const invertMatch = args.includes("-v");
        const countOnly = args.includes("-c");
        const rest = args.filter((arg) => !["-n", "-i", "-v", "-c"].includes(arg));
        const pattern = rest[0];
        if (!pattern) return "grep: bitte Suchtext angeben";
        const targetArgs = rest.slice(1);
        let source = normalizeStdout(stdin);
        if (targetArgs.length > 0) {
          const sourceInfo = readSource("grep");
          if (sourceInfo.error) return sourceInfo.error;
          source = normalizeStdout(sourceInfo.source);
        }
        const lines = source.split("\n");
        const matches = lines
          .map((line, index) => ({ line, index }))
          .filter(({ line }) => {
            const match = ignoreCase ? line.toLowerCase().includes(pattern.toLowerCase()) : line.includes(pattern);
            return invertMatch ? !match : match;
          })
          .map(({ line, index }) => showNumbers ? `${index + 1}:${line}` : line);
        return matches.length ? matches.join("\n") : `grep: keine Treffer für ${pattern}`;
      }
      if (command === "awk") {
        const sourceInfo = args.length > 0 ? readSource("awk") : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        const program = args[0] ?? "";
        const lines = stripTrailingEmptyLine(sourceInfo.source);
        const match = program.match(/\{\s*print\s*\$(\d+)\s*\}/);
        if (match) {
          const field = Math.max(Number(match[1]) - 1, 0);
          return lines.map((line) => line.trim().split(/\s+/)[field] ?? "").join("\n");
        }
        if (/\{\s*print\s+NF\s*\}/.test(program)) {
          return lines.map((line) => String(line.trim().split(/\s+/).filter(Boolean).length)).join("\n");
        }
        return lines.join("\n");
      }
      if (command === "column") {
        const sourceInfo = args.length > 0 ? readSource("column") : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        const delimIndex = args.indexOf("-s");
        const delimiter = delimIndex !== -1 ? (args[delimIndex + 1] ?? ":") : null;
        const lines = stripTrailingEmptyLine(sourceInfo.source).map((line) => delimiter ? line.split(delimiter) : line.trim().split(/\s+/));
        const widths = [];
        lines.forEach((cols) => cols.forEach((col, idx) => widths[idx] = Math.max(widths[idx] ?? 0, col.length)));
        return lines.map((cols) => cols.map((col, idx) => col.padEnd(widths[idx] ?? col.length)).join("  ").trimEnd()).join("\n");
      }
      if (command === "sort") {
        const sourceInfo = args.length > 0 ? readSource("sort") : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        return stripTrailingEmptyLine(sourceInfo.source).sort((a, b) => a.localeCompare(b, "de")).join("\n");
      }
      if (command === "uniq") {
        const sourceInfo = args.length > 0 ? readSource("uniq") : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        const lines = stripTrailingEmptyLine(sourceInfo.source);
        return lines.filter((line, index) => index === 0 || line !== lines[index - 1]).join("\n");
      }
      if (command === "wc") {
        const sourceInfo = args.length > 0 ? readSource("wc") : { source: stdin, label: "stdin" };
        if (sourceInfo.error) return sourceInfo.error;
        const content = normalizeStdout(sourceInfo.source);
        const lines = content.length ? content.split("\n").filter((_, index, arr) => !(index === arr.length - 1 && arr[index] === "")).length : 0;
        const words = content.trim().length ? content.trim().split(/\s+/).length : 0;
        const chars = content.length;
        if (args.includes("-l")) return String(lines);
        if (args.includes("-w")) return String(words);
        if (args.includes("-m")) return String(chars);
        return `${lines} ${words} ${chars} ${sourceInfo.label ?? "stdin"}`;
      }
      if (command === "cut") {
        const delimiterIndex = args.indexOf("-d");
        const fieldIndex = args.indexOf("-f");
        const charIndex = args.indexOf("-c");
        const delimiter = delimiterIndex !== -1 ? args[delimiterIndex + 1] ?? ":" : ":";
        const field = Number(fieldIndex !== -1 ? args[fieldIndex + 1] ?? "1" : "1");
        const positional = args.filter((arg, index) => ![delimiterIndex, delimiterIndex + 1, fieldIndex, fieldIndex + 1, charIndex, charIndex + 1].includes(index));
        const sourceInfo = positional.length > 0 ? readSource("cut") : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        if (charIndex !== -1) {
          const spec = args[charIndex + 1] ?? "1";
          const [startRaw, endRaw] = spec.split("-");
          const start = Math.max(Number(startRaw || "1") - 1, 0);
          const end = endRaw ? Number(endRaw) : start + 1;
          return stripTrailingEmptyLine(sourceInfo.source).map((line) => line.slice(start, end)).join("\n");
        }
        return stripTrailingEmptyLine(sourceInfo.source)
          .map((line) => line.split(delimiter)[Math.max(field - 1, 0)] ?? "")
          .join("\n");
      }
      if (command === "head" || command === "tail") {
        const index = args.findIndex((arg) => arg === "-n");
        const count = index === -1 ? 10 : Number(args[index + 1] ?? "10");
        const rest = index === -1 ? args : args.filter((_, i) => i !== index && i !== index + 1);
        const sourceInfo = rest.length > 0 ? readSource(command) : { source: stdin };
        if (sourceInfo.error) return sourceInfo.error;
        const parts2 = normalizeStdout(sourceInfo.source).split("\n");
        return command === "head"
          ? parts2.slice(0, count).join("\n")
          : parts2.slice(Math.max(parts2.length - count, 0)).join("\n");
      }
      if (command === "tr") {
        if (typeof stdin !== "string") return "tr: in dieser Lernshell wird tr zusammen mit einer Pipe verwendet";
        const from = args[0];
        const to = args[1] ?? "";
        if (!from) return "tr: bitte Zeichen angeben";
        const toChars = [...to];
        const table = new Map();
        [...from].forEach((char, index) => table.set(char, toChars[index] ?? toChars.at(-1) ?? ""));
        return [...normalizeStdout(stdin)].map((char) => table.has(char) ? table.get(char) : char).join("");
      }
      if (command === "tee") {
        const targetArg = args[0];
        const content = normalizeStdout(stdin);
        if (targetArg) {
          const writeResult = writeToFile(targetArg, content + (content.endsWith("\n") ? "" : "\n"), false);
          if (writeResult) return writeResult;
        }
        return content;
      }
      if (command === "seq") {
        const start = args.length === 1 ? 1 : Number(args[0] ?? "1");
        const end = Number(args.length === 1 ? args[0] : args[1] ?? "1");
        if (!Number.isFinite(start) || !Number.isFinite(end)) return "seq: bitte Zahlen angeben";
        const step = start <= end ? 1 : -1;
        const out = [];
        for (let n = start; step > 0 ? n <= end : n >= end; n += step) out.push(String(n));
        return out.join("\n");
      }
      if (command === "ps") {
        return ["  PID TTY          TIME CMD"," 1024 pts/0    00:00:00 bash"," 1188 pts/0    00:00:00 nano"," 1301 pts/0    00:00:00 ps"].join("\n");
