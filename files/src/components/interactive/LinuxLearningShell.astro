      date: () => "So Apr 12 16:00:00 CEST 2026",
      env: () => ["USER=fox","HOME=/home/fox","SHELL=/bin/bash","PWD=" + cwd,"TERM=xterm-256color","EDITOR=nano"].join("\n"),
