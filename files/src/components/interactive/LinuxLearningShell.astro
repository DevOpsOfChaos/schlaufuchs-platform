      history: () => (commandHistory.length ? commandHistory.map((item, index) => `${index + 1}  ${item}`).join("\n") : "Noch keine Befehle ausgeführt."),
      help: () => [
        "Unterstützte Befehle:",
        "pwd, ls, cd, cat, man, --help, help, tree, mkdir, touch, rm, cp, mv, nano, chmod, whoami, groups, id, stat, head, tail, grep, find, file, history, clear, reset, echo, printf, which, wc, basename, dirname, realpath, less, sort, uniq, cut, tr, nl, sed, awk, column, paste, uname, hostname, uptime, cal, ps, date, env, printenv, seq, sleep, tee, comm, df, du, readlink, ln, cmp, sha256sum, md5sum, rev, fmt",
        "Zusätzlich unterstützt: einfache Pipes mit | sowie > und >> für Ausgaben.",
