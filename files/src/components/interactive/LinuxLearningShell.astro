          if (!second || second.type !== "file") return `comm: ${args[1]}: keine Datei`;
          const a = stripTrailingEmptyLine(first.content).sort((x,y)=>x.localeCompare(y,"de"));
          const b = stripTrailingEmptyLine(second.content).sort((x,y)=>x.localeCompare(y,"de"));
          const both = a.filter((line) => b.includes(line));
          return both.length ? both.join("\n") : "comm: keine gemeinsamen Zeilen";
        }
