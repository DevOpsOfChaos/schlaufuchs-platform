      },
      rm: (args) => {
        const recursive = args.includes("-r") || args.includes("-rf") || args.includes("-fr");
        const positional = args.filter((arg) => !["-r", "-rf", "-fr", "-f"].includes(arg));
        const name = positional[0];
        if (!name) return "rm: bitte Ziel angeben";
        const target = resolvePath(name, cwd);
        const entry = getEntry(target);
        if (!entry) return `rm: ${name}: nicht gefunden`;
        if (entry.type === "dir" && hasChildren(target) && !recursive) return `rm: ${name}: Verzeichnis nicht leer`;
