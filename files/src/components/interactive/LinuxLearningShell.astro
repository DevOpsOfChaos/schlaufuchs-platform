      df: (args) => ["Dateisystem   Groesse  Benutzt Verfuegbar Verw% Eingehängt auf","/dev/sim0       32G      8G        24G   25% /","tmpfs           2G     12M       2G    1% /run"].join("\n"),
      du: (args) => {
