        const entry = getEntry(target);
        if (!entry) return `file: ${targetArg}: nicht gefunden`;
        if (entry.type === "dir") return `${targetArg}: directory`;
        const ext = basename(target).split(".").pop();
        const typeMap = { txt: "ASCII text", html: "HTML document", sh: "shell script", csv: "CSV text" };
        return `${targetArg}: ${typeMap[ext] ?? "text file"}`;
      },
      grep: (args) => {
        const showNumbers = args.includes("-n");
        const ignoreCase = args.includes("-i");
        const invertMatch = args.includes("-v");
        const countOnly = args.includes("-c");
        const rest = args.filter((arg) => !["-n", "-i", "-v", "-c"].includes(arg));
        const pattern = rest[0];
        const targetArg = rest[1];
        if (!pattern || !targetArg) return "grep: bitte Suchtext und Datei angeben";
        const target = resolvePath(targetArg, cwd);
        const entry = getEntry(target);
        if (!entry || entry.type !== "file") return `grep: ${targetArg}: keine Datei`;
        const lines = (entry.content ?? "").split("
");
        const matches = lines
          .map((line, index) => ({ line, index }))
          .filter(({ line }) => {
