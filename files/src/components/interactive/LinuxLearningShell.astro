---
import type { LinuxShellScenario } from "../../data/interactive/linuxShellScenarios";

interface Props {
  scenario: LinuxShellScenario;
}

const { scenario } = Astro.props as Props;
const shellId = `linux-shell-${scenario.key.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
const shellIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M5 7l4 4-4 4"></path>
  <path d="M12 15h7"></path>
  <rect x="3" y="4" width="18" height="16" rx="2"></rect>
</svg>`;
---

<section class="linux-shell-card" data-linux-shell-root id={shellId}>
  <div class="shell-head">
    <div>
      <p class="shell-kicker">Interaktive Übung</p>
      <h2>{scenario.title}</h2>
    </div>
    <span class="shell-badge"><span class="badge-icon" set:html={shellIcon} />Linux-Lernshell</span>
  </div>

  <p class="shell-intro">{scenario.intro}</p>

  {scenario.quickNotes && scenario.quickNotes.length > 0 && (
    <div class="shell-notes">
      <p>Worauf du hier achten kannst:</p>
      <ul>
        {scenario.quickNotes.map((note) => <li>{note}</li>)}
      </ul>
    </div>
  )}

  <div class="shell-suggestions">
    <div class="suggestions-head">
      <p>Probiere zum Einstieg:</p>
      <div class="toolbar-actions">
        <button type="button" class="mini-button" data-shell-clear>Ausgabe leeren</button>
        <button type="button" class="mini-button" data-shell-reset>Shell zurücksetzen</button>
      </div>
    </div>
    <ul>
      {scenario.suggestedCommands.map((command) => (
        <li>
          <button type="button" class="command-chip" data-shell-command={command}>
            <code>{command}</code>
          </button>
        </li>
      ))}
    </ul>
  </div>

  <div class="shell-window">
    <div class="shell-toolbar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="shell-toolbar-title">{scenario.prompt}:{scenario.startPath}</span>
    </div>

    <div class="shell-output" data-shell-output aria-live="polite"></div>

    <form class="shell-input-row" data-shell-form>
      <label class="shell-prompt" for={`${shellId}-input`}>{scenario.prompt}:{scenario.startPath}$</label>
      <input
        id={`${shellId}-input`}
        class="shell-input"
        data-shell-input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="Befehl eingeben und mit Enter ausführen"
      />
    </form>
  </div>
</section>

<script is:inline define:vars={{ scenario, shellId }}>
  (() => {
    const root = document.getElementById(shellId);
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const outputEl = root.querySelector("[data-shell-output]");
    const formEl = root.querySelector("[data-shell-form]");
    const inputEl = root.querySelector("[data-shell-input]");
    const promptEl = root.querySelector(".shell-prompt");
    const resetButton = root.querySelector("[data-shell-reset]");
    const clearButton = root.querySelector("[data-shell-clear]");
    const quickButtons = [...root.querySelectorAll("[data-shell-command]")];

    if (!outputEl || !formEl || !inputEl || !promptEl) return;

    const username = "fox";
    const groups = ["fox", "adm", "plugdev"];
    const commandHistory = [];
    let historyIndex = -1;

    const cloneEntries = (items) => items.map((entry) => ({ ...entry }));
    const initialEntries = cloneEntries(scenario.entries);
    let entries = cloneEntries(scenario.entries);
    let cwd = scenario.startPath;

    const manuals = {
      pwd: "pwd zeigt das aktuelle Arbeitsverzeichnis an.",
      ls: "ls listet Inhalte eines Verzeichnisses auf. Mit -l erhältst du eine längere Ansicht, mit -a auch versteckte Einträge.",
      cd: "cd wechselt in ein anderes Verzeichnis. cd .. geht eine Ebene nach oben, cd ~ ins Homeverzeichnis.",
      cat: "cat zeigt den Inhalt einer Datei an.",
      man: "man öffnet Handbuchtexte zu bekannten Befehlen in dieser Lernshell.",
      chmod: "chmod ändert in dieser Lernshell einfache numerische Rechte wie 640 oder 755.",
      nano: "nano simuliert hier das Öffnen einer Datei und erklärt die typische Arbeitsweise.",
      mkdir: "mkdir legt ein Verzeichnis im aktuellen Ordner an.",
      touch: "touch legt eine leere Datei an, wenn sie noch nicht existiert.",
      tree: "tree zeigt die Verzeichnisstruktur unterhalb eines Pfades.",
      rm: "rm entfernt in dieser Lernshell Dateien oder leere Verzeichnisse.",
      cp: "cp kopiert Dateien in dieser Lernshell an einen neuen Ort.",
      mv: "mv verschiebt oder benennt Dateien und leere Verzeichnisse um.",
      find: "find durchsucht ab einem Startpfad die Lernstruktur nach Namen.",
      grep: "grep sucht in Dateiinhalten nach einem Textmuster.",
      stat: "stat zeigt kompakte Metadaten zu Datei oder Verzeichnis.",
      head: "head zeigt die ersten Zeilen einer Datei.",
      tail: "tail zeigt die letzten Zeilen einer Datei.",
      whoami: "whoami zeigt den aktuellen Benutzer der Lernshell an.",
      groups: "groups zeigt die Gruppen des aktuellen Benutzers.",
      id: "id zeigt Benutzer- und Gruppeninformationen kompakt an.",
      file: "file beschreibt grob, um welchen Dateityp es sich handelt.",
      reset: "reset stellt die Lernshell in den Ausgangszustand zurück.",
      clear: "clear leert die aktuelle Ausgabe.",
      help: "help zeigt die unterstützten Befehle dieser Lernshell an.",
      history: "history zeigt die zuletzt ausgeführten Befehle.",
    };

    const normalizePath = (value) => {
      const segments = [];
      const raw = value.split("/");
      for (const segment of raw) {
        if (!segment || segment === ".") continue;
        if (segment === "..") {
          segments.pop();
          continue;
        }
        segments.push(segment);
      }
      return "/" + segments.join("/");
    };

    const dirname = (value) => {
      const normalized = normalizePath(value);
      if (normalized === "/") return "/";
      const parts = normalized.split("/").filter(Boolean);
      parts.pop();
      return "/" + parts.join("/");
    };

    const basename = (value) => normalizePath(value).split("/").filter(Boolean).at(-1) ?? "/";

    const resolvePath = (value, current) => {
      if (!value || value === "~") return "/home/fox";
      if (value.startsWith("~")) return normalizePath(`/home/fox/${value.slice(2)}`);
      if (value.startsWith("/")) return normalizePath(value);
      return normalizePath(`${current}/${value}`);
    };

    const getEntry = (path) => entries.find((entry) => entry.path === path) ?? null;
    const isDir = (path) => getEntry(path)?.type === "dir";
    const hasChildren = (path) => entries.some((entry) => entry.path !== path && entry.path.startsWith(`${path === "/" ? "" : path}/`));

    const listChildren = (path, includeHidden = false) => {
      const prefix = path === "/" ? "/" : `${path}/`;
      return entries
        .filter((entry) => entry.path.startsWith(prefix) && entry.path !== path)
        .filter((entry) => {
          const rest = entry.path.slice(prefix.length);
          if (rest.length === 0 || rest.includes("/")) return false;
          if (!includeHidden && rest.startsWith(".")) return false;
          return true;
        })
        .sort((a, b) => a.path.localeCompare(b.path, "de"));
    };

    const escapeHtml = (value) =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");

    const appendLine = (html, type = "output") => {
      const line = document.createElement("div");
      line.className = `shell-line ${type}`;
      line.innerHTML = html;
      outputEl.appendChild(line);
      outputEl.scrollTop = outputEl.scrollHeight;
    };

    const formatPrompt = () => `${scenario.prompt}:${cwd}$`;
    const updatePrompt = () => {
      promptEl.textContent = formatPrompt();
    };

    const longPerms = (entry) => {
      const perms = (entry.perms ?? (entry.type === "dir" ? "755" : "644")).padStart(3, "0").slice(-3);
      const map = { "0": "---", "1": "--x", "2": "-w-", "3": "-wx", "4": "r--", "5": "r-x", "6": "rw-", "7": "rwx" };
      return `${entry.type === "dir" ? "d" : "-"}${map[perms[0]]}${map[perms[1]]}${map[perms[2]]}`;
    };

    const printTree = (path, prefix = "") => {
      const children = listChildren(path, true);
      const lines = [];
      children.forEach((child, index) => {
        const isLast = index === children.length - 1;
        const connector = isLast ? "└──" : "├──";
        const name = basename(child.path);
        lines.push(`${prefix}${connector} ${name}${child.type === "dir" ? "/" : ""}`);
        if (child.type === "dir") {
          lines.push(...printTree(child.path, `${prefix}${isLast ? "    " : "│   "}`));
        }
      });
      return lines;
    };

    const renderStat = (entry) => {
      const perms = entry.perms ?? (entry.type === "dir" ? "755" : "644");
      const contentLines = entry.content ? entry.content.split("\n").filter(Boolean).length : 0;
      return [
        `Pfad: ${entry.path}`,
        `Typ: ${entry.type === "dir" ? "Verzeichnis" : "Datei"}`,
        `Rechte: ${perms} (${longPerms(entry)})`,
        `Besitzer: ${username}`,
        `Gruppe: ${groups[0]}`,
        `Zeilen: ${entry.type === "file" ? contentLines : "-"}`,
      ].join("\n");
    };

    const parseNumberFlag = (args) => {
      const index = args.findIndex((arg) => arg === "-n");
      if (index === -1) return { count: 10, rest: args };
      const count = Number(args[index + 1] ?? "10");
      const rest = args.filter((_, i) => i !== index && i !== index + 1);
      return { count: Number.isFinite(count) ? count : 10, rest };
    };

    const resetShell = () => {
      entries = cloneEntries(initialEntries);
      cwd = scenario.startPath;
      commandHistory.length = 0;
      historyIndex = -1;
      outputEl.innerHTML = "";
      appendLine(escapeHtml(`Willkommen in der Linux-Lernshell: ${scenario.title}`));
      appendLine("Nutze <strong>help</strong> für eine Übersicht, <strong>reset</strong> für den Anfangszustand oder probiere einen Vorschlag oben aus.");
      updatePrompt();
      inputEl.focus();
    };

    const commandHandlers = {
      pwd: () => cwd,
      whoami: () => username,
      groups: () => groups.join(" "),
      id: () => `uid=1000(${username}) gid=1000(${groups[0]}) groups=${groups.map((group, index) => `${1000 + index}(${group})`).join(",")}`,
      uname: () => "Linux schlaufuchs-learning-shell 6.8.0 x86_64",
      history: () => (commandHistory.length ? commandHistory.map((item, index) => `${index + 1}  ${item}`).join("\n") : "Noch keine Befehle ausgeführt."),
      help: () => [
        "Unterstützte Befehle:",
        "pwd, ls, cd, cat, man, --help, help, tree, mkdir, touch, rm, cp, mv, nano, chmod, whoami, groups, id, stat, head, tail, grep, find, file, history, clear, reset, echo",
      ].join("\n"),
      echo: (args) => args.join(" "),
      clear: () => "__CLEAR__",
      reset: () => "__RESET__",
      tree: (args) => {
        const target = resolvePath(args[0] ?? ".", cwd);
        if (!isDir(target)) return `tree: ${args[0] ?? "."}: kein Verzeichnis`;
        const lines = [target === "/" ? "/" : `${basename(target)}/`, ...printTree(target)];
        return lines.join("\n");
      },
      man: (args) => {
        const topic = args[0];
        if (!topic) return "man: bitte einen Befehl angeben";
        return manuals[topic] ?? `Keine Handbuchseite für ${topic} in dieser Lernshell vorhanden.`;
      },
      cd: (args) => {
        const target = resolvePath(args[0] ?? "~", cwd);
        if (!isDir(target)) return `cd: ${args[0] ?? "~"}: kein Verzeichnis`;
        cwd = target;
        updatePrompt();
        return "";
      },
      ls: (args) => {
        const long = args.includes("-l") || args.includes("-la") || args.includes("-al");
        const all = args.includes("-a") || args.includes("-la") || args.includes("-al");
        const targetArg = args.filter((arg) => !["-l", "-a", "-la", "-al"].includes(arg))[0];
        const target = resolvePath(targetArg ?? ".", cwd);
        if (!isDir(target)) return `ls: ${targetArg ?? "."}: kein Verzeichnis`;
        const children = listChildren(target, all);
        if (long) {
          return children.map((entry) => `${longPerms(entry)} 1 ${username} ${groups[0]} ${basename(entry.path)}${entry.type === "dir" ? "/" : ""}`).join("\n");
        }
        return children.map((entry) => `${basename(entry.path)}${entry.type === "dir" ? "/" : ""}`).join("    ");
      },
      cat: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "cat: bitte Datei angeben";
        const target = resolvePath(targetArg, cwd);
        const entry = getEntry(target);
        if (!entry || entry.type !== "file") return `cat: ${targetArg}: keine Datei`;
        return entry.content ?? "";
      },
      stat: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "stat: bitte Ziel angeben";
        const target = resolvePath(targetArg, cwd);
        const entry = getEntry(target);
        if (!entry) return `stat: ${targetArg}: nicht gefunden`;
        return renderStat(entry);
      },
      file: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "file: bitte Ziel angeben";
        const target = resolvePath(targetArg, cwd);
        const entry = getEntry(target);
        if (!entry) return `file: ${targetArg}: nicht gefunden`;
        if (entry.type === "dir") return `${targetArg}: directory`;
        const ext = basename(target).split(".").pop();
        const typeMap = { txt: "ASCII text", html: "HTML document", sh: "shell script" };
        return `${targetArg}: ${typeMap[ext] ?? "text file"}`;
      },
      grep: (args) => {
        const pattern = args[0];
        const targetArg = args[1];
        if (!pattern || !targetArg) return "grep: bitte Suchtext und Datei angeben";
        const target = resolvePath(targetArg, cwd);
        const entry = getEntry(target);
        if (!entry || entry.type !== "file") return `grep: ${targetArg}: keine Datei`;
        const lines = (entry.content ?? "").split("\n");
        const matches = lines.filter((line) => line.toLowerCase().includes(pattern.toLowerCase()));
        return matches.length ? matches.join("\n") : `grep: keine Treffer für ${pattern}`;
      },
      head: (args) => {
        const { count, rest } = parseNumberFlag(args);
        const targetArg = rest[0];
        if (!targetArg) return "head: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `head: ${targetArg}: keine Datei`;
        return (entry.content ?? "").split("\n").slice(0, count).join("\n");
      },
      tail: (args) => {
        const { count, rest } = parseNumberFlag(args);
        const targetArg = rest[0];
        if (!targetArg) return "tail: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `tail: ${targetArg}: keine Datei`;
        const parts = (entry.content ?? "").split("\n");
        return parts.slice(Math.max(parts.length - count, 0)).join("\n");
      },
      find: (args) => {
        let start = ".";
        let pattern = "";
        if (args[0] && !args[0].startsWith("-")) start = args[0];
        const nameIndex = args.indexOf("-name");
        if (nameIndex !== -1) pattern = (args[nameIndex + 1] ?? "").replace(/['"]/g, "");
        const startPath = resolvePath(start, cwd);
        if (!isDir(startPath)) return `find: ${start}: kein Verzeichnis`;
        const prefix = startPath === "/" ? "/" : `${startPath}/`;
        const matches = entries
          .filter((entry) => entry.path === startPath || entry.path.startsWith(prefix))
          .filter((entry) => !pattern || basename(entry.path).includes(pattern.replaceAll("*", "")))
          .map((entry) => entry.path);
        return matches.join("\n");
      },
      mkdir: (args) => {
        const name = args[0];
        if (!name) return "mkdir: bitte Namen angeben";
        const target = resolvePath(name, cwd);
        if (getEntry(target)) return `mkdir: ${name}: existiert bereits`;
        const parent = dirname(target);
        if (!isDir(parent)) return `mkdir: ${name}: Zielpfad ungültig`;
        entries.push({ path: target, type: "dir", perms: "755" });
        return "";
      },
      touch: (args) => {
        const name = args[0];
        if (!name) return "touch: bitte Dateinamen angeben";
        const target = resolvePath(name, cwd);
        if (!getEntry(target)) {
          const parent = dirname(target);
          if (!isDir(parent)) return `touch: ${name}: Zielpfad ungültig`;
          entries.push({ path: target, type: "file", perms: "644", content: "" });
        }
        return "";
      },
      rm: (args) => {
        const name = args[0];
        if (!name) return "rm: bitte Ziel angeben";
        const target = resolvePath(name, cwd);
        const entry = getEntry(target);
        if (!entry) return `rm: ${name}: nicht gefunden`;
        if (entry.type === "dir" && hasChildren(target)) return `rm: ${name}: Verzeichnis nicht leer`;
        const index = entries.findIndex((item) => item.path === target);
        if (index >= 0) entries.splice(index, 1);
        return "";
      },
      cp: (args) => {
        const [srcArg, destArg] = args;
        if (!srcArg || !destArg) return "cp: bitte Quelle und Ziel angeben";
        const src = resolvePath(srcArg, cwd);
        const entry = getEntry(src);
        if (!entry || entry.type !== "file") return `cp: ${srcArg}: nur Dateien werden in dieser Lernshell kopiert`;
        const dest = resolvePath(destArg, cwd);
        const parent = dirname(dest);
        if (!isDir(parent)) return `cp: ${destArg}: Zielpfad ungültig`;
        const existing = getEntry(dest);
        if (existing && existing.type === "dir") return `cp: ${destArg}: Ziel ist ein Verzeichnis`;
        if (existing) {
          existing.content = entry.content ?? "";
          existing.perms = entry.perms ?? "644";
        } else {
          entries.push({ path: dest, type: "file", perms: entry.perms ?? "644", content: entry.content ?? "" });
        }
        return "";
      },
      mv: (args) => {
        const [srcArg, destArg] = args;
        if (!srcArg || !destArg) return "mv: bitte Quelle und Ziel angeben";
        const src = resolvePath(srcArg, cwd);
        const entry = getEntry(src);
        if (!entry) return `mv: ${srcArg}: nicht gefunden`;
        const dest = resolvePath(destArg, cwd);
        const parent = dirname(dest);
        if (!isDir(parent)) return `mv: ${destArg}: Zielpfad ungültig`;
        if (entry.type === "dir" && hasChildren(src)) return "mv: in dieser Lernshell werden nur leere Verzeichnisse oder Dateien verschoben";
        const existing = getEntry(dest);
        if (existing) return `mv: ${destArg}: existiert bereits`;
        entry.path = dest;
        return "";
      },
      chmod: (args) => {
        const mode = args[0];
        const name = args[1];
        if (!mode || !name) return "chmod: bitte Rechte und Ziel angeben";
        if (!/^[0-7]{3}$/.test(mode)) return "chmod: in dieser Lernshell werden numerische Rechte wie 640 oder 755 unterstützt";
        const target = resolvePath(name, cwd);
        const entry = getEntry(target);
        if (!entry) return `chmod: ${name}: nicht gefunden`;
        entry.perms = mode;
        return "";
      },
      nano: (args) => {
        const name = args[0];
        if (!name) return "nano: bitte Dateinamen angeben";
        const target = resolvePath(name, cwd);
        let entry = getEntry(target);
        if (!entry) {
          entries.push({ path: target, type: "file", perms: "644", content: "" });
          entry = getEntry(target);
        }
        return [
          `nano öffnet hier simuliert die Datei ${name}.`,
          "In der echten Arbeit würdest du nun lesen, gezielt ändern, speichern und sauber beenden.",
          `Aktueller Inhalt: ${entry?.content ? JSON.stringify(entry.content) : "(leer)"}`,
        ].join("\n");
      },
    };

    const runCommand = (rawCommand) => {
      const trimmed = rawCommand.trim();
      appendLine(`<span class="prompt">${escapeHtml(formatPrompt())}</span> <span class="command">${escapeHtml(trimmed)}</span>`, "command");
      if (!trimmed) return;

      if (trimmed.endsWith(" --help")) {
        const baseCmd = trimmed.replace(/\s+--help$/, "");
        const helpText = manuals[baseCmd] ?? `Keine Kurzinfo für ${baseCmd} vorhanden.`;
        appendLine(escapeHtml(helpText));
        return;
      }

      const parts = trimmed.match(/"[^"]*"|'[^']*'|\S+/g) ?? [];
      const command = parts[0];
      const args = parts.slice(1).map((part) => part.replace(/^['"]|['"]$/g, ""));

      const handler = commandHandlers[command];
      if (!handler) {
        appendLine(escapeHtml(`${command}: Befehl in dieser Lernshell nicht verfügbar`));
        return;
      }

      const result = handler(args);
      if (result === "__CLEAR__") {
        outputEl.innerHTML = "";
        return;
      }
      if (result === "__RESET__") {
        resetShell();
        return;
      }
      if (typeof result === "string" && result.length > 0) {
        appendLine(escapeHtml(result).replaceAll("\n", "<br />"));
      }
    };

    formEl.addEventListener("submit", (event) => {
      event.preventDefault();
      const value = inputEl.value;
      if (value.trim()) {
        commandHistory.unshift(value.trim());
        historyIndex = -1;
      }
      runCommand(value);
      inputEl.value = "";
    });

    inputEl.addEventListener("keydown", (event) => {
      if (event.key === "ArrowUp") {
        if (commandHistory.length === 0) return;
        historyIndex = Math.min(historyIndex + 1, commandHistory.length - 1);
        inputEl.value = commandHistory[historyIndex] ?? "";
        event.preventDefault();
      }
      if (event.key === "ArrowDown") {
        if (commandHistory.length === 0) return;
        historyIndex = Math.max(historyIndex - 1, -1);
        inputEl.value = historyIndex === -1 ? "" : commandHistory[historyIndex] ?? "";
        event.preventDefault();
      }
    });

    quickButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const command = button.getAttribute("data-shell-command") ?? "";
        inputEl.value = command;
        inputEl.focus();
      });
    });

    resetButton?.addEventListener("click", resetShell);
    clearButton?.addEventListener("click", () => {
      outputEl.innerHTML = "";
      inputEl.focus();
    });

    resetShell();
  })();
</script>

<style>
  .linux-shell-card {
    display: grid;
    gap: 1rem;
    margin: 1.6rem 0;
    padding: 1.3rem;
    border: 1px solid var(--border);
    border-radius: 28px;
    background: color-mix(in oklab, var(--card-bg) 95%, #eef2ff 5%);
    box-shadow: var(--shadow-soft);
  }

  .shell-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .shell-kicker {
    margin: 0 0 0.6rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .shell-head h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.45rem, 2.2vw, 1.85rem);
    line-height: 1.1;
  }

  .shell-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .badge-icon :global(svg) {
