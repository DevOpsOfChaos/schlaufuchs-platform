      },
      cp: (args) => {
        const [srcArg, destArg] = args;
        if (!srcArg || !destArg) return "cp: bitte Quelle und Ziel angeben";
        const src = resolvePath(srcArg, cwd);
        const entry = getEntry(src);
        if (!entry || entry.type !== "file") return `cp: ${srcArg}: nur Dateien werden in dieser Lernshell kopiert`;
        const dest = resolvePath(destArg, cwd);
        const parent = dirname(dest);
        if (!isDir(parent)) return `cp: ${destArg}: Zielpfad ungültig`;
        const existing = getEntry(dest);
        if (existing && existing.type === "dir") return `cp: ${destArg}: Ziel ist ein Verzeichnis`;
        if (existing) {
          existing.content = entry.content ?? "";
          existing.perms = entry.perms ?? "644";
        } else {
