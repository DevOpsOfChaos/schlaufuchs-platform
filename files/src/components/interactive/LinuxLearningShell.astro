        }
        return "";
      },
      mv: (args) => {
        const [srcArg, destArg] = args;
        if (!srcArg || !destArg) return "mv: bitte Quelle und Ziel angeben";
        const src = resolvePath(srcArg, cwd);
        const entry = getEntry(src);
        if (!entry) return `mv: ${srcArg}: nicht gefunden`;
        const dest = resolvePath(destArg, cwd);
        const parent = dirname(dest);
        if (!isDir(parent)) return `mv: ${destArg}: Zielpfad ungültig`;
        if (entry.type === "dir" && hasChildren(src)) return "mv: in dieser Lernshell werden nur leere Verzeichnisse oder Dateien verschoben";
        const existing = getEntry(dest);
        if (existing) return `mv: ${destArg}: existiert bereits`;
        entry.path = dest;
        return "";
      },
      chmod: (args) => {
        const mode = args[0];
        const name = args[1];
        if (!mode || !name) return "chmod: bitte Rechte und Ziel angeben";
        const target = resolvePath(name, cwd);
        const entry = getEntry(target);
        if (!entry) return `chmod: ${name}: nicht gefunden`;
        if (/^[0-7]{3}$/.test(mode)) {
          entry.perms = mode;
          return "";
        }
        if (!/^[ugo]+[+=-][rwx]+(?:,[ugo]+[+=-][rwx]+)*$/.test(mode)) {
          return "chmod: unterstützt hier numerische Rechte oder einfache symbolische Modi wie u+x,g-w";
        }
        const triples = (entry.perms ?? "644").split("").map((digit) => Number(digit));
        const maskMap = { r: 4, w: 2, x: 1 };
        for (const clause of mode.split(",")) {
          const [, whoRaw, op, permsRaw] = clause.match(/^([ugo]+)([+=-])([rwx]+)$/) || [];
          const mask = [...permsRaw].reduce((sum, ch) => sum + (maskMap[ch] ?? 0), 0);
          const indices = [...whoRaw].map((ch) => ({ u: 0, g: 1, o: 2 })[ch]).filter((v) => v !== undefined);
          for (const idx of indices) {
            if (op === "+") triples[idx] = triples[idx] | mask;
            else if (op === "-") triples[idx] = triples[idx] & (7 - mask);
            else triples[idx] = mask;
          }
        }
        entry.perms = triples.join("");
        return "";
      },
      which: (args) => {
        const name = args[0];
        if (!name) return "which: bitte Befehl angeben";
        return commandHandlers[name] ? `/usr/bin/${name}` : `which: no ${name} in (schlaufuchs-shell)`;
      },
      basename: (args) => {
        const value = args[0];
        if (!value) return "basename: bitte Pfad angeben";
        return basename(resolvePath(value, cwd));
      },
      dirname: (args) => {
        const value = args[0];
        if (!value) return "dirname: bitte Pfad angeben";
        return dirname(resolvePath(value, cwd));
      },
      realpath: (args) => {
        const value = args[0];
        if (!value) return "realpath: bitte Pfad angeben";
        return resolvePath(value, cwd);
      },
      wc: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "wc: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `wc: ${targetArg}: keine Datei`;
        const content = entry.content ?? "";
        const lines = content.length ? content.split("\n").filter((_, index, arr) => !(index === arr.length - 1 && arr[index] === "")).length : 0;
        const words = content.trim().length ? content.trim().split(/\s+/).length : 0;
        const chars = content.length;
        return `${lines} ${words} ${chars} ${targetArg}`;
      },
      less: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "less: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `less: ${targetArg}: keine Datei`;
        return [
          `--- less: ${targetArg} ---`,
          entry.content ?? "",
          "--- Ende der vereinfachten Vorschau ---",
        ].join("\n");
      },
      sort: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "sort: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `sort: ${targetArg}: keine Datei`;
        return (entry.content ?? "").split("\n").filter(Boolean).sort((a, b) => a.localeCompare(b, "de")).join("\n");
      },
      uniq: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "uniq: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `uniq: ${targetArg}: keine Datei`;
        const lines = (entry.content ?? "").split("\n").filter(Boolean);
        const result = lines.filter((line, index) => index === 0 || line !== lines[index - 1]);
        return result.join("\n");
      },
      cut: (args) => {
        const delimiterIndex = args.indexOf("-d");
        const fieldIndex = args.indexOf("-f");
        const charIndex = args.indexOf("-c");
        const delimiter = delimiterIndex !== -1 ? args[delimiterIndex + 1] ?? ":" : ":";
        const field = Number(fieldIndex !== -1 ? args[fieldIndex + 1] ?? "1" : "1");
        const fileArg = args.at(-1);
        if (!fileArg) return "cut: bitte Datei angeben";
        const entry = getEntry(resolvePath(fileArg, cwd));
        if (!entry || entry.type !== "file") return `cut: ${fileArg}: keine Datei`;
        return (entry.content ?? "")
          .split("\n")
          .filter(Boolean)
          .map((line) => line.split(delimiter)[Math.max(field - 1, 0)] ?? "")
          .join("\n");
      },
      ln: (args) => {
        if (args[0] !== "-s") return "ln: in dieser Lernshell wird nur ln -s unterstützt";
        const sourceArg = args[1];
        const targetArg = args[2];
        if (!sourceArg || !targetArg) return "ln -s: bitte Quelle und Ziel angeben";
        const source = resolvePath(sourceArg, cwd);
        const target = resolvePath(targetArg, cwd);
        const parent = dirname(target);
        if (!isDir(parent)) return `ln: ${targetArg}: Zielpfad ungültig`;
        if (getEntry(target)) return `ln: ${targetArg}: existiert bereits`;
        entries.push({ path: target, type: "file", perms: "777", content: `link -> ${source}` , linkTarget: source });
        return "";
      },
      rev: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "rev: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `rev: ${targetArg}: keine Datei`;
        return (entry.content ?? "").split("
").map((line) => [...line].reverse().join("")).join("
");
      },
      fmt: (args) => {
        const targetArg = args[0];
        if (!targetArg) return "fmt: bitte Datei angeben";
        const entry = getEntry(resolvePath(targetArg, cwd));
        if (!entry || entry.type !== "file") return `fmt: ${targetArg}: keine Datei`;
        const words = (entry.content ?? "").split(/\s+/).filter(Boolean);
        const out = [];
        let current = "";
        for (const word of words) {
          if ((current + ' ' + word).trim().length > 48) {
            if (current) out.push(current);
            current = word;
          } else {
            current = (current + ' ' + word).trim();
          }
        }
        if (current) out.push(current);
        return out.join("
");
      },
      nano: (args) => {
        const name = args[0];
        if (!name) return "nano: bitte Dateinamen angeben";
        const target = resolvePath(name, cwd);
        let entry = getEntry(target);
        if (!entry) {
          entries.push({ path: target, type: "file", perms: "644", content: "" });
          entry = getEntry(target);
        }
        return [
          `nano öffnet hier simuliert die Datei ${name}.`,
          "In der echten Arbeit würdest du nun lesen, gezielt ändern, speichern und sauber beenden.",
          `Aktueller Inhalt: ${entry?.content ? JSON.stringify(entry.content) : "(leer)"}`,
        ].join("\n");
      },
    };

    const runCommand = (rawCommand) => {
      const trimmed = rawCommand.trim();
      appendLine(`<span class="prompt">${escapeHtml(formatPrompt())}</span> <span class="command">${escapeHtml(trimmed)}</span>`, "command");
      if (!trimmed) return;

      if (trimmed.endsWith(" --help")) {
        const baseCmd = trimmed.replace(/\s+--help$/, "");
        const helpText = manuals[baseCmd] ?? `Keine Kurzinfo für ${baseCmd} vorhanden.`;
        appendLine(escapeHtml(helpText));
        return;
      }

      const parts = trimmed.match(/"[^"]*"|'[^']*'|\S+/g) ?? [];
      const command = parts[0];
      let args = parts.slice(1).map((part) => part.replace(/^['"]|['"]$/g, ""));

      if ((command === "echo" || command === "printf") && (args.includes(">") || args.includes(">>"))) {
        const redirectToken = args.includes(">>") ? ">>" : ">";
        const redirectIndex = args.indexOf(redirectToken);
        const content = args.slice(0, redirectIndex).join(" ") + (command === "printf" ? "" : "\n");
        const targetArg = args[redirectIndex + 1];
        if (!targetArg) {
          appendLine(escapeHtml(`${command}: bitte Ziel für die Umleitung angeben`));
          return;
        }
        const writeResult = writeToFile(targetArg, content, redirectToken === ">>");
        if (writeResult) appendLine(escapeHtml(writeResult));
        return;
      }

      const handler = commandHandlers[command];
      if (!handler) {
        appendLine(escapeHtml(`${command}: Befehl in dieser Lernshell nicht verfügbar`));
        return;
      }

      const result = handler(args);
      if (result === "__CLEAR__") {
        outputEl.innerHTML = "";
        return;
      }
      if (result === "__RESET__") {
        resetShell();
        return;
      }
      if (typeof result === "string" && result.length > 0) {
        appendLine(escapeHtml(result).replaceAll("\n", "<br />"));
      }
    };

    formEl.addEventListener("submit", (event) => {
      event.preventDefault();
      const value = inputEl.value;
      if (value.trim()) {
        commandHistory.unshift(value.trim());
        historyIndex = -1;
      }
      runCommand(value);
      inputEl.value = "";
    });

    inputEl.addEventListener("keydown", (event) => {
      if (event.key === "ArrowUp") {
        if (commandHistory.length === 0) return;
        historyIndex = Math.min(historyIndex + 1, commandHistory.length - 1);
        inputEl.value = commandHistory[historyIndex] ?? "";
        event.preventDefault();
      }
      if (event.key === "ArrowDown") {
        if (commandHistory.length === 0) return;
        historyIndex = Math.max(historyIndex - 1, -1);
        inputEl.value = historyIndex === -1 ? "" : commandHistory[historyIndex] ?? "";
        event.preventDefault();
      }
    });

    quickButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const command = button.getAttribute("data-shell-command") ?? "";
        inputEl.value = command;
        inputEl.focus();
      });
    });

    resetButton?.addEventListener("click", resetShell);
    clearButton?.addEventListener("click", () => {
      outputEl.innerHTML = "";
      inputEl.focus();
    });

    resetShell();
  })();
</script>

