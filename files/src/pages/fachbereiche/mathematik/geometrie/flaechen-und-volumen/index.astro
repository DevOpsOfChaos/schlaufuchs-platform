---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { withBase } from "../../../../../utils/base";

const targetHref = withBase("wissen/mathematik/geometrie/flaechen-und-volumen");
---

<BaseLayout title="Flächen & Volumen – Fachinfo" description="Die alte Fachseite wird auf die aktuelle Wissensseite weitergeleitet.">
  <script is:inline define:vars={{ targetHref }}>
    window.location.replace(targetHref);
  </script>

  <section>
    <h1>Flächen & Volumen</h1>
    <p>Die ausführliche Wissensseite wird geöffnet.</p>
    <a href={targetHref}>Zur Wissensseite</a>
  </section>
</BaseLayout>
