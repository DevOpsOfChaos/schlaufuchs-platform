---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { getArticlesForSubject, getExercisesForSubject, levelLabels, type ArticleEntry, type ExerciseEntry } from "../../data/content";
import { getSubjectMeta } from "../../data/subjects";
import { getEntriesForPrimarySubject, getSubjectSectionCards, getTopicTail, getSharedTopicPrefixLength } from "../../data/topics";
import { withBase } from "../../utils/base";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";

export async function getStaticPaths() {
  const { getVisibleSubjects } = await import("../../data/content");
  const subjects = await getVisibleSubjects();

  return subjects.map((subject) => ({
    params: { slug: subject.data.slug },
    props: { subject },
  }));
}

const { subject } = Astro.props as { subject: CollectionEntry<"subjects"> };
const detail = getSubjectMeta(subject.data.slug) ?? {
  intro: subject.data.description,
  highlights: [],
  sections: [],
  knowledgeLabel: "Wissensseiten",
  exerciseLabel: "Aufgaben",
  tone: "default",
  icon: "",
  kicker: "Fachbereich",
  entry: "Grundlagen",
};

const [articles, exercises] = await Promise.all([
  getArticlesForSubject(subject.data.slug),
  getExercisesForSubject(subject.data.slug),
]);

const subjectArticles = getEntriesForPrimarySubject(articles, subject.data.slug);
const subjectExercises = getEntriesForPrimarySubject(exercises, subject.data.slug);
const subjectSections = getSubjectSectionCards([...subjectArticles, ...subjectExercises]);

const scoreEntry = (entry: ArticleEntry | ExerciseEntry) => {
  const tail = getTopicTail(entry);
  const hasDeepPath = tail.length >= 2 ? 3 : 0;
  const hasTags = Array.isArray(entry.data.tags) && entry.data.tags.length > 0 ? 1 : 0;
  return hasDeepPath + hasTags - tail.length * 0.05;
};

const featuredArticles = [...subjectArticles].sort((a, b) => scoreEntry(b) - scoreEntry(a)).slice(0, 6);
const directEntry = featuredArticles[0];

const scoreExerciseForArticle = (exercise: ExerciseEntry, article?: ArticleEntry) => {
  if (!article) return scoreEntry(exercise);
  const sharedPath = getSharedTopicPrefixLength(getTopicTail(article), getTopicTail(exercise));
  const sameSection = exercise.data.section === article.data.section ? 2 : 0;
  return sharedPath * 4 + sameSection + scoreEntry(exercise);
};

const featuredExercises = [...subjectExercises]
  .sort((a, b) => scoreExerciseForArticle(b, directEntry) - scoreExerciseForArticle(a, directEntry))
  .slice(0, 6);

const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout title={`${subject.data.title} – Schlaufuchs`} description={subject.data.description}>
  <div class="subject-shell">
    <section class="subject-hero">
      <div class="hero-copy">
        <p class="eyebrow">Fachbereich</p>
        <h1>{subject.data.title}</h1>
        <p class="lead">{detail.intro}</p>
      </div>

      {directEntry && (
        <article class="entry-card">
          <span class="entry-label">Direkter Einstieg</span>
          <h2>{directEntry.data.title}</h2>
          <p>{directEntry.data.description}</p>
          <a href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(directEntry).join("/")}`)}>Zur Fachinfo →</a>
        </article>
      )}
    </section>

    <section class="subject-section">
      <SectionHeading kicker="Themen" title="Direkt in die Fachthemen" />
      <div class="section-grid linked-topics">
        {subjectSections.map((section) => (
          <a class="section-card topic-link-card" href={withBase(`fachbereiche/${subject.data.slug}/${section.slug}`)}>
            <div class="topic-link-top">
              <h3>{section.title}</h3>
              <span class="topic-arrow" aria-hidden="true">→</span>
            </div>
            {section.children.length > 0 ? (
              <ul>
                {section.children.slice(0, 4).map((item) => <li>{item.title}</li>)}
              </ul>
            ) : (
              <p class="topic-link-text">Öffne die Themenübersicht mit Fachinfos und passenden Aufgaben.</p>
            )}
          </a>
        ))}
      </div>
    </section>

    <section class="subject-section">
      <SectionHeading kicker="Fachinfos" title="Wichtige Wissensseiten in diesem Fach" />
      {featuredArticles.length > 0 ? (
        <div class="content-grid">
          {featuredArticles.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={levelLabels[entry.data.level]}
              href={withBase(`fachbereiche/${subject.data.slug}/${getTopicTail(entry).join("/")}`)}
              ctaLabel="Fachinfo öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      ) : (
        <article class="empty-card">
          <h3>Noch keine Wissensseiten sichtbar</h3>
          <p>Für dieses Fach sind aktuell noch keine Wissensseiten sichtbar.</p>
        </article>
      )}
    </section>

    <section class="subject-section">
      <SectionHeading kicker="Aufgaben" title="Passende Aufgaben in diesem Fach" />
      {featuredExercises.length > 0 ? (
        <div class="content-grid">
          {featuredExercises.map((entry) => (
            <ResourceCard
              title={entry.data.title}
              description={entry.data.description}
              meta={levelLabels[entry.data.level]}
              href={withBase(`aufgaben/${entry.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      ) : (
        <article class="empty-card">
          <h3>Noch keine Aufgaben sichtbar</h3>
          <p>Für dieses Fach sind aktuell noch keine Aufgaben sichtbar.</p>
        </article>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .subject-shell,
  .subject-hero,
  .subject-section {
    display: grid;
    gap: 1rem;
  }

  .subject-hero {
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 22rem);
    align-items: start;
  }

  .eyebrow,
  .entry-label {
    margin: 0 0 0.75rem;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.5rem, 4.7vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.05rem;
    max-width: 58rem;
  }

  .subject-section {
    margin-top: 1.8rem;
  }

  .entry-card,
  .section-card,
  .empty-card {
    border: 1px solid var(--border);
    border-radius: 28px;
    background: var(--card-bg);
    box-shadow: var(--shadow-soft);
    padding: 1.35rem;
  }

  .entry-card h2,
  .empty-card h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .entry-card p,
  .empty-card p {
    margin: 0.8rem 0 0;
    color: var(--text);
    line-height: 1.65;
  }

  .entry-card a {
    display: inline-block;
    margin-top: 0.95rem;
    color: var(--text-strong);
    font-weight: 700;
  }

  .section-grid,
  .content-grid {
    display: grid;
    gap: 1rem;
  }

  .section-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .topic-link-card {
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .topic-link-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .topic-link-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .topic-link-top h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .topic-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.24);
    color: var(--text-strong);
    font-weight: 700;
    flex-shrink: 0;
  }

  .section-card ul {
    list-style: none;
    margin: 0.95rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .section-card li {
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    line-height: 1.55;
  }

  .section-card li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .topic-link-text {
    margin: 0.95rem 0 0;
    color: var(--text);
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .subject-hero,
    .section-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
