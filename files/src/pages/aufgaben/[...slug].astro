---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";
import { getSectionDisplayLabel, getTopicDisplayLabel, getTopicFitScore, getTopicOverviewPath, getTopicTail, humanizeTopicSegment } from "../../data/topics";
import { withBase } from "../../utils/base";
import PageTrail from "../../components/content/PageTrail.astro";
import OverviewPanel from "../../components/content/OverviewPanel.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";
import SupportChecklist from "../../components/content/SupportChecklist.astro";

export async function getStaticPaths() {
  const exercises = await getVisibleExercises();

  return exercises.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"exercises"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";
const topicTail = getTopicTail(entry);
const topicBranch = getTopicOverviewPath(entry);
const topicPathHref = topicBranch.length > 0 ? withBase(`fachbereiche/${subjectSlug}/${topicBranch.join("/")}`) : withBase(`fachbereiche/${subjectSlug}`);
const printHref = withBase(`druck/aufgaben/${entry.id}`);
const hintPoints = Array.isArray(entry.data.hintPoints) ? entry.data.hintPoints.filter(Boolean) : [];
const selfCheckPoints = Array.isArray(entry.data.selfCheckPoints) ? entry.data.selfCheckPoints.filter(Boolean) : [];

const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);
const entryTopicLabel = getTopicDisplayLabel(entry);
const entrySectionLabel = getSectionDisplayLabel(entry.data.section);

const rankedRelatedArticles = allArticles
  .filter((item) => resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .map((item) => ({ item, score: getTopicFitScore(entry, item) }))
  .filter(({ score }) => score >= 4)
  .sort((a, b) => b.score - a.score);

const rankedRelatedExercises = allExercises
  .filter((item) => item.id !== entry.id && resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .map((item) => ({ item, score: getTopicFitScore(entry, item) }))
  .filter(({ score }) => score >= 4)
  .sort((a, b) => b.score - a.score);

const relatedArticles = rankedRelatedArticles.map(({ item }) => item).slice(0, 4);
const relatedExercises = rankedRelatedExercises.map(({ item }) => item).slice(0, 4);

const breadcrumbSegments = topicBranch.map((segment, index) => ({
  label: humanizeTopicSegment(segment),
  href: withBase(`fachbereiche/${subjectSlug}/${topicBranch.slice(0, index + 1).join("/")}`),
}));

const trail = [
  { label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) },
  ...breadcrumbSegments,
];

const backHref = breadcrumbSegments.length > 0 ? breadcrumbSegments[breadcrumbSegments.length - 1].href : withBase(`fachbereiche/${subjectSlug}`);

const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;

const overviewPoints = [
  `Diese Aufgabe gehört fachlich zu ${subjectTitle}.`,
  `Sie ergänzt das Thema ${breadcrumbSegments.at(-1)?.label ?? entry.data.section ?? "dieser Wissensbereich"}.`,
  "Darunter findest du passende Wissensseiten und weitere Aufgaben zum gleichen Themenfeld.",
];
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <div class="page-shell">
    <PageTrail backHref={backHref} trail={trail} />

    <section class="exercise-hero">
      <p class="eyebrow">Aufgabe</p>
      <div class="hero-meta-row">
        <span class="meta-chip">{subjectTitle}</span>
        <span class="meta-chip">{levelLabels[entry.data.level]}</span>
        {entry.data.section && <span class="meta-chip">{entrySectionLabel}</span>}
        <span class="meta-chip">{entryTopicLabel}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </section>

    <OverviewPanel
      title="Worum es in dieser Aufgabe geht"
      kicker="Kontext"
      points={overviewPoints}
      actionHref={topicPathHref}
      actionLabel="Zum Themenpfad →"
    />

    <section class="action-row-shell">
      <a class="print-link" href={printHref}>Druckansicht öffnen →</a>
    </section>

    <section class="exercise-shell">
      <article class="exercise-content">
        <Content />
      </article>
    </section>

    {(hintPoints.length > 0 || selfCheckPoints.length > 0) && (
      <section class="exercise-support wide-bleed">
        <SupportChecklist title="Worauf du achten kannst" kicker="Hinweise" items={hintPoints} />
        <SupportChecklist title="Das solltest du am Ende prüfen" kicker="Selbstkontrolle" items={selfCheckPoints} />
      </section>
    )}

    {relatedArticles.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Wissensseiten" title="Passende Fachinfos zu dieser Aufgabe" />
        <p class="related-intro">Diese Wissensseiten liegen im gleichen Themenpfad und helfen dir genau bei dieser Aufgabe weiter.</p>
        <div class="related-grid article-grid">
          {relatedArticles.map((item) => (
            <ResourceCard
              title={item.data.title}
              description={item.data.description}
              meta={getTopicDisplayLabel(item)}
              href={withBase(`wissen/${item.id}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    )}

    {relatedExercises.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Weitere Aufgaben" title="Mehr Aufgaben im gleichen Themenfeld" />
        <p class="related-intro">Hier findest du weitere Aufgaben, die denselben Themenpfad aufgreifen und fachlich nah beieinander liegen.</p>
        <div class="related-grid task-grid">
          {relatedExercises.map((item) => (
            <ResourceCard
              title={item.data.title}
              description={item.data.description}
              meta={levelLabels[item.data.level]}
              href={withBase(`aufgaben/${item.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell {
    display: grid;
    gap: 1.15rem;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.95rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.12rem 0.72rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.78;
    font-size: 1.05rem;
    max-width: 58rem;
  }

  .action-row-shell {
    display: flex;
    justify-content: flex-start;
  }

  .print-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.8rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-soft);
  }

  .exercise-shell,
  .related-section {
    display: grid;
    gap: 1rem;
  }

  .exercise-content {
    padding: clamp(1.3rem, 2vw, 2rem);
    border: 1px solid var(--border);
    border-radius: 30px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .exercise-support,
  .related-grid {
    display: grid;
    gap: 1rem;
  }

  .exercise-support {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .related-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .exercise-content :global(h2) {
    margin-top: 1.8rem;
    color: var(--text-strong);
    font-size: clamp(1.45rem, 2.4vw, 1.85rem);
    line-height: 1.15;
  }

  .exercise-content :global(h2:first-child) {
    margin-top: 0;
  }

  .exercise-content :global(h3) {
    margin-top: 1.2rem;
    color: var(--text-strong);
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .exercise-content :global(p),
  .exercise-content :global(li) {
    color: var(--text);
    line-height: 1.82;
    font-size: 1rem;
  }

  .exercise-content :global(ul),
  .exercise-content :global(ol) {
    padding-left: 1.2rem;
  }

  .exercise-content :global(pre) {
    overflow-x: auto;
  }

  @media (max-width: 980px) {
    .exercise-support,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
