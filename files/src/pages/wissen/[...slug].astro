---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render, type CollectionEntry } from "astro:content";
import { getVisibleArticles, getVisibleExercises, levelLabels } from "../../data/content";
import { resolvePrimarySubjectSlug, subjectTitleMap } from "../../data/subjects";
import { getTopicTail, getSharedTopicPrefixLength, humanizeTopicSegment } from "../../data/topics";
import { withBase } from "../../utils/base";
import PageTrail from "../../components/content/PageTrail.astro";
import OverviewPanel from "../../components/content/OverviewPanel.astro";
import SectionHeading from "../../components/content/SectionHeading.astro";
import ResourceCard from "../../components/content/ResourceCard.astro";
import PracticeIdeas from "../../components/content/PracticeIdeas.astro";
import CommonMistakes from "../../components/content/CommonMistakes.astro";
import KeyTakeaways from "../../components/content/KeyTakeaways.astro";
import LinuxLearningShell from "../../components/interactive/LinuxLearningShell.astro";
import { getLinuxShellScenario } from "../../data/interactive/linuxShellScenarios";

export async function getStaticPaths() {
  const articles = await getVisibleArticles();

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const subjectTitle = subjectTitleMap[entry.data.subject] ?? "Fachbereich";
const subjectSlug = resolvePrimarySubjectSlug(entry.data.subject) ?? "elektrotechnik";
const topicTail = getTopicTail(entry);
const topicBranch = topicTail.slice(0, -1);
const entryTags = entry.data.tags ?? [];
const learningGoals = Array.isArray(entry.data.learningGoals) ? entry.data.learningGoals.filter(Boolean) : [];
const practiceIdeas = Array.isArray(entry.data.practiceIdeas) ? entry.data.practiceIdeas.filter(Boolean) : [];
const commonMistakes = Array.isArray(entry.data.commonMistakes) ? entry.data.commonMistakes.filter(Boolean) : [];
const keyTakeaways = Array.isArray(entry.data.keyTakeaways) ? entry.data.keyTakeaways.filter(Boolean) : [];

const [allArticles, allExercises] = await Promise.all([getVisibleArticles(), getVisibleExercises()]);

const scoreByTopicFit = (item: CollectionEntry<"articles"> | CollectionEntry<"exercises">) => {
  const sharedPath = getSharedTopicPrefixLength(topicTail, getTopicTail(item));
  const sameSection = item.data.section === entry.data.section ? 2 : 0;
  const itemTags = "tags" in item.data && Array.isArray(item.data.tags) ? item.data.tags : [];
  const sharedTags = itemTags.filter((tag) => entryTags.includes(tag)).length;
  return sharedPath * 4 + sameSection + sharedTags;
};

const relatedArticles = allArticles
  .filter((item) => item.id !== entry.id && resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => scoreByTopicFit(b) - scoreByTopicFit(a))
  .slice(0, 4);

const relatedExercises = allExercises
  .filter((item) => resolvePrimarySubjectSlug(item.data.subject) === subjectSlug)
  .sort((a, b) => scoreByTopicFit(b) - scoreByTopicFit(a))
  .slice(0, 6);

const breadcrumbSegments = topicBranch.map((segment, index) => ({
  label: humanizeTopicSegment(segment),
  href: withBase(`fachbereiche/${subjectSlug}/${topicBranch.slice(0, index + 1).join("/")}`),
}));

const trail = [
  { label: subjectTitle, href: withBase(`fachbereiche/${subjectSlug}`) },
  ...breadcrumbSegments,
];

const backHref = breadcrumbSegments.length > 0 ? breadcrumbSegments[breadcrumbSegments.length - 1].href : withBase(`fachbereiche/${subjectSlug}`);
const topicPathHref = topicBranch.length > 0 ? withBase(`fachbereiche/${subjectSlug}/${topicBranch.join("/")}`) : withBase(`fachbereiche/${subjectSlug}`);
const shellScenario = subjectSlug === "linux" ? getLinuxShellScenario(topicTail.join("/")) : null;

const overviewPoints = learningGoals.length > 0
  ? learningGoals
  : [
      `Diese Wissensseite gehört fachlich zu ${subjectTitle}.`,
      `Sie vertieft das Thema ${breadcrumbSegments.at(-1)?.label ?? entry.data.section ?? "dieser Wissensbereich"}.`,
      "Darunter findest du passende Aufgaben und weitere Wissensseiten mit engem Themenbezug.",
    ];

const taskIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M9 11l2 2 4-4"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
const articleIcon = `
<svg viewBox="0 0 24 24" aria-hidden="true">
  <path d="M7 6h10"></path>
  <path d="M7 10h10"></path>
  <path d="M7 14h7"></path>
  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
</svg>`;
---

<BaseLayout title={`${entry.data.title} – Schlaufuchs`} description={entry.data.description}>
  <div class="page-shell">
    <PageTrail backHref={backHref} trail={trail} />

    <section class="article-hero">
      <p class="eyebrow">Wissensseite</p>
      <div class="hero-meta-row">
        <span class="meta-chip">{subjectTitle}</span>
        <span class="meta-chip">{levelLabels[entry.data.level]}</span>
        <span class="meta-chip">{entry.data.section}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
    </section>

    <OverviewPanel
      title="Was du hier lernst"
      kicker="Einstieg"
      points={overviewPoints}
      actionHref={topicPathHref}
      actionLabel="Zum Themenpfad →"
    />

    <section class="article-shell">
      <article class="article-content">
        <Content />
      </article>
    </section>

    {shellScenario && (
      <section class="interactive-section wide-bleed">
        <SectionHeading kicker="Ausprobieren" title="Direkt im Linux-Terminal üben" />
        <p class="interactive-intro">Die Lernshell gehört hier bewusst zum Hauptfluss der Seite. Probiere die vorgeschlagenen Befehle aus und lies die Ausgaben ruhig Schritt für Schritt.</p>
        <LinuxLearningShell scenario={shellScenario} />
      </section>
    )}

    <PracticeIdeas items={practiceIdeas} />

    {(commonMistakes.length > 0 || keyTakeaways.length > 0) && (
      <section class="summary-grid wide-bleed">
        <CommonMistakes items={commonMistakes} />
        <KeyTakeaways items={keyTakeaways} />
      </section>
    )}

    {relatedExercises.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Aufgaben" title="Passende Aufgaben zu diesem Thema" />
        <div class="related-grid task-grid">
          {relatedExercises.map((item) => (
            <ResourceCard
              title={item.data.title}
              description={item.data.description}
              meta={levelLabels[item.data.level]}
              href={withBase(`aufgaben/${item.id}`)}
              ctaLabel="Aufgabe öffnen →"
              icon={taskIcon}
              variant="task"
            />
          ))}
        </div>
      </section>
    )}

    {relatedArticles.length > 0 && (
      <section class="related-section">
        <SectionHeading kicker="Weiterlesen" title="Weitere Wissensseiten in diesem Bereich" />
        <div class="related-grid article-grid">
          {relatedArticles.map((item) => (
            <ResourceCard
              title={item.data.title}
              description={item.data.description}
              meta={item.data.section}
              href={withBase(`wissen/${item.id}`)}
              ctaLabel="Wissensseite öffnen →"
              icon={articleIcon}
              variant="article"
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-shell {
    display: grid;
    gap: 1.2rem;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.95rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.12rem 0.72rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.45rem, 4.8vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--text);
    line-height: 1.8;
    font-size: 1.07rem;
    max-width: 62rem;
  }

  .article-shell,
  .related-section,
  .interactive-section {
    display: grid;
    gap: 1rem;
  }

  .article-content {
    padding: clamp(1.35rem, 2vw, 2rem);
    border: 1px solid var(--border);
    border-radius: 30px;
    background: var(--card-bg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .interactive-intro {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
    max-width: 70rem;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .article-content :global(h2) {
    margin-top: 1.8rem;
    color: var(--text-strong);
    font-size: clamp(1.45rem, 2.4vw, 1.85rem);
    line-height: 1.15;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(h3) {
    margin-top: 1.2rem;
    color: var(--text-strong);
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text);
    line-height: 1.84;
    font-size: 1rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.2rem;
  }

  .article-content :global(pre) {
    overflow-x: auto;
  }

  @media (max-width: 980px) {
    .summary-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
